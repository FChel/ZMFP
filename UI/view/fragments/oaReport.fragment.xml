<core:FragmentDefinition
  xmlns="sap.m"
  xmlns:cd="http://schemas.sap.com/sapui5/extension/sap.ui.core.CustomData/1"
  xmlns:core="sap.ui.core"
  xmlns:c="fss.ssp.controls"
  xmlns:mvc="sap.ui.core.mvc">
  <c:Dialog title="{i18n>OaToPoReport.title}" 
    class="sapUiSizeCompact"
    draggable="true"
    resizable="true"
    type="Message"
    beforeOpen="onLIBeforeOpen"
    contentWidth="{path: 'device>/system', formatter: '.formatter.liDialogWidth'}">
    <c:content>
      <Table
        id="liTable"
        width="auto"
        noDataText="{i18n>reportTable.NoDataText}"
        class="sapUiTinyMargin worklistTable"
        mode="None"
        alternateRowColors="true"
        items="{path: '/',
            filters : [
              { path : 'PoNumber', operator : 'EQ', value1 : '', and: true}
            ]}"
        updateFinished="onReportTableUpdateFinished"
        busy="{= ${viewModel>/busy} === true}"
        busyIndicatorDelay="0">
        <headerToolbar>
          <Toolbar >
            <Title text="{i18n>reportTable.LineItemsSummary}"/>
            <ToolbarSpacer/>
            <Button icon="sap-icon://download" text="{i18n>btn.Download}" press="onDownload" type="Emphasized"/>
          </Toolbar>
        </headerToolbar>
        <columns>
          <Column width="2rem">

          </Column>
          <Column width="5rem" >
            <Text text="{i18n>reportTable.Document}"/>
          </Column>
          <Column width="3rem">
            <Text text="{i18n>reportTable.Line}"/>
          </Column>
          <Column width="5rem">
            <Text text="{i18n>reportTable.Currency}"/>
          </Column>
          <Column width="10rem" hAlign="End">
            <Text text="{i18n>reportTable.OALineValue}"/>
          </Column>
          <Column width="10rem" hAlign="End">
            <Text text="{i18n>reportTable.TotalAssigned}"/>
          </Column>
          <Column width="10rem" hAlign="End">
            <Text text="{i18n>reportTable.UnassignedValue}"/>
          </Column>
          <Column visible="true" demandPopin="true" minScreenWidth="5500px" popinDisplay="WithoutHeader">
            <Text text=""/>
          </Column>
        </columns>
        <items>
          <ColumnListItem id="reportListItem" class="consumptionReport">
            <HBox class="sapUiNoContentPadding sapUiTinyPaddingBeginEnd">
              <Button icon="sap-icon://navigation-right-arrow" type="Transparent" visible="{= ${expand} !== true}" 
                press="onPoExpand" tooltip="Show Purchase Orders"/>
              <Button icon="sap-icon://navigation-down-arrow" type="Transparent" visible="{= ${expand} === true}" press="onPoExpand" tooltip="Hide Purchase Orders"/> 
            </HBox>
            <Text text="{ContractNumber}"  />
            <Text text="{path: 'ContractLi', formatter: '.formatter.lineNumberFormatter'}"/>
            <Text text="{Currency}"/>
            <Text text="{parts: [{path: 'NetPrice'}, {path:'Currency'}], type:'fss.ssp.CustomTypes.CustomCurrency', formatOptions:{showMeasure: false}, constraints:{minimum: 0}}"/>
            <Text text="{parts: [{path: 'TotalAssigned'}, {path:'Currency'}], type:'fss.ssp.CustomTypes.CustomCurrency', formatOptions:{showMeasure: false}, constraints:{minimum: 0}}"/>
            <Text text="{parts: [{path: 'TotalUnassigned'}, {path:'Currency'}], type:'fss.ssp.CustomTypes.CustomCurrency', formatOptions:{showMeasure: false}, constraints:{minimum: 0}}"/>
            <Panel visible="{= ${expand} === true}" expandable="false" expanded="{= ${expand} === true}" 
                class="sapUiSizeCompact sapUiNoContentPadding">
              <ScrollContainer class="sapUiNoContentPadding" horizontal="true" vertical="true" width="100%" focusable="true" >
                <Table
                  width="100%"
                  noDataText="{i18n>reportTable.NoDataTextPo}"
                  class="sapUiNoContentPadding"
                  mode="None"
                  alternateRowColors="true"
                  items="{path: '/',
                      templateShareable:false}"
                  updateFinished="onPoReportTableUpdateFinished"
                  busy="{= ${viewModel>/busy} === true}"
                  busyIndicatorDelay="0">

                  <columns>
                    <Column width="2rem">

                    </Column>
                    <Column width="5rem" >
                      <!--<Text text="Document"/>-->
                    </Column>
                    <Column width="3rem">
                      <!--<Text text="Line"/>-->
                    </Column>
                    <Column width="5rem">
                      <!--<Text text="Currency"/>-->
                    </Column>
                    <Column width="10rem" hAlign="End">
                      <!--<Text text="OA Line Value(ex tax)"/>-->
                    </Column>
                    <Column width="10rem" hAlign="End">
                      <!--<Text text="Total Assigned (ex tax)"/>-->
                    </Column>
                    <Column width="10rem" hAlign="End">
                      <!--<Text text="Unassigned Value (ex tax)"/>-->
                    </Column>
                  </columns>
                  <items>
                    <ColumnListItem  class="sapUiSmallMarginBottom">
                      <Text text=""/>
                      <Text text="{PoNumber}" class="{path: 'IsContract', formatter: '.formatter.consumptionReportCss'}" />
                      <Text text="{path: 'PoLi', formatter: '.formatter.lineNumberFormatter'}"/>
                      <Text text="{Currency}"/>
                      <Text text="{parts: [{path: 'NetPrice'}, {path:'Currency'}], type:'fss.ssp.CustomTypes.CustomCurrency', formatOptions:{showMeasure: false}, constraints:{minimum: 0}}"/>
                      <Text text="{parts: [{path: 'TotalAssigned'}, {path:'Currency'}], type:'fss.ssp.CustomTypes.CustomCurrency', formatOptions:{showMeasure: false}, constraints:{minimum: 0}}"/>
                      <Text text="{parts: [{path: 'TotalUnassigned'}, {path:'Currency'}], type:'fss.ssp.CustomTypes.CustomCurrency', formatOptions:{showMeasure: false}, constraints:{minimum: 0}}"/>

                    </ColumnListItem>
                  </items>
                </Table>
              </ScrollContainer>
            </Panel>
          </ColumnListItem>
        </items>
      </Table>
    </c:content>
    <c:buttons>
      <Button text="Cancel" press="onReportCancel"/>
    </c:buttons>
  </c:Dialog>
</core:FragmentDefinition>