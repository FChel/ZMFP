<core:FragmentDefinition
	xmlns:l="sap.ui.layout"
	xmlns:mvc="sap.ui.core.mvc" 
	xmlns:f="sap.ui.layout.form"
	xmlns:core="sap.ui.core"
	xmlns="sap.m"
	xmlns:c="fss.ssp.controls">
	<c:Dialog 
		title="{i18n>subcontractor.dlg.title}" 
		class="sapUiSizeCompact"
		type="Message"
		draggable="true"
		resizable="true">
        <c:content>
            <f:SimpleForm 
				editable="true"
				layout="ColumnLayout"
				columnsM="2"
				columnsL="2"
				columnsXL="3"
				labelSpanXL="4"
				labelSpanL="5"
				labelSpanM="5">
				
				<f:content>
					<Label wrapping="true" text="{i18n>subcontractor.dlg.name}"/>
					<Input required="true" value="{/ContractorName}" placeholder="Enter {i18n>subcontractor.dlg.name}"/>
		
					<Label wrapping="true" text="{i18n>subcontractor.dlg.abn}" />
					<Input  value="{/ContractorABN}" placeholder="Enter {i18n>subcontractor.dlg.abn}"/>
				</f:content>
			</f:SimpleForm>
        </c:content>
        <c:buttons>
        	<Button id="errorBtn" type="Reject" text="{= ${ErrorModel>/errors}.length}" icon="sap-icon://error" class="errorbtnInDialog"
        			visible= "{= ${ErrorModel>/errors}.length > 0 }" press="onErrorBtnPress"/>
			<c:Button text="OK" press="onAddSubcontractorConfirm" type="Emphasized" visible="{=${viewModel>/IsAdd} === true}"/>
			<c:Button text="OK" press="onEditSubcontractorConfirm" type="Emphasized" visible="{=${viewModel>/IsEdit} === true}"/>
			<Button text="Cancel" press="onAddSubcontractorCancel"/>
		</c:buttons>
        
    </c:Dialog>
</core:FragmentDefinition>