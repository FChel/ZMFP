<core:FragmentDefinition
  xmlns:l="sap.ui.layout"
  xmlns:f="sap.ui.layout.form"
  xmlns:core="sap.ui.core"
  xmlns="sap.m"
  xmlns:c="fss.ssp.controls">
        <ToolbarSpacer/>
        <Button text="{i18n>btn.prf}" tooltip="{i18n>btn.prf.tooltip}" press="onPrfPress" type="Ghost"
            visible="{= ${componentModel>/inFLP} &amp;&amp; (${path: 'ContractNumber', formatter: '.formatter.isNotEmpty'} !== true || ${viewModel>/isContract} === true) }"/>
    <Button visible="{= ${componentModel>/inFLP}}" enabled="{= ${viewModel>/enableEdit} !== false &amp;&amp; ${disableModel>/DisableFlag} !== true}" text="{i18n>btn.edit}" tooltip="{i18n>btn.edit.tooltip}"  press="onEditPress"  type="Emphasized"/>
    <Button visible="{= ${componentModel>/inFLP}}" tooltip="{i18n>btn.more}" icon="sap-icon://overflow" press="onMorePress" />
</core:FragmentDefinition>