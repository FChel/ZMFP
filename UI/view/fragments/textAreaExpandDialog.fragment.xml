<core:FragmentDefinition
	xmlns:mvc="sap.ui.core.mvc" 
	xmlns:f="sap.ui.layout.form"
	xmlns:core="sap.ui.core"
	xmlns="sap.m">
	
	<ResponsivePopover
		placement="Auto"
		class="sapUiContentPadding"
		title="{/headerText}"
		contentWidth="40rem">
		<content>
			<TextArea value="{/text}" width="100%" rows="10" placeholder="{/placeholder}" editable="{= ${/displayMode} !== true}" 
					maxLength="{path: '/maxLength', formatter: '.formatter.lengthFormatter'}"/>
		</content>
		<beginButton>
			<Button text="OK" press="onExpandConfirm" type="Emphasized" visible="{= ${/displayMode} !== true}"/>
		</beginButton>
		<endButton>
			<Button text="Cancel" press="onExpandCancel"/>
		</endButton>
	</ResponsivePopover>
</core:FragmentDefinition>