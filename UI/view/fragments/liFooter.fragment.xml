		<!--<c:Button visible="{= ${/Status} === 'D' &amp;&amp; ${viewModel>/IsEdit} === true }" -->
		<!--					text="{i18n>btn.draft}" press="onDraftEditConfirm" type="Ghost"/>-->
		<c:Button text="OK" press="onAddLIConfirm" type="Emphasized" visible="{=${viewModel>/IsAdd} === true}"/>
		<c:Button text="OK" press="onEditLIConfirm" type="Emphasized" visible="{=${viewModel>/IsEdit} === true}"/>
		<Button text="Cancel" press="onAddLICancel"/>

