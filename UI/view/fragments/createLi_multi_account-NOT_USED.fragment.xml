				</f:content>
			</f:SimpleForm>
			<Table
						id="assignmentTable"
						width="auto"
						items="{ path : '/AccountAssignments'}"
						noDataText="No Account Assignments"
						class="sapUiTinyMargin worklistTable"
						updateFinished="onAssignmentTableUpdateFinished">
						<headerToolbar>
							<Toolbar >
								<Title text="{i18n>AccountAssignment}s"/>
								<ToolbarSpacer/>
								
								<ToolbarSpacer/>
								<HBox visible="{= ${viewModel>/IsEdit} !== false}">
									<Button icon="sap-icon://add" type="Emphasized" tooltip="{i18n>btn.AddPhasing.tooltip}" text="Add Account Assignment"  
											press="onAddAssignment"  enabled="{= ${/AccountAssignments}.length &lt; 1 || ${/Distribution} !== 'S'}"/>
								</HBox>
							</Toolbar>
						</headerToolbar>
						<columns>
							<Column>
								<Text text="{i18n>Asset}"/>
							</Column>
							<Column>
								<Text text="{i18n>GLAccount}"/>
							</Column>
							<Column>
								<Text text="{i18n>CostCentre}"/>
							</Column>
							<Column>
								<Text text="{i18n>InternalOrder}"/>
							</Column>
							<Column>
								<Text text="{i18n>WBSElement}"/>
							</Column>
							<Column>
								<Text text="{i18n>Fund}"/>
							</Column>
							<Column>
								<Text text="Quantity"/>
							</Column>
							<Column>
								<Text text="Percentage"/>
							</Column>
							<Column width="7rem" visible="{= ${viewModel>/displayMode} !== true}">
								<Text text="{i18n>table.col.action}"/>
							</Column>
						</columns>
						<items>
							<ColumnListItem id="phasingListItem" type="Navigation" press="onPhasingPress" >
								<Text text="{path: 'ItemLineNumber', formatter: '.formatter.lineNumberFormatter'}"/>
								<Text text="{LineDescription}"/>
								<Text text="{path: 'PhasingLineNumber', formatter: '.formatter.lineNumberFormatter'}"/>
								<Text text="{path: 'DeliveryDate', type: 'sap.ui.model.type.Date', formatOptions: {pattern:'dd.MM.yyyy', strictParsing:true, UTC: true}}" />
								<Text text="{path: 'SchQuantity', type:'sap.ui.model.odata.type.Decimal', formatOptions: {decimals: 3, groupingEnabled: false}, constraints:{scale: 'variable'}}"/>
								<HBox visible="{= ${viewModel>/displayMode} !== true}">
									<Button icon="sap-icon://copy" tooltip="{i18n>btn.CopyLineItem}" press="onCopyLI" class="sapUiTinyMarginEnd"
													enabled="{= ${viewModel>/enablePhasingAction} === true}" visible="{= ${viewModel>/displayMode} !== true}"/>
									<Button icon="sap-icon://delete" tooltip="{i18n>btn.DeleteLineItem}" press="onDeleteLI" class="sapUiTinyMarginEnd" 
													enabled="{= ${viewModel>/enablePhasingAction} === true &amp;&amp; ${viewModel>/enableDelete} !== false}" visible="{= ${viewModel>/displayMode} !== true}"/>
								</HBox>		
							</ColumnListItem>
						</items>
					</Table>
		
		</c:content>
		<c:buttons>
			<core:Fragment fragmentName="fss.ssp.view.fragments.liFooter" type="XML" />
