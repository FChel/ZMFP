	<Table
		id="assignmentTable"
		width="auto"
		items="{ path : 'AccountAssignments', templateShareable: false,
					sorter: {path: 'AssignmentLineNumber', descending: false}, 
					filters: [
					{
						filters : [
							{ path : 'ItemLineNumber', operator : 'EQ', value1 : 'xxx'},
							{path : 'IsDeleted', operator : 'NE', value1 : 'true'}
						], 
						and: true
					}]}"
		noDataText="{i18n>assignmentsNoDataText}"
		class="sapUiTinyMargin worklistTable"
		updateFinished="onTableUpdateFinished">
		<headerToolbar>
			<Toolbar >
				<Title text="{viewModel>/assignmentTableTitle}"/>
				<!--<Link text="{i18n>coa.app.title}" press="onCOAPress"/>-->
				<ToolbarSpacer/>
				<Select	id="assignmentLineNumberSelect" width="18rem" 
					selectedKey="{viewModel>/AssignmentSelectedLine}" change="onLineItemChange">
					<core:ListItem id="assignmentSelectItem" key="{LineNumber}" 
							text="{parts: [{path: 'LineNumber'}, {path:'LineDescription'}], 
								formatter: '.formatter.valueHelpDisplay'}"
							icon="{path: 'Status', formatter: '.formatter.lineItemStatusIcon'}"/>
				</Select>
				<ToolbarSpacer/>
				<HBox visible="{= ${viewModel>/displayMode} !== true}">
					<Button icon="sap-icon://add" type="Emphasized" tooltip="{i18n>btn.AddAssignment.tooltip}" text="{i18n>btn.AddAssignment}"  
							press="onAddAssignment" enabled="{= ${viewModel>/enableAssignmentAction} === true}"/>
				</HBox>
			</Toolbar>
		</headerToolbar>
		<columns>
			<Column width="3rem">
				<Text text="Seq" />
			</Column>
			<Column visible="{= ${lineModel>AssignmentTypeCode} === 'A'}">
				<Label text="{i18n>Asset}" />
			</Column>
			<Column visible="{= ${lineModel>AssignmentTypeCode} === 'K' || ${lineModel>AssignmentTypeCode} === 'F' || ${lineModel>AssignmentTypeCode} === 'T' || ${lineModel>AssignmentTypeCode} === 'P' || ${lineModel>AssignmentTypeCode} === 'X'}">
				<Label text="{i18n>GLAccount}" />
			</Column>
			<Column visible="{= ${lineModel>AssignmentTypeCode} === 'K' || ${lineModel>AssignmentTypeCode} === 'F' || ${lineModel>AssignmentTypeCode} === 'T' || ${lineModel>AssignmentTypeCode} === 'X'}" >
				<Label text="{i18n>CostCentre}" />
			</Column>
			<Column visible="{= ${lineModel>AssignmentTypeCode} === 'F' || ${lineModel>AssignmentTypeCode} === 'P' || ${lineModel>AssignmentTypeCode} === 'T'}">
				<Label text="{i18n>InternalOrder}" />
			</Column>
			<Column visible="{= ${lineModel>AssignmentTypeCode} === 'F' || ${lineModel>AssignmentTypeCode} === 'P' || ${lineModel>AssignmentTypeCode} === 'T'}" >
				<Label text="{i18n>WBSElement}" />
			</Column>
			<!--<Column >-->
			<!--	<Label text="{i18n>Fund}"/>-->
			<!--</Column>-->
			<Column width="9rem" hAlign="End" visible="{= ${lineModel>Distribution} === '1'}">
				<Text text="{i18n>AssignmentQuantity}"/>
				<footer>
					<Text visible="{= ${lineModel>Distribution} === '1'}" 
						text="{path: 'viewModel>/qtyTotal', type:'sap.ui.model.odata.type.Decimal', formatOptions: {decimals: 3, groupingEnabled: true}, constraints:{scale: 'variable'}}"/>
				</footer>
			</Column>
			<Column width="7rem" hAlign="End" visible="{= ${lineModel>Distribution} === '2'}">
				<Text text="{i18n>AssignmentPercentage}"/>
				<footer>
					<Text visible="{= ${lineModel>Distribution} === '2'}" 
						text="{path: 'viewModel>/percTotal', type:'sap.ui.model.odata.type.Decimal', formatOptions: {decimals: 1, groupingEnabled: true}, constraints:{scale: 'variable'}}"/>
				</footer>
			</Column>
			<Column width="9rem" hAlign="End" visible="{= ${lineModel>Distribution} === '3'}">
				<Text text="{i18n>AssignmentAmount}"/>
				<footer>
					<Text visible="{= ${lineModel>Distribution} === '3'}" text="{parts: [{path: 'viewModel>/amtTotal'}, {path:'lineModel>Currency'}], type:'fss.ssp.CustomTypes.CustomCurrency', formatOptions:{showMeasure: false}, constraints:{minimum: 0}}"/>
				</footer>
			</Column>
			<Column width="4.5rem" visible="{= ${viewModel>/displayMode} !== true}">
				<Text text="{i18n>table.col.action}"/>
			</Column>
		</columns>
		<items>
			<ColumnListItem id="assignmentListItem" type="Navigation" press="onAssignmentPress" >
				<Text text="{path: 'AssignmentLineNumber', formatter: '.formatter.lineNumberFormatter'}"/>
				<Text visible="{= ${lineModel>AssignmentTypeCode} === 'A'}" text="{parts: [{path: 'Asset'}, {path:'AssetSubNumber'}, {path:'AssetDesc'}], formatter: '.formatter.assetValueHelpDisplay'}"/>
				
				<Text visible="{= ${lineModel>AssignmentTypeCode} === 'K' || ${lineModel>AssignmentTypeCode} === 'F' || ${lineModel>AssignmentTypeCode} === 'T' || ${lineModel>AssignmentTypeCode} === 'P' || ${lineModel>AssignmentTypeCode} === 'X'}"
						text="{parts: [{path: 'GLAccount'}, {path:'GLAccountDesc'}], formatter: '.formatter.valueHelpDisplay'}"/>
			
				
				<Text visible="{= ${lineModel>AssignmentTypeCode} === 'K' || ${lineModel>AssignmentTypeCode} === 'F' || ${lineModel>AssignmentTypeCode} === 'T' || ${lineModel>AssignmentTypeCode} === 'X'}"
						text="{parts: [{path: 'CostCentre'}, {path:'CostCentreDesc'}], formatter: '.formatter.valueHelpDisplay'}"/>
				
				
				<Text visible="{= ${lineModel>AssignmentTypeCode} === 'F' || ${lineModel>AssignmentTypeCode} === 'P' || ${lineModel>AssignmentTypeCode} === 'T'}" 
						text="{parts: [{path: 'InternalOrder'}, {path:'InternalOrderDesc'}], formatter: '.formatter.valueHelpDisplay'}"/>
				
				
				<Text visible="{= ${lineModel>AssignmentTypeCode} === 'F' || ${lineModel>AssignmentTypeCode} === 'P' || ${lineModel>AssignmentTypeCode} === 'T'}" 
						text="{parts: [{path: 'WBSElement'}, {path:'WBSElementDesc'}], formatter: '.formatter.valueHelpDisplayKeepZeros'}"/>
				
				<Text text="{path: 'Quantity', type:'sap.ui.model.odata.type.Decimal', formatOptions: {decimals: 3, groupingEnabled: true}, constraints:{scale: 'variable'}}"  
						visible="{= ${lineModel>Distribution} === '1'}"/>
						
				<Text text="{path: 'Percentage', type:'sap.ui.model.odata.type.Decimal', formatOptions: {decimals: 1, groupingEnabled: true}, constraints:{scale: 'variable'}}" 
						visible="{= ${lineModel>Distribution} === '2'}"/>
				
				<Text text="{parts: [{path: 'Amount'}, {path:'lineModel>Currency'}], type:'fss.ssp.CustomTypes.CustomCurrency', formatOptions:{showMeasure: false}, constraints:{minimum: 0}}"  
						visible="{= ${lineModel>Distribution} === '3'}"/>
						
						
				
				<HBox>
					<Button icon="sap-icon://copy" tooltip="{i18n>btn.CopyLineItem}" press="onCopyAssignment" class="sapUiTinyMarginEnd"
								enabled="{= ${viewModel>/enableAssignmentAction} === true}" 
								visible="{= ${viewModel>/displayMode} !== true}"/>
					<Button icon="sap-icon://delete" tooltip="{i18n>btn.DeleteLineItem}" press="onDeleteAssignment" class="sapUiTinyMarginEnd" 
								enabled="{= ${viewModel>/enableAssignmentAction} === true &amp;&amp; ${viewModel>/enableAssignmentDelete} === true}" 
								visible="{= ${viewModel>/displayMode} !== true}"/>
				</HBox>
				
			</ColumnListItem>
		</items>
	</Table>
</core:FragmentDefinition>