      <!--    items="{ path : 'ContractLIs'}" change="onAddressLiChange"-->
      <!--    visible="{= ${viewModel>/isContract} === true}" >-->
      <!--    <core:ListItem key="{LineNumber}" -->
      <!--      text="{parts: [{path: 'LineNumber'}, {path:'LineDescription'}], -->
      <!--        formatter: '.formatter.valueHelpDisplay'}"/>-->
      <!--    <c:layoutData>-->
      <!--      <l:GridData span="XL4 L4 M4 S6"/>-->
      <!--    </c:layoutData>-->
      <!--  </c:Select>-->
      <!--  <c:Select id="addressLiPoSelect" width="{path: 'device>/system', formatter: '.formatter.liDropDownWidth'}"  -->
      <!--    items="{ path : 'PurchaseOrderLIs', events: { change: '.onLiDataChangeAddress' }}" change="onAddressLiChange"-->
      <!--    visible="{= ${viewModel>/isPO} === true}">-->
      <!--    <core:ListItem key="{LineNumber}" -->
      <!--      text="{parts: [{path: 'LineNumber'}, {path:'LineDescription'}], -->
      <!--        formatter: '.formatter.valueHelpDisplay'}"/>-->
      <!--    <c:layoutData>-->
      <!--      <l:GridData span="XL4 L4 M4 S6"/>-->
      <!--    </c:layoutData>-->
      <!--  </c:Select>-->
      <!--  <CheckBox id="addressSameCheck" text="{i18n>SameAddress}" selected="{IsSameAddressForAll}" select="onSameAddressCheckPress" />-->
      <!--  <ToolbarSpacer />-->
      <!--  </Toolbar>-->
      <!--</f:toolbar>-->
    <!--  <f:content>-->
    <!--    <Label text="{i18n>AddressDeliveryType}"/>-->
