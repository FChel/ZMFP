<mvc:View
  xmlns:mvc="sap.ui.core.mvc"
  controllerName="fss.ssp.controller.CreateContact"
  xmlns="sap.m"
  xmlns:core="sap.ui.core"
  xmlns:l="sap.ui.layout"
  xmlns:f="sap.ui.layout.form"
  xmlns:c="fss.ssp.controls"
  xmlns:combo="fss.ssp.controls.ComboBox"
  xmlns:tooltip="fss.ssp.controls.tooltip">
  <f:SimpleForm
    title="{i18n>POContactTitle}"
    editable="true"
        layout="ColumnLayout"
      labelSpanXL="4"
      labelSpanL="4"
      labelSpanM="6"
      labelSpanS="12"
      columnsXL="2"
      columnsL="2"
      columnsM="2"
    class="sapUiSizeCompact">
    <f:content>
      <!--<core:Title text="{i18n>POContactTitle}" />-->
      <Label text="{i18n>EmpID}" />
      <Input value="{parts: [{path: 'ContactDetails/POContactID'}], formatter: '.formatter.valueHelpDisplay'}"
           showValueHelp="true" valueHelpRequest="onValueHelpRequest" change="onSearchHelpValueChange"
           maxLength="{path: 'searchHelpModel>/#User/UserId/@maxLength', formatter: '.formatter.lineNumberFormatter'}">
        <customData>
          <core:CustomData key="dialogName" value="createPOContactEmpDlg"/>
        </customData>
      </Input>

      <Label text="{i18n>Name}" />
      <Input required="true" maxLength="{path: 'mainModel>/#ContactDetails/POContactName/@maxLength', formatter: '.formatter.lineNumberFormatter'}"
          value="{ContactDetails/POContactName}" placeholder="{i18n>Name.placeholder}"/>

      <Label text="{i18n>Email}" />
      <Input required="true" type="Email" maxLength="{path: 'mainModel>/#ContactDetails/POContactEmail/@maxLength', formatter: '.formatter.lineNumberFormatter'}"
          value="{path : 'ContactDetails/POContactEmail', type:'fss.ssp.CustomTypes.Email'}" placeholder="{i18n>Email.placeholder}" />

      <Label text="{i18n>PhoneNumber}" />
      <Input required="true" maxLength="{path: 'mainModel>/#ContactDetails/POContactPhone/@maxLength', formatter: '.formatter.lineNumberFormatter'}"
          value="{path: 'ContactDetails/POContactPhone', type:'fss.ssp.CustomTypes.PhoneNumber'}" placeholder="{i18n>PhoneNumber.placeholder}"/>


      <Label text="{i18n>SpecialInstructions}" />
        <c:ExpandableTextArea value="{ContactDetails/SpecialInstructions}" rows="4"
            placeholder="{i18n>SpecialInstructions.placeholder}"
            maxLength="{path: 'mainModel>/#ContactDetails/SpecialInstructions/@maxLength', formatter: '.formatter.lineNumberFormatter'}"/>

    </f:content>
  </f:SimpleForm>

  <f:SimpleForm
      id="deliveryAddressForm1"
      layout="ColumnLayout"
      editable="true"
      labelSpanXL="4"
      labelSpanL="4"
      labelSpanM="6"
      labelSpanS="12"
      columnsXL="2"
      columnsL="2"
      columnsM="2"
      class="noInnerTitleForm noBorderBar sapUiSmallMarginTop">
      <f:toolbar>
        <Toolbar >
          <Title level="H1" text="{i18n>DeliveryAddress.title}" class="sapUiMediumMarginEnd"/>
          <ToolbarSpacer/>
        <Label wrapping="true" text="Line"/>
        <c:Select id="addressLiContractSelect" width="{path: 'device>/system', formatter: '.formatter.liDropDownWidth'}"
          items="{ path : 'ContractLIs',
              filters: [
                {
                  filters : [
                    { path : 'Status', operator : 'NE', value1 : 'L', and: true}
                  ],
                  and: true
              }],
              events: { change: '.onLiDataChangeAddress' }}" change="onAddressLiChange"
          visible="{= ${viewModel>/isContract} === true || ${IsSinglePO} === true}" enabled="{= ${IsSameAddressForAll} !== true}" >
          <core:ListItem key="{LineNumber}"
            text="{parts: [{path: 'LineNumber'}, {path:'LineDescription'}],
              formatter: '.formatter.valueHelpDisplay'}" icon="{path: 'Status', formatter: '.formatter.lineItemStatusIcon'}"/>
          <c:layoutData>
            <l:GridData span="XL4 L4 M4 S6"/>
          </c:layoutData>
        </c:Select>
        <c:Select id="addressLiPoSelect" width="{path: 'device>/system', formatter: '.formatter.liDropDownWidth'}"
          items="{ path : 'PurchaseOrderLIs',
              filters: [
                {
                  filters : [
                    { path : 'Status', operator : 'NE', value1 : 'L', and: true}
                  ],
                  and: true
              }],
              events: { change: '.onLiDataChangeAddress' }}" change="onAddressLiChange"
          visible="{= ${viewModel>/isPO} === true &amp;&amp; ${IsSinglePO} !== true}" enabled="{= ${IsSameAddressForAll} !== true}">
          <core:ListItem key="{LineNumber}"
            text="{parts: [{path: 'LineNumber'}, {path:'LineDescription'}],
              formatter: '.formatter.valueHelpDisplay'}" icon="{path: 'Status', formatter: '.formatter.lineItemStatusIcon'}"/>
          <c:layoutData>
            <l:GridData span="XL4 L4 M4 S6"/>
          </c:layoutData>
        </c:Select>
        <CheckBox id="addressSameCheck" text="{i18n>SameAddress}" selected="{IsSameAddressForAll}" select="onSameAddressCheckPress" />
        <ToolbarSpacer />
        </Toolbar>
      </f:toolbar>
    </f:SimpleForm>

  <VBox id="addressBox">
    <!--<f:SimpleForm-->
    <!--  layout="ColumnLayout"-->
