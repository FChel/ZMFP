class ZCL_MFP_BAL_LOG_WRAPPER definition
  public
  final
  create private .

public section.

  constants:
    BEGIN OF gc_message_types,
        abort   TYPE symsgty VALUE 'X',
        abend   TYPE symsgty VALUE 'A',
        error   TYPE symsgty VALUE 'E',
        warning TYPE symsgty VALUE 'W',
        info    TYPE symsgty VALUE 'I',
        success TYPE symsgty VALUE 'S',
      END OF gc_message_types .

  methods ADD_TEXT
    importing
      !MESSAGE_TYPE type SY-MSGTY default 'I'
      !MESSAGE_TEXT type STRING
      !PROBLEM_CLASS type BAL_S_MSG-PROBCLASS optional .
  methods DISPLAY .
  class-methods CREATE
    returning
      value(INSTANCE) type ref to ZCL_MFP_BAL_LOG_WRAPPER .
  methods ADD_BAPI_MESSAGE
    importing
      !PROBLEM_CLASS type BAL_S_MSG-PROBCLASS optional
      !RETURN type BAPIRET2
      !CONTEXT type BAL_S_CONT optional
      !PARAMS type BAL_S_PARM optional .
  methods ADD_BAPI_MESSAGES
    importing
      !PROBLEM_CLASS type BAL_S_MSG-PROBCLASS optional
      !RETURN type BAPIRET2_T
      !CONTEXT type BAL_S_CONT optional
      !PARAMS type BAL_S_PARM optional .
  methods ADD_SYSTEM_MESSAGE
    importing
      !PROBLEM_CLASS type BAL_S_MSG-PROBCLASS optional
      !CONTEXT type BAL_S_CONT optional
      !PARAMS type BAL_S_PARM optional
    exporting
      !IS_RETURN type BAPIRET2 .
  class-methods GET_INSTANCE
    importing
      !IV_OBJECT type BALOBJ_D optional
      !IV_SUBOBJECT type BALSUBOBJ optional
      !IV_DESCRIPTION type BALNREXT optional
      !IV_DAYS_TO_KEEP type INT4 optional
    returning
      value(RO_APPLICATION_LOG) type ref to ZCL_MFP_BAL_LOG_WRAPPER .
  methods PERSIST_LOG .
  methods HAS_ERROR_MESSAGES
    returning
      value(RV_HAS_ERROR) type ABAP_BOOL .
  methods HAS_MESSAGES
    returning
      value(RV_HAS_MESSAGES) type ABAP_BOOL .
  methods GET_MESSAGES
    exporting
      !ET_BAL_MESSAGES type BAL_T_MSGR
      !ET_BAPIRET2 type BAPIRET2_T .
  PROTECTED SECTION.
private section.

  data LOG_HANDLE type BALLOGHNDL .
  data AV_MESSAGE_COUNTER type I .
  data AV_ERROR_COUNTER type I .
  constants LC_PROGRAM_PARANAME type BALPAR value 'PROGRAM' ##NO_TEXT.

  methods CONSTRUCTOR
    importing
      !I_OBJ type BALOBJ_D optional
      !I_SUBOBJ type BALSUBOBJ optional
      !I_DESC type BALNREXT optional
      !I_DAYS_TO_KEEP type INT4 optional .
  methods GET_PROBLEM_CLASS
    importing
      !I_MSGTY type SYMSGTY
    returning
      value(RESULT) type BAL_S_MSG-PROBCLASS .
ENDCLASS.



CLASS ZCL_MFP_BAL_LOG_WRAPPER IMPLEMENTATION.


  METHOD ADD_BAPI_MESSAGE.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_BAL_LOG_WRAPPER~ADD_BAPI_MESSAGE
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for Application Logging for MyFi
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
*-----------------------------------------------------------------------
    DATA: ls_s_msg TYPE bal_s_msg.

    CHECK return IS NOT INITIAL.

    ls_s_msg-msgty = return-type.
    ls_s_msg-msgid = return-id.
    ls_s_msg-msgno = return-number.
    ls_s_msg-msgv1 = return-message_v1.
    ls_s_msg-msgv2 = return-message_v2.
    ls_s_msg-msgv3 = return-message_v3.
    ls_s_msg-msgv4 = return-message_v4.
    ls_s_msg-context = context.
    ls_s_msg-params  = params.
    IF problem_class IS SUPPLIED.
      ls_s_msg-probclass = problem_class.
    ELSE.
      ls_s_msg-probclass = me->get_problem_class( ls_s_msg-msgty ).
    ENDIF.

    CALL FUNCTION 'BAL_LOG_MSG_ADD'
      EXPORTING
        i_s_msg       = ls_s_msg
        i_log_handle  = me->log_handle
      EXCEPTIONS
        log_not_found = 0
        OTHERS        = 1.
    IF sy-subrc = 0.
      ADD 1 TO av_message_counter.
      IF ls_s_msg-msgty EQ gc_message_types-abend
      OR ls_s_msg-msgty EQ gc_message_types-abort
      OR ls_s_msg-msgty EQ gc_message_types-error.
        ADD 1 TO av_error_counter.
      ENDIF.
    ENDIF.
  ENDMETHOD.


  METHOD add_bapi_messages.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_BAL_LOG_WRAPPER~ADD_BAPI_MESSAGES
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for Application Logging for MyFi
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
* 16.06.20 290977SCN RD2K919514 DS-11-32-07-01 changed
*          070667JPS
* 21/09/20 290977SCN RD2K919977 DS-11-32-07-01 S 6000002096: MyFi Purchasing (Release 2.2)
*-----------------------------------------------------------------------
    DATA: ls_s_msg TYPE bal_s_msg.

    CHECK return IS NOT INITIAL.
    LOOP AT return INTO DATA(ls_return).
      ls_s_msg-msgty = ls_return-type.
      ls_s_msg-msgid = ls_return-id.
      ls_s_msg-msgno = ls_return-number.
      ls_s_msg-msgv1 = ls_return-message_v1.
      ls_s_msg-msgv2 = ls_return-message_v2.
      ls_s_msg-msgv3 = ls_return-message_v3.
      ls_s_msg-msgv4 = ls_return-message_v4.
      ls_s_msg-context = context.
      ls_s_msg-params  = params.
      IF problem_class IS SUPPLIED.
        ls_s_msg-probclass = problem_class.
      ELSE.
        ls_s_msg-probclass = me->get_problem_class( ls_s_msg-msgty ).
      ENDIF.

      CALL FUNCTION 'BAL_LOG_MSG_ADD'
        EXPORTING
          i_s_msg       = ls_s_msg
          i_log_handle  = me->log_handle
        EXCEPTIONS
          log_not_found = 0
          OTHERS        = 1.
      IF sy-subrc = 0.
        ADD 1 TO av_message_counter.
        IF ls_s_msg-msgty EQ gc_message_types-abend
        OR ls_s_msg-msgty EQ gc_message_types-abort
        OR ls_s_msg-msgty EQ gc_message_types-error.
          ADD 1 TO av_error_counter.
        ENDIF.
      ENDIF.
    ENDLOOP.
  ENDMETHOD.


  METHOD ADD_SYSTEM_MESSAGE.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_BAL_LOG_WRAPPER~ADD_SYSTEM_MESSAGE
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for Application Logging for MyFi
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
*-----------------------------------------------------------------------
    DATA: ls_s_msg TYPE bal_s_msg.

    ls_s_msg-msgty = sy-msgty.
    ls_s_msg-msgid = sy-msgid.
    ls_s_msg-msgno = sy-msgno.
    ls_s_msg-msgv1 = sy-msgv1.
    ls_s_msg-msgv2 = sy-msgv2.
    ls_s_msg-msgv3 = sy-msgv3.
    ls_s_msg-msgv4 = sy-msgv4.
    ls_s_msg-context = context.
    ls_s_msg-params  = params.
    IF problem_class IS SUPPLIED.
      ls_s_msg-probclass = problem_class.
    ELSE.
      ls_s_msg-probclass = me->get_problem_class( ls_s_msg-msgty ).
    ENDIF.
    CALL FUNCTION 'BAL_LOG_MSG_ADD'
      EXPORTING
        i_s_msg       = ls_s_msg
        i_log_handle  = me->log_handle
      EXCEPTIONS
        log_not_found = 0
        OTHERS        = 1.
    IF sy-subrc = 0.
      ADD 1 TO av_message_counter.
      IF ls_s_msg-msgty EQ gc_message_types-abend
      OR ls_s_msg-msgty EQ gc_message_types-abort
      OR ls_s_msg-msgty EQ gc_message_types-error.
        ADD 1 TO av_error_counter.
      ENDIF.
    ENDIF.

    is_return-type       = sy-msgty.
    is_return-id         = sy-msgid.
    is_return-number     = sy-msgno.
    is_return-message_v1 = sy-msgv1.
    is_return-message_v2 = sy-msgv2.
    is_return-message_v3 = sy-msgv3.
    is_return-message_v4 = sy-msgv4.
  ENDMETHOD.


  METHOD ADD_TEXT.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_BAL_LOG_WRAPPER~ADD_TEXT
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for Application Logging for MyFi
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
*-----------------------------------------------------------------------
    DATA: l_text(200) TYPE c.

    l_text = message_text.
    CALL FUNCTION 'BAL_LOG_MSG_ADD_FREE_TEXT'
      EXPORTING
        i_log_handle     = me->log_handle
        i_msgty          = message_type
        i_probclass      = problem_class
        i_text           = l_text
      EXCEPTIONS
        log_not_found    = 1
        msg_inconsistent = 2
        log_is_full      = 3
        OTHERS           = 4.
    IF sy-subrc = 0.
      ADD 1 TO av_message_counter.
      IF message_type EQ gc_message_types-abend
      OR message_type EQ gc_message_types-abort
      OR message_type EQ gc_message_types-error.
        ADD 1 TO av_error_counter.
      ENDIF.
    ENDIF.
  ENDMETHOD.


  METHOD CONSTRUCTOR.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_BAL_LOG_WRAPPER~CONSTRUCTOR
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for Application Logging for MyFi
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
*-----------------------------------------------------------------------
    DATA: ls_s_log TYPE bal_s_log.

    ls_s_log-extnumber = i_desc.
    ls_s_log-object    = i_obj.
    ls_s_log-subobject = i_subobj.

    IF i_days_to_keep IS NOT INITIAL.
      ls_s_log-aldate_del   = sy-datum + i_days_to_keep.
      ls_s_log-del_before   = 'X'.
    ENDIF.

    CALL FUNCTION 'BAL_LOG_CREATE'
      EXPORTING
        i_s_log                 = ls_s_log
      IMPORTING
        e_log_handle            = log_handle
      EXCEPTIONS
        log_header_inconsistent = 1
        OTHERS                  = 2.
    IF sy-subrc <> 0.
      CLEAR log_handle.
    ENDIF.
  ENDMETHOD.


  METHOD CREATE.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_BAL_LOG_WRAPPER~CREATE
