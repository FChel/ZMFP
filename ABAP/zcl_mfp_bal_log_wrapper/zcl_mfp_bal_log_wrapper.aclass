*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
*-----------------------------------------------------------------------
    CREATE OBJECT instance.
  ENDMETHOD.


  METHOD DISPLAY.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_BAL_LOG_WRAPPER~DISPLAY
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for Application Logging for MyFi
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
*-----------------------------------------------------------------------
    DATA ls_display_profile TYPE bal_s_prof.
    DATA: lt_log_handle TYPE bal_t_logh.

    CALL FUNCTION 'BAL_DSP_PROFILE_SINGLE_LOG_GET'
      IMPORTING
        e_s_display_profile = ls_display_profile
      EXCEPTIONS
        OTHERS              = 1.

    IF sy-subrc = 0.
      APPEND me->log_handle TO lt_log_handle.
      CALL FUNCTION 'BAL_DSP_LOG_DISPLAY'
        EXPORTING
          i_s_display_profile  = ls_display_profile
          i_t_log_handle       = lt_log_handle
        EXCEPTIONS
          profile_inconsistent = 0
          internal_error       = 0
          no_data_available    = 0
          no_authority         = 0
          OTHERS               = 0.
    ENDIF.

  ENDMETHOD.


  METHOD GET_INSTANCE.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_BAL_LOG_WRAPPER~GET_INSTANCE
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for Application Logging for MyFi
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
*-----------------------------------------------------------------------
    CREATE OBJECT ro_application_log
      EXPORTING
        i_desc         = iv_description
        i_obj          = iv_object
        i_subobj       = iv_subobject
        i_days_to_keep = iv_days_to_keep.

  ENDMETHOD.


  METHOD GET_MESSAGES.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_BAL_LOG_WRAPPER~GET_MESSAGES
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for Application Logging for MyFi
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
*-----------------------------------------------------------------------
    DATA lt_bal_messages TYPE bal_t_msgr.
    DATA ls_bal_message  TYPE bal_s_msgr.
    DATA ls_bapiret2     TYPE bapiret2.

    CLEAR et_bal_messages.
    CLEAR et_bapiret2.

    CALL FUNCTION 'BAL_LOG_READ'
      EXPORTING
        i_log_handle  = log_handle
      IMPORTING
        et_msg        = lt_bal_messages
*       ET_EXC        =
      EXCEPTIONS
        log_not_found = 1
        OTHERS        = 2.
    IF sy-subrc <> 0.
*   Implement suitable error handling here
    ELSE.
      IF et_bal_messages IS SUPPLIED.
        et_bal_messages = lt_bal_messages.
      ENDIF.
      IF et_bapiret2 IS SUPPLIED.
        LOOP AT lt_bal_messages INTO ls_bal_message.
          ls_bapiret2-type       = ls_bal_message-msgty.
          ls_bapiret2-id         = ls_bal_message-msgid.
          ls_bapiret2-number     = ls_bal_message-msgno.
          ls_bapiret2-message    = ls_bal_message-msg_txt.
          ls_bapiret2-log_msg_no = ls_bal_message-msgnumber.
          ls_bapiret2-message_v1 = ls_bal_message-msgv1.
          ls_bapiret2-message_v2 = ls_bal_message-msgv2.
          ls_bapiret2-message_v3 = ls_bal_message-msgv3.
          ls_bapiret2-message_v4 = ls_bal_message-msgv4.
          APPEND ls_bapiret2 TO et_bapiret2.
        ENDLOOP.
      ENDIF.
    ENDIF.

  ENDMETHOD.


  METHOD GET_PROBLEM_CLASS.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_BAL_LOG_WRAPPER~GET_PROBLEM_CLASS
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for Application Logging for MyFi
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
*-----------------------------------------------------------------------
    CASE i_msgty.
      WHEN gc_message_types-abort
        OR gc_message_types-error
        OR gc_message_types-abend.
        result = '1'.
      WHEN gc_message_types-warning.
        result = '2'.
      WHEN gc_message_types-info
        OR gc_message_types-success.
        result = '4'.
    ENDCASE.
  ENDMETHOD.


  METHOD HAS_ERROR_MESSAGES.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_BAL_LOG_WRAPPER~HAS_ERROR_MESSAGES
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for Application Logging for MyFi
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
*-----------------------------------------------------------------------
    CLEAR: rv_has_error.

    IF av_error_counter = 0.
      rv_has_error = abap_false.
    ELSE.
      rv_has_error = abap_true.
    ENDIF.

  ENDMETHOD.


  METHOD HAS_MESSAGES.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_BAL_LOG_WRAPPER~HAS_MESSAGES
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for Application Logging for MyFi
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
*-----------------------------------------------------------------------
    IF av_message_counter = 0.
      rv_has_messages = abap_false.
    ELSE.
      rv_has_messages = abap_true.
    ENDIF.

  ENDMETHOD.


  METHOD PERSIST_LOG .
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_BAL_LOG_WRAPPER~PERSIST_LOG
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for Application Logging for MyFi
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
*-----------------------------------------------------------------------
    DATA:
      lt_log_handles TYPE bal_t_logh.

    APPEND log_handle TO lt_log_handles.

    CALL FUNCTION 'BAL_DB_SAVE'
      EXPORTING
        i_t_log_handle   = lt_log_handles
      EXCEPTIONS
        log_not_found    = 1
        save_not_allowed = 2
        numbering_error  = 3
        OTHERS           = 4.

    ASSERT sy-subrc EQ 0.

  ENDMETHOD.
ENDCLASS.