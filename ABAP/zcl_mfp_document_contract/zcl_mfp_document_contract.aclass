  METHOD zif_myfi_document~save_draft.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_DOCUMENT_CONTRACT~zif_myfi_document~save_draft
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for MyFi Documents
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
* 18.12.2023 210983DY RD2K924523  6000003043 MyFi Continuous Improvement February Release
*          Stop auto deletion of draft documents
*-----------------------------------------------------------------------
    DATA: lv_event_success TYPE boole_d.
    me->gv_draft_indicator = abap_true.
    IF gs_contract_deep-contractnumber IS INITIAL.                                              "No doc number so a new record
      gs_contract_deep-contractnumber = gs_contract_deep-requestid = zcl_mfp_utilities=>get_next_request_num( ) .
    ENDIF.
** me->zif_myfi_document~source_doc_num =
    me->zif_myfi_document~posting_doc_num = gs_contract_deep-contractnumber.
    me->create_new_doc_header( iv_status = zif_mfp_constants=>gc_doc_status-draft ).
    gs_contract_deep-status = zif_mfp_constants=>gc_doc_status-draft.
    gs_contract_deep-statusdesc = zcl_mfp_utilities=>get_status_desc( iv_status = zif_mfp_constants=>gc_doc_status-draft ).
    gs_contract_deep-statusdesclong = zcl_mfp_utilities=>get_status_desc( iv_status = zif_mfp_constants=>gc_doc_status-draft ).
    me->zif_myfi_document~get_myfi_details( ).
    me->zif_myfi_document~new_doc_header-selected_delegate = gs_contract_deep-approvaldetails-delegateid.
    me->zif_myfi_document~new_doc_header-section23 = gs_contract_deep-approvaldetails-issection23.

*    me->zif_myfi_document~handle_odata( ).
    me->in_admin_details( ).
    me->in_indigsub( ).
*    me->in_linked_pos( ).
    IF gs_contract_deep-draftassigneeid IS NOT INITIAL.
      CALL METHOD me->assign_document
        EXPORTING
          iv_assignee = gs_contract_deep-draftassigneeid.
    ENDIF.
    super->zif_myfi_document~save_draft( ).


*    CALL METHOD zcl_mfp_oa=>create_event
*      EXPORTING
*        iv_ebeln        = me->zif_myfi_document~posting_doc_num
*        iv_event        = zif_mfp_constants=>gc_event-draft
*      IMPORTING
*        ev_event_raised = lv_event_success.
*
*    IF lv_event_success = abap_true.
*      CALL METHOD zcl_mfp_utilities=>log_myfi_event
*        EXPORTING
*          iv_doc_number = me->zif_myfi_document~posting_doc_num
*          iv_user_id    = sy-uname
*          iv_sub_obj    = zif_mfp_constants=>gc_log-sub_obj-wf-draft.
*    ENDIF.


  ENDMETHOD.


  METHOD zif_myfi_document~validate.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_DOCUMENT_CONTRACT~zif_myfi_document~validate
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for MyFi Documents
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
* 16.07.20 070667JPS RD2K919533 DS-11-32-07-01 S 6000001987: MyFi
*                                              Purchasing (Release 2.1).
*                                              Added call to VALIDATE_
*                                              TOTALS.
* 22.07.20 290977SCN RD2K919533 DS-11-32-07-01 Cater for auto release
* 21/09/20 290977SCN RD2K919977 DS-11-32-07-01 S 6000002096: MyFi Purchasing (Release 2.2)
* 21.10.20 290977SCN RD2K919656 DS-11-32-07-01 S 6000002172: MyFi Purchasing (Release 2.3)
* 03/03/21 210983DY  RD2K920554 DS-11-32-07-01 S 6000002250: MyFi Purchasing (Release 2.4 )
*                               Additional logic to handle new validations
* 26.08.21 210983DY RD2K921634 DS-11-32-07-01 S 6000002507: MyFi Continuous Improvement
*                              additional validation for 5 day payment terms
* 29.11.21 210983DY RD2K922223 DS-11-32-07-01 S 6000002550: MyFi Applications (December Release)
* 18.08.22 210983DY RD2K923033 DS-11-32-07-01 S 6000002805: MyFi Continuous Improvement September Release
*                              Remove validation for 5 day payment terms
* 10/10/23 210983DY RD2K924373 DS-11-32-07-01 6000003027: MyFi Continuous Improvement November Rel
*           Additional validation to check against ASA Cost objects
*-----------------------------------------------------------------------
    DATA: ls_header         TYPE bapimeoutheader,
          ls_header_ret     TYPE bapimeoutheader,
          ls_headerx        TYPE bapimeoutheaderx,
          lt_return         TYPE bapiret2_t,
          lt_return2        TYPE bapiret2_t,
          new_ekko          TYPE ekko,
          new_ekpo          TYPE me_ekpo,
          new_ekkn          TYPE me_ekkn,
          ls_item_extension TYPE bapi_te_meoutitem,
          lv_exchangerate   TYPE wkurs,
          lv_amtcheck       TYPE p LENGTH 9 DECIMALS 3,
          ls_return         TYPE bapiret2.

    me->zif_myfi_document~handle_odata( ).
    super->zif_myfi_document~validate( ).

    new_ekpo = bapi_2_ekpo( it_bapiitem = gt_oaitems ).
    me->zif_myfi_document~old_ekpo = get_ekpo( iv_ebeln = me->zif_myfi_document~source_doc_num ).

    new_ekkn = bapi_2_ekkn( it_bapimeoutaccount = gt_oaaccounts it_bapiparex = gt_extension ).
    me->zif_myfi_document~old_ekkn = get_ekkn( iv_ebeln = me->zif_myfi_document~source_doc_num ).

* Raise Error message if Line item is changed and Marked for deletion
* This check is introduced to stop Update Cancellation Error from BAPI
    LOOP AT new_ekpo INTO DATA(ls_new_ekpo) WHERE loekz = 'L'.

      READ TABLE me->zif_myfi_document~old_ekpo INTO DATA(ls_ekpo_old) WITH KEY ebelp = ls_new_ekpo-ebelp.
      IF sy-subrc IS INITIAL AND NOT ls_ekpo_old-loekz = 'L'.
        CLEAR : ls_new_ekpo-loekz, ls_ekpo_old-aedat, ls_ekpo_old-ebeln, ls_ekpo_old-mandt.
        IF ls_new_ekpo-werks NE ls_ekpo_old-werks OR
           ls_new_ekpo-matkl NE ls_ekpo_old-matkl OR
           ls_new_ekpo-ktmng NE ls_ekpo_old-ktmng OR
           ls_new_ekpo-menge NE ls_ekpo_old-menge OR
           ls_new_ekpo-meins NE ls_ekpo_old-meins OR
           ls_new_ekpo-bprme NE ls_ekpo_old-bprme OR
           ls_new_ekpo-mwskz NE ls_ekpo_old-mwskz OR
           ls_new_ekpo-knttp NE ls_ekpo_old-knttp.
          MESSAGE e105(zmfp) INTO ls_return-message WITH ls_new_ekpo-ebelp.
          ls_return-type = 'E'.
          APPEND ls_return TO gt_return.
          CLEAR : ls_return.

        ELSE.

          READ TABLE gt_oaaccounts INTO DATA(ls_account) WITH KEY item_no = ls_new_ekpo-ebelp.
          READ TABLE me->zif_myfi_document~old_ekkn INTO DATA(ls_old_account) WITH KEY ebelp = ls_new_ekpo-ebelp.

          IF ls_account-gl_account NE ls_old_account-sakto OR
             ls_account-costcenter NE ls_old_account-kostl OR
             ls_account-orderid    NE ls_old_account-aufnr OR
             ls_account-asset_no      NE ls_old_account-anln1 OR
             ls_account-fund NE ls_old_account-geber." or.
            MESSAGE e105(zmfp) INTO ls_return-message WITH ls_new_ekpo-ebelp.
            ls_return-type = 'E'.
            APPEND ls_return TO gt_return.
            CLEAR : ls_return.
          ENDIF.
        ENDIF.

      ENDIF.

    ENDLOOP.

    READ TABLE me->gs_contract_deep-contractlis INTO DATA(ls_odata_oaitem) INDEX 1.


* Validate 5 day payment terms for peppol
*    IF gs_contract_deep-pmnttrms = '0005'.
*      IF  NOT gs_contract_deep-isdraft = abap_true.
*
*        DATA(lv_valid_payterm) = zcl_mfp_document=>validate_einv_paymentterm( iv_ebeln = me->gs_oaheader-number ).
*        IF lv_valid_payterm = abap_false.
*          MESSAGE e104(zmfp) INTO ls_return-message WITH TEXT-001 TEXT-002 TEXT-003 TEXT-004.
*          ls_return-type = 'E'.
*          APPEND ls_return TO gt_return.
*          CLEAR : ls_return.
*        ENDIF.
*      ELSE.
*        lv_amtcheck = '1000000.000'.
*        IF gs_contract_deep-acum_value GT lv_amtcheck.
*          MESSAGE e104(zmfp) INTO ls_return-message WITH TEXT-001 TEXT-002 TEXT-003 TEXT-004.
*          ls_return-type = 'E'.
*          APPEND ls_return TO gt_return.
*          CLEAR : ls_return.
*        ENDIF.
*      ENDIF.
*
*
*    ENDIF.

* Check if logged-on user is ASA employee and check if account assignment is for ASA related
    DATA(ls_asa_empl) = zcl_mfp_utilities=>is_asa_empl( ).
    IF ls_asa_empl-is_asa_empl = abap_true AND gs_contract_deep-comp_code = '1000'.
      DATA(lt_nps_costcentres) = zcl_mfp_utilities=>get_nps_costcentres( ).

      CALL METHOD me->get_cc_accountassignments
        EXPORTING
          it_accountassignments = me->gs_contract_deep-accountassignments
        IMPORTING
          et_cc_assignments     = me->gt_cc_assignments.

      LOOP AT gt_cc_assignments INTO DATA(ls_cc_assignments).
        READ TABLE lt_nps_costcentres TRANSPORTING NO FIELDS WITH KEY kostl = ls_cc_assignments-kostl.
        IF sy-subrc IS NOT INITIAL.
          DATA(lv_line) = |{ ls_cc_assignments-ebelp ALPHA = OUT }|.
          MESSAGE e110(zmfp) INTO ls_return-message WITH lv_line.
          ls_return-type = 'E'.
          ls_return-id = sy-msgid.
          ls_return-number = sy-msgno.
          APPEND ls_return TO gt_return.
          CLEAR : ls_return.
        ENDIF.
      ENDLOOP.
    ENDIF.

* Check to make sure multi currency documents are recorded in 'AUD'
    IF NOT gs_contract_deep-currency = 'AUD'.
      LOOP AT gs_contract_deep-contractlis TRANSPORTING NO FIELDS WHERE currency NE gs_contract_deep-currency.
        MESSAGE e103(zmfp) INTO ls_return-message WITH 'AUD'.
        ls_return-type = 'E'.
        ls_return-id = sy-msgid.
        ls_return-number = sy-msgno.
        APPEND ls_return TO gt_return.
        CLEAR : ls_return.
        EXIT.
      ENDLOOP.
    ENDIF.

* Duplicate check with account assignment of first line item on create OA only
    IF gs_contract_deep-isdraft = abap_true.
      DATA(lv_wbs) =  ls_odata_oaitem-wbs_element.
      IF NOT lv_wbs IS INITIAL.
        CALL FUNCTION 'CONVERSION_EXIT_ABPSP_INPUT'
          EXPORTING
            input     = lv_wbs
          IMPORTING
            output    = lv_wbs
          EXCEPTIONS
            not_found = 1
            OTHERS    = 2.

        SELECT SINGLE prctr FROM prps INTO @DATA(lv_prctr) WHERE pspnr = @lv_wbs.
      ENDIF.
      IF NOT ls_odata_oaitem-costcenter IS INITIAL.

        SELECT SINGLE prctr FROM csks INTO @lv_prctr WHERE kokrs = 'CA01'
          AND kostl = @ls_odata_oaitem-costcenter AND
              datbi GE @sy-datum.
      ENDIF.
      IF NOT lv_prctr IS INITIAL.
        zcl_mfp_utilities=>duplicate_check_w_account( EXPORTING iv_bsart = 'WK'
        iv_ebeln  = me->gs_oaheader-number
        iv_lifnr  = me->gs_oaheader-vendor
        iv_prctr  = lv_prctr
        iv_waers  = me->gs_oaheader-currency
        iv_kdate  = me->gs_oaheader-vper_end
        IMPORTING
          et_return = lt_return ).

        IF line_exists( lt_return[ 1 ] ).
          lt_return = message_handler( it_return = lt_return ).
          APPEND LINES OF lt_return TO gt_return.
        ENDIF.
      ENDIF.
    ENDIF.


*    IF me->gt_oacondition_item IS INITIAL.
*      me->gt_oacondition_item = gt_old_oa_cond_item.
*    ENDIF.

    APPEND LINES OF gt_old_oa_cond_item TO me->gt_oacondition_item.
* Validate exchange rate entered at item level
    LOOP AT me->gt_oacondition_item INTO DATA(ls_item) WHERE currency NE 'AUD'.

      READ TABLE me->gt_extension INTO DATA(ls_ext) WITH KEY structure = 'BAPI_TE_MEOUTITEM'
                                                                   valuepart1(5) = ls_item-item_no.
      IF sy-subrc IS INITIAL.
        MOVE ls_ext-valuepart1 TO ls_item_extension.
        lv_exchangerate = ls_item_extension-kursf.
        CLEAR ls_return.
        ls_return = zcl_mfp_document=>exchangerate_deviation( iv_wkurs = lv_exchangerate
        iv_currency = ls_item-currency iv_lineitem = ls_item-item_no ).
        APPEND ls_return TO gt_return. CLEAR ls_return.
      ENDIF.
    ENDLOOP.

    ls_header = me->gs_oaheader.
    ls_headerx = me->gs_oaheaderx.

    me->validate_totals( ).                                 "RD2K919533

    IF ( me->zif_myfi_document~old_doc_header-status EQ zif_mfp_constants=>gc_doc_status-draft
    OR me->zif_myfi_document~old_doc_header-status IS INITIAL )
    AND me->gv_is_legacy NE abap_true.
      CLEAR: ls_header-number, ls_headerx-number.
      CALL FUNCTION 'BAPI_CONTRACT_CREATE'
        EXPORTING
          header              = ls_header
          headerx             = ls_headerx
          testrun             = abap_true
*      IMPORTING
*         purchasingdocument  = lv_doc_number
        TABLES
          return              = lt_return
          item                = me->gt_oaitems
          itemx               = me->gt_oaitemsx
          account             = me->gt_oaaccounts
          accountx            = me->gt_oaaccountsx
*         delivery_address    = lt_bapimeoutaddrdelivery
          header_text         = me->gt_oatextheader
          item_cond_validity  = me->gt_oacond_valid_item
          item_cond_validityx = me->gt_oacond_validx_item
          item_condition      = me->gt_oacondition_item
          item_conditionx     = me->gt_oaconditionx_item
*         extensionin         = lt_extension.
        .
*    CLEAR ls_return.
    ELSE.
      CALL FUNCTION 'BAPI_CONTRACT_CHANGE'
        EXPORTING
          purchasingdocument  = me->zif_myfi_document~source_doc_num                " Purchasing Document Number
          header              = ls_header                " Header Data Outline Agreement
          headerx             = ls_headerx               " Header Data Change Parameter Outline Agreement
*         vendor_address      =                          " Address Structur Vendor Address
          testrun             = abap_true                " Single-Character Indicator
*         technical_data      =                          " Technical Parameters for Outline Agreement BAPIs
        IMPORTING
          exp_header          = ls_header_ret            " Header Data Outline Agreement
        TABLES
          item                = me->gt_oaitems           " Item Data
          itemx               = me->gt_oaitemsx          " Change Parameter - Item Data
          account             = me->gt_oaaccounts        " Account Assignment Data
*         accountprofitsegment  =                       " Account Assignment - Profitability Segment Calculation
          accountx            = me->gt_oaaccountsx       " Change Parameter - Account Assignment Data
*         delivery_address    =                          " Delivery Address
          item_cond_validity  = me->gt_oacond_valid_item
          item_cond_validityx = me->gt_oacond_validx_item
          item_condition      = me->gt_oacondition_item
          item_conditionx     = me->gt_oaconditionx_item
*         item_cond_scale_value =                       " Value Scale
*         item_cond_scale_quan  =                       " Quantity Scale
*         item_text           =                          " Item Text
          header_text         = me->gt_oatextheader      " Header Text
*         head_cond_validity  =                          " Validity Area of Header Condition
*         head_cond_validityx =                       " Change Parameter - Validity Area of Header Condition
*         head_condition      =                          " Header Condition
*         head_conditionx     =                          " Change Parameter - Header Condition
*         head_cond_scale_val =                       " Value Scale
*         head_cond_scale_quan  =                       " Quantity Scale
*         partner             =                          " Partner Data
*         partnerx            =                          " Table Type: Change Parameter Partner Outline Agreement
*         release_docu        =                          " Table Type: Change Parameter Partner Outline Agreement
*         extensionin         =                          " ExtensionIn (Customer Enhancement)
*         extensionout        =                          " ExtensionOut (Customer Enhancement)
          return              = lt_return.               " Return Table

    ENDIF.

    IF gv_errors EQ abap_false AND ( ls_header_ret-po_rel_ind NE zif_mfp_constants=>gc_mm_doc_status-oa_released AND ls_header_ret-po_rel_ind IS NOT INITIAL ) .
      gv_errors = abap_true.
      MESSAGE e100(zmfp) INTO ls_return-message.
      ls_return-type = sy-msgty.
      ls_return-id = sy-msgid.
      ls_return-number = sy-msgno.
      APPEND ls_return TO gt_return.
    ENDIF.

* Display warning message for Exchange rate deviation from BAPI return
    READ TABLE lt_return INTO DATA(ls_msg) WITH KEY type = 'W'
                                                    id = '06'
                                                    number = '208'.
    IF sy-subrc IS INITIAL.
      CLEAR ls_msg-id.
      APPEND ls_msg TO gt_return.
    ENDIF.
    DELETE lt_return WHERE type = 'S'.
    DELETE lt_return WHERE type = 'I'.
    DELETE lt_return WHERE type = 'W'.
    IF lt_return IS NOT INITIAL.
      lt_return = message_handler( it_return = lt_return ).
      APPEND LINES OF lt_return TO gt_return.
      CLEAR gs_contract_deep.
    ELSEIF gv_errors EQ abap_true.
      CLEAR gs_contract_deep.
*      gt_return = message_handler( it_return = gt_return ). " new code 2.4 check and remove
    ELSEIF gt_return IS NOT INITIAL.
      gt_return = message_handler( it_return = gt_return ).
    ELSE.
      CLEAR: ls_return, gt_return.
      MESSAGE s014(zmfp) INTO ls_return-message.
      ls_return-type = sy-msgty.
      ls_return-id = sy-msgid.
      ls_return-number = sy-msgno.
      APPEND ls_return TO gt_return.
      gt_return = message_handler( it_return = gt_return ).
    ENDIF.

  ENDMETHOD.
ENDCLASS.