CLASS ZCL_MFP_DOCUMENT_CONTRACT IMPLEMENTATION.


  METHOD bapi_2_ekkn.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_DOCUMENT_CONTRACT~bapi_2_ekkn
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for MyFi Documents
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
* 15.07.20 290977SCN RD2K919533 DS-11-32-07-01 Fix to handle WBS
* 22.07.20 290977SCN RD2K919533 DS-11-32-07-01 Conversion Exit for WBS field
* 21.10.20 290977SCN RD2K919656 DS-11-32-07-01 S 6000002172: MyFi Purchasing (Release 2.3)
*-----------------------------------------------------------------------
    DATA: ls_bapimeoutaccount TYPE bapimeoutaccount,
          ls_exkn             TYPE exkn,
          ls_ekkn             TYPE ekkn.

    LOOP AT it_bapimeoutaccount INTO ls_bapimeoutaccount.

      CALL METHOD cl_bapi_meout_mapping=>map2i_exkn
        EXPORTING
          bapimeoutaccount = ls_bapimeoutaccount
        RECEIVING
          exkn             = ls_exkn.

      CALL FUNCTION 'CONVERSION_EXIT_ABPSP_INPUT'
        EXPORTING
          input  = ls_bapimeoutaccount-wbs_element
        IMPORTING
          output = ls_exkn-ps_psp_pnr.

      READ TABLE it_bapiparex WITH KEY valuepart1(5) = ls_bapimeoutaccount-item_no structure = zif_mfp_constants=>gc_cobl-oa valuepart1+5(2) = ls_bapimeoutaccount-serial_no INTO DATA(ls_ext).
      ls_exkn-zzesp = ls_ext-valuepart1+7.

      MOVE-CORRESPONDING ls_exkn TO ls_ekkn.
      ls_ekkn-ebelp = ls_bapimeoutaccount-item_no.
      ls_ekkn-zekkn = ls_exkn-zexkn.
      APPEND ls_ekkn TO rt_ekkn.
      CLEAR: ls_ext, ls_ekkn.
    ENDLOOP.
  ENDMETHOD.


  METHOD bapi_2_ekko.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_DOCUMENT_CONTRACT~bapi_2_ekko
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for MyFi Documents
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
*-----------------------------------------------------------------------
    DATA: ls_meoaheader TYPE meout_header.

*try.
    CALL METHOD cl_bapi_meout_mapping=>map2i_header
      EXPORTING
        bapimeoutheader = is_bapimeoutheader
      RECEIVING
        meout_header    = ls_meoaheader.
* catch cx_mmpur_root .
*endtry.

    MOVE-CORRESPONDING ls_meoaheader TO es_ekko.
  ENDMETHOD.


  METHOD bapi_2_ekpo.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_DOCUMENT_CONTRACT~bapi_2_ekpo
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for MyFi Documents
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
*-----------------------------------------------------------------------
    DATA: ls_bapimeoaitem TYPE bapimeoutitem,
          ls_meoaitem     TYPE meout_item,
          ls_ekpo         TYPE ekpo.

    LOOP AT it_bapiitem INTO ls_bapimeoaitem.

      TRY.
          CALL METHOD cl_bapi_meout_mapping=>map2i_item
            EXPORTING
              bapimeoutitem = ls_bapimeoaitem
            RECEIVING
              meout_item    = ls_meoaitem.
        CATCH cx_mmpur_root .
      ENDTRY.
      ls_meoaitem-effwr = ls_bapimeoaitem-net_price * ls_bapimeoaitem-target_qty.
      MOVE-CORRESPONDING ls_meoaitem TO ls_ekpo.
      APPEND ls_ekpo TO rt_ekpo.
    ENDLOOP.
  ENDMETHOD.


