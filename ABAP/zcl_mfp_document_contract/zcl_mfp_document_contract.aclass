  METHOD check_consumption_values.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_DOCUMENT_CONTRACT~check_consumption_values
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for MyFi Documents
*
* AUTHOR:             Stephen Ning (290977SCN)
* CREATE DATE:        21.10.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000002172 - MyFi Purchasing (Release 2.3)
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 21.10.20 290977SCN RD2K919656 DS-11-32-07-01 S 6000002172: MyFi Purchasing (Release 2.3)
* 03/03/21 210983DY  RD2K920554 DS-11-32-07-01 S 6000002250: MyFi Purchasing (Release 2.4 )
*           Additional code to handle Multi Currency Outline Agreements
*-----------------------------------------------------------------------

    DATA: ls_return   TYPE bapiret2,
          lt_return   TYPE bapiret2_t,
          lv_netvalue TYPE bapicurr_d.

    SELECT * FROM ekab INTO TABLE @DATA(lt_ekab) WHERE konnr EQ @me->zif_myfi_document~source_doc_num ORDER BY ktpnr ASCENDING.
    CHECK sy-subrc EQ 0.
    LOOP AT lt_ekab INTO DATA(ls_ekab).
      DATA(lv_waers) = ls_ekab-waers.
      AT END OF ktpnr.
        SUM.
        lv_netvalue = ls_ekab-netwr.
        DATA(lv_netwr) = zcl_mfp_document=>convert_currency_decimal( iv_waers = lv_waers iv_netwr = lv_netvalue ).
        READ TABLE gt_oaitems WITH KEY item_no = ls_ekab-ktpnr INTO DATA(ls_oaitem) .
        IF ls_ekab-menge GT ls_oaitem-target_qty.
          MESSAGE e022(zmfp) INTO ls_return-message WITH ls_ekab-ktpnr ls_ekab-menge.
*        ELSEIF ls_ekab-netwr GT ( ls_oaitem-target_qty * ls_oaitem-net_price ).
        ELSEIF lv_netwr GT ( ls_oaitem-target_qty * ls_oaitem-net_price ).
          MESSAGE e023(zmfp) INTO ls_return-message WITH ls_ekab-ktpnr ls_ekab-netwr.
        ENDIF.
        IF ls_return IS NOT INITIAL.
          ls_return-type = sy-msgty.
          ls_return-id = sy-msgid.
          ls_return-number = sy-msgno.
          APPEND ls_return TO lt_return.
        ENDIF.
        CLEAR ls_return.
      ENDAT.
    ENDLOOP.
    IF lt_return IS NOT INITIAL.
      et_return = lt_return.
    ENDIF.
  ENDMETHOD.


  METHOD check_delegate.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_DOCUMENT_CONTRACT~check_delegate
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for MyFi Documents
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
* 16.06.20 290977SCN RD2K919514 DS-11-32-07-01 changed
*          070667JPS
* 13/01/22  210983DY RD2K922296 6000002623: MyFi Applications (February Release)
*         Convert Delgate amount from foreign currency to AUD and check delegate
*-----------------------------------------------------------------------
    DATA: lv_total_amt        TYPE effwr,
          lv_foreign_cur      TYPE waers,
          lv_foreign_amt_st   TYPE string,
          lv_foreign_amt      TYPE string,
          lv_delegation_limit TYPE effwr,
          ls_return           TYPE bapiret2.

    IF me->gs_contract_deep-approvaldetails-delegateid IS INITIAL.
      rv_ok = abap_true.
      RETURN.
    ENDIF.

*    LOOP AT me->gt_oaitems ASSIGNING FIELD-SYMBOL(<fs_item>).
*      lv_total_amt = lv_total_amt + ( <fs_item>-target_qty * <fs_item>-net_price ).
*    ENDLOOP.
    lv_total_amt = me->gs_oaheader-acum_value.

    IF me->gs_oaheader-currency EQ 'AUD'.
      lv_total_amt = lv_total_amt.
    ELSE.
      lv_foreign_cur = me->gs_oaheader-currency.
      lv_foreign_amt_st = lv_total_amt.

      SELECT SINGLE currdec INTO @DATA(lv_decimals) FROM  tcurx
                   WHERE  currkey = @me->gs_oaheader-currency.

      CALL FUNCTION 'Z_CURRENCY_IN_DECIMAL'
        EXPORTING
          iv_amount   = lv_foreign_amt_st
          iv_currency = lv_foreign_cur
        IMPORTING
          ev_amount   = lv_foreign_amt.

      CASE lv_decimals.
        WHEN 2.
        WHEN 3.
          lv_foreign_amt = lv_foreign_amt * 100.
        WHEN OTHERS.
      ENDCASE.

* Use exchange rate entered on UI
*      lv_total_amt = lv_foreign_amt * me->gs_contract_deep-exch_rate.
      CALL FUNCTION 'CONVERT_TO_LOCAL_CURRENCY'
        EXPORTING
          date             = sy-datum
          foreign_amount   = lv_foreign_amt
          foreign_currency = lv_foreign_cur
          local_currency   = 'AUD'
          rate             = me->gs_contract_deep-exch_rate
        IMPORTING
          local_amount     = lv_total_amt
        EXCEPTIONS
          no_rate_found    = 1
          overflow         = 2
          no_factors_found = 3
          no_spread_found  = 4
          derived_2_times  = 5
          OTHERS           = 6.
    ENDIF.

    lv_delegation_limit = zcl_mfp_utilities=>get_user_delegation( EXPORTING iv_userid = me->gs_contract_deep-approvaldetails-delegateid ).

    IF lv_delegation_limit GE lv_total_amt.
      gv_delegate_ok = rv_ok = abap_true.

    ELSE.
      MESSAGE e101(zmfp) INTO ls_return-message.
      ls_return-type = sy-msgty.
      ls_return-id = sy-msgid.
      ls_return-number = sy-msgno.
      APPEND ls_return TO gt_return.
      gt_return = message_handler( it_return = gt_return ).
      CLEAR gs_contract_deep.
    ENDIF.

  ENDMETHOD.


method constructor.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_DOCUMENT_CONTRACT~constructor
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for MyFi Documents
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
* 30.11.20 220977FKC RD2K920449 DS-11-32-07-01 6000002172: MyFi Purchasing (Release 2.3)
*                                              Enable legacy i.e. non-myfi created docs
*-----------------------------------------------------------------------
  super->constructor( ).
  zif_myfi_document~gv_useraction  = iv_action.
  zif_myfi_document~source_doc_num = iv_ebeln.
  if iv_ebeln is not initial.
    select single * from ztmfp_doc_header
      where zmfp_doc_id eq @iv_ebeln
      into corresponding fields of @zif_myfi_document~old_doc_header.
    if sy-subrc = 0.
      gv_doc_type = me->zif_myfi_document~old_doc_header-category.
      gs_contract_deep-changed_in_gui = zif_myfi_document~old_doc_header-changed_in_gui.
    else.
      me->gv_is_legacy = gs_contract_deep-islegacy = abap_true.
      select single aedat, frgke
        from ekko
        into (@data(lv_aedat), @data(lv_frgke))
        where ebeln = @iv_ebeln.
      zif_myfi_document~old_doc_header-status = zcl_mfp_utilities=>translate_mm_status_to_mfp( lv_frgke ).
      zif_myfi_document~old_doc_header-create_date = lv_aedat.
      zif_myfi_document~old_doc_header-category = zif_mfp_constants=>gc_myfi_doc_type-myfi_oa.
    endif.
    if gv_doc_type is initial.
      gv_doc_type = zif_mfp_constants=>gc_myfi_doc_type-myfi_oa.
    endif.
  else.
    gv_doc_type = iv_myfi_doc_type.
  endif.
  gt_doc_mapping = me->get_field_mappings( iv_doc_type = gv_doc_type ).
  if is_deep_entity is not initial.
    gs_contract_deep = is_deep_entity.
  endif.
  zif_myfi_document~handle_action( ).

endmethod.


  METHOD convert_mm_table_string.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_DOCUMENT_CONTRACT~convert_mm_table_string
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for MyFi Documents
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
*-----------------------------------------------------------------------
    DATA: ls_line  TYPE string,
          lv_first TYPE boole_d VALUE abap_true.

    LOOP AT it_texts INTO DATA(ls_text).
      IF ls_text-text_id EQ iv_tdid.
        IF lv_first EQ abap_false AND ls_text-text_form EQ '*'.
          ls_line = |{ ls_line }{ cl_abap_char_utilities=>newline }{ ls_text-text_line }|.
        ELSE.
          ls_line = |{ ls_line }{ ls_text-text_line }|.
        ENDIF.
        lv_first = abap_false.

      ENDIF.
    ENDLOOP.
    rv_string = ls_line.


  ENDMETHOD.


  METHOD convert_mm_table_str_item.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_DOCUMENT_CONTRACT~convert_mm_table_string
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for MyFi Documents
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
* 14/01/21 210983DY  RD2K920558 DS-11-32-07-01 S 6000002251: MyFi Purchasing (Release 2.3 Defect Fixes)
*                               Added ItemNo to the method
*-----------------------------------------------------------------------
    DATA: ls_line  TYPE string,
          lv_first TYPE boole_d VALUE abap_true.

    LOOP AT it_texts INTO DATA(ls_text) WHERE item_no = iv_item.
      IF ls_text-text_id EQ iv_tdid.
        IF lv_first EQ abap_false AND ls_text-text_form EQ '*'.
          ls_line = |{ ls_line }{ cl_abap_char_utilities=>newline }{ ls_text-text_line }|.
        ELSE.
          ls_line = |{ ls_line }{ ls_text-text_line }|.
        ENDIF.
        lv_first = abap_false.

      ENDIF.
    ENDLOOP.
    rv_string = ls_line.


  ENDMETHOD.


  METHOD convert_string_mm_item_table.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_DOCUMENT_CONTRACT~convert_string_mm_table
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for MyFi Documents
*
* AUTHOR:             Dathri Yellamarthy (210983DY)
* CREATE DATE:        13.11.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 13.11.20 210983DY RD2K919078 DS-11-32-07-01 Created

*-----------------------------------------------------------------------
    DATA: ls_bapi_string TYPE bapimeoutitemtext,
          lt_table       TYPE STANDARD TABLE OF text132,
          lv_string      TYPE string,
          lt_split_lines TYPE STANDARD TABLE OF string.

    SPLIT iv_string AT cl_abap_char_utilities=>newline INTO TABLE lt_split_lines.
    IF lt_split_lines IS INITIAL.
      ls_bapi_string-item_no = iv_item.
      ls_bapi_string-text_id = iv_tdid.
      ls_bapi_string-text_form = '*'.
      ls_bapi_string-text_line = ''.  "Empty string - i.e. clear out the pickup location if it has a value
      APPEND ls_bapi_string TO rt_texts.
    ELSE.
      LOOP AT lt_split_lines INTO lv_string.

        CALL FUNCTION 'CONVERT_STRING_TO_TABLE'
          EXPORTING
            i_string         = lv_string
            i_tabline_length = 132
          TABLES
            et_table         = lt_table.

        ls_bapi_string-item_no = iv_item.
        ls_bapi_string-text_id = iv_tdid.
        ls_bapi_string-text_form = '*'.
        LOOP AT lt_table INTO DATA(ls_table).
          ls_bapi_string-text_line = ls_table.
          APPEND ls_bapi_string TO rt_texts.
          CLEAR ls_bapi_string-text_form.
        ENDLOOP.
        CLEAR lt_table.
      ENDLOOP.

    ENDIF.

  ENDMETHOD.


  METHOD convert_string_mm_table.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_DOCUMENT_CONTRACT~convert_string_mm_table
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for MyFi Documents
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
*-----------------------------------------------------------------------
    DATA: ls_bapi_string TYPE bapimeouttext,
          lt_table       TYPE STANDARD TABLE OF text132,
          lv_string      TYPE string,
          lt_split_lines TYPE STANDARD TABLE OF string.

    SPLIT iv_string AT cl_abap_char_utilities=>newline INTO TABLE lt_split_lines.
    IF lt_split_lines IS INITIAL.
      ls_bapi_string-text_id = iv_tdid.
      ls_bapi_string-text_form = '*'.
      ls_bapi_string-text_line = ''.  "Empty string - i.e. clear out the pickup location if it has a value
      APPEND ls_bapi_string TO rt_texts.
    ELSE.
      LOOP AT lt_split_lines INTO lv_string.

        CALL FUNCTION 'CONVERT_STRING_TO_TABLE'
          EXPORTING
            i_string         = lv_string
            i_tabline_length = 132
          TABLES
            et_table         = lt_table.

        ls_bapi_string-text_id = iv_tdid.
        ls_bapi_string-text_form = '*'.
        LOOP AT lt_table INTO DATA(ls_table).
          ls_bapi_string-text_line = ls_table.
          APPEND ls_bapi_string TO rt_texts.
          CLEAR ls_bapi_string-text_form.
        ENDLOOP.
        CLEAR lt_table.
      ENDLOOP.

    ENDIF.

  ENDMETHOD.


  METHOD create_item_condition.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_DOCUMENT_CONTRACT~CREATE_ITEM_CONDITION
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2.2).
*                     This method creates a condition line for an MyFi OA document.
*
* AUTHOR:             Stephen Ning (290977SCN)
* CREATE DATE:        21.09.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000002096 - MyFi Purchasing Release 2.2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 21/09/20 290977SCN RD2K919977 DS-11-32-07-01 S 6000002096: MyFi Purchasing (Release 2.2)
* 21.10.20 290977SCN RD2K919656 DS-11-32-07-01 S 6000002172: MyFi Purchasing (Release 2.3)
* 03/03/21 210983DY  RD2K920554 DS-11-32-07-01 S 6000002250: MyFi Purchasing (Release 2.4 )
*                               Additional code to handle creation of condition record for OA's
*-----------------------------------------------------------------------

    DATA: ls_bapi_lineitem    TYPE bapimeoutitem,
          ls_bapi_condition   TYPE bapimeoutcondition,
          ls_bapi_conditionx  TYPE bapimeoutconditionx,
          ls_bapi_cond_valid  TYPE bapimeoutvalidity,
          ls_bapi_cond_validx TYPE bapimeoutvalidityx,
          lv_count            TYPE         i.

    ls_bapi_lineitem = is_bapi_lineitem.
    ADD 1 TO lv_count.
**    CHECK sy-subrc EQ 0.

    LOOP AT me->gt_old_oa_val_cond_item INTO DATA(ls_cond_val) WHERE item_no EQ ls_bapi_lineitem-item_no AND
                                                                     valid_from LE sy-datum AND
                                                                     valid_to GE sy-datum.
      READ TABLE me->gt_old_oa_cond_item WITH KEY serial_id = ls_cond_val-serial_id item_no = ls_cond_val-item_no deletion_ind = ' '
                                             INTO DATA(ls_cond).
      EXIT.
    ENDLOOP.

    IF sy-subrc NE 0 OR NOT ( ls_cond-cond_value EQ ls_bapi_lineitem-net_price AND
             ls_cond-currency EQ iv_currency AND
             ls_cond-base_uom EQ ls_bapi_lineitem-po_unit ).

      ls_bapi_condition-item_no = ls_bapi_lineitem-item_no.
      ls_bapi_condition-cond_type = 'PB00'.
      ls_bapi_condition-scale_type = 'A'.
      ls_bapi_condition-cond_value = ls_bapi_lineitem-net_price.
      ls_bapi_condition-currency = iv_currency.
      ls_bapi_condition-calctypcon = 'C'.
      ls_bapi_condition-base_uom = ls_bapi_lineitem-po_unit.
      ls_bapi_condition-cond_unit = ls_bapi_lineitem-orderpr_un. "zcl_mfp_utilities=>get_uom( iv_uom = ls_bapi_lineitem-orderpr_un ).
      ls_bapi_condition-cond_count = '01'.
      ls_bapi_condition-cond_p_unt = 1.
      ls_bapi_condition-numerator = 1.
      ls_bapi_condition-denominator = 1.
      ls_bapi_condition-change_id = 'I'.

      ls_bapi_condition-serial_id = ls_bapi_lineitem-item_no."lv_count

      APPEND ls_bapi_condition TO gt_oacondition_item.

      ls_bapi_conditionx-item_no = ls_bapi_lineitem-item_no.
      ls_bapi_conditionx-serial_id = ls_bapi_condition-serial_id."ls_bapi_lineitem-item_no. "'X'.
      ls_bapi_conditionx-serial_idx = 'X'.
      ls_bapi_conditionx-item_nox = 'X'.
      ls_bapi_conditionx-cond_type = 'X'.
      ls_bapi_conditionx-cond_count = '01'.  " DY
      ls_bapi_conditionx-cond_countx = abap_true.  " DY
      ls_bapi_conditionx-scale_type = 'X'.
      ls_bapi_conditionx-cond_value = 'X'.
      ls_bapi_conditionx-currency = 'X'.
      ls_bapi_conditionx-calctypcon = 'X'.
      ls_bapi_conditionx-cond_unit = 'X'.
      ls_bapi_conditionx-base_uom = 'X'.
      ls_bapi_conditionx-cond_count = 'X'.
      ls_bapi_conditionx-cond_p_unt = 'X'.
      ls_bapi_conditionx-numerator = 'X'.
      ls_bapi_conditionx-denominator = 'X'.
      APPEND ls_bapi_conditionx TO gt_oaconditionx_item.

      ls_bapi_cond_valid-item_no = ls_bapi_lineitem-item_no.
      ls_bapi_cond_valid-valid_from = sy-datum.
      ls_bapi_cond_valid-valid_to = '99991231'.
      ls_bapi_cond_valid-serial_id = ls_bapi_condition-serial_id."ls_bapi_lineitem-item_no.
      APPEND ls_bapi_cond_valid TO gt_oacond_valid_item.

      ls_bapi_cond_validx-item_no = ls_bapi_lineitem-item_no.
      ls_bapi_cond_validx-item_nox = 'X'.
      ls_bapi_cond_validx-valid_from = 'X'.
      ls_bapi_cond_validx-valid_to = 'X'.
      ls_bapi_cond_validx-serial_idx = 'X'.
      ls_bapi_cond_validx-serial_id = ls_bapi_condition-serial_id. "ls_bapi_lineitem-item_no.
      APPEND ls_bapi_cond_validx TO gt_oacond_validx_item.
    ENDIF.
  ENDMETHOD.


  METHOD create_new_doc_header.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_DOCUMENT_CONTRACT~create_new_doc_header
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for MyFi Documents
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
*-----------------------------------------------------------------------
    IF me->zif_myfi_document~old_doc_header IS INITIAL.
      super->create_new_doc_header( iv_status = iv_status ).
    ELSE.
      me->zif_myfi_document~new_doc_header = me->zif_myfi_document~old_doc_header.
      me->zif_myfi_document~new_doc_header-selected_delegate = gs_contract_deep-approvaldetails-delegateid.
    ENDIF.
*    me->zif_myfi_document~new_doc_header-selected_delegate = gs_contract_deep-approvaldetails-delegateid.
*    me->zif_myfi_document~new_doc_header-section23 = gs_contract_deep-approvaldetails-issection23.
  ENDMETHOD.


  METHOD delegate_required.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_DOCUMENT_CONTRACT~delegate_required
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for MyFi Documents
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
* 22.07.20 290977SCN RD2K919533 DS-11-32-07-01 Cater downfund and line deletions
* 21/09/20 290977SCN RD2K919977 DS-11-32-07-01 S 6000002096: MyFi Purchasing (Release 2.2)
* 13/01/22  210983DY RD2K922296 6000002623: MyFi Applications (February Release)
*
*-----------------------------------------------------------------------
    DATA: new_ekko       TYPE ekko,
          new_ekpo       TYPE me_ekpo,
          new_ekkn       TYPE me_ekkn,
          lt_changes     TYPE TABLE OF zsmfp_changed_fields,
          lt_amt_changes TYPE zmfp_ekkn_totals_tt,
          ls_return      TYPE bapiret2.

    LOOP AT gs_contract_deep-contractlis INTO DATA(ls_odata_oaitem)
          WHERE status NE zif_mfp_constants=>gc_line_status-deleted.
      EXIT.
    ENDLOOP.
    CHECK sy-subrc EQ 0 AND gs_contract_deep-acum_value NE '0.01'. "all lines deleted and target value is 0.01

    IF me->zif_myfi_document~gv_useraction = zif_mfp_constants=>gc_action-odata-create OR me->zif_myfi_document~old_doc_header-status NE zif_mfp_constants=>gc_doc_status-approved.
      gv_errors = abap_true.
    ENDIF.

    IF gv_errors EQ abap_false.

      new_ekko = bapi_2_ekko( is_bapimeoutheader = gs_oaheader ).
      me->zif_myfi_document~old_ekko = get_ekko( iv_ebeln = me->zif_myfi_document~source_doc_num ).

      zcl_mfp_utilities=>convert_curr_format(
        EXPORTING
          iv_amount = me->zif_myfi_document~old_ekko-ktwrt                  " Target Value for Header Area per Distribution
          iv_curr   = me->zif_myfi_document~old_ekko-waers                 " Currency Key
        RECEIVING
          rv_amount = me->zif_myfi_document~old_ekko-ktwrt                 " Target Value for Header Area per Distribution
      ).

      CALL METHOD zcl_mfp_utilities=>check_sensitive_fields_ekko
        EXPORTING
          is_new_ekko        = new_ekko
          is_old_ekko        = me->zif_myfi_document~old_ekko
          iv_check_sensitive = abap_true
          iv_table_2_test    = 'EKKO'
        IMPORTING
          et_changed_fields  = lt_changes.

      READ TABLE lt_changes WITH KEY approval_req = abap_true TRANSPORTING NO FIELDS.
      IF sy-subrc = 0.
        gv_errors = abap_true.
      ENDIF.
    ENDIF.
    IF gv_errors EQ abap_false.

      new_ekpo = bapi_2_ekpo( it_bapiitem = gt_oaitems ).
      me->zif_myfi_document~old_ekpo = get_ekpo( iv_ebeln = me->zif_myfi_document~source_doc_num ).

      CALL METHOD zcl_mfp_utilities=>check_sensitive_fields_ekpo
        EXPORTING
          it_new_ekpo        = new_ekpo                " Purchasing Document Header
          it_old_ekpo        = me->zif_myfi_document~old_ekpo                 " Purchasing Document Header
          iv_check_sensitive = abap_true                 " Data element for domain BOOLE: TRUE (='X') and FALSE (=' ')
          iv_table_2_test    = 'EKPO'                 " Field of length 16
        IMPORTING
          et_changed_fields  = lt_changes.                 " Sensitive fields tab
      READ TABLE lt_changes WITH KEY approval_req = abap_true TRANSPORTING NO FIELDS.
      IF sy-subrc = 0.
        gv_errors = abap_true.
      ENDIF.
    ENDIF.
    IF gv_errors EQ abap_false.

      new_ekkn = bapi_2_ekkn( it_bapimeoutaccount = gt_oaaccounts it_bapiparex = gt_extension ).
      me->zif_myfi_document~old_ekkn = get_ekkn( iv_ebeln = me->zif_myfi_document~source_doc_num ).

      LOOP AT me->zif_myfi_document~old_ekkn ASSIGNING FIELD-SYMBOL(<fs_old_ekkn>) .
        CLEAR <fs_old_ekkn>-vproz.
      ENDLOOP.
      CALL METHOD zcl_mfp_utilities=>check_sensitive_cost_assign
        EXPORTING
          it_ekpo_new        = new_ekpo                 " Table Type for Purchasing Document Items
          it_ekkn_new        = new_ekkn                 " Table Type for EKKN
          it_ekpo_old        = me->zif_myfi_document~old_ekpo                " Table Type for Purchasing Document Items
          it_ekkn_old        = me->zif_myfi_document~old_ekkn                " Table Type for EKKN
          iv_check_sensitive = abap_true                " Data element for domain BOOLE: TRUE (='X') and FALSE (=' ')
        RECEIVING
          rt_ekkn_total      = lt_amt_changes.                  " Table Type for EKKN

      LOOP AT lt_amt_changes ASSIGNING FIELD-SYMBOL(<ls_changes>).
        IF <ls_changes>-app_req EQ abap_true.
          gv_errors = abap_true.
          EXIT.
        ENDIF.
      ENDLOOP.
    ENDIF.

    IF gv_errors EQ abap_true.

      MESSAGE e100(zmfp) INTO ls_return-message.
      ls_return-type = sy-msgty.
      ls_return-id = sy-msgid.
      ls_return-number = sy-msgno.
      APPEND ls_return TO gt_return.
    ENDIF.

  ENDMETHOD.


  METHOD fill_gs_edm_details.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_DOCUMENT_CONTRACT~fill_gs_edm_details
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for MyFi Documents
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
*-----------------------------------------------------------------------
    DATA: ls_ekkn   TYPE ekkn,
          lv_total  TYPE effwr,
          ls_poitem TYPE bapimepoitem.

    gs_edm_oa-requestid = me->zif_myfi_document~source_doc_num.

    SELECT SINGLE name1
      FROM lfa1
      INTO gs_edm_oa-vendorname
     WHERE lifnr = me->zif_myfi_document~old_ekko-lifnr.

    MOVE-CORRESPONDING me->zif_myfi_document~old_doc_header TO gs_edm_oa.
    MOVE-CORRESPONDING is_oaheader TO gs_edm_oa.

    LOOP AT me->zif_myfi_document~old_ekkn INTO ls_ekkn.
      MOVE-CORRESPONDING ls_ekkn TO gs_edm_oa.
      EXIT. " only one account assignment is being used currently for MyFi.
    ENDLOOP.


  ENDMETHOD.


  METHOD fill_gs_edm_totals.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_DOCUMENT_CONTRACT~fill_gs_edm_totals
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for MyFi Documents
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
*-----------------------------------------------------------------------
    DATA: ls_edm_totals TYPE zsmfp_edm_consumption_summ.
    CLEAR: gv_edm_totals.
    LOOP AT it_bapiekbes_tp INTO DATA(line_total).
      CASE line_total-serial_no.
        WHEN '00'. "GRs
          gv_edm_totals-tobedelivered = gv_edm_totals-tobedelivered + line_total-deliv_qty .
          gv_edm_totals-totalordered = gv_edm_totals-totalordered + line_total-val_gr_loc .
        WHEN '01'. "IRs
          gv_edm_totals-totalinvoiced = gv_edm_totals-totalinvoiced + line_total-val_iv_loc .
        WHEN OTHERS.
      ENDCASE.
    ENDLOOP.
  ENDMETHOD.


  METHOD get_consumption.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_DOCUMENT_CONTRACT->GET_CONSUMPTION
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2.2).
*                     This method retrieves the Consumption data for an OA and related POs
*
* AUTHOR:             Stephen Ning (290977SCN)
* CREATE DATE:        21.09.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000002096 - MyFi Purchasing Release 2.2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 24/09/20 290977SCN RD2K919977 DS-11-32-07-01 S 6000002096: MyFi Purchasing (Release 2.2)
* 03/03/21 210983DY  RD2K920554 DS-11-32-07-01 S 6000002250: MyFi Purchasing (Release 2.4 )
*                  Additional code to handle Multi Currency Outline Agreements
* 16.04.21 210983DY RD2K920923  DS-11-32-07-01 S 6000002348: MyFi Purchasing (May Release)
*                               Additional logic to handle currencey translation ratio for
*                               Multiple Currenecies
*-----------------------------------------------------------------------
    DATA: lv_total      TYPE val_forcurr, " ktwrt, "val_forcurr,
          ls_po_summary TYPE zcl_zedm_mfp_mpc=>ts_consumptionsummary.

    DATA(l_multi_curr_oa) = zcl_mfp_utilities=>multi_currency_oa(
            i_ebeln = me->zif_myfi_document~source_doc_num
            i_waers = me->gs_oaheader-currency ).

    IF l_multi_curr_oa = abap_true. ENDIF.

    SELECT a~ebeln, a~netwr, a~konnr, a~wkurs     "added exchange rate
      FROM ekab AS a
      INTO TABLE @DATA(lt_ekab)
                              WHERE a~konnr EQ @me->zif_myfi_document~source_doc_num
                           ORDER BY a~ebeln ASCENDING.

    LOOP AT lt_ekab INTO DATA(ls_ekab).
      IF ls_po_summary-contractnumber IS INITIAL.
        ls_po_summary-contractnumber = ls_ekab-konnr.
      ENDIF.
      DATA(lv_wkurs) = ls_ekab-wkurs.
      AT END OF ebeln.
        SUM.
        lv_total = ls_ekab-netwr.
        CHECK NOT lv_total IS INITIAL.
        SELECT SINGLE ekgrp, aedat, waers FROM ekko INTO @DATA(ls_ekko) WHERE ebeln EQ @ls_ekab-ebeln.

        CALL METHOD zcl_mfp_utilities=>get_po_consumption_summary
          EXPORTING
            iv_ebeln       = ls_ekab-ebeln
            iv_ekgrp       = ls_ekko-ekgrp
            iv_createdate  = ls_ekko-aedat
            iv_currency    = ls_ekko-waers
            iv_total_fcurr = lv_total
          IMPORTING
            es_po_con_summ = ls_po_summary.

        APPEND ls_po_summary TO gt_oa_po_consumption.

* Release 2.4 - multi currency OA change
        IF l_multi_curr_oa = abap_true .

          DATA(lv_factor) = zcl_mfp_utilities=>get_currency_factor(
               iv_currency = ls_ekko-waers ).

          ls_po_summary-contracttotalordered = ls_po_summary-contracttotalordered * lv_wkurs.
          ls_po_summary-contracttotalordered = ls_po_summary-contracttotalordered / lv_factor.
        ENDIF.

        me->gs_contract_deep-consumptionsummary-contracttotalordered = me->gs_contract_deep-consumptionsummary-contracttotalordered
                                                                          + ls_po_summary-contracttotalordered.
        me->gs_contract_deep-consumptionsummary-contracttotalordered = round( val = me->gs_contract_deep-consumptionsummary-contracttotalordered dec = 2 ).
        me->gs_contract_deep-consumptionsummary-tobedelivered = me->gs_contract_deep-consumptionsummary-tobedelivered
                                                                          + ls_po_summary-tobedelivered.
        me->gs_contract_deep-consumptionsummary-tobeinvoiced = me->gs_contract_deep-consumptionsummary-tobeinvoiced
                                                                          + ls_po_summary-tobeinvoiced.
        me->gs_contract_deep-consumptionsummary-totaldelivered = me->gs_contract_deep-consumptionsummary-totaldelivered
                                                                          + ls_po_summary-totaldelivered.
        me->gs_contract_deep-consumptionsummary-totalinvoiced = me->gs_contract_deep-consumptionsummary-totalinvoiced
                                                                          + ls_po_summary-totalinvoiced.
        me->gs_contract_deep-consumptionsummary-totalordered = me->gs_contract_deep-consumptionsummary-totalordered
                                                                          + ls_po_summary-totalordered.
        CLEAR: lv_total, ls_po_summary, lv_wkurs.
      ENDAT.
    ENDLOOP.
    me->gs_contract_deep-consumptionsummary-contractnumber = me->zif_myfi_document~source_doc_num.
    me->gs_contract_deep-consumptionsummary-parentnumber = me->zif_myfi_document~source_doc_num.
    me->gs_contract_deep-consumptionsummary-contracttotalvalue = zcl_mfp_utilities=>convert_curr_format( iv_amount = me->gs_oaheader-acum_value
                                                                   iv_curr   = me->gs_oaheader-currency ) .
    me->gs_contract_deep-consumptionsummary-contractunassignedvalue = me->gs_contract_deep-consumptionsummary-contracttotalvalue -
                                                                      me->gs_contract_deep-consumptionsummary-contracttotalordered.

    me->gs_contract_deep-consumptionsummary-contractunassignedvalue = round( val = me->gs_contract_deep-consumptionsummary-contractunassignedvalue dec = 2 ).
    me->gs_contract_deep-consumptionsummary-currency = me->gs_oaheader-currency.

  ENDMETHOD.


  METHOD get_quantity_left.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_DOCUMENT_CONTRACT~get_quantity_left
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for MyFi Documents
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
*-----------------------------------------------------------------------
    is_odata_lineitem-qtyleft = is_odata_lineitem-target_qty.
    LOOP AT me->gt_oareleasedocu INTO DATA(ls_rel_docu) WHERE item_no EQ is_odata_lineitem-linenumber.
      is_odata_lineitem-qtyleft = is_odata_lineitem-qtyleft - ls_rel_docu-quantity.
    ENDLOOP.
  ENDMETHOD.


