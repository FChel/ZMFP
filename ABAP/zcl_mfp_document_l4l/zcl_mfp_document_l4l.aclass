  METHOD in_prepmnt_line.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_DOCUMENT_L4L~in_prepmnt_line
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for MyFi Documents
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
* 14.03.2024 210983DY RD2K924772    6000003112: MyFi Continuous Improvement Release 2024
*                 Amended logic for new Prepayment and FMS field changes
*-----------------------------------------------------------------------
    DATA: ls_new_prepmnt TYPE ztmfp_prepmnt,
          ls_bapi_poitem TYPE bapimepoitem,
          lv_oa_item     TYPE ebelp,
          lv_exit_flag   TYPE boole_d.

    LOOP AT gs_contract_deep-contractlis INTO DATA(ls_odata_oaitem).
      lv_oa_item = ls_odata_oaitem-linenumber.
      IF is_odata_oaitem IS NOT INITIAL.
        ls_odata_oaitem = is_odata_oaitem.
        lv_oa_item = iv_oa_item.
        lv_exit_flag = abap_true.
      ENDIF.
      CLEAR ls_new_prepmnt.
      ls_new_prepmnt-zmfp_doc_id = gs_oaheader-number.
      ls_new_prepmnt-linenumber = lv_oa_item.

      ls_new_prepmnt-isprepayment = ls_odata_oaitem-isprepayment.
      ls_new_prepmnt-isstraightline = ls_odata_oaitem-isstraightline.
      ls_new_prepmnt-purchasetype = ls_odata_oaitem-purchasetype.

      IF ls_odata_oaitem-prepaymentcompleteddate IS NOT INITIAL.
        ls_new_prepmnt-prepaymentcompleteddate = zcl_mfp_utilities=>get_date_from_ts( EXPORTING iv_timestamp = ls_odata_oaitem-prepaymentcompleteddate ).
      ENDIF.
      APPEND ls_new_prepmnt TO me->zif_myfi_document~new_prepmnts.
      IF lv_exit_flag EQ abap_true.
        EXIT.
      ENDIF.
    ENDLOOP.

  ENDMETHOD.


  METHOD map_admindtl_prf.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_DOCUMENT_L4L~MAP_ADMINDTL_PRF
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for MyFi Documents
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
* 19.06.20 290977SCN RD2K919517 DS-11-32-07-01 S 6000001863: MyFi
*          070667JPS                           Purchasing Release 2_ECC
*                                              DEFECTS II.  Corrected
*                                              indigenous subcontractor
*                                              mapping.
*-----------------------------------------------------------------------
    CONSTANTS: BEGIN OF zgrp_fields_const,
                 fiscal_yr          TYPE name_komp VALUE 'ERP_FISCAL_YEAR',
                 vendor_id          TYPE name_komp VALUE 'ERP_VENDOR_ID',
                 vendor_name        TYPE name_komp VALUE 'ERP_VENDOR_NAM',
                 vendor_vatno       TYPE name_komp VALUE 'ERP_VENDOR_VATNO',
                 total_amount_value TYPE name_komp VALUE 'ERP_TOTAL_CONTRACT_VAL',
                 total_value_curr   TYPE name_komp VALUE 'ERP_TOTAL_VAL_CURR',
                 ctr_strt_dt        TYPE name_komp VALUE 'ERP_CTR_START_DT',
                 ctr_end_dt         TYPE name_komp VALUE 'ERP_CTR_END_DT',
                 po_grp             TYPE name_komp VALUE 'ERP_PO_GRP',
                 day_calc_ref       TYPE name_komp VALUE 'ERP_DAY_CALC_REF',
                 co_code            TYPE name_komp VALUE 'ITEM_CO_CODE',
                 del_ind            TYPE name_komp VALUE 'DELETION_STATUS_FLAG',
                 item_amount_value  TYPE name_komp VALUE 'CONTRACT_VALUE',
                 gl_account         TYPE name_komp VALUE 'GL_ACCOUNT',
                 material_group     TYPE name_komp VALUE 'MATERIAL_GRP',
                 release_status     TYPE name_komp VALUE 'RELEASE_STATUS', "2623667
                 son_id             TYPE name_komp VALUE 'SON_ID', "MyFI Additional Fields
                 son_mul            TYPE name_komp VALUE 'SON_MUL', "MyFI Additional Fields
                 ind_bus            TYPE name_komp VALUE 'IND_BUS', "MyFI Additional Fields
                 ind_sub            TYPE name_komp VALUE 'IND_SUB', "MyFI Additional Fields
               END OF zgrp_fields_const,
               lc_header_index TYPE char1 VALUE 1.

    DATA: lv_indi_contract TYPE zzctrwithindig.
    DATA: lv_indi_sub        TYPE zzindigsubqtn,
          ls_struc_line_item TYPE zgrp_s_data_transfer_struc,
          lt_header_data     TYPE zgrp_t_data_transfer_struc,
          lt_item_data       TYPE zgrp_t_data_transfer_struc.


    .   "Check to see if MyFI contains SON
    "SON ID
    ls_struc_line_item-tableindex = 0.
    ls_struc_line_item-fieldname = zgrp_fields_const-son_id.
    ls_struc_line_item-data = gs_contract_deep-sonid.
    APPEND ls_struc_line_item TO lt_item_data.
    ls_struc_line_item-tableindex = 1.
    APPEND ls_struc_line_item TO lt_item_data.
    CLEAR ls_struc_line_item.

    "SON MUL
    ls_struc_line_item-tableindex = 0.
    ls_struc_line_item-fieldname = zgrp_fields_const-son_mul.
    IF gs_contract_deep-sonid IS INITIAL.
      ls_struc_line_item-data = 'N'.
    ELSE.
      ls_struc_line_item-data = 'Y'.
    ENDIF.
    APPEND ls_struc_line_item TO lt_item_data.
    ls_struc_line_item-tableindex = 1.
    APPEND ls_struc_line_item TO lt_item_data.
    CLEAR ls_struc_line_item.

    IF is_admindtl-indigenous_outcome EQ 'S'.
      lv_indi_contract = 'Y'.
    ELSE.
      lv_indi_contract = 'N'.
    ENDIF.

    "Indigenous Business
    ls_struc_line_item-tableindex = 0.
    ls_struc_line_item-fieldname = zgrp_fields_const-ind_bus.
    ls_struc_line_item-data = lv_indi_contract. " UPDATE to get DATA from MyFi
    APPEND ls_struc_line_item TO lt_item_data.
    ls_struc_line_item-tableindex = 1.
    APPEND ls_struc_line_item TO lt_item_data.
    CLEAR ls_struc_line_item.

*    IF is_admindtl-is_indig_subcontract EQ abap_true.
*      lv_indi_sub = 'Y'.
*    ELSE.
*      lv_indi_sub = 'N'.is_admindtl-is_indig_subcontract
*    ENDIF.

*    lv_indi_sub = is_admindtl-is_indig_subcontract.
*
*
*    "Indigenous Subcontractor
*    ls_struc_line_item-tableindex = 0.
*    ls_struc_line_item-fieldname = zgrp_fields_const-ind_sub.
*    ls_struc_line_item-data = lv_indi_sub. " UPDATE to get DATA from MyFi
*    APPEND ls_struc_line_item TO lt_item_data.
*    ls_struc_line_item-tableindex = 1.
*    APPEND ls_struc_line_item TO lt_item_data.
*    CLEAR ls_struc_line_item.
*
*
    APPEND LINES OF lt_item_data TO ct_item_data.


  ENDMETHOD.


  METHOD message_handler.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_DOCUMENT_L4L~MESSAGE_HANDLER
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2.2).
*
* AUTHOR:             Stephen Ning (290977SCN)
* CREATE DATE:        21.10.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000002096 - MyFi Purchasing Release 2.2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 21.10.20 290977SCN RD2K919656 DS-11-32-07-01 S 6000002172: MyFi Purchasing (Release 2.3)
*-----------------------------------------------------------------------
    DATA: lt_return TYPE bapiret2_t.

    CALL METHOD super->message_handler
      EXPORTING
        it_return = it_return
      RECEIVING
        rt_return = lt_return.

    LOOP AT lt_return ASSIGNING FIELD-SYMBOL(<return>).
      CASE <return>-parameter.
        WHEN 'HEADER'.
        WHEN 'ITEM'.
          <return>-message = |Item({ <return>-row }) - { <return>-message }|.
        WHEN OTHERS.
      ENDCASE.
    ENDLOOP.
    rt_return = lt_return.
  ENDMETHOD.


  METHOD post_l4l_po.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_DOCUMENT_L4L~post_l4l_po
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for MyFi Documents
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
*-----------------------------------------------------------------------
    me->zif_myfi_document~read_data( ).

    fill_l4l_po_deep( ).
    CREATE OBJECT go_l4l_po TYPE zcl_mfp_document_po
      EXPORTING
        iv_ebeln         = me->zif_myfi_document~old_doc_header-ref_id                 " Purchasing Document Number
        is_deep_entity   = gs_l4l_po_deep
        iv_action        = zif_mfp_constants=>gc_action-odata-create
        iv_myfi_doc_type = zif_mfp_constants=>gc_myfi_doc_type-l4l_po
        iv_requestor     = gv_l4l_requestor.
    .
    et_return = go_l4l_po->gt_return.
    READ TABLE et_return WITH KEY type = 'S' TRANSPORTING NO FIELDS.
    IF sy-subrc EQ 0.

      zcl_mfp_utilities=>transfer_connection_of_mime(
        EXPORTING
          iv_sending_doc_id    = iv_oa_ebeln
          iv_receiving_doc_id  = go_l4l_po->zif_myfi_document~posting_doc_num
          iv_receiving_obj_typ = zif_mfp_constants=>gc_bor-bus2012
      ).

*** Update OA header Doc Ref ID
      me->zif_myfi_document~source_doc_num = me->zif_myfi_document~posting_doc_num = iv_oa_ebeln.
      me->zif_myfi_document~new_doc_header = me->zif_myfi_document~old_doc_header.
      me->zif_myfi_document~new_doc_header-ref_id = go_l4l_po->zif_myfi_document~posting_doc_num.
      me->zif_myfi_document~update_myfi_tables( ).


*** Update PO header Doc Ref ID
      go_l4l_po->zif_myfi_document~new_doc_header-ref_id = iv_oa_ebeln.
      go_l4l_po->zif_myfi_document~new_doc_header-status = me->zif_myfi_document~new_doc_header-status.
      go_l4l_po->zif_myfi_document~source_doc_num = go_l4l_po->zif_myfi_document~posting_doc_num.
      go_l4l_po->zif_myfi_document~update_myfi_tables( ).

    ENDIF.

  ENDMETHOD.


  METHOD recall_approval.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_DOCUMENT_L4L~recall_approval
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for MyFi Documents
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
* 05/11/21 210983DY  RD2K922034 DS-11-32-07-01 S6000002550: MyFi Applications (December Release)
*                    Additional code to enable Multi Account Assignment
*-----------------------------------------------------------------------
    DATA: lv_event_success TYPE boole_d.

    IF me->zif_myfi_document~old_doc_header-status = zif_mfp_constants=>gc_doc_status-awaiting_approval OR
       me->zif_myfi_document~old_doc_header-status = zif_mfp_constants=>gc_doc_status-awaiting_asset OR
       me->zif_myfi_document~old_doc_header-status = zif_mfp_constants=>gc_doc_status-awaiting_prf.

      CALL METHOD zcl_mfp_oa=>create_event
        EXPORTING
          iv_ebeln        = me->zif_myfi_document~source_doc_num
          iv_event        = zif_mfp_constants=>gc_event-recall
          iv_commit       = abap_false
        IMPORTING
          ev_event_raised = lv_event_success.

      IF lv_event_success = abap_true.
        CALL METHOD zcl_mfp_utilities=>log_myfi_event
          EXPORTING
            iv_doc_number = me->zif_myfi_document~posting_doc_num
            iv_user_id    = sy-uname
            iv_sub_obj    = zif_mfp_constants=>gc_log-sub_obj-wf-recall.
      ENDIF.
      super->recall_approval( ).
    ENDIF.


  ENDMETHOD.


  METHOD trigger_prf.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_DOCUMENT_L4L~trigger_prf
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for MyFi Documents
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
*-----------------------------------------------------------------------
    CONSTANTS: BEGIN OF grp_fields_const,
*                 fiscal_yr          TYPE name_komp VALUE 'ERP_FISCAL_YEAR',
*                 vendor_id          TYPE name_komp VALUE 'ERP_VENDOR_ID',
*                 vendor_name        TYPE name_komp VALUE 'ERP_VENDOR_NAM',
*                 vendor_vatno       TYPE name_komp VALUE 'ERP_VENDOR_VATNO',
*                 total_amount_value TYPE name_komp VALUE 'ERP_TOTAL_CONTRACT_VAL',
                 total_value_curr TYPE name_komp VALUE 'ERP_TOTAL_VAL_CURR',
*                 ctr_strt_dt        TYPE name_komp VALUE 'ERP_CTR_START_DT',
*                 ctr_end_dt         TYPE name_komp VALUE 'ERP_CTR_END_DT',
*                 po_grp             TYPE name_komp VALUE 'ERP_PO_GRP',
*                 day_calc_ref       TYPE name_komp VALUE 'ERP_DAY_CALC_REF',
*                 del_ind            TYPE name_komp VALUE 'DELETION_STATUS_FLAG',
*                 item_amount_value  TYPE name_komp VALUE 'CONTRACT_VALUE',
               END OF grp_fields_const,
               lc_header_index TYPE char1 VALUE 1.

    DATA:lv_prf_trigger_appl TYPE boolean_flg,
         lt_prf_trigger_urls TYPE zgrp_t_data_transfer_struc,
         lt_prf_return       TYPE bapiret2_t,
         ls_prf_trigger_urls LIKE LINE OF lt_prf_trigger_urls,
         lv_powl_url         TYPE string,
         ev_trigger_appl     TYPE boole_d.

    DATA: lr_grp_log          TYPE REF TO zcl_grp_bal_log_wrapper,
          lt_header_data      TYPE zgrp_t_data_transfer_struc,
          lt_item_data        TYPE zgrp_t_data_transfer_struc,
          lt_return           TYPE bapiret2_t,
          ls_return           TYPE bapiret2,
          ls_struc_line_item  TYPE zbapi_grp_s_data_transfr_struc,
          lv_dtype_code       TYPE zgrp_regm_doc_type,
          lv_doc_no_val       TYPE zgrp_doc_no,
          lv_co_code_val      TYPE zgrp_co_code,
          lv_cntry_code       TYPE land1,
          lv_trigger_grp_appl TYPE xfeld,
          lv_amt              TYPE zgrp_s_item-total_contract_val,
          lv_total_amt        TYPE zgrp_s_item-total_contract_val,
          lv_local_curr       TYPE waers,
          lt_trigger_urls     TYPE zgrp_t_data_transfer_struc,
          lx_root             TYPE REF TO cx_mmpur_root.

    DATA: ls_header_det  TYPE zgrp_c_header.
    DATA: ls_ekko        TYPE ekko.
    DATA: ls_temp_header TYPE meout_header.

    DATA: ls_temp_ekpo   TYPE meout_item.
    DATA: lt_ekpo        TYPE meout_t_ekpo.
    DATA: ls_ekpo        TYPE ekpo.
    DATA: ls_bapi_ekpo   TYPE bapimeoutitem.

    DATA: lt_ekkn        TYPE meout_t_ekkn.
    DATA: ls_bapi_ekkn   TYPE bapimeoutaccount.
    DATA: ls_ekkn        TYPE ekkn.
    DATA: ls_ekxn        TYPE exkn.

    lv_doc_no_val = iv_ebeln.
    IF zcl_grp_activation_switch=>grp_process( ) = abap_false.
      RETURN. "   return_if_grp_not_active.
    ENDIF.

    TRY.
        CALL METHOD cl_bapi_meout_mapping=>map2i_header
          EXPORTING
            bapimeoutheader = is_ekko
          RECEIVING
            meout_header    = ls_temp_header.
      CATCH cx_mmpur_root INTO lx_root.
        RETURN.
    ENDTRY.
    MOVE-CORRESPONDING ls_temp_header TO ls_ekko.

    LOOP AT it_ekpo INTO ls_bapi_ekpo.
      TRY.
          CALL METHOD cl_bapi_meout_mapping=>map2i_item
            EXPORTING
              bapimeoutitem = ls_bapi_ekpo
            RECEIVING
              meout_item    = ls_temp_ekpo.
        CATCH cx_mmpur_root INTO lx_root.
          RETURN.
      ENDTRY.
      MOVE-CORRESPONDING ls_temp_ekpo TO ls_ekpo.
      APPEND ls_ekpo TO lt_ekpo.

    ENDLOOP.

    LOOP AT it_ekkn INTO ls_bapi_ekkn.
      TRY.
          CALL METHOD cl_bapi_meout_mapping=>map2i_exkn
            EXPORTING
              bapimeoutaccount = ls_bapi_ekkn
            RECEIVING
              exkn             = ls_ekxn.
        CATCH cx_mmpur_root INTO lx_root.
          RETURN.
      ENDTRY.
      MOVE-CORRESPONDING ls_ekxn TO ls_ekkn.
      APPEND ls_ekkn TO lt_ekkn.
    ENDLOOP.

    CLEAR lv_total_amt.

    DATA: lr_assist TYPE REF TO zcl_grp_assist.
    CREATE OBJECT lr_assist.

    " Get reporting currency
    CALL FUNCTION 'BAPI_GRP_GET_REPORTING_CURR'
      IMPORTING
        ev_currency_code = lv_local_curr.

    "Total value Currency
    ls_struc_line_item-tableindex = lc_header_index.
    ls_struc_line_item-fieldname = grp_fields_const-total_value_curr.
    ls_struc_line_item-data = lv_local_curr.
    APPEND ls_struc_line_item TO lt_header_data.
    CLEAR ls_struc_line_item.

    lv_trigger_grp_appl = abap_false.

    lv_co_code_val = ls_ekko-bukrs.
    SELECT SINGLE land1 INTO lv_cntry_code FROM t001 WHERE bukrs = lv_co_code_val.

    "CIR524 (S 6000002812 - OCT 2022: Only pass SON on create)
    if iv_creating = abap_true.
      CALL METHOD map_admindtl_prf
        EXPORTING
          is_admindtl    = is_admindtl
        CHANGING
          ct_header_data = lt_header_data                " Data Contents of the tables Fields
          ct_item_data   = lt_item_data.                " Data Contents of the tables Fields
    endif.

    CALL METHOD zcl_mfp_utilities=>save_myfip_oa_trigger(
      EXPORTING
        im_ekko             = ls_ekko
        it_ekpo             = lt_ekpo
        it_ekkn             = lt_ekkn
        lv_local_curr       = lv_local_curr
      CHANGING
        ct_header_data      = lt_header_data
        ct_item_data        = lt_item_data
        cv_trigger_grp_appl = ev_trigger_appl
        cv_dtype_code       = lv_dtype_code
        lv_total_amt        = lv_total_amt ).

    CHECK ev_trigger_appl = abap_true.

    IF lt_header_data IS NOT INITIAL.
      CALL METHOD zcl_grp_assist=>trigger_grp_capture
        EXPORTING
          iv_country             = lv_cntry_code            " Country Key
          iv_co_code             = lv_co_code_val           " Co-Code
          iv_doc_type            = lv_dtype_code            " Regime Document type
          iv_doc_no              = lv_doc_no_val            " Source Document number
          iv_open_in_change_mode = abap_true                " Application mode
          iv_trigger_scrn        = abap_false
          it_header_data         = lt_header_data
          it_items_data          = lt_item_data
          iv_check_only          = iv_check_only
*         iv_hdr_key             = iv_hdr_key
        IMPORTING
          es_header_det          = ls_header_det
          et_trigger_urls        = lt_trigger_urls.

      LOOP AT lt_trigger_urls INTO ls_prf_trigger_urls.
        CONCATENATE lv_powl_url ls_prf_trigger_urls-data INTO lv_powl_url.
      ENDLOOP.

      rt_prf_url = lv_powl_url.

    ENDIF.



  ENDMETHOD.


  METHOD update_l4l_po_draft.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_DOCUMENT_L4L~create_l4l_po_draft
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for MyFi Documents
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
* 21/09/20 290977SCN RD2K919977 DS-11-32-07-01 S 6000002096: MyFi Purchasing (Release 2.2)
*-----------------------------------------------------------------------

    me->get_doc_header(
      EXPORTING
        iv_zmfp_doc_id      = me->zif_myfi_document~posting_doc_num
      IMPORTING
        es_ztmfp_doc_header = DATA(ls_doc_header)                 " MyFi Purchasing UI5 Application Document Header Tabl
    ).

    SELECT SINGLE ebeln FROM ekko INTO @DATA(lv_ebeln) WHERE ebeln EQ @ls_doc_header-ref_id .
    IF sy-subrc <> 0.
      me->gv_draft_indicator = abap_true.
      me->zif_myfi_document~source_doc_num = ls_doc_header-zmfp_doc_id. "me->zif_myfi_document~posting_doc_num.
      me->zif_myfi_document~posting_doc_num = ls_doc_header-ref_id.
      fill_l4l_po_deep( ).
      gs_l4l_po_deep-agreement = ls_doc_header-zmfp_doc_id.
      gs_l4l_po_deep-requestid = gs_l4l_po_deep-po_number = ls_doc_header-ref_id.
      gs_l4l_po_deep-isdraft = abap_true.
*      CLEAR gs_l4l_po_deep-po_number.

      CREATE OBJECT go_l4l_po TYPE zcl_mfp_document_po
        EXPORTING
          iv_ebeln         = ls_doc_header-ref_id                 " Purchasing Document Number
          is_deep_entity   = gs_l4l_po_deep
          iv_action        = zif_mfp_constants=>gc_action-odata-draft
          iv_myfi_doc_type = zif_mfp_constants=>gc_myfi_doc_type-l4l_po.                 " MyFi Purchasing UI5 Application Document Category

*      me->zif_myfi_document~new_doc_header-ref_id = ls_doc_header-zmfp_doc_id.
*      me->zif_myfi_document~source_doc_num = ls_doc_header-ref_id.
*      go_l4l_po->zif_myfi_document~update_myfi_tables( ).
    ENDIF.
  ENDMETHOD.


  METHOD update_po_status_after_oa_chg.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_DOCUMENT_L4L~update_po_status_after_oa_chg
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for MyFi Documents
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
* 22.07.20 290977SCN RD2K919533 DS-11-32-07-01 Updated importing parameters for decide_new_status
* 21/09/20 290977SCN RD2K919977 DS-11-32-07-01 S 6000002096: MyFi Purchasing (Release 2.2)
* 30/11/20 210983DY  RD2K919656 DS-11-32-07-01 S 6000002172: MyFi Purchasing (Release 2.3)
*-----------------------------------------------------------------------
    DATA: lt_return           TYPE bapiret2_t,
          lv_po_rel_ind       TYPE frgke,
          lv_new_po_status    TYPE zmfp_status,
          ls_header_new       TYPE yztmfp_doc_header,
          ls_header_old       TYPE yztmfp_doc_header,
          lv_change_indicator	TYPE cdchngindh,
          lt_header_old       TYPE yztmfp_doc_headers,
          lt_header_new       TYPE yztmfp_doc_headers,
          ls_header_update    TYPE ztmfp_doc_header,
          lv_objid            TYPE cdhdr-objectid,
          lv_log_subobj       TYPE balsubobj,
          lv_log_type         TYPE bapi_mtype.


    SELECT SINGLE * FROM ztmfp_doc_header WHERE zmfp_doc_id EQ @me->zif_myfi_document~old_doc_header-ref_id INTO @DATA(ls_po_doc_header).

    IF ls_po_doc_header-status EQ zif_mfp_constants=>gc_doc_status-approved.

      CALL FUNCTION 'BAPI_PO_RESET_RELEASE'
        EXPORTING
          purchaseorder     = me->zif_myfi_document~old_doc_header-ref_id
          po_rel_code       = 'R1'
          use_exceptions    = space
        IMPORTING
          rel_indicator_new = lv_po_rel_ind
        TABLES
          return            = lt_return.

      decide_new_status(
        EXPORTING
          iv_action        = zif_mfp_constants=>gc_action-odata-change                 " MyFi Purchasing App Action ID
          iv_myfi_doc_type = zif_mfp_constants=>gc_myfi_doc_type-l4l_po                 " MyFi Purchasing UI5 Application Document Category
          iv_old_status    = me->zif_myfi_document~old_doc_header-status                " MyFi Purchasing UI5 Application Document Status
          iv_mm_status     = lv_po_rel_ind                 " Release Indicator: Purchasing Document
          iv_ebeln         = me->zif_myfi_document~old_doc_header-ref_id
        RECEIVING
          rv_new_status    = lv_new_po_status                 " MyFi Purchasing UI5 Application Document Status
      ).

      COMMIT WORK AND WAIT.

      MOVE-CORRESPONDING ls_po_doc_header TO ls_header_new.
      ls_header_new-status = lv_new_po_status.
      APPEND ls_header_new TO lt_header_new.

      MOVE-CORRESPONDING ls_po_doc_header TO ls_header_old.
      APPEND ls_header_old TO lt_header_old.

      MOVE-CORRESPONDING ls_header_new TO ls_header_update.
      ls_header_update-zmfp_doc_id = me->zif_myfi_document~old_doc_header-ref_id.
      lv_log_subobj = zif_mfp_constants=>gc_log-sub_obj-data-update.
      lv_change_indicator = 'U'.
      lv_objid = me->zif_myfi_document~old_doc_header-ref_id.
      MODIFY ztmfp_doc_header FROM ls_header_update.
      IF sy-subrc <> 0.
        lv_log_type = zif_mfp_constants=>gc_log-type-error.
      ELSE.
        lv_log_type = zif_mfp_constants=>gc_log-type-success.
      ENDIF.

      CALL METHOD zcl_mfp_utilities=>log_myfi_data
        EXPORTING
          iv_doc_number = me->zif_myfi_document~old_doc_header-ref_id
          iv_user_id    = sy-uname
          iv_log_type   = lv_log_type
          iv_sub_obj    = lv_log_subobj.

      CALL FUNCTION 'ZMFP_CHANGELOG_WRITE_DOCUMENT'
        EXPORTING
          objectid                = lv_objid
          tcode                   = zif_mfp_constants=>gc_tcode
          utime                   = sy-uzeit
          udate                   = sy-datum
          username                = sy-uname
          object_change_indicator = lv_change_indicator
          upd_ztmfp_doc_header    = lv_change_indicator
        TABLES
          xztmfp_doc_header       = lt_header_new
          yztmfp_doc_header       = lt_header_old.
    ENDIF.

  ENDMETHOD.


  METHOD validate_l4l_po.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_DOCUMENT_L4L~validate_l4l_po
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2.4).
*                     This method is used for MyFi Documents
*
* AUTHOR:             Dathri Yellamarthy ( 210983DY )
* CREATE DATE:        30.01.2021
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000002250 - MyFi Purchasing Release 2.4
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
*
*-----------------------------------------------------------------------
    me->gv_draft_indicator = abap_true.
* Check if document is draft
    SELECT SINGLE status INTO @data(lv_status) FROM ztmfp_doc_header WHERE zmfp_doc_id = @me->zif_myfi_document~old_doc_header-ref_id.
    IF NOT lv_status = '10'.
      me->zif_myfi_document~read_data( ).

      fill_l4l_po_deep( ).
      gs_l4l_po_deep-po_number = me->zif_myfi_document~old_doc_header-ref_id.
      CREATE OBJECT go_l4l_po TYPE zcl_mfp_document_po
        EXPORTING
          iv_ebeln         = me->zif_myfi_document~old_doc_header-ref_id                 " Purchasing Document Number
          is_deep_entity   = gs_l4l_po_deep
          iv_action        = zif_mfp_constants=>gc_action-odata-validate
          iv_myfi_doc_type = zif_mfp_constants=>gc_myfi_doc_type-l4l_po
          iv_requestor     = gv_l4l_requestor.
      .

      et_return = go_l4l_po->gt_return.
    ENDIF.
  ENDMETHOD.


  METHOD validate_l4l_totals.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_DOCUMENT_L4L~validate_l4l_totals
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for MyFi Documents
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
* 19.06.20 070667JPS RD2K919517 DS-11-32-07-01 S 6000001863: MyFi
*                                              Purchasing Release 2_ECC
*                                              DEFECTS II
* 20.07.20 070667JPS RD2K919533 DS-11-32-07-01 S 6000001987: MyFi
*          290977SCN                           Purchasing (Release 2.1).
*                                              Removal of tolerance logic
*                                              create error when totals don't match.
* 22.07.20 290977SCN RD2K919533 DS-11-32-07-01 Cater downfund and line deletions
* 05.08.20 290977SCN RD2K919848 DS-11-32-07-01 Removal of rounding logic.
* 22.10.20 290977SCN RD2K919656 DS-11-32-07-01 S 6000002172: MyFi Purchasing (Release 2.3)
* 03/03/21 210983DY  RD2K920554 DS-11-32-07-01 S 6000002250: MyFi Purchasing (Release 2.4 )
*                               Additional code to display amounts in error message
*-----------------------------------------------------------------------
    DATA:
      lv_totalval        TYPE val_iv_for,
      lv_totalval_comp   TYPE wrbtr,
      lv_subtotal        TYPE wrbtr,
      lv_nettotal        TYPE wrbtr,
      ls_return          TYPE bapiret2,
      lt_return          TYPE STANDARD TABLE OF bapiret2,
      lv_nettotal_string TYPE string,
      lv_acumval_string  TYPE string,
      lv_acum_val        TYPE wrbtr,
      lv_nettotal_val    TYPE bapicurr_d,
      lv_total_val       TYPE bapicurr_d,
      lv_total_dec3      TYPE dec16_3,
      lv_acum_dec3       TYPE dec16_3.


*check if L4L OA values have gone below consumed values of the PO.
    CLEAR ls_return.
    check_consumption_values(
      IMPORTING
        et_return = lt_return                 " Return Parameter table
    ).

* Check if target value is equal to aggregate value of line items
    LOOP AT gs_contract_deep-contractlis INTO DATA(ls_odata_oaitem)
      WHERE status NE zif_mfp_constants=>gc_line_status-deleted.    "L means deleted, S means locked, empty means open

      lv_nettotal = ( ls_odata_oaitem-price_unit * ls_odata_oaitem-target_qty ).
      lv_nettotal_val = ( ls_odata_oaitem-price_unit * ls_odata_oaitem-target_qty ).

      zcl_mfp_utilities=>calculate_tax(
            EXPORTING
              iv_bukrs = gs_oaheader-comp_code      " Company Code
              iv_mwskz = ls_odata_oaitem-tax_code   " Sales Tax Code
              iv_wrbtr = lv_nettotal                " Amount in document currency
              iv_koart = 'M'                        " Account Type
            RECEIVING
              rv_wmwst = lv_subtotal ).             " Amount in document currency

      lv_totalval = lv_totalval + lv_subtotal + lv_nettotal.
*      lv_nettotal_val = lv_nettotal_val + lv_subtotal.
      lv_total_val = lv_total_val + lv_subtotal + lv_nettotal_val.

    ENDLOOP.
    IF sy-subrc NE 0 AND ls_return IS INITIAL.
      CHECK gs_contract_deep-acum_value NE '0.01'.
    ENDIF.
* Get a comparison value
    lv_totalval_comp = lv_totalval.

    CLEAR: ls_return.

    SELECT SINGLE currdec INTO @DATA(lv_decimals) FROM  tcurx
             WHERE  currkey = @gs_contract_deep-currency.
    IF NOT sy-subrc IS INITIAL.
      lv_decimals = '2'.
    ENDIF.

    IF lv_totalval_comp NE gs_contract_deep-acum_value.

      CASE lv_decimals.
        WHEN 2.
          lv_acum_val = gs_contract_deep-acum_value.
          MESSAGE e017(zmfp) INTO ls_return-message WITH lv_totalval_comp lv_acum_val.
        WHEN 3.
          lv_total_dec3 = lv_total_val.
          lv_acum_dec3  = gs_contract_deep-acum_value.
          MESSAGE e017(zmfp) INTO ls_return-message WITH lv_total_dec3 lv_acum_dec3.
        WHEN OTHERS.
          lv_nettotal_string = lv_total_val.
          lv_acumval_string = gs_contract_deep-acum_value.
          lv_nettotal_string =  zcl_mfp_document=>convert_text_currency( iv_waers = gs_contract_deep-currency iv_netwr = lv_nettotal_string ).
          lv_acumval_string =  zcl_mfp_document=>convert_text_currency( iv_waers = gs_contract_deep-currency iv_netwr = lv_acumval_string ).
          REPLACE '.' WITH ',' INTO lv_nettotal_string.
          REPLACE '.' WITH ',' INTO lv_acumval_string.
          MESSAGE e017(zmfp) INTO ls_return-message WITH lv_nettotal_string lv_acumval_string.
      ENDCASE.
*      MESSAGE e017(zmfp) INTO ls_return-message WITH lv_totalval_comp gs_contract_deep-acum_value.
      ls_return-type = sy-msgty.
      ls_return-id = sy-msgid.
      ls_return-number = sy-msgno.
      APPEND ls_return TO lt_return.
      CLEAR : lv_acum_val, lv_total_dec3, lv_acum_dec3, lv_nettotal_string, lv_acumval_string.
    ENDIF.

    IF lt_return IS NOT INITIAL.
      gv_errors = abap_true.
      lt_return = message_handler( it_return = lt_return ).
      APPEND LINES OF lt_return TO gt_return.
    ENDIF.

  ENDMETHOD.


  METHOD zif_myfi_document~bapi_change.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_DOCUMENT_L4L~zif_myfi_document~bapi_change
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for MyFi Documents
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
* 16.06.20 290977SCN RD2K919514 DS-11-32-07-01 changed
*          070667JPS
* 16.06.20 290977SCN RD2K919533 DS-11-32-07-01 Handle blank rel indicator
* 21/09/20 290977SCN RD2K919977 DS-11-32-07-01 S 6000002096: MyFi Purchasing (Release 2.2)
* 30/11/20 210983DY  RD2K919656 DS-11-32-07-01 S 6000002172: MyFi Purchasing (Release 2.3)
*                                            Additional code for Item Texts and Header texts
* 20.12.22 210983DY  RD2K923348 DS-11-32-07-01 S 6000002854: MyFi Continuous Improvement December Release
*                 CIR 516 - Dont pass line items that are not edited and has Locked cost object to BAPI
* 23.01.23 210983DY RD2K923485  DS-11-32-07-01 S 6000002854: MyFi Continuous Improvement December Release
*                 CIR 516 - Dont pass line items that are not edited and has Locked cost object to BAPI
*-----------------------------------------------------------------------
    DATA: lt_return       TYPE bapiret2_t,
          ls_return       TYPE bapiret2,
          ls_oaheader_ret TYPE bapimeoutheader.

* Dont pass line items that are not edited and has Locked cost object to BAPI
* UI logic will inhibit users from submitting line items with locked cost objects upon Edit
    IF NOT gv_locked_costobject IS INITIAL.
      LOOP AT gt_oaaccounts INTO DATA(ls_accounts) WHERE delete_ind = abap_true.

        DELETE gt_oaaccountsx WHERE item_no = ls_accounts-item_no.
        DELETE gt_oaitems WHERE item_no = ls_accounts-item_no.
        DELETE gt_oaitemsx WHERE item_no = ls_accounts-item_no.
        DELETE gt_oacond_valid_item WHERE item_no = ls_accounts-item_no.
        DELETE gt_oacond_validx_item WHERE item_no = ls_accounts-item_no.
        DELETE gt_extension WHERE valuepart1+0(5) = ls_accounts-item_no.
        DELETE me->gt_oacondition_item WHERE item_no = ls_accounts-item_no.
        DELETE me->gt_oaconditionx_item WHERE item_no = ls_accounts-item_no.
      ENDLOOP.
      DELETE gt_oaaccounts WHERE delete_ind = abap_true.

    ENDIF.

    CALL FUNCTION 'BAPI_CONTRACT_CHANGE'
      EXPORTING
        purchasingdocument  = me->zif_myfi_document~source_doc_num                 " Purchasing Document Number
        header              = gs_oaheader                 " Header Data Outline Agreement
        headerx             = gs_oaheaderx                 " Header Data Change Parameter Outline Agreement
*       vendor_address      =                  " Address Structur Vendor Address
*       testrun             =                  " Single-Character Indicator
*       technical_data      =                  " Technical Parameters for Outline Agreement BAPIs
      IMPORTING
        exp_header          = ls_oaheader_ret                " Header Data Outline Agreement
      TABLES
        item                = gt_oaitems                 " Item Data
        itemx               = gt_oaitemsx                 " Change Parameter - Item Data
        account             = gt_oaaccounts                 " Account Assignment Data
*       accountprofitsegment  =                  " Account Assignment - Profitability Segment Calculation
        accountx            = gt_oaaccountsx                 " Change Parameter - Account Assignment Data
*       delivery_address    =                  " Delivery Address
        item_cond_validity  = me->gt_oacond_valid_item
        item_cond_validityx = me->gt_oacond_validx_item
        item_condition      = me->gt_oacondition_item
        item_conditionx     = me->gt_oaconditionx_item
*       item_cond_scale_value =                  " Value Scale
*       item_cond_scale_quan  =                  " Quantity Scale
        item_text           = gt_oaitemtext                " Item Text
        header_text         = gt_oatextheader                 " Header Text
*       head_cond_validity  =                  " Validity Area of Header Condition
*       head_cond_validityx =                  " Change Parameter - Validity Area of Header Condition
*       head_condition      =                  " Header Condition
*       head_conditionx     =                  " Change Parameter - Header Condition
*       head_cond_scale_val =                  " Value Scale
*       head_cond_scale_quan  =                  " Quantity Scale
*       partner             =                  " Partner Data
*       partnerx            =                  " Table Type: Change Parameter Partner Outline Agreement
*       release_docu        =                  " Table Type: Change Parameter Partner Outline Agreement
        extensionin         = gt_extension  " ExtensionIn (Customer Enhancement)
*       extensionout        =                  " ExtensionOut (Customer Enhancement)
        return              = lt_return.                 " Return Table

    zcl_mfp_utilities=>log_myfi_bapi(
      EXPORTING
        iv_doc_number = me->zif_myfi_document~source_doc_num                 " Purchasing Document Number
        iv_action     = zif_mfp_constants=>gc_log-sub_obj-bapi-oa_change                 " Application Log: Subobject
        iv_user_id    = sy-uname                 " User Name
        it_return     = lt_return                 " Return table
    ).

    READ TABLE lt_return WITH KEY type = 'S' TRANSPORTING NO FIELDS.
    IF sy-subrc <> 0.
      gt_return = message_handler( it_return = lt_return ).
      CLEAR gs_contract_deep.
    ELSE.
      gv_doc_posted_ok = ev_success = abap_true.
      CLEAR: ls_return, gt_return.
      MESSAGE s014(zmfp) INTO ls_return-message.
      ls_return-type = sy-msgty.
      ls_return-id = sy-msgid.
      ls_return-number = sy-msgno.
      APPEND ls_return TO gt_return.
      gt_return = message_handler( it_return = gt_return ).
      ev_success = abap_true.
      me->gs_contract_deep-contractnumber = me->zif_myfi_document~posting_doc_num = me->gs_oaheader-number .
      CLEAR me->gs_contract_deep-prfurledit.
      me->gs_contract_deep-prfurl = me->gs_contract_deep-prfurledit =  me->trigger_prf(
            it_ekkn         = me->gt_oaaccounts
            is_admindtl     = me->zif_myfi_document~new_adm_dtl
            iv_ebeln        = me->zif_myfi_document~posting_doc_num
            is_ekko         = ls_oaheader_ret
            it_ekpo         = me->gt_oaitems ).

      CASE ls_oaheader_ret-po_rel_ind.
        WHEN zif_mfp_constants=>gc_mm_doc_status-new.
          IF me->gs_contract_deep-prfurl IS INITIAL.
            me->gv_mm_status = zif_mfp_constants=>gc_mm_doc_status-req_del_appr.
          ELSE.
            me->gv_mm_status = ls_oaheader_ret-po_rel_ind.
          ENDIF.
        WHEN ''.
          me->gv_mm_status = zif_mfp_constants=>gc_mm_doc_status-oa_released.
        WHEN OTHERS.
          me->gv_mm_status = ls_oaheader_ret-po_rel_ind.
      ENDCASE.

    ENDIF.

  ENDMETHOD.


  METHOD zif_myfi_document~bapi_create.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_DOCUMENT_L4L~zif_myfi_document~bapi_create
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for MyFi Documents
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
* 16.06.20 290977SCN RD2K919514 DS-11-32-07-01 changed
*          070667JPS
* 22.07.20 290977SCN RD2K919514 DS-11-32-07-01 Handle blank rel indicator
* 21/09/20 290977SCN RD2K919977 DS-11-32-07-01 S 6000002096: MyFi Purchasing (Release 2.2)
* 30/11/20 210983DY  RD2K919656 DS-11-32-07-01 S 6000002172: MyFi Purchasing (Release 2.3)
*                                            Additional code for Item Texts and Header texts
*-----------------------------------------------------------------------
    DATA:
      lt_return           TYPE bapiret2_t,
      ls_return           TYPE bapiret2,
      lt_prf_trigger_urls TYPE zgrp_t_data_transfer_struc,
      ls_oaheader_ret     TYPE bapimeoutheader.


    CLEAR: me->gs_oaheader-number.
    CALL FUNCTION 'BAPI_CONTRACT_CREATE'
      EXPORTING
        header              = me->gs_oaheader
        headerx             = me->gs_oaheaderx
*       VENDOR_ADDRESS      =
*       TESTRUN             =
*       TECHNICAL_DATA      =
      IMPORTING
        purchasingdocument  = me->gs_oaheader-number
        exp_header          = ls_oaheader_ret
      TABLES
        return              = lt_return
        item                = me->gt_oaitems
        itemx               = me->gt_oaitemsx
        account             = me->gt_oaaccounts
*       ACCOUNTPROFITSEGMENT        =
        accountx            = me->gt_oaaccountsx
*       DELIVERY_ADDRESS    =
        item_cond_validity  = me->gt_oacond_valid_item
        item_cond_validityx = me->gt_oacond_validx_item
        item_condition      = me->gt_oacondition_item
        item_conditionx     = me->gt_oaconditionx_item
*       ITEM_COND_SCALE_VALUE       =
*       ITEM_COND_SCALE_QUAN        =
       ITEM_TEXT            = me->gt_oaitemtext
        header_text         = me->gt_oatextheader
*       HEAD_COND_VALIDITY  =
*       HEAD_COND_VALIDITYX =
*       HEAD_CONDITION      =
*       HEAD_CONDITIONX     =
*       HEAD_COND_SCALE_VAL =
*       HEAD_COND_SCALE_QUAN        =
*       PARTNER             =
*       PARTNERX            =
        extensionin         = gt_extension
*       EXTENSIONOUT        =
      .

    zcl_mfp_utilities=>log_myfi_bapi(
      EXPORTING
        iv_doc_number = me->gs_oaheader-number                 " Purchasing Document Number
        iv_action     = zif_mfp_constants=>gc_log-sub_obj-bapi-oa_create                 " Application Log: Subobject
        iv_user_id    = sy-uname                 " User Name
        it_return     = lt_return                 " Return table
    ).

    READ TABLE lt_return WITH KEY type = 'S' TRANSPORTING NO FIELDS.
    IF sy-subrc <> 0.
      gt_return = message_handler( it_return = lt_return ).
      CLEAR gs_contract_deep.
    ELSE.
      gv_doc_posted_ok = ev_success = abap_true.
      CLEAR: ls_return, gt_return.
      MESSAGE s014(zmfp) INTO ls_return-message.
      ls_return-type = sy-msgty.
      ls_return-id = sy-msgid.
      ls_return-number = sy-msgno.
      APPEND ls_return TO gt_return.
      gt_return = message_handler( it_return = gt_return ).

      me->gs_contract_deep-contractnumber = me->zif_myfi_document~posting_doc_num = me->gs_oaheader-number .
      CLEAR me->gs_contract_deep-prfurledit.

      me->gs_contract_deep-prfurl = me->gs_contract_deep-prfurledit =  me->trigger_prf(
            it_ekkn         = me->gt_oaaccounts
            is_admindtl     = me->zif_myfi_document~new_adm_dtl
            iv_ebeln        = me->zif_myfi_document~posting_doc_num
            is_ekko         = ls_oaheader_ret
            it_ekpo         = me->gt_oaitems
            iv_creating     = abap_true ).

      CASE ls_oaheader_ret-po_rel_ind.
        WHEN zif_mfp_constants=>gc_mm_doc_status-new.
          IF me->gs_contract_deep-prfurl IS INITIAL.
            me->gv_mm_status = zif_mfp_constants=>gc_mm_doc_status-req_del_appr.
          ELSE.
            me->gv_mm_status = ls_oaheader_ret-po_rel_ind.
          ENDIF.
        WHEN ''.
          me->gv_mm_status = zif_mfp_constants=>gc_mm_doc_status-oa_released.
        WHEN OTHERS.
          me->gv_mm_status = ls_oaheader_ret-po_rel_ind.
      ENDCASE.

    ENDIF.

  ENDMETHOD.


  METHOD zif_myfi_document~bapi_read.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_DOCUMENT_L4L~zif_myfi_document~bapi_read
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for MyFi Documents
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
* 21/09/20 290977SCN RD2K919977 DS-11-32-07-01 S 6000002096: MyFi Purchasing (Release 2.2)
* 30/11/20 210983DY  RD2K919656 DS-11-32-07-01 S 6000002172: MyFi Purchasing (Release 2.3)
*                                            Additional code for Item Texts and Header texts
*-----------------------------------------------------------------------
    DATA:
*      ls_oaheader          type bapimeoutheader,
      lt_oaitem            TYPE TABLE OF bapimeoutitem,
      lt_oaaccount         TYPE TABLE OF bapimeoutaccount,
      lt_oaaddrdelivery    TYPE TABLE OF bapimeoutaddrdelivery,
      lt_oaitmcondvalid    TYPE TABLE OF bapimeoutvalidity,
      lt_oaitemcond        TYPE TABLE OF bapimeoutcondition,
      lt_oaitemcondscalevl TYPE TABLE OF bapimeoutitemscaleval,
      lt_oaitemcondscaleqn TYPE TABLE OF bapimeoutitemscalequan,
      lt_oatextitem        TYPE TABLE OF bapimeoutitemtext,
      lt_oatextheader      TYPE TABLE OF bapimeouttext,
      lt_oahdrcondval      TYPE TABLE OF bapimeoutheadvalidity,
      lt_oahdrcond         TYPE TABLE OF bapimeoutheadercond,
      lt_oahdrcondscalevl  TYPE TABLE OF bapimeoutscalevalue,
      lt_oahdrcondscaleqn  TYPE TABLE OF bapimeoutscale,
      lt_oapartner         TYPE TABLE OF bapimeoutpartner,
      lt_oareleasedocu     TYPE TABLE OF bapimeoutreleaseinfo,
      lt_extensionout      TYPE bapiparex_t,
      lt_return            TYPE TABLE OF bapiret2.


    CALL FUNCTION 'BAPI_CONTRACT_GETDETAIL'
      EXPORTING
        purchasingdocument = me->zif_myfi_document~source_doc_num                 " Purchasing Document Number
        item_data          = abap_true
        account_data       = abap_true
*       condition_data     = abap_true
        text_data          = abap_true
*       partner_data       = abap_true
        release_data       = abap_true
      IMPORTING
        header             = gs_oaheader   " Header Data Outline Agreement
      TABLES
        item               = gt_oaitems    " Item Data of Contract
        account            = gt_oaaccounts   " Account Assignment Data - Outline Agreement
*       delivery_address   = lt_oaaddrdelivery   " PO Item: Address Structure BAPIADDR1 for Inbound Delivery
*       item_cond_validity = lt_oaitmcondvalid   " Validity Periods of Conditions
*       item_condition     = lt_oaitemcond        " Master Conditions in Outline Agreement
*       item_cond_scale_value = lt_oaitemcondscalevl  " Value-Based Scales
*       item_cond_scale_quan  = lt_oaitemcondscaleqn  " Quantity Scales for Conditions
        item_text          = gt_oaitemtext         " Text Data - Outline Agreement
        header_text        = gt_oatextheader       " Header Text - Outline Agreement
*       head_cond_validity = lt_oahdrcondval       " Validity Periods of Header Conditions
*       head_condition     = lt_oahdrcond          " Master Conditions in Outline Agreement (Header)
*       head_cond_scale_val   = lt_oahdrcondscalevl   " Value Scales
*       head_cond_scale_quan  = lt_oahdrcondscaleqn  " Value Scales for Conditions
*       partner            = lt_oapartner         " Partner Information for Outline Agreement
        release_docu       = gt_oareleasedocu     " Release Documentation for Outline Agreements
        extensionout       = gt_extensionout      " Ref. structure for BAPI parameter ExtensionIn/ExtensionOut
        return             = gt_return.           " Return Parameter

    me->zif_myfi_document~old_ekpo  = me->get_ekpo( iv_ebeln = me->zif_myfi_document~source_doc_num ).
    me->zif_myfi_document~old_ekkn  = me->get_ekkn( iv_ebeln = me->zif_myfi_document~source_doc_num ) .
    me->zif_myfi_document~approval_history = me->get_approval_history(  iv_object = me->zif_myfi_document~source_doc_num ) .
    IF zif_myfi_document~gv_useraction EQ zif_mfp_constants=>gc_action-odata-read.
      CALL METHOD zcl_mfp_utilities=>get_prf_display_url
        EXPORTING
          iv_ebeln        = me->zif_myfi_document~source_doc_num
          iv_grp_doc_type = zif_mfp_constants=>gc_prf_doc_type-oa
        RECEIVING
          rv_url          = gs_contract_deep-prfurldisplay.

      CALL METHOD zcl_mfp_utilities=>get_prf_change_url
        EXPORTING
          iv_ebeln        = me->zif_myfi_document~source_doc_num
          iv_grp_doc_type = zif_mfp_constants=>gc_prf_doc_type-oa
        RECEIVING
          rv_url          = gs_contract_deep-prfurledit.

    ENDIF.


  ENDMETHOD.


  METHOD zif_myfi_document~change.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_DOCUMENT_L4L~zif_myfi_document~change
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for MyFi Documents
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
* 21/09/20 290977SCN RD2K919977 DS-11-32-07-01 S 6000002096: MyFi Purchasing (Release 2.2)
* 05.07.2021 210983DY RD2K921312 DS-11-32-07-01 S6000002419: MyFi Purchasing (July Release)
*                               Additional logic to complete workitem for recall workflow
*                               on 'SUBMIT'
*-----------------------------------------------------------------------
    DATA: lv_delegate      TYPE swhactor,
          lv_event_success TYPE boole_d,
          lt_return        TYPE bapiret2_t,
          lv_po_rel_ind    TYPE frgke.

    me->zif_myfi_document~handle_odata( ).
    create_new_doc_header( ).
    IF gs_contract_deep-draftassigneeid IS NOT INITIAL.
      CALL METHOD me->assign_document
        EXPORTING
          iv_assignee = gs_contract_deep-draftassigneeid.
    ENDIF.

    super->zif_myfi_document~change( ).
    IF gv_doc_posted_ok EQ abap_true.

      CALL METHOD zcl_mfp_oa=>complete_recall_workitem
        EXPORTING
          iv_ebeln   = me->zif_myfi_document~posting_doc_num
        RECEIVING
          ev_success = DATA(lv_success).

      CASE gv_mm_status.
        WHEN zif_mfp_constants=>gc_mm_doc_status-oa_released.    " me->gs_contract_deep-approvaldetails-delegateid IS NOT INITIAL.
          change_l4l_po(
            EXPORTING
              iv_oa_ebeln = me->zif_myfi_document~posting_doc_num ).

        WHEN OTHERS.
          lv_delegate-objid = me->gs_contract_deep-approvaldetails-delegateid.
          lv_delegate-otype = |US|.
          CALL METHOD zcl_mfp_oa=>create_event
            EXPORTING
              iv_recipient    = lv_delegate
              iv_ebeln        = me->zif_myfi_document~posting_doc_num
              iv_event        = zif_mfp_constants=>gc_event-change
            IMPORTING
              ev_event_raised = lv_event_success.

          IF lv_event_success = abap_true.
            CALL METHOD zcl_mfp_utilities=>log_myfi_event
              EXPORTING
                iv_doc_number = me->zif_myfi_document~posting_doc_num
                iv_user_id    = sy-uname
                iv_sub_obj    = zif_mfp_constants=>gc_log-sub_obj-wf-change.
          ENDIF.
          update_po_status_after_oa_chg( ).
      ENDCASE.
      update_l4l_po_draft( ).
    ENDIF.
  ENDMETHOD.


  METHOD zif_myfi_document~create.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_DOCUMENT_L4L~zif_myfi_document~create
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for MyFi Documents
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
* 16.06.20 290977SCN RD2K919514 DS-11-32-07-01 changed
*          070667JPS
* 26.08.20 290977SCN RD2K919977 DS-11-32-07-01 S 6000002096: MyFi Purchasing (Release 2.2)
*-----------------------------------------------------------------------
    DATA: lv_event_success TYPE boole_d,
          lv_delegate      TYPE swhactor.

    me->create_new_doc_header( iv_status = zif_mfp_constants=>gc_doc_status-draft ).
    me->zif_myfi_document~handle_odata( ).

    IF gs_contract_deep-draftassigneeid IS NOT INITIAL.
      CALL METHOD me->assign_document
        EXPORTING
          iv_assignee = gs_contract_deep-draftassigneeid.
    ENDIF.

    super->zif_myfi_document~create( ).
    IF gv_doc_posted_ok EQ abap_true.

      lv_delegate-objid = me->gs_contract_deep-approvaldetails-delegateid.
      lv_delegate-otype = |US|.
      CALL METHOD zcl_mfp_oa=>create_event
        EXPORTING
          iv_recipient    = lv_delegate
          iv_ebeln        = me->zif_myfi_document~posting_doc_num
          iv_event        = zif_mfp_constants=>gc_event-submit
        IMPORTING
          ev_event_raised = lv_event_success.

      IF lv_event_success = abap_true.
        CALL METHOD zcl_mfp_utilities=>log_myfi_event
          EXPORTING
            iv_doc_number = me->zif_myfi_document~posting_doc_num
            iv_user_id    = sy-uname
            iv_sub_obj    = zif_mfp_constants=>gc_log-sub_obj-wf-submit.
      ENDIF.
      IF me->zif_myfi_document~source_doc_num IS NOT INITIAL AND me->zif_myfi_document~source_doc_num NE me->zif_myfi_document~posting_doc_num.
        move_attachments(
          EXPORTING
            iv_sending_doc        =  me->zif_myfi_document~source_doc_num
            iv_receiving_doc      =  me->zif_myfi_document~posting_doc_num ).

        CALL METHOD zcl_mfp_oa=>create_event
          EXPORTING
*           iv_recipient    = lv_delegate
            iv_ebeln        = me->zif_myfi_document~source_doc_num
            iv_event        = zif_mfp_constants=>gc_event-draft_submit
*           iv_reason       = me->gs_contract_deep-approvaldetails-commentforapprover
          IMPORTING
            ev_event_raised = lv_event_success.
      ENDIF.

      create_l4l_po_draft( ).
    ENDIF.

  ENDMETHOD.


  METHOD zif_myfi_document~duplicate_chk.
*----------------------------------------------------------------------*
* METHOD ID:          ZIF_MYFI_DOCUMENT~DUPLICATE_CHK
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2.2).
*                     This method checks for a duplicate L4L document
*
* AUTHOR:             Stephen Ning (290977SCN)
* CREATE DATE:        21.09.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000002096 - MyFi Purchasing Release 2.2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 21/09/20 290977SCN RD2K919977 DS-11-32-07-01 S 6000002096: MyFi Purchasing (Release 2.2)
*-----------------------------------------------------------------------
    DATA: lt_return TYPE bapiret2_t,
          ls_return TYPE bapiret2.

    me->zif_myfi_document~handle_odata( ).

    CALL METHOD zcl_mfp_utilities=>duplicate_check
      EXPORTING
        iv_ebeln  = me->zif_myfi_document~source_doc_num
        iv_bsart  = 'WK'
        iv_lifnr  = me->gs_oaheader-vendor
        iv_ktwrt  = me->gs_oaheader-acum_value
        iv_waers  = me->gs_oaheader-currency
        iv_kdatb  = me->gs_oaheader-vper_start
        iv_kdate  = me->gs_oaheader-vper_end
      IMPORTING
        et_return = lt_return.
    IF lt_return IS NOT INITIAL.
      lt_return = message_handler( it_return = lt_return ).
      APPEND LINES OF lt_return TO gt_return.
    ENDIF.

  ENDMETHOD.


  METHOD zif_myfi_document~fill_attachment_entityset.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_DOCUMENT_L4L~ZIF_MYFI_DOCUMENT~FILL_ATTACHMENT_ENTITYSET.
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for MyFi Documents
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
