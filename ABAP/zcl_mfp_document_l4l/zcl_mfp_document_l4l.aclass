        iv_posting_doc_num = me->zif_myfi_document~posting_doc_num.



  ENDMETHOD.


  METHOD zif_myfi_document~validate.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_DOCUMENT_L4L~zif_myfi_document~validate
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for MyFi Documents
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
* 22.07.20 290977SCN RD2K919533 DS-11-32-07-01 Cater for auto approval
* 21/09/20 290977SCN RD2K919977 DS-11-32-07-01 S 6000002096: MyFi Purchasing (Release 2.2)
* 21.10.20 290977SCN RD2K919656 DS-11-32-07-01 S 6000002172: MyFi Purchasing (Release 2.3)
* 03/03/21 210983DY  RD2K920554 DS-11-32-07-01 S 6000002250: MyFi Purchasing (Release 2.4 )
*                 Additional logic to validate Invoice approver email
* 03.09.21 210983DY RD2K921716 DS-11-32-07-01 S 6000002507: MyFi Continuous Improvement
*                              additional validation for 5 day payment terms
* 29.11.21 210983DY RD2K922223 DS-11-32-07-01 S 6000002550: MyFi Applications (December Release)
* 06/07/22 210983DY  RD2K922923 DS-11-32-07-01 S6000002777:MyFi Continuous Improvement
*                                              August Release - PO Currency Validation
* 18.08.22 210983DY RD2K923033 DS-11-32-07-01 S 6000002805: MyFi Continuous Improvement September Release
*                              Remove validation for 5 day payment terms
* 10/01/23  210983DY RD2K923348
*                    RD2K923485 S 6000002854: MyFi Continuous Improvement December Rel
*          Additional logic to handle Account assignment validation for locked objects
* 03.03.2023 210983DY  RD2K923630,RD2K923728,RD2K923771
*                    6000002898 MyFi Continuous Improvement April Release
*                    Additional code for validation of delivery address
* 10/10/23 210983DY RD2K924373 DS-11-32-07-01 6000003027: MyFi Continuous Improvement November Rel
*           Additional logic to validate against cost objects of ASA Program
*-----------------------------------------------------------------------
    DATA: ls_header             TYPE bapimeoutheader,
          ls_header_ret         TYPE bapimeoutheader,
          ls_headerx            TYPE bapimeoutheaderx,
          lt_return             TYPE bapiret2_t,
          new_ekko              TYPE ekko,
          new_ekpo              TYPE me_ekpo,
          new_ekkn              TYPE me_ekkn,
          lv_error              TYPE boole_d,
          lv_email_change       TYPE boole_d,
          lv_amtcheck           TYPE p LENGTH 9 DECIMALS 3,
          lv_date               TYPE datum,
          lv_date_ext           TYPE string,
          ls_return             TYPE bapiret2,
          lv_linenumber         TYPE c LENGTH 5,
          lt_cc_assignments     TYPE zsfss_mfp_asa_cc_tt,
          lt_po_deliveryaddress TYPE bapimepoaddrdelivery_tp.

    me->zif_myfi_document~handle_odata( ).
    super->zif_myfi_document~validate( ).

    new_ekpo = bapi_2_ekpo( it_bapiitem = gt_oaitems ).
    me->zif_myfi_document~old_ekpo = get_ekpo( iv_ebeln = me->zif_myfi_document~source_doc_num ).

    new_ekkn = bapi_2_ekkn( it_bapimeoutaccount = gt_oaaccounts it_bapiparex = gt_extension ).
    me->zif_myfi_document~old_ekkn = get_ekkn( iv_ebeln = me->zif_myfi_document~source_doc_num ).

* Raise Error message if Line item is changed and Marked for deletion
* This check is introduced to stop Update Cancellation Error from BAPI
    LOOP AT new_ekpo INTO DATA(ls_new_ekpo) WHERE loekz = 'L'.

      READ TABLE me->zif_myfi_document~old_ekpo INTO DATA(ls_ekpo_old) WITH KEY ebelp = ls_new_ekpo-ebelp.
      IF sy-subrc IS INITIAL AND NOT ls_ekpo_old-loekz = 'L'.
        CLEAR : ls_new_ekpo-loekz, ls_ekpo_old-aedat, ls_ekpo_old-ebeln, ls_ekpo_old-mandt.
        IF ls_new_ekpo-werks NE ls_ekpo_old-werks OR
           ls_new_ekpo-matkl NE ls_ekpo_old-matkl OR
           ls_new_ekpo-ktmng NE ls_ekpo_old-ktmng OR
           ls_new_ekpo-menge NE ls_ekpo_old-menge OR
           ls_new_ekpo-meins NE ls_ekpo_old-meins OR
           ls_new_ekpo-bprme NE ls_ekpo_old-bprme OR
           ls_new_ekpo-mwskz NE ls_ekpo_old-mwskz OR
           ls_new_ekpo-knttp NE ls_ekpo_old-knttp
          .
          MESSAGE e105(zmfp) INTO ls_return-message WITH ls_new_ekpo-ebelp.
          ls_return-type = 'E'.
          APPEND ls_return TO gt_return.
          CLEAR : ls_return.

        ELSE.

          READ TABLE gt_oaaccounts INTO DATA(ls_account) WITH KEY item_no = ls_new_ekpo-ebelp.
          READ TABLE me->zif_myfi_document~old_ekkn INTO DATA(ls_old_account) WITH KEY ebelp = ls_new_ekpo-ebelp.

          IF ls_account-gl_account NE ls_old_account-sakto OR
             ls_account-costcenter NE ls_old_account-kostl OR
             ls_account-orderid    NE ls_old_account-aufnr OR
             ls_account-asset_no      NE ls_old_account-anln1 OR
             ls_account-fund NE ls_old_account-geber." or.
            MESSAGE e105(zmfp) INTO ls_return-message WITH ls_new_ekpo-ebelp.
            ls_return-type = 'E'.
            APPEND ls_return TO gt_return.
            CLEAR : ls_return.
          ENDIF.
        ENDIF.

      ENDIF.

    ENDLOOP.

    LOOP AT gs_contract_deep-phasings INTO DATA(ls_phasings).
      lv_date = zcl_mfp_utilities=>get_date_from_ts( EXPORTING iv_timestamp = ls_phasings-delivery_date ).

      DATA(ls_invalid_dates) = zcl_mfp_utilities=>validate_deliverydate( iv_delivery_date = lv_date ).

      CALL FUNCTION 'CONVERT_DATE_TO_EXTERNAL'
        EXPORTING
          date_internal            = lv_date
        IMPORTING
          date_external            = lv_date_ext
        EXCEPTIONS
          date_internal_is_invalid = 1
          OTHERS                   = 2.
      IF sy-subrc <> 0.
* Implement suitable error handling here
      ENDIF.
      IF ls_invalid_dates-deliv_date = abap_true.

        MESSAGE e107(zmfp) INTO ls_return-message WITH lv_date_ext ls_phasings-po_item.
        gv_errors = abap_true.
        ls_return-type = 'E'.
        APPEND ls_return TO gt_return.
        CLEAR : ls_return.
      ENDIF.
      IF ls_invalid_dates-budget_date = abap_true.

        MESSAGE e108(zmfp) INTO ls_return-message WITH lv_date_ext ls_phasings-po_item.
        gv_errors = abap_true.
        ls_return-type = 'E'.
        APPEND ls_return TO gt_return.
        CLEAR : ls_return.

      ENDIF.
    ENDLOOP.
* validate 5 day payment terms for peppol
*    IF gs_contract_deep-pmnttrms = '0005'.
*      IF  NOT gs_contract_deep-isdraft = abap_true.
*
*        DATA(lv_valid_payterm) = zcl_mfp_document=>validate_einv_paymentterm( iv_ebeln = me->gs_oaheader-number ).
*        IF lv_valid_payterm = abap_false.
*          MESSAGE e104(zmfp) INTO ls_return-message WITH TEXT-001 TEXT-002 TEXT-003 TEXT-004.
*          ls_return-type = 'E'.
*          APPEND ls_return TO gt_return.
*          CLEAR : ls_return.
*        ENDIF.
*      ELSE.
*        lv_amtcheck = '1000000.000'.
*        IF gs_contract_deep-acum_value GT lv_amtcheck.
*          MESSAGE e104(zmfp) INTO ls_return-message WITH TEXT-001 TEXT-002 TEXT-003 TEXT-004.
*          ls_return-type = 'E'.
*          APPEND ls_return TO gt_return.
*          CLEAR : ls_return.
*        ENDIF.
*      ENDIF.
*
*    ENDIF.

* Check if logged-on user is ASA employee and check if account assignment is for ASA related
    DATA(ls_asa_empl) = zcl_mfp_utilities=>is_asa_empl( ).
    IF ls_asa_empl-is_asa_empl = abap_true AND gs_contract_deep-comp_code = '1000'.
      DATA(lt_nps_costcentres) = zcl_mfp_utilities=>get_nps_costcentres( ).

      CALL METHOD me->get_cc_accountassignments
        EXPORTING
          it_accountassignments = me->gs_contract_deep-accountassignments
        IMPORTING
          et_cc_assignments     = lt_cc_assignments.

      LOOP AT lt_cc_assignments INTO DATA(ls_cc_assignments).
        READ TABLE lt_nps_costcentres TRANSPORTING NO FIELDS WITH KEY kostl = ls_cc_assignments-kostl.
        IF sy-subrc IS NOT INITIAL.
          DATA(lv_line) = |{ ls_cc_assignments-ebelp ALPHA = OUT }|.
          gv_errors = abap_true.
          MESSAGE e110(zmfp) INTO ls_return-message WITH lv_line.
          ls_return-type = 'E'.
          ls_return-id = sy-msgid.
          ls_return-number = sy-msgno.
          APPEND ls_return TO gt_return.
          CLEAR : ls_return.
        ENDIF.
      ENDLOOP.
    ENDIF.
*   Get vendor currency
    CALL METHOD zcl_mfp_utilities=>get_vendor_currency
      EXPORTING
        iv_vendor          = gs_contract_deep-vendor
        iv_company         = gs_contract_deep-comp_code
      IMPORTING
        ev_currency        = DATA(lv_vendor_currency)
        ev_permitted_payee = DATA(lv_permitted_payee).

    CLEAR : lv_error.
    lv_error = COND char1(
        WHEN lv_permitted_payee = abap_true AND gs_contract_deep-diff_inv IS INITIAL THEN abap_true
        WHEN lv_permitted_payee = abap_false  THEN abap_true ).

    IF lv_vendor_currency NE gs_contract_deep-currency.
      IF lv_error = abap_true.
        MESSAGE e106(zmfp) INTO ls_return-message WITH TEXT-005.
        ls_return-type = 'E'.
        APPEND ls_return TO gt_return.
        CLEAR : ls_return.
      ENDIF.
    ENDIF.


* validation for invoice approver email

*    READ TABLE gs_contract_deep-deliveryaddresses INTO DATA(ls_deliveryaddress) INDEX 1.
    READ TABLE gs_contract_deep-deliveryaddresses ASSIGNING FIELD-SYMBOL(<fs_deliveryaddress>) INDEX 1.
    IF sy-subrc IS INITIAL AND <fs_deliveryaddress> IS ASSIGNED.
      DATA(lv_email) = <fs_deliveryaddress>-invoicecontactemail.
      TRANSLATE lv_email TO UPPER CASE.
      ls_return = zcl_mfp_document=>check_invoice_approver_email( iv_email = lv_email ).

      IF NOT ls_return IS INITIAL.
        gv_errors = abap_true.
        APPEND ls_return TO gt_return.
        CLEAR ls_return.
      ENDIF.
*   check if invoice contact email is changed
      SELECT SINGLE remark FROM adrct INTO @DATA(lv_old_email) WHERE addrnumber = @<fs_deliveryaddress>-romanaddresscode.
      IF sy-subrc IS INITIAL. TRANSLATE lv_old_email TO UPPER CASE. ENDIF.
      CLEAR lv_email_change.
      lv_email_change = COND char1(
      WHEN lv_email NE lv_old_email THEN abap_true ).
      IF lv_email NE lv_old_email.
        CLEAR <fs_deliveryaddress>-romanaddresscode.
      ENDIF.
    ENDIF.

    me->validate_l4l_totals( ).

    ls_header = me->gs_oaheader.
    ls_headerx = me->gs_oaheaderx.

    IF me->zif_myfi_document~old_doc_header-status EQ zif_mfp_constants=>gc_doc_status-draft OR me->zif_myfi_document~old_doc_header-status IS INITIAL.
      CLEAR: ls_header-number, ls_headerx-number.
      CALL FUNCTION 'BAPI_CONTRACT_CREATE'
        EXPORTING
          header              = ls_header
          headerx             = ls_headerx
          testrun             = abap_true
        IMPORTING
          exp_header          = ls_header_ret
*         purchasingdocument  = lv_doc_number
        TABLES
          return              = lt_return
          item                = me->gt_oaitems
          itemx               = me->gt_oaitemsx
          account             = me->gt_oaaccounts
          accountx            = me->gt_oaaccountsx
*         delivery_address    = lt_bapimeoutaddrdelivery
          header_text         = me->gt_oatextheader
          item_cond_validity  = me->gt_oacond_valid_item
          item_cond_validityx = me->gt_oacond_validx_item
          item_condition      = me->gt_oacondition_item
          item_conditionx     = me->gt_oaconditionx_item
*         extensionin         = lt_extension.
        .
*    CLEAR ls_return.
    ELSE.

      IF NOT gv_locked_costobject IS INITIAL.
        CALL FUNCTION 'BAPI_PO_GETDETAIL1'
          EXPORTING
            purchaseorder    = me->zif_myfi_document~old_doc_header-ref_id
            delivery_address = 'X'
*         IMPORTING
*           POHEADER         =
*           POEXPIMPHEADER   =
          TABLES
*           RETURN           =
*           POITEM           =
            poaddrdelivery   = lt_po_deliveryaddress.

        LOOP AT gs_contract_deep-deliveryaddresses ASSIGNING FIELD-SYMBOL(<fs_delivery_address>).
          IF <fs_delivery_address>-deliverytype = 'NewAddress' OR
            <fs_delivery_address>-deliverytype = 'Pickup'.
            CLEAR <fs_delivery_address>-romanaddresscode.
          ENDIF.
*          IF <fs_delivery_address>-romanaddresscode = ls_deliveryaddress-romanaddresscode
*            AND lv_email_change = abap_true.
*            CLEAR <fs_delivery_address>-romanaddresscode.
*          ENDIF.
        ENDLOOP.

        LOOP AT gt_oaaccounts INTO DATA(ls_accounts) WHERE delete_ind = abap_true.

          lv_linenumber = ls_accounts-item_no.
          SHIFT lv_linenumber LEFT DELETING LEADING '0'.
          IF line_exists( gs_contract_deep-deliveryaddresses[ linenumber = lv_linenumber ] ).
            DATA(lv_new_address) = gs_contract_deep-deliveryaddresses[ linenumber = lv_linenumber ]-romanaddresscode.
          ENDIF.
          IF line_exists( lt_po_deliveryaddress[ po_item = ls_accounts-item_no ] ).
            DATA(lv_old_address) = lt_po_deliveryaddress[ po_item = ls_accounts-item_no ]-addr_no.
          ENDIF.

          IF lv_new_address = lv_old_address.
            DELETE gt_oaaccountsx WHERE item_no = ls_accounts-item_no.
            DELETE gt_oaitems WHERE item_no = ls_accounts-item_no.
            DELETE gt_oaitemsx WHERE item_no = ls_accounts-item_no.
            DELETE gt_oacond_valid_item WHERE item_no = ls_accounts-item_no.
            DELETE gt_oacond_validx_item WHERE item_no = ls_accounts-item_no.
            DELETE gt_extension WHERE valuepart1+0(5) = ls_accounts-item_no.
            DELETE me->gt_oacondition_item WHERE item_no = ls_accounts-item_no.
            DELETE me->gt_oaconditionx_item WHERE item_no = ls_accounts-item_no.
            DELETE gt_oaaccounts WHERE delete_ind = abap_true AND item_no = ls_accounts-item_no .
          ELSE.
            gv_errors = abap_true.
            MESSAGE e109(zmfp) INTO ls_return-message WITH lv_linenumber."TEXT-005.
            ls_return-type = 'E'.
            APPEND ls_return TO gt_return.
            CLEAR : ls_return.
          ENDIF.

          CLEAR : lv_new_address, lv_old_address.
        ENDLOOP.
      ENDIF.

      CALL FUNCTION 'BAPI_CONTRACT_CHANGE'
        EXPORTING
          purchasingdocument  = me->zif_myfi_document~source_doc_num                " Purchasing Document Number
          header              = ls_header                " Header Data Outline Agreement
          headerx             = ls_headerx                " Header Data Change Parameter Outline Agreement
*         vendor_address      =                  " Address Structur Vendor Address
          testrun             = abap_true                " Single-Character Indicator
*         technical_data      =                  " Technical Parameters for Outline Agreement BAPIs
        IMPORTING
          exp_header          = ls_header_ret                " Header Data Outline Agreement
        TABLES
          item                = me->gt_oaitems                " Item Data
          itemx               = me->gt_oaitemsx                " Change Parameter - Item Data
          account             = me->gt_oaaccounts                " Account Assignment Data
*         accountprofitsegment  =                  " Account Assignment - Profitability Segment Calculation
          accountx            = me->gt_oaaccountsx                 " Change Parameter - Account Assignment Data
*         delivery_address    =                  " Delivery Address
          item_cond_validity  = me->gt_oacond_valid_item
          item_cond_validityx = me->gt_oacond_validx_item
          item_condition      = me->gt_oacondition_item
          item_conditionx     = me->gt_oaconditionx_item
*         item_cond_scale_value =                  " Value Scale
*         item_cond_scale_quan  =                  " Quantity Scale
*         item_text           =                  " Item Text
          header_text         = me->gt_oatextheader                 " Header Text
*         head_cond_validity  =                  " Validity Area of Header Condition
*         head_cond_validityx =                  " Change Parameter - Validity Area of Header Condition
*         head_condition      =                  " Header Condition
*         head_conditionx     =                  " Change Parameter - Header Condition
*         head_cond_scale_val =                  " Value Scale
*         head_cond_scale_quan  =                  " Quantity Scale
*         partner             =                  " Partner Data
*         partnerx            =                  " Table Type: Change Parameter Partner Outline Agreement
*         release_docu        =                  " Table Type: Change Parameter Partner Outline Agreement
*         extensionin         =                  " ExtensionIn (Customer Enhancement)
*         extensionout        =                  " ExtensionOut (Customer Enhancement)
          return              = lt_return.                 " Return Table

    ENDIF.


    IF gv_errors EQ abap_false AND ( ls_header_ret-po_rel_ind NE zif_mfp_constants=>gc_mm_doc_status-oa_released AND ls_header_ret-po_rel_ind IS NOT INITIAL ) .
      gv_errors = abap_true.
      MESSAGE e100(zmfp) INTO ls_return-message.
      ls_return-type = sy-msgty.
      ls_return-id = sy-msgid.
      ls_return-number = sy-msgno.
      APPEND ls_return TO gt_return.
    ENDIF.

* Display warning message for Exchange rate deviation from BAPI return
    READ TABLE lt_return INTO DATA(ls_msg) WITH KEY type = 'W'
                                                    id = '06'
                                                    number = '208'.
    IF sy-subrc IS INITIAL.
      CLEAR ls_msg-id.
      APPEND ls_msg TO gt_return.
    ENDIF.

*    APPEND LINES OF lt_return_po TO lt_return.  " l4l validation message
    DELETE lt_return WHERE type = 'S'.
    DELETE lt_return WHERE type = 'I'.
    DELETE lt_return WHERE type = 'W'.
    IF lt_return IS NOT INITIAL.
      lt_return = message_handler( it_return = lt_return ).
      APPEND LINES OF lt_return TO gt_return.
      CLEAR gs_contract_deep.
    ELSEIF gv_errors EQ abap_true.
      CLEAR gs_contract_deep.
    ELSE.
      CLEAR: ls_return, gt_return.
      MESSAGE s014(zmfp) INTO ls_return-message.
      ls_return-type = sy-msgty.
      ls_return-id = sy-msgid.
      ls_return-number = sy-msgno.
      APPEND ls_return TO gt_return.
      gt_return = message_handler( it_return = gt_return ).
    ENDIF.

***  Duplicate Check
**    IF  ls_header_ret-doc_type    IS NOT INITIAL AND
**        ls_header_ret-vendor      IS NOT INITIAL AND
**        ls_header_ret-acum_value  IS NOT INITIAL AND
**        ls_header_ret-currency    IS NOT INITIAL AND
**        ls_header_ret-vper_start  IS NOT INITIAL AND
**        ls_header_ret-vper_end    IS NOT INITIAL.
**
**      CLEAR lt_return.
**      zcl_mfp_utilities=>duplicate_check(
**        EXPORTING
**          iv_ebeln  = ls_header_ret-number                    " Purchasing Document Number
**          iv_bsart  = ls_header_ret-doc_type                  " Order Type (Purchasing)
**          iv_lifnr  = ls_header_ret-vendor                    " Account Number of Vendor or Creditor
**          iv_ktwrt  = ls_header_ret-acum_value                " Target Value for Header Area per Distribution
**          iv_waers  = ls_header_ret-currency                  " Currency Key
**          iv_kdatb  = ls_header_ret-vper_start                " Start of Validity Period
**          iv_kdate  = ls_header_ret-vper_end                  " End of Validity Period
**        IMPORTING
**          et_return = lt_return                                        " Return Parameter Table
**      ).
**
**      IF lt_return IS NOT INITIAL.
**        lt_return = message_handler( it_return = lt_return ).
**        APPEND LINES OF lt_return TO gt_return.
**      ENDIF.
**
**    ENDIF.



  ENDMETHOD.
ENDCLASS.