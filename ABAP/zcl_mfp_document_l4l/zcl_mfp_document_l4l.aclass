  METHOD zif_myfi_document~out_header.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_DOCUMENT_L4L~zif_myfi_document~out_header
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for MyFi Documents
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
* 21/09/20 290977SCN RD2K919977 DS-11-32-07-01 S 6000002096: MyFi Purchasing (Release 2.2)
* 04.08.21 210983DY RD2K921440  DS-11-32-07-01 S6000002451: MyFi Purchasing (August Release)
*                                              Enable Your Reference in MyFi Purchasing
*-----------------------------------------------------------------------
    DATA: lv_amount TYPE /bcv/sin_dec16_3.
    me->map_bapi_2_odata(
      EXPORTING
        is_sending_structure   = gs_oaheader
      IMPORTING
        es_data                = gs_contract_deep
    ).
    gs_contract_deep-ihrez = gs_oaheader-ref_1.

    SELECT SINGLE name1 FROM lfa1 INTO gs_contract_deep-vendorname WHERE lifnr = gs_contract_deep-vendor.
    CASE me->gv_doc_type.
      WHEN zif_mfp_constants=>gc_myfi_doc_type-l4l_oa.
        gs_contract_deep-issinglepo = abap_true.
      WHEN zif_mfp_constants=>gc_myfi_doc_type-myfi_oa.
        gs_contract_deep-iscontractonly = abap_true.
      WHEN OTHERS.
    ENDCASE.

    lv_amount  = zcl_mfp_utilities=>convert_curr_format(
                                      iv_amount = gs_oaheader-acum_value
                                      iv_curr   = gs_oaheader-currency
                                    ).
    gs_contract_deep-acum_value = lv_amount.
    gs_contract_deep-status = me->zif_myfi_document~old_doc_header-status.
    gs_contract_deep-statusdesclong = gs_contract_deep-statusdesc
            = zcl_mfp_utilities=>get_status_desc( iv_status = me->zif_myfi_document~old_doc_header-status ).

  ENDMETHOD.


  METHOD zif_myfi_document~out_line_items.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_DOCUMENT_L4L~zif_myfi_document~out_line_items
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for MyFi Documents
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
* 07.09.20 290977SCN RD2K919977 DS-11-32-07-01 Changed - non-delete flag
* 21.10.20 290977SCN RD2K919656 DS-11-32-07-01 S 6000002172: MyFi Purchasing (Release 2.3) Changed - UOM Changeable Flag
* 30/11/20 210983DY  RD2K919656 DS-11-32-07-01 S 6000002172: MyFi Purchasing (Release 2.3)
*                                            Additional code for Item Texts and Header texts
* 14/01/21 210983DY  RD2K920558 DS-11-32-07-01 S 6000002251: MyFi Purchasing (Release 2.3 Defect Fixes)
*                               Additional code to fix Line Item Texts and Item Note with line break
* 03/03/21 210983DY  RD2K920554 DS-11-32-07-01 S 6000002250: MyFi Purchasing (Release 2.4 )
*                               Additional logic to handle Multi Delivery address and PO Close
* 04.08.21 210983DY RD2K921440  DS-11-32-07-01 S6000002451: MyFi Purchasing (August Release)
* 05/11/21 210983DY  RD2K922034 DS-11-32-07-01 S6000002550: MyFi Applications (December Release)
*                    Additional code to enable Multi Account Assignment
* 20.10.2022 210983DY RD2K923161  6000002831: MyFi Continuous Improvement November Release
*                        Amended logic to fix issue with UoM issue
* 11.09.2023 210983DY RD2K924301     6000002999 MyFi Continuous Improvement October Release
*          Additional logic to display data from L4L OA awaiting approval changes for
*    Delivery date, Final Invocie Indicator and Delivery Complete Indicator
* 14.03.2024 210983DY RD2K924772    6000003112: MyFi Continuous Improvement Release 2024
*                 Amended logic for new Prepayment and FMS field changes
* 30.04.2024 210983DY RD2K924953    6000003126: MyFi Fix
*         Amended logic to fix issue with Prepayment fields
*-----------------------------------------------------------------------
*CALL METHOD SUPER->ZIF_MYFI_DOCUMENT~OUT_LINE_ITEMS
*    .
    DATA: ls_lineitem           TYPE bapimeoutitem,
          ls_odata_lineitem     TYPE zcl_zedm_mfp_mpc=>ts_lineitem,
          lt_odata_lineitems    TYPE TABLE OF zcl_zedm_mfp_mpc=>ts_lineitem WITH DEFAULT KEY,
          lt_ekkn               TYPE STANDARD TABLE OF ekkn,
          lv_item               TYPE ebelp,
          ls_ekkn               TYPE ekkn,
          lv_objname            TYPE tdobname,
          lt_text               TYPE TABLE OF tline,
          lv_line               TYPE string,
          gs_contract_deep_temp TYPE zcl_zedm_mfp_dpc_ext=>ty_contract_deep,
          ls_text               TYPE tline.

* Read the EKKN account assignment data to get the ESP field as the BAPI ExtensionOut can't be used for this
* as the OA line item and sequence (ZEKKN) are missing from the BAPI Extension output
    SELECT *
      FROM ekkn
      INTO TABLE lt_ekkn
     WHERE ebeln = me->gs_contract_deep-contractnumber
       AND zekkn = '01'.  " Only get the first account assignment row as the app only handles one Acct Assignment

    DATA(lv_po) = me->gs_contract_deep-purchaseorder.

* Get Status of Purchase order from MyFi Header table
    SELECT SINGLE status INTO @DATA(lv_status_po) FROM ztmfp_doc_header WHERE zmfp_doc_id = @lv_po.

    LOOP AT gt_oaitems INTO ls_lineitem.

      me->map_bapi_2_odata(
        EXPORTING
          is_sending_structure   = ls_lineitem
        IMPORTING
          es_data                = ls_odata_lineitem
      ).

      ls_odata_lineitem-isgr = ls_lineitem-gr_ind.

      ls_odata_lineitem-distrib = ls_lineitem-distrib.
      ls_odata_lineitem-part_inv = ls_lineitem-part_inv.

*      READ TABLE gt_oaaccounts WITH KEY item_no = ls_lineitem-item_no INTO DATA(ls_account).
*      me->map_bapi_2_odata(
*        EXPORTING
*          is_sending_structure   = ls_account
*        IMPORTING
*          es_data                = ls_odata_lineitem
*      ).

      IF NOT ls_lineitem-trackingno IS INITIAL.
        ls_odata_lineitem-trackingno = ls_lineitem-trackingno.
      ENDIF.

      IF NOT ls_lineitem-vend_mat IS INITIAL.
        ls_odata_lineitem-vendormaterial = ls_lineitem-vend_mat.
      ENDIF.

      IF ls_lineitem-net_price = '0.00'
           AND ls_lineitem-gr_ind = abap_false
           AND ls_lineitem-ir_ind = abap_false
           AND ls_lineitem-gr_basediv = abap_false .
        ls_odata_lineitem-zerovalue = abap_true.
      ENDIF.

      SELECT SINGLE mseh3 FROM  t006a
       WHERE  spras  = 'E'
       AND    msehi  = @ls_lineitem-orderpr_un
       INTO @ls_odata_lineitem-po_unit.


* ESP
      READ TABLE lt_ekkn INTO ls_ekkn
        WITH KEY ebelp = ls_lineitem-item_no.

      IF sy-subrc = 0.
        ls_odata_lineitem-esp = ls_ekkn-zzesp.
      ENDIF.

      lv_item = ls_odata_lineitem-linenumber.

* Get line item texts
      ls_odata_lineitem-itemtext = convert_mm_table_str_item( EXPORTING it_texts  = gt_oaitemtext iv_item = lv_item
                                                                                           iv_tdid   = zif_mfp_constants=>gc_header_text-oa-item-text ).

      ls_odata_lineitem-inforecordpotext = convert_mm_table_str_item( EXPORTING it_texts  = gt_oaitemtext iv_item = lv_item
                                                                                   iv_tdid   = zif_mfp_constants=>gc_header_text-oa-item-info_record ).

      ls_odata_lineitem-materialpotext =   convert_mm_table_str_item( EXPORTING it_texts  = gt_oaitemtext iv_item = lv_item
                                                                                        iv_tdid   = zif_mfp_constants=>gc_header_text-oa-item-mat_po ).

      ls_odata_lineitem-inforecordnote = convert_mm_table_str_item( EXPORTING it_texts  = gt_oaitemtext iv_item = lv_item
                                                                                        iv_tdid   = zif_mfp_constants=>gc_header_text-oa-item-info_note ).

* For L4L scenario, UI allows to enter Item Note on OA which is not available
* for contract on backend. Following logic will derive Item Note line item text
* from PO and make it available for display and edit on OA.

      IF NOT lv_status_po = zif_mfp_constants=>gc_doc_status-draft. " Draft
        CONCATENATE lv_po lv_item INTO lv_objname.
        CLEAR : lv_line.
        CALL FUNCTION 'READ_TEXT'
          EXPORTING
            client                  = sy-mandt
            id                      = 'F08'
            language                = sy-langu
            name                    = lv_objname " PO and Itemnumber
            object                  = 'EKPO'
          TABLES
            lines                   = lt_text
          EXCEPTIONS
            id                      = 1
            language                = 2
            name                    = 3
            not_found               = 4
            object                  = 5
            reference_check         = 6
            wrong_access_to_archive = 7
            OTHERS                  = 8.
        IF sy-subrc <> 0.
* Implement suitable error handling here
        ELSE.
          LOOP AT lt_text INTO ls_text.
            lv_line = |{ lv_line }{ cl_abap_char_utilities=>newline }{ ls_text-tdline }|.
          ENDLOOP.

          IF NOT lv_line IS INITIAL.
            ls_odata_lineitem-infonote = lv_line.
          ENDIF.
        ENDIF.

      ELSE. " For L4L scenario where OA is awaiting approval

        READ TABLE me->gs_contract_deep-contractlis INTO DATA(ls_contract_li) WITH KEY linenumber = ls_odata_lineitem-linenumber.
        IF sy-subrc IS INITIAL.
          ls_odata_lineitem-infonote = ls_contract_li-infonote.
        ENDIF.

      ENDIF.

* Delivery Date
      LOOP AT gs_contract_deep-contractlis INTO DATA(ls_line)
        WHERE agmt_item = ls_lineitem-item_no.
        IF ls_line-deliverydate IS NOT INITIAL.
          ls_odata_lineitem-deliverydate = ls_line-deliverydate.
        ENDIF.
        EXIT.  " Only should be one line
      ENDLOOP.

      get_quantity_left( CHANGING is_odata_lineitem = ls_odata_lineitem ).
      ls_odata_lineitem-currency = gs_contract_deep-currency.
      ls_odata_lineitem-parentnumber = gs_contract_deep-contractnumber.
      READ TABLE go_l4l_po->gs_po_deep-purchaseorderlis WITH KEY agmt_item = ls_odata_lineitem-linenumber INTO DATA(ls_po_line).
*      linenumber = ls_odata_lineitem-linenumber INTO DATA(ls_po_line).

      IF gs_contract_deep-status NE zif_mfp_constants=>gc_doc_status-approved. "'40'.
* Get Delivery date from String table for unapproved documents
        /ui2/cl_json=>deserialize( EXPORTING json = me->gs_deep_entity pretty_name = /ui2/cl_json=>pretty_mode-camel_case CHANGING data = gs_contract_deep_temp ).
        LOOP AT gs_contract_deep_temp-contractlis INTO ls_line
        WHERE linenumber = ls_lineitem-item_no.
          IF ls_line-deliverydate IS NOT INITIAL.
            ls_odata_lineitem-deliverydate = ls_line-deliverydate.
          ENDIF.
          ls_odata_lineitem-final_inv = ls_line-final_inv.
          ls_odata_lineitem-deliv_compl = ls_line-deliv_compl.
          EXIT.  " Only should be one line
        ENDLOOP.

      ELSE.
        ls_odata_lineitem-final_inv = ls_po_line-final_inv.
        ls_odata_lineitem-deliv_compl = ls_po_line-deliv_compl.
      ENDIF.

      ls_odata_lineitem-non_delete = zcl_mfp_utilities=>is_non_deleteable_line(
                                       it_po_history_totals = me->go_l4l_po->gt_pohistory_totals
                                       iv_ebelp             = ls_lineitem-item_no
                                     ).
      ls_odata_lineitem-iscloseable = ls_po_line-iscloseable.
      ls_odata_lineitem-itemqtyleft = ls_po_line-itemqtyleft.
      ls_odata_lineitem-qty_invoiced = ls_po_line-qty_invoiced.

* UOM Changeable
      IF  ls_odata_lineitem-non_delete EQ abap_true.
        ls_odata_lineitem-uom_changeable = abap_false.
      ELSE.
        ls_odata_lineitem-uom_changeable = abap_true.
      ENDIF.

      IF lv_status_po = zif_mfp_constants=>gc_doc_status-draft.
        ls_odata_lineitem-uom_changeable = abap_true.
      ELSE.
        ls_odata_lineitem-uom_changeable = abap_false.
      ENDIF.

      IF ls_odata_lineitem-distrib IS INITIAL.

        ls_odata_lineitem-distrib = '0'.

      ENDIF.

      IF me->zif_myfi_document~old_doc_header-status NE zif_mfp_constants=>gc_doc_status-approved.
        READ TABLE me->zif_myfi_document~old_prepmnts WITH KEY linenumber = ls_odata_lineitem-linenumber INTO DATA(ls_prepay).
        CONVERT DATE ls_prepay-prepaymentcompleteddate INTO TIME STAMP ls_odata_lineitem-prepaymentcompleteddate TIME ZONE 'UTC'.
        ls_odata_lineitem-isprepayment = SWITCH #( ls_prepay-isprepayment
              WHEN 'X' THEN 'Y'
              WHEN 'Y' THEN 'Y'
              WHEN 'N' THEN 'N'
              WHEN ' ' THEN 'N' ).
        ls_odata_lineitem-isstraightline = SWITCH #( ls_prepay-isstraightline
              WHEN 'X' THEN 'Y'
              WHEN 'Y' THEN 'Y'
              WHEN 'N' THEN 'N'
              WHEN ' ' THEN 'N' ).
        ls_odata_lineitem-purchasetype = ls_prepay-purchasetype.
      ELSE.
        ls_odata_lineitem-prepaymentcompleteddate = ls_po_line-prepaymentcompleteddate.
        ls_odata_lineitem-isprepayment = SWITCH #( ls_po_line-isprepayment
              WHEN 'X' THEN 'Y'
              WHEN 'Y' THEN 'Y'
              WHEN 'N' THEN 'N'
              WHEN ' ' THEN 'N' ).
        ls_odata_lineitem-isstraightline =  SWITCH #( ls_po_line-isstraightline
              WHEN 'X' THEN 'Y'
              WHEN 'Y' THEN 'Y'
              WHEN 'N' THEN 'N'
              WHEN ' ' THEN 'N' ).
        ls_odata_lineitem-purchasetype = ls_po_line-purchasetype.
      ENDIF.

      APPEND ls_odata_lineitem TO lt_odata_lineitems.
      CLEAR : ls_odata_lineitem.
    ENDLOOP.

    gs_contract_deep-contractlis = lt_odata_lineitems.
    gs_contract_deep-iscloseable = go_l4l_po->gs_po_deep-iscloseable.

  ENDMETHOD.


  METHOD zif_myfi_document~out_strings.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_DOCUMENT_L4L~ZIF_MYFI_DOCUMENT~REASSIGN_DOC
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for MyFi Documents
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
* 30/11/20 210983DY  RD2K919656 DS-11-32-07-01 S 6000002172: MyFi Purchasing (Release 2.3)
*                                            Additional code for Item Texts and Header texts
* 03/03/21 210983DY  RD2K920554 DS-11-32-07-01 S 6000002250: MyFi Purchasing (Release 2.4 )
*                               Additional code to handle Multi delivery address
*-----------------------------------------------------------------------
    FIELD-SYMBOLS <string_record> LIKE LINE OF me->zif_myfi_document~old_strings.

    me->gs_contract_deep-romancomment = convert_mm_table_string( EXPORTING it_texts  = gt_oatextheader
                                                                           iv_tdid   = zif_mfp_constants=>gc_header_text-oa-header ).

* header note
    me->gs_contract_deep-headertexts-headernote = convert_mm_table_string( exporting it_texts  = gt_oatextheader
                                                                               iv_tdid   = zif_mfp_constants=>gc_header_text-oa-note ).
*Contract Riders
    me->gs_contract_deep-headertexts-contractriders = convert_mm_table_string( EXPORTING it_texts  = gt_oatextheader
                                                                               iv_tdid   = zif_mfp_constants=>gc_header_text-oa-riders ).

*Alternate Terms and Conditions

    DATA(lv_alternatetc) = convert_mm_table_string( EXPORTING it_texts  = gt_oatextheader
                                                                               iv_tdid   = zif_mfp_constants=>gc_header_text-oa-alt_tc_cond ).
    IF NOT lv_alternatetc IS INITIAL.
      me->gs_contract_deep-headertexts-alternatetc = abap_true.
    ELSE.
      me->gs_contract_deep-headertexts-alternatetc = abap_false.
    ENDIF.

    me->gs_contract_deep-headertexts-parentnumber = gs_contract_deep-contractnumber.

* Retrieve the strings table data from the me->zif_myfi_document~old_strings variable.
    LOOP AT me->zif_myfi_document~old_strings ASSIGNING <string_record>.

      CASE <string_record>-string_type.
        WHEN zif_mfp_constants=>gc_string_type-value_for_money.
          me->gs_contract_deep-approvaldetails-valueformoney = <string_record>-string_data.
        WHEN zif_mfp_constants=>gc_string_type-comment_approver.
          me->gs_contract_deep-approvaldetails-commentforapprover = <string_record>-string_data.
        WHEN zif_mfp_constants=>gc_string_type-reject_comment.
          me->gs_contract_deep-approvaldetails-rejectcomments = <string_record>-string_data.
        WHEN zif_mfp_constants=>gc_string_type-etp_justif.
          me->gs_contract_deep-admindetails-etp_justification = <string_record>-string_data.
        WHEN zif_mfp_constants=>gc_string_type-pickup_loc.
**          me->gs_contract_deep-deliveryaddresses-pickuplocation = <string_record>-string_data.
        WHEN zif_mfp_constants=>gc_string_type-spec_instr.
          me->gs_contract_deep-contactdetails-specialinstructions = <string_record>-string_data.
        WHEN zif_mfp_constants=>gc_string_type-indig_no_appr.
          me->gs_contract_deep-admindetails-indig_no_approach_rsn = <string_record>-string_data.
      ENDCASE.

    ENDLOOP.

  ENDMETHOD.


