  METHOD zif_myfi_document~save_draft.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_DOCUMENT_L4L~zif_myfi_document~save_draft
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for MyFi Documents
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
* 18.12.2023 210983DY RD2K924523  6000003043 MyFi Continuous Improvement February Release
*          Stop auto deletion of draft documents
*-----------------------------------------------------------------------
    DATA: lv_event_success TYPE boole_d.
    me->gv_draft_indicator = abap_true.
    IF gs_contract_deep-contractnumber IS INITIAL.                                              "No doc number so a new record
      gs_contract_deep-contractnumber = gs_contract_deep-requestid = zcl_mfp_utilities=>get_next_request_num( ) .
    ENDIF.
** me->zif_myfi_document~source_doc_num =
    me->zif_myfi_document~posting_doc_num = gs_contract_deep-contractnumber.
    me->create_new_doc_header( iv_status = zif_mfp_constants=>gc_doc_status-draft ).
    gs_contract_deep-status = zif_mfp_constants=>gc_doc_status-draft.
    gs_contract_deep-statusdesc = zcl_mfp_utilities=>get_status_desc( iv_status = zif_mfp_constants=>gc_doc_status-draft ).
    gs_contract_deep-statusdesclong = zcl_mfp_utilities=>get_status_desc( iv_status = zif_mfp_constants=>gc_doc_status-draft ).
    me->in_admin_details( ).
    me->in_indigsub( ).
    me->zif_myfi_document~new_doc_header-selected_delegate = gs_contract_deep-approvaldetails-delegateid.
    me->zif_myfi_document~new_doc_header-section23 = gs_contract_deep-approvaldetails-issection23.
    MOVE-CORRESPONDING gs_contract_deep-contactdetails TO me->zif_myfi_document~new_doc_header.
*    in_prepmnt_line( ).

    IF gs_contract_deep-draftassigneeid IS NOT INITIAL.
      CALL METHOD me->assign_document
        EXPORTING
          iv_assignee = gs_contract_deep-draftassigneeid.
    ENDIF.
    super->zif_myfi_document~save_draft( ).
*    CALL METHOD zcl_mfp_oa=>create_event
*      EXPORTING
*        iv_ebeln        = me->zif_myfi_document~posting_doc_num
*        iv_event        = zif_mfp_constants=>gc_event-draft
*      IMPORTING
*        ev_event_raised = lv_event_success.
*
*    IF lv_event_success = abap_true.
*      CALL METHOD zcl_mfp_utilities=>log_myfi_event
*        EXPORTING
*          iv_doc_number = me->zif_myfi_document~posting_doc_num
*          iv_user_id    = sy-uname
*          iv_sub_obj    = zif_mfp_constants=>gc_log-sub_obj-wf-draft.
*    ENDIF.


  ENDMETHOD.


  METHOD zif_myfi_document~update_old_doc_header.
