  METHOD zif_myfi_document~fill_deep_entity.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_DOCUMENT_L4L~zif_myfi_document~fill_deep_entity
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for MyFi Documents
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
* 03/03/21 210983DY  RD2K920554 DS-11-32-07-01 S 6000002250: MyFi Purchasing (Release 2.4 )
*                               Additional logic to handle Multi delivery address
* 20/05/21 210983DY  RD2K921041 DS-11-32-07-01 S6000002393: June DFSS release for MyFi Purchasing
*              Additional code to restrict user to chose payment justification text from dropdown
* 05/11/21 210983DY  RD2K922034 DS-11-32-07-01 S6000002550: MyFi Applications (December Release)
*                    Additional code to enable Multi Account Assignment
* 29/03/22 210983DY RD2K922546  DS-11-32-07-01 S 6000002692: MyFi Applications (May Release)
*                               Derive Account assignment from OA
* 23.01.23 210983DY RD2K923485  DS-11-32-07-01 S 6000002854: MyFi Continuous Improvement December Release
*           CIR 516 - Enable undelete option on UI for Line items with locked cost objects on contracts
*03.03.2023 210983DY  RD2K923630, RD2K923771
*                    6000002898 MyFi Continuous Improvement April Release
*                    Additional code for toggle of delivery address
* 03/07/2023 210983DY RD2K923919 6000002957 MyFi Continuous Improvement
* 10/10/23 210983DY RD2K924373 DS-11-32-07-01 6000003027: MyFi Continuous Improvement November Rel
*           Additional logic to display Justification Desription for Payment Term selected
* 14.03.2024 210983DY RD2K924772    6000003112: MyFi Continuous Improvement Release 2024
*                 Amended logic for new Prepayment and FMS field changes
*-----------------------------------------------------------------------
    DATA: ls_indigsub           TYPE zcl_zedm_mfp_mpc=>ts_indigenoussubcontractor,
*          ls_oaaccount          TYPE bapimeoutaccount,
          ls_accountassignments TYPE zcl_zedm_mfp_mpc=>ts_accountassignment.

    IF me->gv_draft_indicator EQ abap_true.
      /ui2/cl_json=>deserialize( EXPORTING json = me->gs_deep_entity pretty_name = /ui2/cl_json=>pretty_mode-camel_case CHANGING data = me->gs_contract_deep ).
    ELSE.

      me->gs_contract_deep-isprepaymentexempt = go_l4l_po->gs_po_deep-isprepaymentexempt.

      MOVE-CORRESPONDING me->zif_myfi_document~old_adm_dtl TO me->gs_contract_deep-admindetails.
      me->gs_contract_deep-paymenttermsjustification              = me->zif_myfi_document~old_adm_dtl-pay_term_just.
      me->gs_contract_deep-paymenttermsjustification              = me->zif_myfi_document~old_adm_dtl-pay_term_just_dd.
      me->gs_contract_deep-justificationdescription               = me->zif_myfi_document~old_adm_dtl-justificationdescription.
      me->gs_contract_deep-admindetails-parentnumber              = me->gs_contract_deep-contractnumber.
      ls_indigsub-contractnumber                                  = me->gs_contract_deep-contractnumber.
      LOOP AT me->zif_myfi_document~old_inidigsub INTO DATA(ls_subbie).
        IF ls_subbie-deletion_flag EQ abap_true.
          CONTINUE.
        ENDIF.
        ls_indigsub-sequence                                      = ls_subbie-sequence.
        ls_indigsub-contractorabn                                 = ls_subbie-contractorabn.
        ls_indigsub-contractorname                                = ls_subbie-contractorname.
        APPEND ls_indigsub TO me->gs_contract_deep-indigenoussubcontractors.
      ENDLOOP.
      IF NOT ( me->zif_myfi_document~gv_useraction EQ zif_mfp_constants=>gc_action-odata-edit AND
         me->zif_myfi_document~old_doc_header-status EQ zif_mfp_constants=>gc_doc_status-approved ).
        IF me->zif_myfi_document~old_doc_header-selected_delegate IS NOT INITIAL.
          me->gs_contract_deep-approvaldetails-delegateid           = zcl_mfp_utilities=>get_pernr_from_user( me->zif_myfi_document~old_doc_header-selected_delegate ).
        ENDIF.
      ENDIF.
      me->gs_contract_deep-approvaldetails-issection23            = me->zif_myfi_document~old_doc_header-section23.
      me->gs_contract_deep-approvaldetails-parentnumber           = me->zif_myfi_document~source_doc_num.
      me->gs_contract_deep-sonid                                  = me->zif_myfi_document~old_adm_dtl-sonid.
*      me->gs_contract_deep-issameaddressforall = me->zif_myfi_document~old_doc_header-issameaddressforall.
      MOVE-CORRESPONDING me->zif_myfi_document~approval_history TO me->gs_contract_deep-approvalhistory.

      MOVE-CORRESPONDING me->zif_myfi_document~old_doc_header TO me->gs_contract_deep-contactdetails.
      MOVE-CORRESPONDING me->zif_myfi_document~old_doc_header TO me->gs_contract_deep-approvaldetails.

      MOVE me->go_l4l_po->gs_po_deep-contactdetails-invoicecontactemail TO me->gs_contract_deep-contactdetails-invoicecontactemail.

      gs_contract_deep-issameaddressforall = go_l4l_po->gs_po_deep-issameaddressforall.  "2023 April release

* UI sometime doesn't clear address code for 'NewAddress' drop down
      LOOP AT me->gs_contract_deep-deliveryaddresses ASSIGNING FIELD-SYMBOL(<fs_deliveraddress>).
        IF <fs_deliveraddress>-deliverytype = 'NewAddress'.
          CLEAR <fs_deliveraddress>-romanaddresscode.
        ENDIF.
      ENDLOOP.
      DATA(lv_address) = gs_contract_deep-deliveryaddresses[ 1 ]-romanaddresscode.
      LOOP AT me->gs_contract_deep-deliveryaddresses INTO DATA(ls_deliveryaddress).
        IF ls_deliveryaddress-romanaddresscode NE lv_address OR ls_deliveryaddress-romanaddresscode IS INITIAL.
          gs_contract_deep-issameaddressforall = abap_false.
          EXIT.
        ENDIF.
      ENDLOOP.

      CALL METHOD me->get_account_assignment
        EXPORTING
          iv_document    = me->zif_myfi_document~source_doc_num
          it_lineitems   = me->gs_contract_deep-contractlis
        IMPORTING
          et_assignments = gs_contract_deep-accountassignments.

* Due to limitation in SAP OA's, Set undelete button flag on UI to 'True' for line items with blocked cost objects on Contracts and L4L's
      LOOP AT gs_contract_deep-accountassignments INTO ls_accountassignments WHERE islocked = abap_true.
        READ TABLE gs_contract_deep-contractlis ASSIGNING FIELD-SYMBOL(<fs_lineitem>) WITH KEY linenumber = ls_accountassignments-linenumber
                                                                              status = 'L'.
        IF sy-subrc IS INITIAL AND <fs_lineitem> IS ASSIGNED.
          <fs_lineitem>-un_delete = abap_true.
        ENDIF.

      ENDLOOP.

    ENDIF.
  ENDMETHOD.


  METHOD zif_myfi_document~get_myfi_details.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_DOCUMENT_L4L~zif_myfi_document~get_myfi_details
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for MyFi Documents
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
* 08.09.22 210983DY RD2K923064 6000002812: MyFi Continuous Improvement October Release
*                           Get Delivery address from MyFi string table
*                           for awaiting approval documents
* 03.03.2023 210983DY  RD2K923630 6000002898 MyFi Continuous Improvement April Release
*                    Additional code for toggle of delivery address
*-----------------------------------------------------------------------
    super->zif_myfi_document~get_myfi_details( ).
    DATA: ls_temp_contract_deep TYPE zcl_zedm_mfp_dpc_ext=>ty_contract_deep.
    IF me->gv_draft_indicator = abap_true.
      RETURN.
    ELSE.
      CREATE OBJECT go_l4l_po TYPE zcl_mfp_document_po
        EXPORTING
          iv_ebeln         = me->zif_myfi_document~old_doc_header-ref_id
          iv_action        = '99'
          iv_myfi_doc_type = zif_mfp_constants=>gc_myfi_doc_type-l4l_po.
    ENDIF.
    MOVE-CORRESPONDING go_l4l_po->gs_po_deep-purchaseorderlis TO gs_contract_deep-contractlis.
*    gs_contract_deep-issameaddressforall = go_l4l_po->gs_po_deep-issameaddressforall.
    gs_contract_deep-purchaseorder = go_l4l_po->gs_po_deep-po_number.
    gs_contract_deep-deliveryaddresses = go_l4l_po->gs_po_deep-deliveryaddresses.
    gs_contract_deep-contactdetails = go_l4l_po->gs_po_deep-contactdetails.
    gs_contract_deep-consumptiongrs = go_l4l_po->gs_po_deep-consumptiongrs.
    gs_contract_deep-consumptionirs = go_l4l_po->gs_po_deep-consumptionirs.
    gs_contract_deep-consumptionsummary = go_l4l_po->gs_po_deep-consumptionsummary.


    IF me->zif_myfi_document~old_doc_header-status NE zif_mfp_constants=>gc_doc_status-approved.
      SELECT SINGLE string_data FROM ztmfp_strings
      WHERE zmfp_doc_id EQ @me->zif_myfi_document~source_doc_num AND
            string_type EQ @zif_mfp_constants=>gc_string_type-json INTO
            @me->gs_deep_entity.
      /ui2/cl_json=>deserialize( EXPORTING json = me->gs_deep_entity pretty_name = /ui2/cl_json=>pretty_mode-camel_case CHANGING data = ls_temp_contract_deep ).
      gs_contract_deep-phasings = ls_temp_contract_deep-phasings.
      gs_contract_deep-diff_inv = ls_temp_contract_deep-diff_inv.
      gs_contract_deep-deliveryaddresses = ls_temp_contract_deep-deliveryaddresses.
    ELSE.
      gs_contract_deep-phasings = go_l4l_po->gs_po_deep-phasings.
      gs_contract_deep-diff_inv = go_l4l_po->gs_po_deep-diff_inv.
    ENDIF.
  ENDMETHOD.


  METHOD zif_myfi_document~handle_odata.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_DOCUMENT_L4L~zif_myfi_document~handle_odata
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for MyFi Documents
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
* 05/11/21 210983DY  RD2K922034 DS-11-32-07-01 S6000002550: MyFi Applications (December Release)
*                    Additional code to enable Multi Account Assignment
* 20.09.2023 210983DY RD2K924353  6000002999 MyFi Continuous Improvement October Release
*          Additional logic to fix update of Plant for Legacy documents
* 14.03.2024 210983DY RD2K924772    6000003112: MyFi Continuous Improvement Release 2024
*                 Amended logic for new Prepayment and FMS field changes
*-----------------------------------------------------------------------

    IF me->gs_contract_deep-isdraft EQ abap_false.
      CALL FUNCTION 'BAPI_CONTRACT_GETDETAIL'
        EXPORTING
          purchasingdocument = me->zif_myfi_document~source_doc_num
          text_data          = abap_true
          account_data       = abap_true
        TABLES
          item               = gt_old_oaitems
          item_text          = gt_old_oaitemtext         " Text Data - Outline Agreement
          account            = gt_old_oaaccounts.         " Text Data - Outline Agreement
    ENDIF.

    super->zif_myfi_document~handle_odata( ).
    me->zif_myfi_document~new_doc_header-selected_delegate = gs_contract_deep-approvaldetails-delegateid.
    me->zif_myfi_document~new_doc_header-section23 = gs_contract_deep-approvaldetails-issection23.
    me->zif_myfi_document~new_doc_header-isaaicompliance = gs_contract_deep-approvaldetails-isaaicompliance.
    me->zif_myfi_document~new_doc_header-isfpmapproved = gs_contract_deep-approvaldetails-isfpmapproved.
    me->zif_myfi_document~new_doc_header-isasfinapproved = gs_contract_deep-approvaldetails-isasfinapproved.
    MOVE-CORRESPONDING gs_contract_deep-contactdetails TO me->zif_myfi_document~new_doc_header.
    me->in_admin_details( ).
    me->in_indigsub( ).
*    me->in_linked_pos( ).
  ENDMETHOD.


  METHOD zif_myfi_document~in_account_assignment ##NEEDED.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_DOCUMENT_L4L~ZIF_MYFI_DOCUMENT~IN_ACCOUNT_ASSIGNMENT
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for MyFi Documents
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
* 05/11/21 210983DY  RD2K922034 DS-11-32-07-01 S6000002550: MyFi Applications (December Release)
*                    Additional code to enable Multi Account Assignment
* 13/01/22  210983DY RD2K922296 6000002623: MyFi Applications (February Release)
* 10/01/23  210983DY RD2K923348,
*                   RD2K923485 S 6000002854: MyFi Continuous Improvement December Rel
*          Additional logic to handle Account assignment validation for locked objects
* 03/07/2023 210983DY RD2K923919 6000002957 MyFi Continuous Improvement -
*    Amend logic to maintain corect cost assignment updates between K and P
*-----------------------------------------------------------------------

    DATA: ls_ci_cobl   TYPE bapi_te_mereqaccounting,
          ls_ci_coblx  TYPE bapi_te_mereqaccountingx,
          ls_csks      TYPE csksv,
          lv_pspnr     TYPE ps_posnr,
          ls_extension TYPE bapiparex.

    DATA: lineassignments  TYPE zcl_zedm_mfp_mpc=>ts_accountassignment,
          ls_bapi_account  TYPE bapimeoutaccount,
          ls_bapi_accountx TYPE bapimeoutaccountx,
          r_descr          TYPE REF TO cl_abap_structdescr,
          wa_comp          TYPE abap_compdescr.


    CLEAR: gt_oaaccounts,gt_oaaccountsx, gt_extension.

    me->zif_myfi_document~old_ekpo = get_ekpo( iv_ebeln = me->zif_myfi_document~source_doc_num ).
    LOOP AT gt_old_oaaccounts ASSIGNING FIELD-SYMBOL(<fs_accounts>).

      CALL FUNCTION 'CONVERSION_EXIT_ALPHA_OUTPUT'
        EXPORTING
          input  = <fs_accounts>-item_no
        IMPORTING
          output = <fs_accounts>-item_no.

      CALL FUNCTION 'CONVERSION_EXIT_ALPHA_OUTPUT'
        EXPORTING
          input  = <fs_accounts>-serial_no
        IMPORTING
          output = <fs_accounts>-serial_no.

    ENDLOOP.

    r_descr ?= cl_abap_typedescr=>describe_by_data( ls_bapi_account ).

    IF gt_oaaccounts IS INITIAL.
      LOOP AT gs_contract_deep-accountassignments INTO lineassignments." WHERE isdeleted = space .
*  CIR516
** Check status of Cost object
        IF NOT lineassignments-costcenter IS INITIAL.

          CALL FUNCTION 'RK_KOSTL_READ'
            EXPORTING
              datum              = sy-datum
              kokrs              = 'CA01'
              kostl              = lineassignments-costcenter
            IMPORTING
              xcsksv             = ls_csks
            EXCEPTIONS
              kostl_not_complete = 1
              kostl_not_found    = 2
              text_not_found     = 3
              kokrs_missing      = 4
              OTHERS             = 5.
          IF sy-subrc <> 0.
* Implement suitable error handling here
          ENDIF.

          IF ls_csks-bkzkp = abap_true OR ls_csks-bkzks = abap_true OR ls_csks-bkzer = abap_true OR
             ls_csks-bkzob = abap_true OR ls_csks-pkzkp = abap_true OR ls_csks-pkzks = abap_true OR
             ls_csks-pkzer = abap_true.
            DATA(lv_inactive) = abap_true.
          ENDIF.
        ENDIF.

        IF NOT lineassignments-asset_no IS INITIAL.

          SELECT SINGLE a~anln1 AS assetnumber
                INTO @DATA(lv_asset)
                FROM anla AS a
                     INNER JOIN anlz AS b ON b~bukrs = a~bukrs
                                         AND b~anln1 = a~anln1
                                         AND b~anln2 = a~anln2
               WHERE a~bukrs = @gs_contract_deep-comp_code
                 AND a~anln1 = @lineassignments-asset_no    "Asset Number - passed in search criteria
                 AND a~anln2 = @lineassignments-sub_number
                 AND a~xspeb EQ @space              "Acquisition Lock
                 AND a~xloev EQ @space              "Deletion Flag
                 AND a~deakt EQ '00000000'         "Deactivation Date
                 AND b~bdatu GE @sy-datlo.           "Date validity ends

          IF NOT sy-subrc IS INITIAL.
            lv_inactive = abap_true.
          ENDIF.
        ENDIF.

        IF NOT lineassignments-wbs_element IS INITIAL.

          CALL FUNCTION 'CONVERSION_EXIT_ABPSP_INPUT'
            EXPORTING
              input     = lineassignments-wbs_element
            IMPORTING
              output    = lv_pspnr
            EXCEPTIONS
              not_found = 1
              OTHERS    = 2.
          IF sy-subrc <> 0.
* Implement suitable error handling here
          ELSE.

            SELECT a~posid AS key,
                       a~post1 AS description,
                       c~pspid AS project,
                       c~post1 AS projectdescription
                  INTO TABLE @DATA(lt_wbs) "et_entityset
                  FROM prps AS a
                       INNER JOIN jest AS b ON b~objnr = a~objnr
                       INNER JOIN proj AS c ON c~pspnr = a~psphi
                 WHERE a~posid = @lineassignments-wbs_element "IN lt_wbsnumbr_filter  "WBS Element
                   AND a~belkz EQ 'X'                 "Indicator: Account assignment element
                   AND b~stat EQ 'I0002'              "Released
                   AND b~inact NE 'X'                 "Inactive
                   AND b~objnr NOT IN ( SELECT objnr
                                          FROM jest
                                         WHERE objnr EQ b~objnr
                                           AND ( ( stat = 'I0043' AND inact = @space )       "Locked and active status record
                                            OR   ( stat = 'I0045' AND inact = @space )       "Technically completed and active status record
                                            OR   ( stat = 'I0046' AND inact = @space )       "Closed and active status record
                                            OR   ( stat = 'I0076' AND inact = @space ) ) ).  "Deletion Flag and active status record

            IF NOT sy-subrc IS INITIAL.
              lv_inactive = abap_true.
*              CONTINUE.
            ENDIF.
          ENDIF.
        ENDIF.

*      ELSE
        IF NOT lineassignments-orderid IS INITIAL.

          SELECT a~aufnr AS key,
                     a~ktext AS value
                FROM aufk AS a
                     INNER JOIN jest AS b ON b~objnr = a~objnr
                INTO TABLE @DATA(lt_order)
               WHERE a~aufnr = @lineassignments-orderid "  "Internal Order Number
                 AND a~auart = 'A000'              "Order Type
                 AND a~kokrs = 'CA01'              "Controlling Area
                 AND a~phas1 = 'X'                 "'Release' Status
                 AND a~loekz = @space               "'Deletion Flag
                 AND b~stat = 'I0002'              "Released Status in JEST
                 AND b~inact = @space               "Active Released Status in JEST
                 AND b~objnr NOT IN ( SELECT objnr "Ensure that there are no other status that make the IO record unvailable for posting
                                        FROM jest
                                       WHERE objnr EQ b~objnr
                                         AND ( ( stat = 'I0043' AND inact = @space )       "Locked and active status record
                                          OR   ( stat = 'I0045' AND inact = @space )       "Technically completed and active status record
                                          OR   ( stat = 'I0046' AND inact = @space )       "Closed and active status record
                                          OR   ( stat = 'I0076' AND inact = @space ) ) ).  "Deletion Flag and active status record

          IF NOT sy-subrc IS INITIAL.
            lv_inactive = abap_true.
*           CONTINUE.
          ENDIF.
        ENDIF.

        IF NOT lineassignments-gl_account IS INITIAL.

          SELECT SINGLE a~saknr INTO @DATA(lv_valid_gl)
          FROM ska1 AS a INNER JOIN skb1 AS b ON a~saknr = b~saknr
          WHERE a~ktopl = 'COA'
            AND a~saknr = @lineassignments-gl_account
              AND a~xloev = @space
              AND a~xspeb = @space
              AND b~bukrs = @gs_contract_deep-comp_code
              AND b~xloeb = @space
              AND b~xspeb = @space.
          IF NOT sy-subrc IS INITIAL.
            lv_inactive = abap_true.
          ENDIF.
        ENDIF.

        READ TABLE gt_old_oaaccounts INTO DATA(ls_old_oaaccount) WITH KEY item_no = lineassignments-linenumber
                                                                          serial_no = lineassignments-assignment_item.
        IF sy-subrc IS INITIAL.
          MOVE-CORRESPONDING ls_old_oaaccount TO ls_bapi_account.
        ENDIF.
        CLEAR : ls_bapi_account, ls_bapi_accountx.
        MOVE-CORRESPONDING lineassignments TO ls_bapi_account.
        ls_bapi_account-delete_ind = lineassignments-isdeleted.

        IF lv_inactive = abap_true.

          READ TABLE me->zif_myfi_document~old_ekpo INTO DATA(ls_ekpo_old) WITH KEY ebelp = lineassignments-linenumber.

          IF sy-subrc IS INITIAL AND ( ls_ekpo_old-loekz = zif_mfp_constants=>gc_lock_type-blocked OR
             ls_ekpo_old-loekz = zif_mfp_constants=>gc_lock_type-deleted ). " Old Status is Blocked or Deleted

            READ TABLE gs_contract_deep-contractlis INTO DATA(ls_ctr_item) WITH KEY linenumber = lineassignments-linenumber.
            IF ls_ctr_item-status = zif_mfp_constants=>gc_lock_type-blocked OR
           ls_ctr_item-status = zif_mfp_constants=>gc_lock_type-deleted. " New status is blocked or deleted

              ls_bapi_account-delete_ind = abap_true.
              ls_bapi_accountx-delete_ind = abap_true.

            ENDIF.

          ELSE.

            ls_bapi_account-delete_ind = abap_true.
            ls_bapi_accountx-delete_ind = abap_true.

          ENDIF.


        ENDIF. " Avoid BAPI error for unchanged lines with blocked cost object

        ls_bapi_account-item_no = lineassignments-linenumber.
        ls_bapi_account-serial_no = lineassignments-assignment_item.
        ls_bapi_account-net_value = lineassignments-amount.
        ls_bapi_account-distr_perc = lineassignments-vproz.

        IF ls_bapi_account-wbs_element = '00000000'.
          CLEAR ls_bapi_account-wbs_element.
        ENDIF.

        READ TABLE gs_contract_deep-contractlis INTO DATA(ls_odata_oaitem) WITH KEY linenumber = lineassignments-linenumber.
        IF sy-subrc IS INITIAL.

          IF ls_odata_oaitem-esp IS NOT INITIAL.

            CALL METHOD me->map_odata_2_bapi
              EXPORTING
                is_sending_structure   = ls_odata_oaitem
                is_sending_x_structure = abap_false
              IMPORTING
                es_data                = ls_ci_cobl
                es_data_x              = ls_ci_cobl.  "Not needed

            ls_ci_cobl-serial_no = ls_bapi_account-serial_no.

            ls_extension-structure = zif_mfp_constants=>gc_cobl-oa.
            ls_extension+30 = ls_ci_cobl.  "Causes a warning in the syntax check
            APPEND ls_extension TO gt_extension.

            ls_ci_coblx-preq_item = ls_ci_cobl-preq_item.
            ls_ci_coblx-serial_no = ls_ci_cobl-serial_no.
            ls_ci_coblx-zzesp = abap_true.

            ls_extension-structure = zif_mfp_constants=>gc_cobl-oax.
            ls_extension+30 = ls_ci_coblx.  "Causes a warning in the syntax check
            APPEND ls_extension TO gt_extension.
          ENDIF.
        ENDIF.

*        APPEND ls_bapi_account TO gt_oaaccounts.

        LOOP AT r_descr->components INTO wa_comp.
          ASSIGN COMPONENT wa_comp-name OF STRUCTURE ls_bapi_account TO FIELD-SYMBOL(<fs_value>).
          IF sy-subrc = 0 AND <fs_value> IS NOT INITIAL.
            ASSIGN COMPONENT wa_comp-name OF STRUCTURE ls_bapi_accountx TO <fs_value>.
            <fs_value> = abap_true.
          ENDIF.
        ENDLOOP.

        LOOP AT r_descr->components INTO wa_comp WHERE name = 'WBS_ELEMENT'.
          ASSIGN COMPONENT wa_comp-name OF STRUCTURE ls_bapi_account TO <fs_value>.
          IF sy-subrc = 0 AND <fs_value> = '00000000'.
            CLEAR <fs_value>.
            ASSIGN COMPONENT wa_comp-name OF STRUCTURE ls_bapi_accountx TO <fs_value>.
            <fs_value> = abap_false.
          ENDIF.

        ENDLOOP.

        ls_bapi_accountx-item_no    = ls_bapi_account-item_no.
        ls_bapi_accountx-item_nox   = abap_true.
        ls_bapi_accountx-serial_no  = ls_bapi_account-serial_no.
        ls_bapi_accountx-serial_nox = abap_true.

* Clear Cost centre for account assignment Project and
* clear WBS for account assignment Cost centre
        IF ls_odata_oaitem-acctasscat = 'P'.
          CLEAR ls_bapi_account-costcenter.
          ls_bapi_accountx-costcenter = abap_true.
        ENDIF.
        IF ls_odata_oaitem-acctasscat = 'K'.
          CLEAR ls_bapi_account-wbs_element.
          ls_bapi_accountx-wbs_element = abap_true.
        ENDIF.
        APPEND ls_bapi_account TO gt_oaaccounts.
        APPEND ls_bapi_accountx TO gt_oaaccountsx.

        CLEAR: ls_bapi_account, lv_inactive.
      ENDLOOP.
    ENDIF.

    READ TABLE gt_oaaccounts TRANSPORTING NO FIELDS WITH KEY delete_ind = abap_true.
    IF sy-subrc IS INITIAL. gv_locked_costobject = abap_true. ENDIF.

  ENDMETHOD.


  METHOD zif_myfi_document~in_header.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_DOCUMENT_L4L~zif_myfi_document~in_header
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for MyFi Documents
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
* 30.11.20 220977FKC RD2K920449 DS-11-32-07-01 6000002172: MyFi Purchasing (Release 2.3)
*                                              Enable legacy i.e. non-myfi created docs
* 04.08.21 210983DY RD2K921440  DS-11-32-07-01 S6000002451: MyFi Purchasing (August Release)
*                                              Enable Your reference field in MyFi Purchasing
* 20.10.2022 210983DY RD2K923161
*                     RD2K923261  6000002831: MyFi Continuous Improvement November Release
*               Amended logic to fix issue with CLOSE document, Update Document value
*               to appropriate value while CLOSING the document
*-----------------------------------------------------------------------

    DATA: lv_nettotal     TYPE wrbtr,
          lv_totalval     TYPE val_iv_for,
*          lv_nettotal_string TYPE string,
          lv_nettotal_val TYPE bapicurr_d,
          lv_total_val    TYPE bapicurr_d,
          lv_subtotal     TYPE wrbtr.

    CALL METHOD me->map_odata_2_bapi
      EXPORTING
        is_sending_structure   = gs_contract_deep
        is_sending_x_structure = abap_true
      IMPORTING
        es_data                = gs_oaheader
        es_data_x              = gs_oaheaderx.

    IF me->zif_myfi_document~gv_useraction EQ zif_mfp_constants=>gc_action-odata-create OR gs_contract_deep-isdraft EQ abap_true.
      gs_oaheader-item_intvl = 00001.
      gs_oaheaderx-item_intvl = abap_true.
      gs_oaheader-doc_type = 'WK'.
      gs_oaheaderx-doc_type = abap_true.
      gs_oaheader-creat_date = sy-datum.
      gs_oaheaderx-creat_date = abap_true.
      gs_oaheader-created_by = sy-uname.
      gs_oaheaderx-created_by = abap_true.
      gs_oaheader-our_ref = '00000000001'.
      gs_oaheaderx-our_ref = abap_true.
      CALL METHOD zcl_mfp_utilities=>get_porg_from_ccode
        EXPORTING
          bukrs = gs_oaheader-comp_code
        RECEIVING
          ekorg = gs_oaheader-purch_org.
      gs_oaheaderx-purch_org = abap_true.
    ELSE.
      gs_oaheader-our_ref = get_ref_number( iv_ebeln = gs_oaheader-number ).
      gs_oaheaderx-our_ref = abap_true.
    ENDIF.

* For Close Action, get the revised document value
    IF me->zif_myfi_document~gv_useraction EQ zif_mfp_constants=>gc_action-odata-po_close AND NOT gs_oaheader-acum_value = '0.01'.
      CLEAR: lv_total_val, lv_nettotal, lv_subtotal, lv_nettotal_val, lv_total_val, lv_totalval.
      LOOP AT gs_contract_deep-contractlis INTO DATA(ls_odata_oaitem) WHERE final_inv = abap_true AND deliv_compl = abap_true.

        lv_nettotal = ( ls_odata_oaitem-price_unit * ls_odata_oaitem-target_qty ).
        lv_nettotal_val = ( ls_odata_oaitem-price_unit * ls_odata_oaitem-target_qty ).

        zcl_mfp_utilities=>calculate_tax(
              EXPORTING
                iv_bukrs = gs_oaheader-comp_code      " Company Code
                iv_mwskz = ls_odata_oaitem-tax_code   " Sales Tax Code
                iv_wrbtr = lv_nettotal                " Amount in document currency
                iv_koart = 'M'                        " Account Type
              RECEIVING
                rv_wmwst = lv_subtotal ).             " Amount in document currency

        lv_totalval = lv_totalval + lv_subtotal + lv_nettotal.
        lv_total_val = lv_total_val + lv_subtotal + lv_nettotal_val.

      ENDLOOP.


      IF lv_total_val = '0.00'.
        gs_contract_deep-acum_value =  gs_oaheader-acum_value = '0.01'.
      ELSE.
        gs_contract_deep-acum_value = gs_oaheader-acum_value = lv_total_val.
      ENDIF.
      gs_oaheaderx-acum_value = abap_true.

    ENDIF.

    gs_oaheader-ref_1 = gs_contract_deep-ihrez.
    gs_oaheaderx-ref_1 = abap_true.
  ENDMETHOD.


  METHOD zif_myfi_document~in_line_items.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_DOCUMENT_L4L~ZIF_MYFI_DOCUMENT~IN_LINE_ITEMS
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for MyFi Documents
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
* 21/09/20 290977SCN RD2K919977 DS-11-32-07-01 S 6000002096: MyFi Purchasing (Release 2.2)
* 21.10.20 290977SCN RD2K919656 DS-11-32-07-01 S 6000002172: MyFi Purchasing (Release 2.3)
* 30/11/20 210983DY  RD2K919656 DS-11-32-07-01 S 6000002172: MyFi Purchasing (Release 2.3)
*                                            Additional code for Item Texts
* 14/01/21 210983DY  RD2K920558 DS-11-32-07-01 S 6000002251: MyFi Purchasing (Release 2.3 Defect Fixes)
*                               Additional code to fix Line Item Texts with line break
* 04.08.21 210983DY RD2K921440  DS-11-32-07-01 S6000002451: MyFi Purchasing (August Release)
*26.08.21 210983DY RD2K921634 DS-11-32-07-01 S 6000002507: MyFi Continuous Improvement
* 05/11/21 210983DY  RD2K922034 DS-11-32-07-01 S6000002550: MyFi Applications (December Release)
*                    Additional code to enable Multi Account Assignment
*15/12/21  210983DY RD2K922296 DS-11-32-07-01 S6000002623: MyFi Applications (February Release)
* 20.10.2022 210983DY RD2K923161  6000002831: MyFi Continuous Improvement November Release
*                        Amended logic to fix UoM issue
* 11.09.2023 210983DY RD2K924301,RD2K924353   6000002999 MyFi Continuous Improvement October Release
*          Additional logic to fix update of Plant for Legacy documents
*-----------------------------------------------------------------------
    DATA: ls_bapi_oaitem     TYPE bapimeoutitem,
          ls_bapi_oaitemx    TYPE bapimeoutitemx,
          ls_bapi_oaaccount  TYPE bapimeoutaccount,
          ls_bapi_oaaccountx TYPE bapimeoutaccountx,
          ls_ci_cobl         TYPE bapi_te_mereqaccounting,
          ls_ci_coblx        TYPE bapi_te_mereqaccountingx,
          ls_extension       TYPE bapiparex.

    LOOP AT gs_contract_deep-contractlis INTO DATA(ls_odata_oaitem).
      CLEAR: ls_bapi_oaitem,ls_bapi_oaitemx,ls_bapi_oaaccount,ls_bapi_oaaccountx. "lt_bapi_oatext.
      CALL METHOD me->map_odata_2_bapi
        EXPORTING
          is_sending_structure   = ls_odata_oaitem
          is_sending_x_structure = abap_true
        IMPORTING
          es_data                = ls_bapi_oaitem
          es_data_x              = ls_bapi_oaitemx.

*      * Partial Invoice mapping
      ls_bapi_oaitem-part_inv = ls_odata_oaitem-part_inv.
      ls_bapi_oaitemx-part_inv = abap_true.

* Distribution Indicator
      IF ls_odata_oaitem-distrib = '0'.
        CLEAR: ls_odata_oaitem-distrib.
        ls_bapi_oaitemx-gr_non_val = abap_true.
      ELSE.
        ls_bapi_oaitem-distrib = ls_odata_oaitem-distrib.
        ls_bapi_oaitemx-distrib = abap_true.
        ls_bapi_oaitem-gr_non_val = abap_true.
        ls_bapi_oaitemx-gr_non_val = abap_true.
      ENDIF.

      ls_bapi_oaitem-agreement      = gs_oaheader-agreement.
      ls_bapi_oaitemx-agreement     = abap_true.
* Get the value of plant from existing document
      DATA(lv_old_plant) = VALUE #( gt_old_oaitems[ item_no = ls_bapi_oaitem-item_no ]-plant OPTIONAL ).
      DATA(ls_item_old) = VALUE #( gt_old_oaitems[ item_no = ls_bapi_oaitem-item_no ] OPTIONAL ).

*      DATA(lv_old_plant) = VALUE #( gt_oaitems[ item_no = ls_bapi_oaitem-item_no ]-plant OPTIONAL ).
* Get plant value from company code
      SELECT SINGLE bwkey
               INTO @DATA(lv_plant)
               FROM t001k
              WHERE bukrs = @gs_oaheader-comp_code.
* Pass Plant value from Company code, for creation of new documents
* and retain existing value for all other actions
      IF zif_myfi_document~gv_useraction EQ zif_mfp_constants=>gc_action-odata-create OR
         ls_item_old-item_no IS INITIAL.
        ls_bapi_oaitem-plant = lv_plant.
        ls_bapi_oaitemx-plant         = abap_true.
      ELSE.
        IF lv_old_plant IS INITIAL.
          ls_bapi_oaitemx-plant         = abap_false.
        ELSE.
          ls_bapi_oaitem-plant = lv_old_plant.
          ls_bapi_oaitemx-plant = abap_true.
        ENDIF.
      ENDIF.

      ls_bapi_oaitemx-item_no       = ls_bapi_oaitem-item_no.
      ls_bapi_oaitemx-item_nox      = abap_true.
*      IF gv_draft_indicator EQ abap_true.
      ls_bapi_oaitem-price_date = '99991231'. "sy-datum.
      ls_bapi_oaitemx-price_date = abap_true.
*      ENDIF.

      SELECT SINGLE msehi FROM  t006a
       WHERE  spras  = 'E'
       AND    mseh3  = @ls_odata_oaitem-po_unit
       INTO @ls_bapi_oaitem-orderpr_un.
      ls_bapi_oaitem-po_unit = ls_bapi_oaitem-orderpr_un.
      ls_bapi_oaitem-orderpr_un = ls_bapi_oaitem-orderpr_un.
*     CIR549 - Update UOM
*      SELECT SINGLE ebelp FROM ekpo INTO @DATA(lv_ebelp) WHERE ebeln = @me->gs_oaheader-number AND ebelp = @ls_bapi_oaitem-item_no.
*
*      IF sy-subrc EQ 0.
*        CLEAR ls_bapi_oaitemx-po_unit.
*      ENDIF.

* Tracking Number
*      IF NOT ls_odata_oaitem-trackingno IS INITIAL.
      ls_bapi_oaitem-trackingno = ls_odata_oaitem-trackingno.
      ls_bapi_oaitemx-trackingno = abap_true.
*      ENDIF.
* Vendor Material
*      IF NOT ls_odata_oaitem-vendormaterial IS INITIAL.
      ls_bapi_oaitem-vend_mat = ls_odata_oaitem-vendormaterial.
      ls_bapi_oaitemx-vend_mat = abap_true.
*      ENDIF.

* Zero value indicator
      IF ls_odata_oaitem-zerovalue = abap_true.
        CLEAR: ls_bapi_oaitem-gr_non_val, ls_bapi_oaitemx-gr_non_val.
        ls_bapi_oaitem-net_price = '0.00'.
        ls_bapi_oaitem-gr_ind = abap_false.
        ls_bapi_oaitemx-gr_ind = abap_true.

        ls_bapi_oaitem-ir_ind = abap_false.
        ls_bapi_oaitemx-ir_ind = abap_true.
        ls_bapi_oaitem-gr_basediv = abap_false.
        ls_bapi_oaitemx-gr_basediv = abap_true.
        ls_bapi_oaitemx-gr_non_val = abap_true.


      ENDIF.

* Turn off GR Indicator Flag and GR Based Invoice flag for Prepayment Line
      IF ls_odata_oaitem-isprepayment = abap_true.
        CLEAR: ls_bapi_oaitem-gr_non_val, ls_bapi_oaitemx-gr_non_val.
        ls_bapi_oaitem-gr_ind = abap_false.
        ls_bapi_oaitemx-gr_ind = abap_true.
        ls_bapi_oaitem-gr_basediv = abap_false.
        ls_bapi_oaitemx-gr_basediv = abap_true.
        ls_bapi_oaitemx-gr_non_val = abap_true.
      ENDIF.

      CALL METHOD me->create_item_condition
        EXPORTING
          is_bapi_lineitem = ls_bapi_oaitem
          iv_currency      = ls_odata_oaitem-currency.


      APPEND ls_bapi_oaitem  TO gt_oaitems.
      APPEND ls_bapi_oaitemx TO gt_oaitemsx.

*      CALL METHOD me->map_odata_2_bapi
*        EXPORTING
*          is_sending_structure   = ls_odata_oaitem
*          is_sending_x_structure = abap_true
*        IMPORTING
*          es_data                = ls_bapi_oaaccount
*          es_data_x              = ls_bapi_oaaccountx.

*      IF ls_bapi_oaitem-delete_ind = zif_mfp_constants=>gc_lock_type-blocked OR
*         ls_bapi_oaitem-delete_ind = zif_mfp_constants=>gc_lock_type-deleted.
*        ls_bapi_oaaccount-delete_ind = zif_mfp_constants=>gc_lock_type-blocked.
*        ls_bapi_oaaccountx-delete_ind = abap_true.
*
*      ENDIF.

*      ls_bapi_oaaccount-serial_no = '01'.
*      ls_bapi_oaaccountx-serial_nox = abap_true.
*      APPEND ls_bapi_oaaccount TO gt_oaaccounts.

*      ls_bapi_oaaccountx-item_no    = ls_bapi_oaaccount-item_no.
*      ls_bapi_oaaccountx-item_nox   = abap_true.
*      ls_bapi_oaaccountx-serial_no  = ls_bapi_oaaccount-serial_no.
*      ls_bapi_oaaccountx-serial_nox = abap_true.
*      APPEND ls_bapi_oaaccountx TO gt_oaaccountsx.

* ESP
      IF ls_odata_oaitem-esp IS NOT INITIAL.

        CALL METHOD me->map_odata_2_bapi
          EXPORTING
            is_sending_structure   = ls_odata_oaitem
            is_sending_x_structure = abap_false
          IMPORTING
            es_data                = ls_ci_cobl
            es_data_x              = ls_ci_cobl.  "Not needed

        ls_ci_cobl-serial_no = ls_bapi_oaaccount-serial_no.

        ls_extension-structure = zif_mfp_constants=>gc_cobl-oa.
        ls_extension+30 = ls_ci_cobl.  "Causes a warning in the syntax check
        APPEND ls_extension TO gt_extension.

        ls_ci_coblx-preq_item = ls_ci_cobl-preq_item.
        ls_ci_coblx-serial_no = ls_ci_cobl-serial_no.
        ls_ci_coblx-zzesp = abap_true.

        ls_extension-structure = zif_mfp_constants=>gc_cobl-oax.
        ls_extension+30 = ls_ci_coblx.  "Causes a warning in the syntax check
        APPEND ls_extension TO gt_extension.
      ENDIF.

*      IF NOT ls_odata_oaitem-itemtxt IS INITIAL.

      DATA(lv_itemtext) = convert_mm_table_str_item( EXPORTING it_texts  = gt_old_oaitemtext iv_item = ls_bapi_oaitem-item_no
                                                              iv_tdid   = zif_mfp_constants=>gc_header_text-oa-item-text ).

      IF NOT lv_itemtext = ls_odata_oaitem-itemtext .

        CALL METHOD me->convert_string_mm_item_table
          EXPORTING
            iv_item   = ls_bapi_oaitem-item_no
            iv_string = ls_odata_oaitem-itemtext
            iv_tdid   = zif_mfp_constants=>gc_header_text-oa-item-text
          CHANGING
            rt_texts  = gt_oaitemtext.

      ENDIF.
*      ENDIF.

*      IF NOT ls_odata_oaitem-inforecordpotext IS INITIAL.

      DATA(lv_inforecordpotext) = convert_mm_table_str_item( EXPORTING it_texts  = gt_old_oaitemtext iv_item = ls_bapi_oaitem-item_no
                                                              iv_tdid   = zif_mfp_constants=>gc_header_text-oa-item-info_record ).

      IF NOT lv_inforecordpotext = ls_odata_oaitem-inforecordpotext.

        CALL METHOD me->convert_string_mm_item_table
          EXPORTING
            iv_item   = ls_bapi_oaitem-item_no
            iv_string = ls_odata_oaitem-inforecordpotext
            iv_tdid   = zif_mfp_constants=>gc_header_text-oa-item-info_record
          CHANGING
            rt_texts  = gt_oaitemtext.

      ENDIF.
*      ENDIF.
*      IF NOT ls_odata_oaitem-materialpotext IS INITIAL.

      DATA(lv_materialpotext) = convert_mm_table_str_item( EXPORTING it_texts  = gt_old_oaitemtext iv_item = ls_bapi_oaitem-item_no
                                                                      iv_tdid   = zif_mfp_constants=>gc_header_text-oa-item-mat_po ).
      IF NOT lv_materialpotext = ls_odata_oaitem-materialpotext.

        CALL METHOD me->convert_string_mm_item_table
          EXPORTING
            iv_item   = ls_bapi_oaitem-item_no
            iv_string = ls_odata_oaitem-materialpotext
            iv_tdid   = zif_mfp_constants=>gc_header_text-oa-item-mat_po
          CHANGING
            rt_texts  = gt_oaitemtext.

      ENDIF.
*      ENDIF.

*      IF NOT ls_odata_oaitem-inforecordnote IS INITIAL.

      DATA(lv_inforecordnote) = convert_mm_table_str_item( EXPORTING it_texts  = gt_old_oaitemtext iv_item = ls_bapi_oaitem-item_no
                                                             iv_tdid   = zif_mfp_constants=>gc_header_text-oa-item-info_note ).
      IF NOT lv_inforecordnote = ls_odata_oaitem-inforecordnote.

        CALL METHOD me->convert_string_mm_item_table
          EXPORTING
            iv_item   = ls_bapi_oaitem-item_no
            iv_string = ls_odata_oaitem-inforecordnote
            iv_tdid   = zif_mfp_constants=>gc_header_text-oa-item-info_note
          CHANGING
            rt_texts  = gt_oaitemtext.
      ENDIF.
*      ENDIF.



      in_prepmnt_line(
        EXPORTING
          is_odata_oaitem = ls_odata_oaitem                  " Purchase Order Item
          iv_oa_item      = ls_bapi_oaitem-item_no                 " Item Number of Purchasing Document
      ).


    ENDLOOP.



  ENDMETHOD.


  METHOD zif_myfi_document~in_strings.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_DOCUMENT_L4L~zif_myfi_document~in_strings
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for MyFi Documents
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
* 30/11/20 210983DY  RD2K919656 DS-11-32-07-01 S 6000002172: MyFi Purchasing (Release 2.3)
*                                            Additional code for Item Texts and Header texts
* 03/03/21 210983DY  RD2K920554 DS-11-32-07-01 S 6000002250: MyFi Purchasing (Release 2.4 )
*                               Additional logic to handle Multi delivery address
*-----------------------------------------------------------------------
    DATA: ls_string_entry TYPE ztmfp_strings,
          lv_alternatetc  TYPE string,
          lt_strings      TYPE TABLE OF ztmfp_strings.

    ls_string_entry-zmfp_doc_id = me->zif_myfi_document~posting_doc_num.

*******  JSON ********
    me->gs_contract_deep-contractnumber = me->zif_myfi_document~posting_doc_num.
    me->gs_contract_deep-statusdesclong =  me->gs_contract_deep-statusdesc = zcl_mfp_utilities=>get_status_desc( iv_status = me->zif_myfi_document~new_doc_header-status ).
    ls_string_entry-string_data         = /ui2/cl_json=>serialize( data = me->gs_contract_deep compress = abap_true pretty_name = /ui2/cl_json=>pretty_mode-camel_case ).
    ls_string_entry-string_type         = zif_mfp_constants=>gc_string_type-json.
    APPEND ls_string_entry TO lt_strings.

*******  header texts    *********
    ls_string_entry-string_data = me->gs_contract_deep-romancomment.
    ls_string_entry-string_type = zif_mfp_constants=>gc_string_type-header-text.
    APPEND ls_string_entry TO lt_strings.

    ls_string_entry-string_data = me->gs_contract_deep-headertexts-headernote.
    ls_string_entry-string_type = zif_mfp_constants=>gc_string_type-header-note.
    APPEND ls_string_entry TO lt_strings.

    ls_string_entry-string_data = me->gs_contract_deep-headertexts-contractriders.
    ls_string_entry-string_type = zif_mfp_constants=>gc_string_type-header-riders.
    APPEND ls_string_entry TO lt_strings.

    IF me->gs_contract_deep-headertexts-alternatetc = abap_true.
      lv_alternatetc = '.'.
    ELSE.
      lv_alternatetc = ''.
    ENDIF.

    CALL METHOD me->convert_string_mm_table
      EXPORTING
        iv_string = lv_alternatetc
        iv_tdid   = zif_mfp_constants=>gc_header_text-oa-alt_tc_cond
      CHANGING
        rt_texts  = gt_oatextheader.

    CALL METHOD me->convert_string_mm_table
      EXPORTING
        iv_string = me->gs_contract_deep-romancomment
        iv_tdid   = zif_mfp_constants=>gc_header_text-oa-header
      CHANGING
        rt_texts  = gt_oatextheader.

    CALL METHOD me->convert_string_mm_table
      EXPORTING
        iv_string = me->gs_contract_deep-headertexts-headernote
        iv_tdid   = zif_mfp_constants=>gc_header_text-oa-note
      CHANGING
        rt_texts  = gt_oatextheader.

    CALL METHOD me->convert_string_mm_table
      EXPORTING
        iv_string = me->gs_contract_deep-headertexts-contractriders
        iv_tdid   = zif_mfp_constants=>gc_header_text-oa-riders
      CHANGING
        rt_texts  = gt_oatextheader.

* Special Delivery Instructions - store in Header Delivery text
    CALL METHOD me->convert_string_mm_table
      EXPORTING
        iv_string = me->gs_contract_deep-contactdetails-specialinstructions
        iv_tdid   = zif_mfp_constants=>gc_header_text-oa-delivery
      CHANGING
        rt_texts  = gt_oatextheader.

* delivery address
    IF me->gs_contract_deep-contactdetails-specialinstructions IS NOT INITIAL.
      ls_string_entry-string_data = me->gs_contract_deep-contactdetails-specialinstructions.
      ls_string_entry-string_type =   zif_mfp_constants=>gc_string_type-spec_instr.
      APPEND ls_string_entry TO lt_strings.
    ENDIF.

* Admin Details
    IF me->gs_contract_deep-admindetails-etp_justification IS NOT INITIAL.
      ls_string_entry-string_data = me->gs_contract_deep-admindetails-etp_justification.
      ls_string_entry-string_type =   zif_mfp_constants=>gc_string_type-etp_justif.
      APPEND ls_string_entry TO lt_strings.
    ENDIF.

    IF me->gs_contract_deep-admindetails-indig_no_approach_rsn IS NOT INITIAL.
      ls_string_entry-string_data = me->gs_contract_deep-admindetails-indig_no_approach_rsn.
      ls_string_entry-string_type =   zif_mfp_constants=>gc_string_type-indig_no_appr.
      APPEND ls_string_entry TO lt_strings.
    ENDIF.

* Approval Details
    IF me->gs_contract_deep-approvaldetails-commentforapprover IS NOT INITIAL.
      ls_string_entry-string_data = me->gs_contract_deep-approvaldetails-commentforapprover.
      ls_string_entry-string_type =   zif_mfp_constants=>gc_string_type-comment_approver.
      APPEND ls_string_entry TO lt_strings.
    ENDIF.

    IF me->gs_contract_deep-approvaldetails-valueformoney IS NOT INITIAL.
      ls_string_entry-string_data = me->gs_contract_deep-approvaldetails-valueformoney.
      ls_string_entry-string_type =   zif_mfp_constants=>gc_string_type-value_for_money.
      APPEND ls_string_entry TO lt_strings.
    ENDIF.

* SON ID - store in Header Alternate T&Cs Agreement Number text
    CALL METHOD me->convert_string_mm_table
      EXPORTING
        iv_string = me->gs_contract_deep-sonid
        iv_tdid   = zif_mfp_constants=>gc_header_text-oa-sonid
      CHANGING
        rt_texts  = gt_oatextheader.



    me->zif_myfi_document~new_strings = lt_strings.

  ENDMETHOD.


