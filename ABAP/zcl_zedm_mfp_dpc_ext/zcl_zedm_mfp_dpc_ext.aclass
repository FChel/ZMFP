class ZCL_ZEDM_MFP_DPC_EXT definition
  public
  inheriting from ZCL_ZEDM_MFP_DPC
  create public .

public section.

  types:
    gr_nonasa_company TYPE RANGE OF ekko-bukrs .
  types:
    BEGIN OF ty_contract_deep.
        INCLUDE TYPE zcl_zedm_mfp_mpc=>ts_contract.
      TYPES:
        admindetails             TYPE zcl_zedm_mfp_mpc=>ts_admindetails,
        approvaldetails          TYPE zcl_zedm_mfp_mpc=>ts_approvaldetails,
        attachments              TYPE STANDARD TABLE OF zcl_zedm_mfp_mpc=>ts_attachment WITH DEFAULT KEY,
        consumptiongrs           TYPE STANDARD TABLE OF zcl_zedm_mfp_mpc=>ts_consumptiongr WITH DEFAULT KEY,
        consumptionirs           TYPE STANDARD TABLE OF zcl_zedm_mfp_mpc=>ts_consumptionir WITH DEFAULT KEY,
        consumptionsummary       TYPE zcl_zedm_mfp_mpc=>ts_consumptionsummary,
        contactdetails           TYPE zcl_zedm_mfp_mpc=>ts_contactdetails,
        contractlis              TYPE STANDARD TABLE OF zcl_zedm_mfp_mpc=>ts_lineitem WITH DEFAULT KEY,
        deliveryaddresses        TYPE STANDARD TABLE OF zcl_zedm_mfp_mpc=>ts_deliveryaddress WITH DEFAULT KEY,
*        deliveryaddresses        TYPE zcl_zedm_mfp_mpc=>ts_deliveryaddress,
        headertexts              TYPE zcl_zedm_mfp_mpc=>ts_headertexts,
        indigenoussubcontractors TYPE STANDARD TABLE OF zcl_zedm_mfp_mpc=>ts_indigenoussubcontractor WITH DEFAULT KEY,
        phasings                 TYPE STANDARD TABLE OF zcl_zedm_mfp_mpc=>ts_phasing WITH DEFAULT KEY,
        accountassignments       TYPE STANDARD TABLE OF zcl_zedm_mfp_mpc=>ts_accountassignment WITH DEFAULT KEY,
        purchaseorders           TYPE STANDARD TABLE OF zcl_zedm_mfp_mpc=>ts_purchaseorder WITH DEFAULT KEY,
        approvalhistory          TYPE ztmfp_approvals,
      END OF ty_contract_deep .
  types:
    BEGIN OF ty_po_deep.
        INCLUDE TYPE zcl_zedm_mfp_mpc=>ts_purchaseorder.
      TYPES:
        approvaldetails    TYPE zcl_zedm_mfp_mpc=>ts_approvaldetails,
        attachments        TYPE STANDARD TABLE OF zcl_zedm_mfp_mpc=>ts_attachment WITH DEFAULT KEY,
        consumptiongrs     TYPE STANDARD TABLE OF zcl_zedm_mfp_mpc=>ts_consumptiongr WITH DEFAULT KEY,
        consumptionirs     TYPE STANDARD TABLE OF zcl_zedm_mfp_mpc=>ts_consumptionir WITH DEFAULT KEY,
        consumptionsummary TYPE zcl_zedm_mfp_mpc=>ts_consumptionsummary,
        contactdetails     TYPE zcl_zedm_mfp_mpc=>ts_contactdetails,
        purchaseorderlis   TYPE STANDARD TABLE OF zcl_zedm_mfp_mpc=>ts_lineitem WITH DEFAULT KEY,
        deliveryaddresslis TYPE STANDARD TABLE OF zcl_zedm_mfp_mpc=>ts_deliveryaddress WITH DEFAULT KEY,
        deliveryaddresses  TYPE  STANDARD TABLE OF zcl_zedm_mfp_mpc=>ts_deliveryaddress WITH DEFAULT KEY,
        headertexts        TYPE zcl_zedm_mfp_mpc=>ts_headertexts,
        phasings           TYPE STANDARD TABLE OF zcl_zedm_mfp_mpc=>ts_phasing WITH DEFAULT KEY,
        accountassignments TYPE STANDARD TABLE OF zcl_zedm_mfp_mpc=>ts_accountassignment WITH DEFAULT KEY,
        changelog          TYPE ztmfp_changelog,
        approvalhistory    TYPE ztmfp_approvals,
      END OF ty_po_deep .
  types GS_NAV_PROP type STRING .

  data GO_DOCUMENT_PO type ref to ZCL_MFP_DOCUMENT_PO .
  data GO_DOCUMENT_CONTRACT type ref to ZCL_MFP_DOCUMENT_CONTRACT .
  data GO_DOCUMENT_L4L type ref to ZCL_MFP_DOCUMENT_L4L .
  constants GC_CONTRACTS_ENTITYSET type /IWBEP/MGW_TECH_NAME value 'Contracts' ##NO_TEXT.
  constants GC_PO_ENTITYSET type /IWBEP/MGW_TECH_NAME value 'PurchaseOrders' ##NO_TEXT.
  constants:
    BEGIN OF gc_action,
        save_draft     TYPE zmfp_action VALUE '00' ##NO_TEXT,
        delete_draft   TYPE zmfp_action VALUE '00' ##NO_TEXT,
        reassign_draft TYPE zmfp_action VALUE '20' ##NO_TEXT,
        validate       TYPE zmfp_action VALUE '30' ##NO_TEXT,
        submit         TYPE zmfp_action VALUE '40' ##NO_TEXT,
      END OF gc_action .
  constants:
    BEGIN OF gc_process,
        po  TYPE char1 VALUE 'P' ##NO_TEXT,
        oa  TYPE char1 VALUE 'C' ##NO_TEXT,
        l4l TYPE char1 VALUE 'L' ##NO_TEXT,
      END OF gc_process .
  constants GC_SAP_OBJECT type TOAOM-SAP_OBJECT value 'BUS2014' ##NO_TEXT.
  constants GC_AR_OBJECT type TOAOM-AR_OBJECT value 'ZSSP_OA' ##NO_TEXT.
  data GV_PROCESS_TYPE type CHAR1 .

  methods GET_ENTITY_PROPERTIES
    importing
      !IV_ENTITY_NAME type ANY
    returning
      value(RT_PROPERTIES) type /IWBEP/IF_MGW_ODATA_RE_PROP=>TY_T_MGW_ODATA_PROPERTIES .
  methods ODATA_2_ABAP
    importing
      !IT_MAPPING_TABLE type /IWBEP/IF_MGW_ODATA_RE_PROP=>TY_T_MGW_ODATA_PROPERTIES
      !ODATA type ANY
    exporting
      value(RS_ABAP) type ANY .
  methods ABAP_2_ODATA
    importing
      !IT_MAPPING_TABLE type /IWBEP/IF_MGW_ODATA_RE_PROP=>TY_T_MGW_ODATA_PROPERTIES
      !ABAP type ANY
    exporting
      value(RS_ODATA) type ANY .
  methods HANDLE_ODATA_FILTER
    importing
      !IT_FILTER_OPTIONS type /IWBEP/T_MGW_SELECT_OPTION
    exporting
      !ET_SELECTION_CRITERIA type RSPARAMS_TT .
  methods GET_MM_ENTITY_SET
    importing
      !IT_FILTER_SELECT_OPTIONS type /IWBEP/T_MGW_SELECT_OPTION
      !IT_KEY_TAB type /IWBEP/T_MGW_NAME_VALUE_PAIR
      !IV_ENTITY_NAME type STRING
    exporting
      !ET_ENTITYSET type ANY TABLE .
  methods GET_DRAFT_DOCS
    importing
      !IT_DOC_HEADER type ANY TABLE
    exporting
      !ET_DRAFT_DOCS type ANY TABLE .
  class-methods GET_NONASA_COMPNAYCODE
    returning
      value(ER_COMPANY) type GR_NONASA_COMPANY .

  methods /IWBEP/IF_MGW_APPL_SRV_RUNTIME~CREATE_DEEP_ENTITY
    redefinition .
  methods /IWBEP/IF_MGW_APPL_SRV_RUNTIME~CREATE_STREAM
    redefinition .
  methods /IWBEP/IF_MGW_APPL_SRV_RUNTIME~DELETE_STREAM
    redefinition .
