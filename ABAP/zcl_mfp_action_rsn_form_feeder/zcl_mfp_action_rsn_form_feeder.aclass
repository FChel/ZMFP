      all methods final .

  constants C_STRUCTURE type TABNAME value 'ZSMFP_ACTION_REASON_FORM' ##NO_TEXT.
  constants:
    BEGIN OF e_field,
              BEGIN OF action_reason,
                  name TYPE fpmgb_s_formfield_descr-name VALUE 'ACTION_REASON' ##no_text,
                  label_text TYPE fpmgb_s_formfield_descr-label_text VALUE 'Reason' ##no_text,
              END OF action_reason,
            END OF e_field .
  constants:
    BEGIN OF e_action,
                BEGIN OF cancel,
                  id TYPE fpmgb_s_actiondef-id VALUE 'CANCEL' ##no_text,
                  text TYPE fpmgb_s_actiondef-text VALUE 'Cancel' ##no_text,
                  enabled TYPE fpmgb_s_actiondef-enabled VALUE abap_true ##no_text,
                  visible TYPE fpmgb_s_actiondef-visible VALUE cl_wd_uielement=>e_visible-visible ##no_text,
                END OF cancel,
                BEGIN OF submit,
                  id TYPE fpmgb_s_actiondef-id VALUE 'SUBMIT' ##no_text,
                  text TYPE fpmgb_s_actiondef-text VALUE 'Submit' ##no_text,
                  enabled TYPE fpmgb_s_actiondef-enabled VALUE abap_true ##no_text,
                  visible TYPE fpmgb_s_actiondef-visible VALUE cl_wd_uielement=>e_visible-visible ##no_text,
                END OF submit,
              END OF e_action .
  constants:
    BEGIN OF e_event,
            BEGIN OF fpm_open_dialog,
              id TYPE fpm_event_id VALUE 'FPM_OPEN_DIALOG' ##no_text,
              BEGIN OF parameters,
                BEGIN OF mfp_action,
                  key TYPE string VALUE 'MFP_ACTION' ##no_text,
                END OF mfp_action,
              END OF parameters,
            END OF fpm_open_dialog,
          END OF e_event .

  class-methods REPORT_SY_MESSAGE
    importing
      !API type ref to IF_WD_CONTROLLER .
protected section.
