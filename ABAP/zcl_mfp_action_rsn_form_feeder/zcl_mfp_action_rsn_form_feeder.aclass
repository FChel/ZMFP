METHOD IF_FPM_GUIBB_FORM~GET_DATA ##needed.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_ACTION_RSN_FORM_FEEDER~IF_FPM_GUIBB_FORM~GET_DATA
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for the MyFi Admin POWL
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
* 29.10.20 290977SCN RD2K919656 DS-11-32-07-01 S 6000002172: MyFi Purchasing (Release 2.3)
*-----------------------------------------------------------------------
  DATA: ls_data TYPE zsmfp_action_reason_form.
  DATA: l_dummy TYPE string ##needed.

  IF io_event IS NOT BOUND.
    RETURN.
  ENDIF.
  CASE io_event->mv_event_id.
    WHEN cl_fpm_event=>gc_event_open_dialog_box.
      CLEAR ls_data.
      io_event->mo_event_data->get_value(
        EXPORTING
          iv_key = e_event-fpm_open_dialog-parameters-mfp_action-key
        IMPORTING
          ev_value = ls_data
      ).
      CLEAR ls_data-action_reason.
      cs_data = ls_data.
      ev_data_changed = abap_true.
    WHEN e_action-submit-id.
      ls_data = cs_data.
      IF ls_data-action_reason IS INITIAL.
        MESSAGE e201(zmfp) WITH e_field-action_reason-label_text INTO l_dummy.
        add_sy_message( CHANGING messages = et_messages ).
        RETURN.
      ELSE.
        handle_reject( EXPORTING data = cs_data CHANGING messages = et_messages ).
      ENDIF.
    WHEN e_action-cancel-id.
      close_dialog( ).
      RETURN. "nothing to do...
    WHEN OTHERS.
      IF iv_raised_by_own_ui = abap_true.
        ASSERT 0 = 1. "event not configured?
      ELSE.
        RETURN. "nothing to do...
      ENDIF.
  ENDCASE.
ENDMETHOD.


METHOD IF_FPM_GUIBB_FORM~GET_DEFAULT_CONFIG ##needed.
ENDMETHOD.


METHOD IF_FPM_GUIBB_FORM~GET_DEFINITION.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_ACTION_RSN_FORM_FEEDER~IF_FPM_GUIBB_FORM~GET_DEFINITION
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for the MyFi Admin POWL
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
*-----------------------------------------------------------------------
  DATA: ls_field_description TYPE fpmgb_s_formfield_descr.
  DATA: ls_action_definition TYPE fpmgb_s_actiondef.

  DEFINE add_action. "<action>
    clear ls_action_definition.
    ls_action_definition-id = &1-id.
    ls_action_definition-text = &1-text.
    ls_action_definition-enabled = &1-enabled.
    ls_action_definition-visible = &1-visible.
    append ls_action_definition to et_action_definition.
  END-OF-DEFINITION.
  DEFINE add_field. "<field>
    clear ls_field_description.
    ls_field_description-name = &1-name.
    ls_field_description-label_text = &1-label_text.
    append ls_field_description to et_field_description.
  END-OF-DEFINITION.

  eo_field_catalog ?= cl_abap_structdescr=>describe_by_name( c_structure ).

  add_field e_field-action_reason.

  add_action e_action-cancel.
  add_action e_action-submit.
ENDMETHOD.


