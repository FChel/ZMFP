class ZCL_MFP_OA definition
  public
  create public .

public section.

  interfaces BI_OBJECT .
  interfaces BI_PERSISTENT .
  interfaces IF_WORKFLOW .

  constants C_CLASSNAME type SEOCLSNAME value 'ZCL_MFP_OA' ##NO_TEXT.
  data APPROVER_COMMENTS type CHAR80_T .
  data BUS2014 type SIBFLPORB value ZCL_WF_BOR_TYPES=>BUS2014 ##NO_TEXT.
  data GS_ZTMFP_DOC_HEADER type ZTMFP_DOC_HEADER .
  data GV_AMT type DEC_16_02_S .
  data GV_APRAPP_URL type STRING .
  data GV_DEADLINE type DATUM .
  data GV_EBELN type EBELN read-only .
  data GV_IDM_URL type STRING .
  data GV_SSP_URL type STRING .
  data HEADER_COMMENTS type CHAR80_T .
  data LPOR type SIBFLPOR .
  data VENDOR_NAME type NAME1 .
  data VENDOR_NUM type LIFNR .

  events SUBMIT
    exporting
      value(RECIPIENT) type SWHACTOR
      value(REASON) type STRING optional .
  events DRAFT .
  events REJECT
    exporting
      value(REASON) type STRING .
  events FORWARD
    exporting
      value(RECIPIENT) type SWHACTOR
      value(REASON) type STRING optional .
  events CHANGE
    exporting
      value(RECIPIENT) type SWHACTOR
      value(REASON) type STRING optional .
  events RECALL .
  events DRAFT_SUBMITTED .
  events DRAFT_DELETED .
  events APPROVED .

  methods CONSTRUCTOR
    importing
      value(IV_EBELN) type EBELN
    raising
      CX_BO_FIND_ERROR .
  class-methods CREATE_EVENT
    importing
      !IV_REASON type STRING optional
      !IV_RECIPIENT type SWHACTOR optional
      !IV_EBELN type EBELN
      !IV_EVENT type SWO_EVENT
      !IV_COMMIT type BOOLE_D optional
    exporting
      !EV_EVENT_RAISED type BOOLE_D .
  class-methods CREATE_INSTANCE
    importing
      !IV_EBELN type EBELN
    returning
      value(EO_MFP_DOC) type ref to ZCL_MFP_OA .
  class-methods UPDATE_MYFI_STATUS
    importing
      !IV_EBELN type EBELN
      !IV_ACTION type ZMFP_ACTION
      !IV_MYFI_DOC_TYPE type ZMFP_CATEGORY optional
      !IV_OLD_STATUS type ZMFP_STATUS optional
    exporting
      !EV_NEW_STATUS type ZMFP_STATUS
    raising
      CX_BO_TEMPORARY .
  methods CALCULATE_DEADLINE_DATE .
  methods DUMMY .
  class-methods POST_L4L_PO
    importing
      !IV_OA_EBELN type EBELN
      !IV_REQUESTOR type UNAME
    exporting
      !ET_RETURN type BAPIRET2_T
      !EV_PO_EBELN type EBELN .
  class-methods DELETE_DRAFT
    importing
      !IV_EBELN type EBELN
    exporting
      !EV_SUCCESS_FLAG type BOOLE_D .
  methods CHECK_APPR_AUTH
    importing
      !IV_USERID type UNAME
    exporting
      !EV_AUTHORISED type BOOLE_D .
  class-methods CREATE_PO_PDF_EVENT
    importing
      !IV_EBELN type EBELN
      !IV_RECIPIENT type SWHACTOR
    raising
      CX_BO_FIND_ERROR .
  class-methods L4L_R1_RELEASE
    importing
      !IV_EBELN type EBELN
      !IV_RELEASE_STEP type FRGCO optional
    exporting
      !ET_RETURN type BAPIRET2_T
    raising
      resumable(CX_BO_TEMPORARY) .
  class-methods GET_USER_DETAILS
    importing
      !IV_USERID type ACTORID
    exporting
      !EV_NAME type AD_NAMTEXT
      !EV_TITLE type AD_TITLETX
      !EV_EMAIL type AD_SMTPADR .
  class-methods RELEASE_PO
    importing
      !IV_EBELN type EBELN .
  class-methods COMPLETE_RECALL_WORKITEM
    importing
      !IV_EBELN type EBELN
    returning
      value(EV_SUCCESS) type BOOLE_D .
  class-methods CHECK_AWAITING_ASSET
    importing
      !IV_EBELN type EBELN
    exporting
      !EV_AWAITING_ASSET_CONF type BOOLE_D .
  class-methods GET_PO_DETAILS
    importing
      !IV_EBELN type EBELN
    exporting
      !EV_PO type ref to ZCL_MFP_PO .
  methods CHECK_ASSET_CHANGED
    importing
      !IV_DOCUMENT type EBELN
    exporting
      !EV_ASSET_CHANGED type BOOLE_D
      !EV_ASSET_EMAIL type AD_SMTPADR
      !EV_ASSET_DELETED type BOOLE_D .
protected section.
private section.

  constants:
    BEGIN OF e_lpor,
        catid  TYPE sibflpor-catid VALUE 'CL',
        typeid TYPE sibflpor-typeid VALUE c_classname,
      END OF e_lpor .
ENDCLASS.



CLASS ZCL_MFP_OA IMPLEMENTATION.


  method BI_OBJECT~DEFAULT_ATTRIBUTE_VALUE ##needed.
  endmethod.


  method BI_OBJECT~EXECUTE_DEFAULT_METHOD ##needed.
  endmethod.


  method BI_OBJECT~RELEASE ##needed.
  endmethod.


  METHOD bi_persistent~find_by_lpor.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_OA~bi_persistent~find_by_lpor
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for OA Workflows for MyFi
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
*-----------------------------------------------------------------------
    DATA: lv_ebeln  TYPE ebeln.

    lv_ebeln = lpor-instid.

    IF lpor-catid = e_lpor-catid AND lpor-typeid = e_lpor-typeid.
      TRY.
          CREATE OBJECT result TYPE zcl_mfp_oa
            EXPORTING
              iv_ebeln = lv_ebeln.
        CATCH cx_bo_find_error.
      ENDTRY.
    ELSE.
      CLEAR result.
    ENDIF.


  ENDMETHOD.


  method BI_PERSISTENT~LPOR.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_OA~BI_PERSISTENT~LPOR
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for OA Workflows for MyFi
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
