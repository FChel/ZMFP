  METHOD get_user_details.
*----------------------------------------------------------------------*
* METHOD ID:          GET_USER_DETAILS
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2.2).
*                     This method is used to get a users details.
*
* AUTHOR:             Stephen Ning (290977SCN)
* CREATE DATE:        21.09.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000002096 - MyFi Purchasing Release 2.2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 21/09/20 290977SCN RD2K919977 DS-11-32-07-01 S 6000002096: MyFi Purchasing (Release 2.2)
*-----------------------------------------------------------------------
    DATA: lv_userid TYPE sysid.

    lv_userid = iv_userid.

    SELECT SINGLE a~vorna, a~nachn, a~titel, c~usrid_long FROM pa0002 AS a
                                           INNER JOIN pa0105 AS b ON a~pernr EQ b~pernr
                                      LEFT OUTER JOIN pa0105 AS c ON a~pernr EQ c~pernr
      INTO @DATA(ls_details)
      WHERE a~begda LE @sy-datum AND
            a~endda GE @sy-datum AND
            b~usrid EQ @lv_userid AND
            b~subty EQ '0001' AND
            b~begda LE @sy-datum AND
            b~endda GE @sy-datum AND
            c~pernr EQ b~pernr AND
            c~subty EQ '0010' AND
            c~begda LE @sy-datum AND
            c~endda GE @sy-datum.

    IF ls_details IS NOT INITIAL.

      ev_name = ls_details-vorna && | | && ls_details-nachn.
      ev_title = ls_details-titel.
      ev_email = ls_details-usrid_long.
    ELSE.
      SELECT SINGLE a~bname, a~name_first, a~name_last, a~name_text, e~title_medi, d~smtp_addr FROM user_addrs AS a
            INNER JOIN user_addr_idad3 AS b ON a~bname EQ b~bname
            LEFT OUTER JOIN adr6 AS d ON b~addrnumber EQ d~addrnumber AND b~persnumber EQ d~persnumber
            LEFT OUTER JOIN tsad3t  AS e ON b~title_p EQ e~title AND e~langu EQ 'E'
            INTO @DATA(ls_user)
            WHERE a~bname EQ @iv_userid .
      ev_name = ls_user-name_text.
      ev_title = ls_user-title_medi.
      ev_email = ls_user-smtp_addr.
    ENDIF.


  ENDMETHOD.


  METHOD l4l_r1_release.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_OA~l4l_r1_release
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for the release of L4L POs
*
* AUTHOR:             Stephen Ning (290977SCN)
* CREATE DATE:        20.07.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001987 - MyFi Purchasing Release 2.1
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 20.07.20 290977SCN RD2K919533 DS-11-32-07-01 Created
* 07.09.20 290977SCN RD2K919977 DS-11-32-07-01 Changed - Check that linked OA is released.
* 21/09/20 290977SCN RD2K919977 DS-11-32-07-01 S 6000002096: MyFi Purchasing (Release 2.2)
* 12/10/20 290977SCN RD2K920230 DS-11-32-07-01 S 6000002096: MyFi Purchasing (Release 2.2)
*-----------------------------------------------------------------------
    DATA: lt_return      TYPE TABLE OF bapireturn,
          ls_return      TYPE bapiret2,
          lt_return2     TYPE bapiret2_t,
          lv_rel_ind_new TYPE frgke,
          lv_ret_code    TYPE sy-subrc.

    IF zcl_mfp_utilities=>is_myfi( iv_doc_num = iv_ebeln ) EQ abap_true AND
        zcl_mfp_utilities=>is_l4l( iv_ebeln = iv_ebeln ) EQ abap_true.

      WAIT UP TO 5 SECONDS.

      SELECT SINGLE ref_id FROM ztmfp_doc_header INTO @DATA(lv_oa_ebeln) WHERE zmfp_doc_id EQ @iv_ebeln.
      SELECT SINGLE status FROM ztmfp_doc_header INTO @DATA(lv_oa_status) WHERE zmfp_doc_id EQ @lv_oa_ebeln.
      SELECT SINGLE frgke  FROM ekko INTO @DATA(lv_po_frgke) WHERE ebeln EQ @iv_ebeln.
      IF lv_oa_status EQ zif_mfp_constants=>gc_doc_status-approved AND ( lv_po_frgke EQ zif_mfp_constants=>gc_mm_doc_status-new OR
                                                                         lv_po_frgke EQ zif_mfp_constants=>gc_mm_doc_status-req_del_appr ).

        CALL FUNCTION 'BAPI_PO_RELEASE'
          EXPORTING
            purchaseorder     = iv_ebeln
            po_rel_code       = 'R1'
            use_exceptions    = abap_false
            no_commit         = abap_false
          IMPORTING
*           REL_STATUS_NEW    =
            rel_indicator_new = lv_rel_ind_new
            ret_code          = lv_ret_code
          TABLES
            return            = lt_return.
        IF lv_ret_code EQ 0.
          ls_return-type = 'S'.
          ls_return-id   = 'ZMFP'.
          ls_return-number = '164'.
          ls_return-message_v1 = iv_ebeln.
          ls_return-message_v2 = lv_po_frgke.
          ls_return-message_v3 = lv_rel_ind_new.
          ls_return-message_v4 = lv_ret_code.
          MESSAGE s164(zmfp) WITH iv_ebeln lv_po_frgke lv_rel_ind_new lv_ret_code INTO ls_return-message.
          APPEND ls_return TO et_return.
        ELSE.
          MOVE-CORRESPONDING lt_return TO et_return.
        ENDIF.

        zcl_mfp_utilities=>log_myfi_bapi(
         EXPORTING
         iv_doc_number = iv_ebeln                 " Purchasing Document Number
         iv_action     = zif_mfp_constants=>gc_log-sub_obj-bapi-po_release                " Application Log: Subobject
         iv_user_id    = sy-uname                 " User Name
         it_return     = et_return                 " Return table
     ).

      ENDIF.
    ENDIF.

    zcl_mfp_utilities=>align_status( iv_ebeln = iv_ebeln ).
  ENDMETHOD.


  METHOD post_l4l_po.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_OA~post_l4l_po
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for OA Workflows for MyFi
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
*-----------------------------------------------------------------------
    DATA: lo_document_l4l TYPE REF TO zcl_mfp_document_l4l.

    SELECT SINGLE * FROM ztmfp_doc_header
      INTO @DATA(ls_docheader)
      WHERE zmfp_doc_id EQ @iv_oa_ebeln.

    SELECT SINGLE ebeln FROM ekko
      INTO @DATA(lv_ekko_po)
      WHERE ebeln = @ls_docheader-ref_id.

    IF sy-subrc = 0.
      CREATE OBJECT lo_document_l4l
        EXPORTING
          iv_ebeln         = iv_oa_ebeln
          iv_action        = zif_mfp_constants=>gc_action-odata-change_l4l_po
          iv_l4l_requestor = iv_requestor.
    ELSE.
      CREATE OBJECT lo_document_l4l
        EXPORTING
          iv_ebeln         = iv_oa_ebeln
          iv_action        = zif_mfp_constants=>gc_action-odata-create_l4l_po
          iv_l4l_requestor = iv_requestor.
    ENDIF.


    ev_po_ebeln = lo_document_l4l->go_l4l_po->zif_myfi_document~posting_doc_num.

  ENDMETHOD.


  METHOD RELEASE_PO.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_OA~RELEASE_PO
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used to release purchasing document
*
* AUTHOR:             Dathri Yellamarthy (210983DY)
* CREATE DATE:        27.Nov.2021
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000002550 - MyFi Applications (December Release)
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------

* 29.11.21 210983DY RD2K922223 DS-11-32-07-01 S 6000002550: MyFi Applications (December Release)
*-----------------------------------------------------------------------
    DATA: l_ret_code TYPE sy-subrc,
          lt_return  TYPE TABLE OF bapiret2,
          ls_return  LIKE LINE OF lt_return.

    CALL FUNCTION 'BAPI_PO_RELEASE'
      EXPORTING
        purchaseorder          = iv_ebeln
        po_rel_code            = 'R1'
        use_exceptions         = ' '
        no_commit              = ' '
      IMPORTING
        ret_code               = l_ret_code
      TABLES
        return                 = lt_return
      EXCEPTIONS
        authority_check_fail   = 1
        document_not_found     = 2
        enqueue_fail           = 3
        prerequisite_fail      = 4
        release_already_posted = 5
        responsibility_fail    = 6
        OTHERS                 = 7.
    IF sy-subrc IS INITIAL.
      CALL FUNCTION 'BAPI_TRANSACTION_COMMIT'
        EXPORTING
          wait   = 'X'
        IMPORTING
          return = ls_return.
      IF sy-subrc = 0.

      ELSE.
        RAISE EXCEPTION TYPE /iwbep/cx_mgw_busi_exception
          EXPORTING
            message = ls_return-message.
      ENDIF.
    ELSE.
      READ TABLE lt_return INTO ls_return INDEX 1.
      RAISE EXCEPTION TYPE /iwbep/cx_mgw_busi_exception
        EXPORTING
          message = ls_return-message.
    ENDIF.

  ENDMETHOD.


  method update_myfi_status.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_OA~update_myfi_status
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for OA Workflows for MyFi
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
* 19.06.20 290977SCN RD2K919517 DS-11-32-07-01 S 6000001863: MyFi
*          070667JPS                           Purchasing Release 2_ECC
*                                              DEFECTS II.  Corrected
*                                              logging of status message.
* 22.07.20 290977SCN RD2K919533 DS-11-32-07-01 Updated importing parameters for decide_new_status
* 21/09/20 290977SCN RD2K919977 DS-11-32-07-01 S 6000002096: MyFi Purchasing (Release 2.2)
* 13/10/20 290977SCN RD2K920238 DS-11-32-07-01 S 6000002096: MyFi Purchasing (Release 2.2)
* 30.11.20 220977FKC RD2K920449 DS-11-32-07-01 6000002172: MyFi Purchasing (Release 2.3)
*                                              Enable legacy i.e. non-myfi created docs
*-----------------------------------------------------------------------
    data: lv_old_status       type zmfp_status,
          lv_mm_status        type frgke,
          lv_doc_type         type zmfp_category,
          ls_new_doc_header   type ztmfp_doc_header,
          lv_change_indicator type cdchngindh value 'U',
          lt_header_old       type yztmfp_doc_headers,
          lt_header_new       type yztmfp_doc_headers,
          ls_header_old       type yztmfp_doc_header,
          ls_header_new       type yztmfp_doc_header,
          lv_user             type uname,
          objectid            type cdhdr-objectid,
          lv_message          type char50.

    lv_user = sy-uname.
    lv_doc_type = iv_myfi_doc_type.
    lv_old_status = iv_old_status.

    select single frgke from ekko
                       where ebeln = @iv_ebeln
                        into @lv_mm_status.

    select single * from ztmfp_doc_header
                        where zmfp_doc_id = @iv_ebeln
                         into @data(ls_old_doc_header).
    check sy-subrc = 0.
    if iv_old_status    is initial. lv_old_status = ls_old_doc_header-status. endif.
    if iv_myfi_doc_type is initial. lv_doc_type = ls_old_doc_header-category. endif.

    ls_new_doc_header = ls_old_doc_header.

    ev_new_status = zcl_mfp_document=>decide_new_status(
      exporting
        iv_action        = iv_action
        iv_myfi_doc_type = lv_doc_type
        iv_old_status    = lv_old_status
        iv_mm_status     = lv_mm_status
        iv_ebeln         = iv_ebeln ).

    check ev_new_status is not initial.
    ls_new_doc_header-status = ev_new_status.

* Update User with selected delegate from table ztmfp_doc_header
    if ev_new_status eq zif_mfp_constants=>gc_doc_status-approved.
      lv_user = ls_old_doc_header-selected_delegate.
      ls_new_doc_header-released_on = sy-datum.
      ls_new_doc_header-released_at = sy-uzeit.
    endif.

    if ls_new_doc_header ne ls_old_doc_header.
      ls_new_doc_header-changed_on = sy-datum.
      ls_new_doc_header-changed_at = sy-uzeit.
      "clear ls_new_doc_header-changed_in_gui.
      update ztmfp_doc_header from ls_new_doc_header.
      commit work and wait.

      move-corresponding ls_old_doc_header to ls_header_old.
      move-corresponding ls_new_doc_header to ls_header_new.

      append ls_header_old to lt_header_old.
      append ls_header_new to lt_header_new.
      objectid = iv_ebeln.
      call function 'ZMFP_CHANGELOG_WRITE_DOCUMENT'
        exporting
          objectid                = objectid
          tcode                   = zif_mfp_constants=>gc_tcode
          utime                   = sy-uzeit
          udate                   = sy-datum
          username                = lv_user
          object_change_indicator = lv_change_indicator
          upd_ztmfp_doc_header    = lv_change_indicator
        tables
          xztmfp_doc_header       = lt_header_new
          yztmfp_doc_header       = lt_header_old.
    endif.
    if ev_new_status eq zif_mfp_constants=>gc_doc_status-approved.
      select single status from ztmfp_doc_header
                           into @data(lv_status)
                          where zmfp_doc_id eq @iv_ebeln and
                                     status eq @zif_mfp_constants=>gc_doc_status-approved.
      if sy-subrc eq 0.
        call method zcl_mfp_oa=>create_event
          exporting
            iv_ebeln  = iv_ebeln
            iv_event  = zif_mfp_constants=>gc_event-approved
            iv_commit = abap_false.
      else.
        raise exception type cx_bo_temporary.
      endif.
    endif.
  endmethod.
ENDCLASS.