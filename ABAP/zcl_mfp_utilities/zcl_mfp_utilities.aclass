ENDCLASS.



CLASS ZCL_MFP_UTILITIES IMPLEMENTATION.


  METHOD add_user_objects.
*----------------------------------------------------------------------*
* METHOD ID:          ADD_USER_OBJECTS
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method adds documents to a user's object list.
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        09.06.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 09.06.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
* 06/07/22 210983DY  RD2K922923 DS-11-32-07-01 S6000002777:MyFi Continuous Improvement
*                                              August Release
*-----------------------------------------------------------------------
    DATA: lo_myfi_objects TYPE REF TO cl_myobjects_model,
          ls_user_ebeln   TYPE zif_mfp_constants=>ty_s_user_ebeln,
          lt_objects      TYPE sgo_t_tre,
          lt_ebeln        TYPE RANGE OF ekko-ebeln,
          lt_objects_new  TYPE sgo_t_tre,
          ls_object       TYPE smyotrees,
          lv_user         TYPE uname,
          ls_doc          TYPE zif_mfp_constants=>ty_s_objtyp_ebeln.
    CLEAR ls_object.
    IF iv_user IS INITIAL.
      lv_user = sy-uname.
    ELSE.
      lv_user = iv_user.
    ENDIF.
    CREATE OBJECT lo_myfi_objects EXPORTING im_uname = lv_user.

    lt_ebeln = VALUE #( FOR ls_ebeln IN it_docs ( sign = 'I' option = 'EQ' low = ls_ebeln-ebeln ) ).

*    Get Objects
    SELECT *
            FROM smyotree
            INTO TABLE lt_objects
              WHERE user_name = lv_user
              AND   folder    = iv_folder
              AND   objkey   IN lt_ebeln.

    DELETE lt_objects WHERE folder NE zif_mfp_constants=>gc_object_folder AND
                                     folder NE zif_mfp_constants=>gc_object_folder_drafts.

    LOOP AT it_docs INTO ls_doc.

      READ TABLE lt_objects WITH KEY objkey = ls_doc-ebeln folder = iv_folder TRANSPORTING NO FIELDS.
      IF sy-subrc <> 0.
        TRY.
            ls_object-guid = cl_system_uuid=>create_uuid_c32_static( ).
          CATCH cx_uuid_error .
            RAISE EXCEPTION TYPE cx_fatal_exception.
        ENDTRY.
        ls_object-mandt = sy-mandt.
        ls_object-objkey = ls_doc-ebeln.
        ls_object-text = |{ zif_mfp_constants=>gc_app_title }-{ ls_doc-ebeln } | .
        ls_object-user_name = iv_user.
        ls_object-objtype = ls_doc-objtyp.
        ls_object-logsys = |LOG{ sy-sysid }{ sy-mandt }| .
        CONVERT DATE sy-datum TIME sy-uzeit INTO TIME STAMP ls_object-timestamp TIME ZONE sy-zonlo.
        ls_object-folder = iv_folder.
        APPEND ls_object TO lt_objects_new.
      ELSE.
*        DELETE lt_objects WHERE objkey = ls_doc-ebeln AND objtype = ls_doc-objtyp.
      ENDIF.
    ENDLOOP.

    IF NOT lt_objects_new IS INITIAL.
      lo_myfi_objects->if_myobjects_model~update_objects( it_mod_obj = lt_objects_new ).
    ENDIF.


  ENDMETHOD.


  METHOD align_status.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_PO~UPDATE_MYFI_STATUS
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for PO Workflows for MyFi
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          S 6000002096: MyFi Purchasing (Release 2.2)
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 12.10.20 290977SCN RD2K920230 DS-11-32-07-01 Created
*-----------------------------------------------------------------------

    DATA: ls_doc_header       TYPE ztmfp_doc_header,
          ls_old_doc_header   TYPE ztmfp_doc_header,
          lv_change_indicator TYPE cdchngindh VALUE 'U',
          lt_header_old       TYPE yztmfp_doc_headers,
          lt_header_new       TYPE yztmfp_doc_headers,
          ls_header_old       TYPE yztmfp_doc_header,
          ls_header_new       TYPE yztmfp_doc_header,
          lv_user             TYPE uname,
          objectid            TYPE cdhdr-objectid,
          lv_message          TYPE char50.

    SELECT SINGLE a~ebeln, a~frgke, b~status FROM ekko AS a
       INNER JOIN ztmfp_doc_header AS b ON b~zmfp_doc_id EQ a~ebeln
             INTO @DATA(ls_data)
            WHERE a~ebeln EQ @iv_ebeln.
    SELECT SINGLE * FROM ztmfp_doc_header INTO @ls_doc_header WHERE zmfp_doc_id EQ @iv_ebeln.
    ls_old_doc_header = ls_doc_header.

    IF   (  ls_data-status EQ zif_mfp_constants=>gc_mm_doc_status-oa_released
         OR ls_data-status EQ zif_mfp_constants=>gc_mm_doc_status-po_released )
      AND ls_data-status NE zif_mfp_constants=>gc_doc_status-approved.
      ls_doc_header-status = zif_mfp_constants=>gc_doc_status-approved.
    ENDIF.

*    IF ( ls_data-status EQ zif_mfp_constants=>gc_mm_doc_status-new
*         or ls_data-status EQ zif_mfp_constants=>gc_mm_doc_status-req_prf_comp )
*      AND ls_data-status NE zif_mfp_constants=>gc_doc_status-awaiting_prf.
*      ls_doc_header-status = zif_mfp_constants=>gc_doc_status-awaiting_prf.
*    ENDIF.
*
*    IF ls_data-status EQ zif_mfp_constants=>gc_mm_doc_status-req_del_appr
*      AND ls_data-status NE zif_mfp_constants=>gc_doc_status-awaiting_approval.
*      ls_doc_header-status = zif_mfp_constants=>gc_doc_status-awaiting_approval.
*    ENDIF.

    IF ls_doc_header NE ls_old_doc_header.

      UPDATE ztmfp_doc_header FROM ls_doc_header.
      COMMIT WORK AND WAIT.
      IF sy-subrc EQ 0.
        SELECT SINGLE * FROM ztmfp_doc_header
                  INTO @DATA(ls_updated_header)
                 WHERE zmfp_doc_id EQ @ls_doc_header-zmfp_doc_id.

        MOVE-CORRESPONDING ls_old_doc_header TO ls_header_old.
        MOVE-CORRESPONDING ls_updated_header TO ls_header_new.

        APPEND ls_header_old TO lt_header_old.
        APPEND ls_header_new TO lt_header_new.
        objectid = iv_ebeln.
        CALL FUNCTION 'ZMFP_CHANGELOG_WRITE_DOCUMENT'
          EXPORTING
            objectid                = objectid
            tcode                   = zif_mfp_constants=>gc_tcode
            utime                   = sy-uzeit
            udate                   = sy-datum
            username                = lv_user
            object_change_indicator = lv_change_indicator
            upd_ztmfp_doc_header    = lv_change_indicator
          TABLES
            xztmfp_doc_header       = lt_header_new
            yztmfp_doc_header       = lt_header_old.
      ENDIF.
    ENDIF.

  ENDMETHOD.


  METHOD append_message.

*-----------------------------------------------------------------------------------------
* DESCRIPTION:  Utility method appends string (i_append) to message string (i_message)
* NOTES:
*
* AUTHOR:       Fred Chelashaw
* CREATE DATE:  10.11.2020
*
* ACTIVITY:     AD-11-32-07 - Self Service Purchasing App
* DEV SCRIPT:   DS-11-32-07-01 - MyFi Purchasing (Self Service Purchasing) App
*-----------------------------------------------------------------------------------------
* VERSION CONTROL:
*
* Date       Author    CTS Req    SCR        Description
* ---------- --------- ---------- ---------- ---------------------------------------------
* 10.11.2020 220977FKC RD2K919656 6000002172 MyFi Purchasing (Release 2.3)
*-----------------------------------------------------------------------------------------


    IF i_message IS NOT INITIAL.
      i_message = i_message && |\n\r |.
    ENDIF.

    r_message = i_message && i_append.

  ENDMETHOD.


  method archivlink_get_metadata.
*----------------------------------------------------------------------*
* METHOD ID:          ARCHIVLINK_GET_METADATA
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method retrieves archivelink metadata for
*                     attachments.
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        09.06.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 09.06.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
*-----------------------------------------------------------------------
    data:
      ls_return  type bapiret2.

    data:
      lv_root type ref to cx_root.

    try.
        call function 'ARCHIV_METAINFO_GET'
          exporting
            active_flag           = abap_true
            ar_object             = IV_AR_OBJECT
            sap_object            = IV_SAP_OBJECT
          tables
            toaom_fkt             = et_toaom
          exceptions
            error_connectiontable = 1
            error_parameter       = 2
            others                = 3.

* Need proper error handling in MFP class
*        if sy-subrc ne 0.
*          ls_return-type = 'E'.
*          ls_return-message = sy-msgv1.
*          add_message( msg = ls_return ).
*          clear ls_return.
*        endif.

      catch cx_root into lv_root.
        ls_return-type = 'E'.
        ls_return-message = lv_root->get_text( ).
*        add_message( msg = ls_return ).
        clear ls_return.
    endtry.
  endmethod.


  METHOD auth_check.
*----------------------------------------------------------------------*
* METHOD ID:          AUTH_CHECK
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method performs an authority check on the
*                     "S_SERVICE" object.
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        09.06.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 09.06.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
*-----------------------------------------------------------------------
    AUTHORITY-CHECK OBJECT 'S_SERVICE' FOR USER iv_userid
           ID 'SRV_NAME' FIELD iv_application
           ID 'SRV_TYPE' FIELD zif_mfp_constants=>gc_service_type-ht.

    IF sy-subrc EQ 0.
      rv_authorised = abap_true.
    ENDIF.
  ENDMETHOD.


