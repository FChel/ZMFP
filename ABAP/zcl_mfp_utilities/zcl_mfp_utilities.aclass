  METHOD BAPIMEPOACCT_2BAPIEKKN_2EKKN.
*----------------------------------------------------------------------*
* METHOD ID:          BAPIMEPOACCT_2BAPIEKKN_2EKKN
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method moves data from the BAPIMEPOACCT table
*                     to the BAPIEKKN_2EKKN table.
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        12.06.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 12.06.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
*-----------------------------------------------------------------------

    DATA: ls_bapimepoaccount TYPE bapimepoaccount,
          ls_bapiekkn        TYPE bapiekkn,
          ls_ekkn            TYPE ekkn.

    LOOP AT it_bapimepoacct INTO ls_bapimepoaccount.

      ls_bapimepoaccount-activity       = ls_bapiekkn-activity.
      ls_bapimepoaccount-asset_no       = ls_bapiekkn-asset_no         = ls_ekkn-anln1.
      ls_bapimepoaccount-bus_area       = ls_bapiekkn-bus_area         = ls_ekkn-gsber.
      ls_bapimepoaccount-cmmt_item      = ls_bapiekkn-cmmt_item        = ls_ekkn-fipos.
      ls_bapimepoaccount-cmmt_item_long = ls_bapiekkn-cmmt_item_long.
      ls_bapimepoaccount-co_area        = ls_bapiekkn-co_area          = ls_ekkn-kokrs.
      ls_bapimepoaccount-costcenter     = ls_bapiekkn-cost_ctr         = ls_ekkn-kostl.
      ls_bapimepoaccount-costobject     = ls_bapiekkn-cost_obj         = ls_ekkn-kstrg.
      ls_bapimepoaccount-distr_perc     = ls_bapiekkn-distr_perc       = ls_ekkn-vproz.
      ls_bapimepoaccount-func_area      = ls_bapiekkn-func_area.
      ls_bapimepoaccount-func_area_long = ls_bapiekkn-func_area_long   = ls_ekkn-fkber.
      ls_bapimepoaccount-fund           = ls_bapiekkn-fund             = ls_ekkn-geber.
      ls_bapimepoaccount-funds_ctr      = ls_bapiekkn-funds_ctr        = ls_ekkn-fistl.
      ls_bapimepoaccount-gl_account     = ls_bapiekkn-g_l_acct         = ls_ekkn-SAKTO.
      ls_bapimepoaccount-gr_rcpt        = ls_bapiekkn-gr_rcpt          = ls_ekkn-wempf.
      ls_bapimepoaccount-grant_nbr      = ls_bapiekkn-grant_nbr        = ls_ekkn-grant_nbr.
      ls_bapimepoaccount-itm_number     = ls_bapiekkn-sdoc_item        = ls_ekkn-vbelp.
      ls_bapimepoaccount-network        = ls_bapiekkn-network          = ls_ekkn-nplnr.
      ls_bapimepoaccount-orderid        = ls_bapiekkn-order_no         = ls_ekkn-aufnr.
      ls_bapimepoaccount-part_acct      = ls_bapiekkn-part_acct        = ls_ekkn-VPTNR.
      ls_bapimepoaccount-po_item        = ls_bapiekkn-po_item          = ls_ekkn-ebelp.
      ls_bapimepoaccount-profit_ctr     = ls_bapiekkn-profit_ctr       = ls_ekkn-prctr.
      ls_bapimepoaccount-quantity       = ls_bapiekkn-quantity         = ls_ekkn-menge.
      ls_bapimepoaccount-rec_ind        = ls_bapiekkn-rec_ind          = ls_ekkn-recid.
      ls_bapimepoaccount-ref_date       = ls_bapiekkn-ref_date         = ls_ekkn-dabrz.
      ls_bapimepoaccount-rl_est_key     = ls_bapiekkn-rl_est_key       = ls_ekkn-imkey.
      ls_bapimepoaccount-sched_line     = ls_bapiekkn-sched_line       = ls_ekkn-veten.
      ls_bapimepoaccount-sd_doc         = ls_bapiekkn-sd_doc           = ls_ekkn-vbeln.
      ls_bapimepoaccount-serial_no      = ls_bapiekkn-serial_no        = ls_ekkn-zekkn.
      ls_bapimepoaccount-sub_number     = ls_bapiekkn-sub_number       = ls_ekkn-anln2.
      ls_bapimepoaccount-unload_pt      = ls_bapiekkn-unload_pt        = ls_ekkn-ablad.
      ls_bapimepoaccount-wbs_element    = ls_bapiekkn-wbs_elem_e       = ls_ekkn-ps_psp_pnr.

      APPEND ls_bapiekkn TO et_bapiekkn.
      APPEND ls_ekkn      TO et_ekkn.
    ENDLOOP.
  ENDMETHOD.


  METHOD bapimepoitem_2bapiekpo_2ekpo.
*----------------------------------------------------------------------*
* METHOD ID:          BAPIMEPOITEM_2BAPIEKPO_2EKPO
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method moves data from the BAPIMEPOITEM table
*                     to the BAPIEKPO_2EKPO table.
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        12.06.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 12.06.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
*-----------------------------------------------------------------------

    DATA: ls_bapimepoitem TYPE bapimepoitem,
          ls_mepoitem     TYPE mepoitem,
          ls_ekpo         TYPE ekpo.

    LOOP AT it_bapimepoitem INTO ls_bapimepoitem.
      CALL FUNCTION 'MAP2I_BAPIITEM_TO_ITEM'
        EXPORTING
          bapimepoitem = ls_bapimepoitem
        CHANGING
          mepoitem     = ls_mepoitem
*      EXCEPTIONS
*         error_converting_iso_code = 1
*         others       = 2
        .
      IF sy-subrc <> 0.
*     MESSAGE ID sy-msgid TYPE sy-msgty NUMBER sy-msgno
*       WITH sy-msgv1 sy-msgv2 sy-msgv3 sy-msgv4.
      ENDIF.
      MOVE-CORRESPONDING ls_mepoitem TO ls_ekpo.
      APPEND ls_ekpo TO et_ekpo.
      APPEND ls_mepoitem TO et_bapiekpo.

    ENDLOOP.
  ENDMETHOD.


METHOD calculate_tax.
*----------------------------------------------------------------------*
* METHOD ID:          CALCULATE_TAX
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method calculates the tax for a net amount.
*                     It is a copy of class ZCL_INVOICE_SERVICES,
*                     method TAX_CALCULATION.  The comments for this
*                     method are still included below.
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        12.06.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 12.06.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
*-----------------------------------------------------------------------
*====================================================================*
* CLASS         : ZCL_INVOICE_SERVICES
* METHOD        : TAX_CALCULATION
* DESCRIPTION   : Calculate the Tax Amount for the given Tax Code
*
* LEVEL         : Instance Method
* VISIBILITY    : Public
*
* AUTHOR        : Michael Boulton
* COMPANY       : Department of Defence
* CREATED ON    : 15 July 2011
* R/3 RELEASE   : ECC6
* ACTIVITY      : AD-02-09-03
*====================================================================*
* VERSION CONTROL ECC6
* Date       Author    CTS Req    Dev Script  Description (most recent at the top)
*--------------------------------------------------------------------*
* 02.11.2011 8017884   RD2K906478 02-09-03-17 AR Customer Master
*                                             Maintenance and Invoice
*                                             - redevelopment.
* 19.10.2011 8017884   RD2K906427 02-09-03-17 AR Customer Master
*                                             Maintenance and Invoice
*                                             - redevelopment.
* 19.09.2011 8001721   RD2K906386 02-09-03-17 AR Customer Master
*                                             Maintenance and Invoice
*                                             - redevelopment.
* 15.08.2011 8001721   RD2K906350 02-09-03-17 AR Customer Master
*                                             Maintenance and Invoice
*                                             - redevelopment.
* 15.07.2011 8001721   RD2K906314 02-09-03-17 AR Customer Master
*                                             Maintenance and Invoice
*                                             - redevelopment.
*====================================================================*

*--------------------------------------------------------------------*
  DATA lv_bukrs          TYPE bukrs.
  DATA lv_waers          TYPE waers.
  DATA lv_mwskz          TYPE mwskz.
  DATA lv_wrbtr          TYPE wrbtr.
  DATA lv_koart          TYPE koart.
  DATA ls_taxcom         TYPE taxcom.
  DATA ls_komv           TYPE komv.
  DATA lt_komv           TYPE TABLE OF komv INITIAL SIZE 0.
  DATA lv_tax_amount     TYPE bapiwrbtr.
  DATA: lv_wrbtr_nonaud  TYPE bapiwrbtr.
  DATA lv_condition_type TYPE kschl.
*--------------------------------------------------------------------*
* Get local copy of Input parameters
*--------------------------------------------------------------------*
  lv_bukrs = iv_bukrs.
  lv_waers = iv_waers.
  lv_mwskz = iv_mwskz.
  lv_wrbtr = iv_wrbtr.
  lv_wrbtr_nonaud = iv_wrbtr_nonaud.
  lv_koart = iv_koart.
*--------------------------------------------------------------------*
* Clear local Change parameters
*--------------------------------------------------------------------*
  CLEAR lv_tax_amount.
  CLEAR lv_condition_type.
*--------------------------------------------------------------------*
* Clear working variables
*--------------------------------------------------------------------*
  CLEAR ls_komv.
  CLEAR ls_taxcom.
*--------------------------------------------------------------------*
  ls_taxcom-bukrs = lv_bukrs.
  ls_taxcom-budat = sy-datum.
  ls_taxcom-waers = lv_waers.
  ls_taxcom-hwaer = 'AUD'.
  ls_taxcom-xmwst = abap_true.  "Make it calculate the tax conditions
  ls_taxcom-kposn = 1.
  ls_taxcom-mwskz = lv_mwskz.
  ls_taxcom-txjcd = abap_false. "Tax Jurisdiction
  ls_taxcom-koart = lv_koart.

  IF iv_wrbtr < 0.
    ls_taxcom-shkzg = 'H'. "gc_credit.
    ls_taxcom-wrbtr = 0 - iv_wrbtr.
  ELSE.
    ls_taxcom-shkzg = 'S'. "gc_debit.
    ls_taxcom-wrbtr = lv_wrbtr.
  ENDIF.

  IF iv_wrbtr IS INITIAL.
    IF iv_wrbtr_nonaud < 0.
      ls_taxcom-shkzg = 'H'. "gc_credit.
      ls_taxcom-wrbtr = 0 - iv_wrbtr_nonaud.
    ELSE.
      ls_taxcom-shkzg = 'S'. "gc_debit.
      ls_taxcom-wrbtr = lv_wrbtr_nonaud.

    ENDIF.
  ENDIF.
  ls_taxcom-wmwst = 0.
  ls_taxcom-wskto = 0.
  ls_taxcom-skfbt = 0.
  ls_taxcom-zbd1p = 0.
*--------------------------------------------------------------------*
* Initialise Tax Amount
*--------------------------------------------------------------------*
  lv_tax_amount   = 0.
*--------------------------------------------------------------------*
* Initialise Condition Type
*--------------------------------------------------------------------*
  CLEAR lv_condition_type.
*--------------------------------------------------------------------*
* Only calculate Tax Amount if Sales Tax Code is not blank
*--------------------------------------------------------------------*
  IF NOT ls_taxcom-mwskz IS INITIAL.

    CALL FUNCTION 'CALCULATE_TAX_ITEM'
      EXPORTING
        inklusive = abap_false  "'X' (true) is Gross
        i_taxcom  = ls_taxcom
      IMPORTING
        e_taxcom  = ls_taxcom
      TABLES
        t_xkomv   = lt_komv
      EXCEPTIONS
        OTHERS    = 0.
*--------------------------------------------------------------------*
*   Create tax line item totals based on KOMV tax calc
*--------------------------------------------------------------------*
    LOOP AT lt_komv INTO ls_komv
      WHERE krech = 'A' "gc_percentage "Calculation type for condition
      AND   kposn = ls_taxcom-kposn.
*--------------------------------------------------------------------*
*     Get Tax Amount
*--------------------------------------------------------------------*
      lv_tax_amount = ls_komv-kwert.
*--------------------------------------------------------------------*
*     Get Condition Type
*--------------------------------------------------------------------*
      lv_condition_type = ls_komv-kschl.
    ENDLOOP.
  ENDIF.
*--------------------------------------------------------------------*
* Set Change parameters
*--------------------------------------------------------------------*
  rv_wmwst = lv_tax_amount.
*  cv_kschl = lv_condition_type.
*--------------------------------------------------------------------*
ENDMETHOD.


  method changed_in_gui.
*----------------------------------------------------------------------*
* METHOD ID:          CHANGED_IN_GUI
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method determines if an MFP document has been
*                     changed in the GUI and sets the CHANGE_IN_GUI flag
*                     if so.
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        12.06.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 12.06.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
* 30.11.20 220977FKC RD2K920449 DS-11-32-07-01 6000002172: MyFi Purchasing (Release 2.3)
*                                              Enable legacy i.e. non-myfi created docs
*-----------------------------------------------------------------------
    data:
      lv_objid            type cdhdr-objectid,
      lt_header_old       type yztmfp_doc_headers,
      lt_header_new       type yztmfp_doc_headers,
      lv_change_indicator type cdchngindh value 'U',
      ls_doc_header_new   type ztmfp_doc_header,
      lt_doc_header_new   type table of ztmfp_doc_header.

    select single *
      from ztmfp_doc_header
     where zmfp_doc_id = @iv_ebeln
      into @data(ls_doc_header_old).

    if sy-subrc eq 0.
      append ls_doc_header_old to lt_header_old.
      ls_doc_header_new = ls_doc_header_old.
      ls_doc_header_new-changed_in_gui = abap_true.
      ls_doc_header_new-changed_on = sy-datum.
      ls_doc_header_new-changed_at = sy-uzeit.
      if ls_doc_header_old-category eq zif_mfp_constants=>gc_myfi_doc_type-l4l_oa.
        ls_doc_header_new-category = zif_mfp_constants=>gc_myfi_doc_type-myfi_oa.
        ls_doc_header_new-was_l4l = abap_true.
      endif.
      if ls_doc_header_old-category eq zif_mfp_constants=>gc_myfi_doc_type-l4l_po.
        ls_doc_header_new-category = zif_mfp_constants=>gc_myfi_doc_type-myfi_po.
        ls_doc_header_new-was_l4l = abap_true.
      endif.
      append ls_doc_header_new to lt_doc_header_new.
      append ls_doc_header_new to lt_header_new.

      lv_objid = ls_doc_header_new-zmfp_doc_id.
      call function 'ZMFP_CHANGELOG_WRITE_DOCUMENT'
        exporting
          objectid                = lv_objid
          tcode                   = sy-tcode
          utime                   = sy-uzeit
          udate                   = sy-datum
          username                = sy-uname
          object_change_indicator = lv_change_indicator
          upd_ztmfp_doc_header    = lv_change_indicator
        tables
          xztmfp_doc_header       = lt_header_new
          yztmfp_doc_header       = lt_header_old.
      clear: lt_header_new, lt_header_old.

      if ls_doc_header_old-category eq zif_mfp_constants=>gc_myfi_doc_type-l4l_oa
      or ls_doc_header_old-category eq zif_mfp_constants=>gc_myfi_doc_type-l4l_po.
        select single *
          from ztmfp_doc_header
         where zmfp_doc_id = @ls_doc_header_old-ref_id
          and ( category = @zif_mfp_constants=>gc_myfi_doc_type-l4l_oa or category = @zif_mfp_constants=>gc_myfi_doc_type-l4l_po )
          into @ls_doc_header_old.

        if sy-subrc eq 0.
          append ls_doc_header_old to lt_header_old.
          ls_doc_header_new = ls_doc_header_old.
          ls_doc_header_new-was_l4l = abap_true.
          if ls_doc_header_old-category eq zif_mfp_constants=>gc_myfi_doc_type-l4l_oa.
            ls_doc_header_new-category = zif_mfp_constants=>gc_myfi_doc_type-myfi_oa.
          endif.
          if ls_doc_header_old-category eq zif_mfp_constants=>gc_myfi_doc_type-l4l_po.
            ls_doc_header_new-category = zif_mfp_constants=>gc_myfi_doc_type-myfi_po.
          endif.
          append ls_doc_header_new to lt_doc_header_new.
          append ls_doc_header_new to lt_header_new.
          lv_objid = ls_doc_header_new-zmfp_doc_id.
          call function 'ZMFP_CHANGELOG_WRITE_DOCUMENT'
            exporting
              objectid                = lv_objid
              tcode                   = sy-tcode
              utime                   = sy-uzeit
              udate                   = sy-datum
              username                = sy-uname
              object_change_indicator = lv_change_indicator
              upd_ztmfp_doc_header    = lv_change_indicator
            tables
              xztmfp_doc_header       = lt_header_new
              yztmfp_doc_header       = lt_header_old.
        endif.
      endif.
      update ztmfp_doc_header from table lt_doc_header_new.
    endif.
  endmethod.


  METHOD check_asset_confirmation.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_UTILITIES~CHECK_AWAITING_ASSET
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used to check if there are any awaiting assets
*                     against purchasing document
*
* AUTHOR:             Dathri Yellamarthy (210983DY)
* CREATE DATE:        27.Nov.2021
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000002550 - MyFi Applications (December Release)
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------

* 29.11.21 210983DY RD2K922223 DS-11-32-07-01 S 6000002550: MyFi Applications (December Release)
*-----------------------------------------------------------------------
    SELECT COUNT( * ) FROM ekpo
     WHERE ebeln =  iv_ebeln
       AND knttp =  'X'
       AND loekz NE 'X'.
    IF sy-subrc IS INITIAL.

      rv_awaiting_asset = abap_true.

    ENDIF.
  ENDMETHOD.


  METHOD check_sensitive_cost_assign.
*----------------------------------------------------------------------*
* METHOD ID:          CHECK_SENSITIVE_COST_ASSIGN
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method checks if a change has occurred to the
*                     sensitive cost assignment fields and sets the
*                     approval required flag if this is the case.
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        12.06.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* DEV SCRIPT:         DS-11-32-07-01
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date       Author    CTS Req    Description
*-----------------------------------------------------------------------
* 12.06.2020 290977SCN RD2K919078 Created
* 21.10.2020 290977SCN RD2K919656 MyFi Purchasing (Release 2.3)
* 03.06.2022 220977FKC RD2K922841 MyFi Continuous Improvement July Release
*-----------------------------------------------------------------------

    DATA: lt_aa_combo       TYPE TABLE OF zsmfp_sensitive_acc_assign,
          lr_context        TYPE REF TO if_fdt_context,
          lr_admin_data     TYPE REF TO if_fdt_admin_data,
          lr_function       TYPE REF TO  if_fdt_function,
          lr_fdt_result     TYPE REF TO if_fdt_result,
          lrx_fdt           TYPE REF TO cx_root,
          ls_aa_combo       TYPE zsmfp_sensitive_acc_assign,
          ls_ekkn_totals    TYPE zsmfp_ekkn_totals,
          ls_temp_ekkn      TYPE ekkn,
          ls_ekkn           TYPE ekkn,
          is_ekpo           TYPE ekpo,
          lv_effwr          TYPE effwr,
          lt_ekkn_total_new TYPE zmfp_ekkn_totals_tt,
          lt_ekkn_total_old TYPE zmfp_ekkn_totals_tt.

    FIELD-SYMBOLS: <ls_ekkn_temp_total> TYPE zsmfp_ekkn_totals.

    TRY .
        cl_fdt_factory=>get_instance_generic( EXPORTING iv_id = zif_mfp_constants=>gc_brf_guid-ekkn
                                              IMPORTING eo_instance = lr_admin_data ).
        lr_function ?= lr_admin_data.
        lr_context ?= lr_function->get_process_context( ).
        lr_context->set_value( iv_name = 'SENSITIVE_FIELD_BOOL' ia_value = iv_check_sensitive ).
        lr_function->process( EXPORTING io_context = lr_context
                              IMPORTING eo_result  = lr_fdt_result ).
        lr_fdt_result->get_value( IMPORTING ea_value = lt_aa_combo ).
      CATCH cx_fdt cx_sy_move_cast_error cx_sy_ref_is_initial INTO lrx_fdt.
    ENDTRY.

    LOOP AT lt_aa_combo INTO ls_aa_combo.
      get_sensitive_ekkn(
        EXPORTING
          it_ekkn     =  it_ekkn_new
          it_ekpo     =  it_ekpo_new
          is_aa_combo =  ls_aa_combo
     RECEIVING
          rt_ekkn     =  lt_ekkn_total_new
      ).

      get_sensitive_ekkn(
        EXPORTING
          it_ekkn     =  it_ekkn_old
          it_ekpo     =  it_ekpo_old
          is_aa_combo =  ls_aa_combo
     RECEIVING
          rt_ekkn     = lt_ekkn_total_old
      ).

      LOOP AT lt_ekkn_total_new ASSIGNING <ls_ekkn_temp_total>.
        READ TABLE lt_ekkn_total_old WITH KEY acc_assign = <ls_ekkn_temp_total>-acc_assign INTO ls_ekkn_totals.
        IF ls_ekkn_totals IS INITIAL.
          <ls_ekkn_temp_total>-app_req = abap_true.
        ELSE.
          <ls_ekkn_temp_total>-effwr_old = ls_ekkn_totals-effwr_new.
          IF <ls_ekkn_temp_total>-effwr_new GT <ls_ekkn_temp_total>-effwr_old.
            <ls_ekkn_temp_total>-app_req = abap_true.
          ENDIF.
        ENDIF.
        CLEAR ls_ekkn_totals.
        APPEND <ls_ekkn_temp_total> TO rt_ekkn_total.
      ENDLOOP.
    ENDLOOP.
  ENDMETHOD.


  METHOD check_sensitive_fields_ekko.
*----------------------------------------------------------------------*
* METHOD ID:          CHECK_SENSITIVE_FIELDS_EKKO
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method checks if a change has occurred to the
*                     sensitive EKKO fields.
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        12.06.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 12.06.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
*-----------------------------------------------------------------------

    DATA:lr_context    TYPE REF TO if_fdt_context,
         lr_admin_data TYPE REF TO if_fdt_admin_data,
         lr_function   TYPE REF TO  if_fdt_function,
         lr_fdt_result TYPE REF TO if_fdt_result,
         lrx_fdt       TYPE REF TO cx_root.

    TRY .
        cl_fdt_factory=>get_instance_generic( EXPORTING iv_id = zif_mfp_constants=>gc_brf_guid-ekko
                                              IMPORTING eo_instance = lr_admin_data ).
        lr_function ?= lr_admin_data.
        lr_context ?= lr_function->get_process_context( ).
        lr_context->set_value( iv_name = 'NEW_EKKO' ia_value = is_new_ekko ).
        lr_context->set_value( iv_name = 'OLD_EKKO' ia_value = is_old_ekko ).
        lr_context->set_value( iv_name = 'SENSITIVE_FIELD_BOOL' ia_value = iv_check_sensitive ).
        lr_context->set_value( iv_name = 'TABLE_2_TEST' ia_value = iv_table_2_test ).
        lr_function->process( EXPORTING io_context = lr_context
                              IMPORTING eo_result  = lr_fdt_result ).
        lr_fdt_result->get_value( IMPORTING ea_value = et_changed_fields ).
      CATCH cx_fdt cx_sy_move_cast_error cx_sy_ref_is_initial INTO lrx_fdt.
    ENDTRY.
  ENDMETHOD.


  METHOD check_sensitive_fields_ekpo.
*----------------------------------------------------------------------*
* METHOD ID:          CHECK_SENSITIVE_FIELDS_EKPO
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method checks if a change has occurred to the
*                     sensitive EKPO fields.
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        12.06.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 12.06.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
*-----------------------------------------------------------------------
    DATA:lr_context    TYPE REF TO if_fdt_context,
         lr_admin_data TYPE REF TO if_fdt_admin_data,
         lr_function   TYPE REF TO  if_fdt_function,
         lr_fdt_result TYPE REF TO if_fdt_result,
         lrx_fdt       TYPE REF TO cx_root.

    TRY .
        cl_fdt_factory=>get_instance_generic( EXPORTING iv_id = zif_mfp_constants=>gc_brf_guid-ekpo
                                              IMPORTING eo_instance = lr_admin_data ).
        lr_function ?= lr_admin_data.
        lr_context ?= lr_function->get_process_context( ).
        lr_context->set_value( iv_name = 'NEW_EKPO_TAB' ia_value = it_new_ekpo ).
        lr_context->set_value( iv_name = 'OLD_EKPO_TAB' ia_value = it_old_ekpo ).
        lr_context->set_value( iv_name = 'SENSITIVE_FIELD_BOOL' ia_value = iv_check_sensitive ).
        lr_context->set_value( iv_name = 'TABLE_2_TEST' ia_value = iv_table_2_test ).
        lr_function->process( EXPORTING io_context = lr_context
                              IMPORTING eo_result  = lr_fdt_result ).
        lr_fdt_result->get_value( IMPORTING ea_value = et_changed_fields ).
      CATCH cx_fdt cx_sy_move_cast_error cx_sy_ref_is_initial INTO lrx_fdt.
    ENDTRY.
  ENDMETHOD.


  METHOD connect_mime_to_doc.
*----------------------------------------------------------------------*
* METHOD ID:          CONNECT_MIME_TO_DOC
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method assigns an attachment to a document.
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        12.06.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 12.06.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
*-----------------------------------------------------------------------
    DATA:
      lv_arc_doc_id TYPE  toav0-arc_doc_id,
      lv_ar_object  TYPE  toaom-ar_object,
      lv_object_id  TYPE  sapb-sapobjid,
      lv_sap_object TYPE  toaom-sap_object,
      lv_filename   TYPE  toaat-filename,
      lv_descr      TYPE  toaat-descr,
      lv_creator    TYPE  toaat-creator.

    lv_arc_doc_id = is_attachment-arc_doc_id.
    lv_ar_object = is_attachment-ar_object.
    lv_object_id  = is_attachment-object_id.
    lv_sap_object = is_attachment-sap_object.
    lv_filename  =  is_attachment-filename.
    lv_descr     =  is_attachment-descr.
    lv_creator   = is_attachment-creator.

    CALL FUNCTION 'ARCHIV_CONNECTION_INSERT'
      EXPORTING
        arc_doc_id            = lv_arc_doc_id
        ar_object             = lv_ar_object
        object_id             = lv_object_id
        sap_object            = lv_sap_object
        filename              = lv_filename
        descr                 = lv_descr
        creator               = lv_creator
      EXCEPTIONS
        error_connectiontable = 1
        OTHERS                = 2.

    IF sy-subrc <> 0.
* Implement suitable error handling here
    ENDIF.

  ENDMETHOD.


  METHOD convert_curr_format.
*----------------------------------------------------------------------*
* METHOD ID:          CONVERT_CURR_FORMAT
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method converts an amount for displaying.
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        12.06.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 12.06.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
* 21/09/20 290977SCN RD2K919977 DS-11-32-07-01 S 6000002096: MyFi Purchasing (Release 2.2)
*-----------------------------------------------------------------------

    DATA: lv_amount TYPE bapicurr-bapicurr. "wmto_s-amount.

    lv_amount = iv_amount.

    CALL FUNCTION 'CURRENCY_AMOUNT_SAP_TO_BAPI'
      EXPORTING
        currency    = iv_curr
        sap_amount  = lv_amount
      IMPORTING
        bapi_amount = lv_amount.

    rv_amount = lv_amount.

    IF sy-subrc <> 0.
* Implement suitable error handling here
    ENDIF.

  ENDMETHOD.


  METHOD convert_string_table.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_POWL_FEEDER_OA2PO~if_powl_feeder~get_objects
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used to convert a string to a table
*
* AUTHOR:             Stephen Ning (290977SCN)
* CREATE DATE:        22.07.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001987 - MyFi Purchasing Release 2.1
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 22.07.20 290977SCN RD2K919533 DS-11-32-07-01 Created
*-----------------------------------------------------------------------
    DATA: lt_split_lines TYPE STANDARD TABLE OF string,
          lv_string      TYPE string,
          lt_string      TYPE char80_t.

    SPLIT iv_string AT cl_abap_char_utilities=>newline INTO TABLE lt_split_lines.

    LOOP AT lt_split_lines INTO lv_string.
      CALL FUNCTION 'CONVERT_STRING_TO_TABLE'
        EXPORTING
          i_string         = iv_string
          i_tabline_length = 80
        TABLES
          et_table         = lt_string.
      APPEND LINES OF lt_string TO et_string.
    ENDLOOP.

  ENDMETHOD.


  METHOD delegate_search.
*----------------------------------------------------------------------*
* METHOD ID:          DELEGATE_SEARCH
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method performs the delegate data selection from
*                     the back-end tables. It is called by the Searchhelp
*                     service for employees.
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        12.06.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 12.06.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
* 15/06/21 210983DY  RD2K921278 DS-11-32-07-01 S 6000002416: DFG BAR 2021-13 S23 Variable Delegation
* 26.05.22 210983DY  RD2K922710 S6000002735: MyFi Continuous Improvement June
*                    Release - Made additional changes for SES approver Field -
*                              Users will be able to be selected under SES field if they have approved
*                              a contract and are no longer backfilling in this position.
* 02.08.22 010965MI  RD2K922968 DS-11-32-07-01 S 6000002805: MyFi Continuous Improvement.  Performance
* 30.08.22 010965MI  RD2K923068 DS-11-32-07-01 S 6000002812: MyFi Continuous Improvement October - Performance
* 29.09.22 010965MI  RD2K923161 DS-11-32-07-01 S 6000002831: MyFi Continuous Improvement November Rel - Short dump & performance
* 24.11.22 010965MI  RD2K923395 DS-11-32-07-01   4500000101 - MyFi Production Fix – Approver
* 16.01.23 010965MI  RD2K923348 DS-11-32-07-01 S 6000002854: MyFi Continuous Improvement December Rel (re-transport)
*-----------------------------------------------------------------------
    CONSTANTS: lc_subty_0001 TYPE subty VALUE '0001'.

    DATA: lt_userid_range     TYPE mmpurui_range_tty,
          lt_first_range      TYPE mmpurui_range_tty,
          lt_last_range       TYPE mmpurui_range_tty,
          lt_eid_range        TYPE mmpurui_range_tty,
          lt_start_date_range TYPE mmpurui_range_tty,
          lt_end_date_range   TYPE mmpurui_range_tty,
          lt_companycode      TYPE RANGE OF bukrs,
          es_employee_data    TYPE zcl_zedm_searchhelp_mpc=>ts_employee.


    FIELD-SYMBOLS <fs_range> TYPE mmpurui_range_sty.
    IF NOT is_emptype_range-select_options IS INITIAL.
      IF is_emptype_range-select_options[ 1 ]-low = 'ASA'.
        DATA(lv_asa) = abap_true.
        lt_companycode = VALUE #( sign = 'I' option = 'EQ' ( low = '3000' ) ).
      ENDIF.
    ENDIF.

    lt_start_date_range = VALUE #(
        ( sign   = zif_mfp_constants=>e_selcrit-sign-including
          option = zif_mfp_constants=>e_selcrit-option-less_equal
          low    = sy-datum ) ).
    lt_end_date_range = VALUE #(
        ( sign   = zif_mfp_constants=>e_selcrit-sign-including
          option = zif_mfp_constants=>e_selcrit-option-greater_equal
          low    = sy-datum ) ).

    MOVE-CORRESPONDING is_userid_range-select_options TO lt_userid_range.
    LOOP AT lt_userid_range ASSIGNING <fs_range>.
      TRANSLATE <fs_range>-low TO UPPER CASE.
    ENDLOOP.

    MOVE-CORRESPONDING is_first_range-select_options TO lt_first_range.
    LOOP AT lt_first_range ASSIGNING <fs_range>.
      TRANSLATE <fs_range>-low TO UPPER CASE.
    ENDLOOP.

    MOVE-CORRESPONDING is_last_range-select_options TO lt_last_range.
    LOOP AT lt_last_range ASSIGNING <fs_range>.
      TRANSLATE <fs_range>-low TO UPPER CASE.
    ENDLOOP.

    MOVE-CORRESPONDING is_eid_range-select_options TO lt_eid_range.

    LOOP AT lt_eid_range ASSIGNING <fs_range>.
      IF <fs_range>-option = 'EQ'.
        <fs_range>-low = <fs_range>-low(8).
      ENDIF.
      "Employee ID is numeric 8 - If the search string is not just numbers (and wildcards)
      " nothing will match, so just exit
      IF ( <fs_range>-option = 'EQ' AND NOT ( <fs_range>-low CO '1234567890 ' AND <fs_range>-low+8 IS INITIAL ) )
      OR ( NOT ( <fs_range>-low CO '1234567890 *' AND <fs_range>-low+10 IS INITIAL ) ).
        RETURN.
      ENDIF.
    ENDLOOP.

    IF lt_eid_range IS NOT INITIAL.
      " Get user name / pernr pairs to update the usernaname in the output (This avoids joining PA0105 in the main select, which is expensive)
      SELECT  pernr, usrid
        FROM  pa0105
        INTO TABLE @DATA(lt_0105_uname)
        WHERE pernr IN @lt_eid_range
          AND endda IN @lt_end_date_range
          AND begda IN @lt_start_date_range
          AND subty EQ @lc_subty_0001.
    ENDIF.

    IF lt_userid_range IS NOT INITIAL.
      " map USER ID's to EID's and then append to eid range table
      " this is need because some searches (direct search into the box)
      " and user lookup for the apps in standalone mode (e.g. via approval link)
      " passes in USER ID when it should be passing PERNR

      SELECT  pernr, usrid
        FROM  pa0105
        INTO TABLE @DATA(lt_0105_uname_2)
        WHERE usrid IN @lt_userid_range
          AND endda IN @lt_end_date_range
          AND begda IN @lt_start_date_range
          AND subty EQ @lc_subty_0001.

      IF sy-subrc IS NOT INITIAL.

        LOOP AT lt_userid_range ASSIGNING <fs_range>.
          IF  <fs_range>-option = 'EQ'.
            <fs_range>-low = <fs_range>-low(8).
          ENDIF.
          TRANSLATE <fs_range>-low TO UPPER CASE.
          IF <fs_range>-low CA sy-abcde.
            RETURN.    "Employee ID is numeric - nothing will match, so just exit
          ENDIF.
        ENDLOOP.
        SELECT  pernr, usrid
          FROM  pa0105
          INTO TABLE @lt_0105_uname_2
          WHERE pernr IN @lt_userid_range
            AND endda IN @lt_end_date_range
            AND begda IN @lt_start_date_range
            AND subty EQ @lc_subty_0001.
        IF sy-subrc IS NOT INITIAL.
          RETURN.    "No match on userid or pernr, so just exit
        ENDIF.
      ENDIF.
      LOOP AT lt_0105_uname_2 ASSIGNING FIELD-SYMBOL(<0105_uname>).
        lt_eid_range = VALUE #( BASE lt_eid_range ( sign = 'I' option = 'EQ' low = <0105_uname>-pernr ) ).
        APPEND <0105_uname> TO lt_0105_uname.
      ENDLOOP.

      CLEAR lt_userid_range.

    ENDIF.
    SORT lt_0105_uname BY pernr.


    IF it_delegation_range IS INITIAL.

      IF lv_asa IS INITIAL.
        " For performance, just read from PA0002
        " Then read the additional person attributes from the other tables with separate reads.
        SELECT a~pernr, a~nachn, a~vorna, a~cname, a~titel
          FROM pa0002 AS a                                 " Last name, first name, fullname
          UP TO @i_max_rows ROWS
          INTO TABLE @DATA(lt_delegate)
          WHERE a~pernr IN @lt_eid_range
            AND a~nchmc IN @lt_last_range
            AND a~vnamc IN @lt_first_range
            AND a~endda IN @lt_end_date_range
            AND a~begda IN @lt_start_date_range
            ORDER BY a~pernr.
      ELSE.
        " For performance, just read from PA0002
        " Then read the additional person attributes from the other tables with separate reads.
        SELECT a~pernr, a~nachn, a~vorna, a~cname, a~titel
          FROM pa0002 AS a INNER JOIN pa0001 AS b ON a~pernr EQ b~pernr        " Last name, first name, fullname
          UP TO @i_max_rows ROWS
          INTO TABLE @lt_delegate
          WHERE a~pernr IN @lt_eid_range
            AND a~nchmc IN @lt_last_range
            AND a~vnamc IN @lt_first_range
            AND a~endda IN @lt_end_date_range
            AND a~begda IN @lt_start_date_range
          AND b~endda IN @lt_end_date_range
          AND b~begda IN @lt_start_date_range
          AND b~bukrs IN @lt_companycode
            ORDER BY a~pernr.

      ENDIF.

    ELSE.
      " join PA0001 to HRP1010 and PA0001 to include the delegation restriction
      SELECT a~pernr, a~nachn, a~vorna, a~cname, a~titel
        FROM pa0002 AS a                                 " Last name, first name, fullname
        INNER JOIN pa0001 AS b ON a~pernr EQ b~pernr     " Org assignment
        INNER JOIN hrp1010 AS d ON b~plans = d~objid
        UP TO @i_max_rows ROWS
        INTO TABLE @lt_delegate
        WHERE a~pernr IN @lt_eid_range
          AND a~nchmc IN @lt_last_range
          AND a~vnamc IN @lt_first_range
          AND a~endda IN @lt_end_date_range
          AND a~begda IN @lt_start_date_range
          AND b~endda IN @lt_end_date_range
          AND b~begda IN @lt_start_date_range
          AND d~subty IN @it_delegation_range
          AND d~endda IN @lt_end_date_range
          AND d~begda IN @lt_start_date_range
         ORDER BY a~pernr.

    ENDIF.

    IF lt_delegate IS INITIAL.
      RETURN.
    ENDIF.

    " Org assignment
    IF i_read_org_assignment = abap_true.
      SELECT pernr, plans, bukrs, persk
        FROM pa0001     " Org assignment
        INTO TABLE @DATA(lt_0001)
        FOR ALL ENTRIES IN @lt_delegate
        WHERE pernr EQ @lt_delegate-pernr
          AND endda IN @lt_end_date_range
          AND begda IN @lt_start_date_range.
      SORT lt_0001 BY pernr.
    ENDIF.

    " Email address
    SELECT  pernr, usrid_long
      FROM  pa0105
      INTO TABLE @DATA(lt_0105)
      FOR ALL ENTRIES IN @lt_delegate
      WHERE pernr EQ @lt_delegate-pernr
        AND endda IN @lt_end_date_range
        AND begda IN @lt_start_date_range
        AND subty EQ '0010'.
    SORT lt_0105 BY pernr.

    " If there was no EID or Userid filter, then the username lookup table will be empty
    IF lt_0105_uname IS INITIAL.
      SELECT  pernr, usrid
        FROM  pa0105
        INTO TABLE @lt_0105_uname
        FOR ALL ENTRIES IN @lt_delegate
        WHERE pernr EQ @lt_delegate-pernr
          AND endda IN @lt_end_date_range
          AND begda IN @lt_start_date_range
          AND subty EQ @lc_subty_0001.
      SORT lt_0105_uname BY pernr.
    ENDIF.

    " Classification.  Read individually later, as there are only a small number.  Could just select the whole lot.
    DATA:
      BEGIN OF ls_503t,
        persk TYPE t503t-persk,
        ptext TYPE t503t-ptext,
      END OF ls_503t.
    DATA lt_503t LIKE HASHED TABLE OF ls_503t WITH UNIQUE KEY persk.

    LOOP AT lt_delegate INTO DATA(ls_delegate).
      es_employee_data = VALUE #(
          employeeid = ls_delegate-pernr
          firstname = ls_delegate-vorna
          surname = ls_delegate-nachn
          username = COND #( WHEN ls_delegate-cname IS NOT INITIAL THEN ls_delegate-cname
                                              ELSE |{ ls_delegate-vorna } { ls_delegate-nachn }| )
          fullname = |{ ls_delegate-titel } { ls_delegate-vorna } { ls_delegate-nachn }|
          ).

      " Username is stored in PA0105, suptype 0001
      READ TABLE lt_0105_uname ASSIGNING FIELD-SYMBOL(<pa0105_uname>) WITH KEY pernr = ls_delegate-pernr BINARY SEARCH.
      IF sy-subrc IS INITIAL.
        es_employee_data-userid = <pa0105_uname>-usrid.
      ENDIF.

      " Email address is stored in PA0105, suptype 0010 - read after the main select
      READ TABLE lt_0105 ASSIGNING FIELD-SYMBOL(<pa0105>) WITH KEY pernr = ls_delegate-pernr BINARY SEARCH.
      IF sy-subrc IS INITIAL.
        es_employee_data-email = <pa0105>-usrid_long.
      ENDIF.

      " Phone number
      " Not actually stored in PA0006.  Have to read from the user master record.
      IF i_read_telnr = abap_true.
        SELECT b~tel_number
              FROM usr21 AS a
              INNER JOIN adr2 AS b ON b~addrnumber EQ a~addrnumber AND b~persnumber EQ a~persnumber
              UP TO 1 ROWS     "Select single is not valid for joins
              INTO @es_employee_data-phone
              WHERE  bname       = @es_employee_data-userid.
          CONDENSE es_employee_data-phone NO-GAPS.
        ENDSELECT.
      ENDIF.

      " Org assignment
      " Only for delegate search, not required for user search
      IF i_read_org_assignment = abap_true.
        READ TABLE lt_0001 ASSIGNING FIELD-SYMBOL(<pa0001>) WITH KEY pernr = ls_delegate-pernr BINARY SEARCH.
        IF sy-subrc IS INITIAL.
          es_employee_data-companycode = <pa0001>-bukrs.

          IF ls_503t-persk NE <pa0001>-persk.
            READ TABLE lt_503t INTO ls_503t WITH TABLE KEY persk = <pa0001>-persk.
            IF sy-subrc IS NOT INITIAL.
              SELECT SINGLE persk ptext
                FROM t503t
                INTO ls_503t
                WHERE persk = <pa0001>-persk
                AND   sprsl EQ 'E'.
              INSERT ls_503t INTO TABLE lt_503t.
            ENDIF.
          ENDIF.
          es_employee_data-classification = ls_503t-ptext.
        ENDIF.
      ENDIF.

      APPEND es_employee_data TO et_employee_data.
    ENDLOOP.
  ENDMETHOD.


  METHOD delete_draft.
*----------------------------------------------------------------------*
* METHOD ID:          DELETE_DRAFT
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method performs the deletion of draft records.
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        12.06.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 12.06.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
* 23.09.20 290977SCN RD2K919977 DS-11-32-07-01 S 6000002096: MyFi Purchasing (Release 2.2)
*-----------------------------------------------------------------------
    DATA: lv_new_status   TYPE zmfp_status,
          ls_oa_deep      TYPE zcl_zedm_mfp_dpc_ext=>ty_contract_deep,
          ls_po_deep      TYPE zcl_zedm_mfp_dpc_ext=>ty_po_deep,
          ls_doc_header   TYPE ztmfp_doc_header,
          ls_ztmfp_string TYPE ztmfp_strings.

    FIELD-SYMBOLS: <fs_json> TYPE string.

    SELECT SINGLE ebeln FROM ekko WHERE ebeln = @iv_ebeln INTO @DATA(lv_ebeln).
    CHECK sy-subrc <> 0.
    CALL METHOD zcl_mfp_oa=>update_myfi_status
      EXPORTING
        iv_ebeln      = iv_ebeln
        iv_action     = zif_mfp_constants=>gc_action-odata-delete
        iv_old_status = zif_mfp_constants=>gc_doc_status-draft
      IMPORTING
        ev_new_status = lv_new_status.
    CHECK lv_new_status = zif_mfp_constants=>gc_doc_status-deleted.
    rv_success = abap_true.

    CALL METHOD zcl_mfp_document=>get_doc_header
      EXPORTING
        iv_zmfp_doc_id      = iv_ebeln                 " Purchasing Document Number
      IMPORTING
        es_ztmfp_doc_header = ls_doc_header.                  " MyFi Purchasing UI5 Application Document Header Tabl

    SELECT SINGLE * FROM ztmfp_strings
             INTO @ls_ztmfp_string
            WHERE zmfp_doc_id = @iv_ebeln AND
                  string_type = @zif_mfp_constants=>gc_string_type-json.
    ASSIGN ls_ztmfp_string-string_data TO <fs_json>.
    CASE ls_doc_header-category.
      WHEN zif_mfp_constants=>gc_myfi_doc_type-l4l_oa OR zif_mfp_constants=>gc_myfi_doc_type-myfi_oa.
        /ui2/cl_json=>deserialize( EXPORTING json = <fs_json> pretty_name = /ui2/cl_json=>pretty_mode-camel_case CHANGING data = ls_oa_deep ).
        ls_oa_deep-status = lv_new_status.
        <fs_json> = /ui2/cl_json=>serialize( data = ls_oa_deep compress = abap_true pretty_name = /ui2/cl_json=>pretty_mode-camel_case ).
        CALL METHOD zcl_mfp_oa=>create_event
          EXPORTING
            iv_ebeln = iv_ebeln
            iv_event = zif_mfp_constants=>gc_event-draft_delete.

      WHEN zif_mfp_constants=>gc_myfi_doc_type-l4l_po OR zif_mfp_constants=>gc_myfi_doc_type-myfi_po.
        /ui2/cl_json=>deserialize( EXPORTING json = <fs_json> pretty_name = /ui2/cl_json=>pretty_mode-camel_case CHANGING data = ls_po_deep ).
        ls_po_deep-status = lv_new_status.
        <fs_json> = /ui2/cl_json=>serialize( data = ls_po_deep compress = abap_true pretty_name = /ui2/cl_json=>pretty_mode-camel_case ).
        CALL METHOD zcl_mfp_po=>create_event
          EXPORTING
            iv_ebeln = iv_ebeln
            iv_event = zif_mfp_constants=>gc_event-draft_delete.

      WHEN OTHERS.
    ENDCASE.

    MODIFY ztmfp_strings FROM ls_ztmfp_string.
  ENDMETHOD.


  METHOD delete_user_object.
*----------------------------------------------------------------------*
* METHOD ID:          DELETE_USER_OBJECT
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method performs the removal of a document from
*                     a user's object list.
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        12.06.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 12.06.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
* 06/07/22 210983DY  RD2K922923 DS-11-32-07-01 S6000002777:MyFi Continuous Improvement
*                                              August Release
*-----------------------------------------------------------------------
    DATA: lo_myfi_objects TYPE REF TO cl_myobjects_model,
          lt_user_objects TYPE sgo_t_tre,
          ls_user_objects TYPE smyotrees,
          lt_objs_delete  TYPE sgo_t_guid,
          ls_objs_delete  TYPE sgo_s_guid,
          lt_ebeln        TYPE RANGE OF ekko-ebeln,
          lv_user         TYPE uname.

    FIELD-SYMBOLS: <docs> TYPE zif_mfp_constants=>ty_s_objtyp_ebeln.

    IF iv_user IS INITIAL.
      lv_user = sy-uname.
    ELSE.
      lv_user = iv_user.
    ENDIF.
    lt_ebeln = VALUE #( FOR ls_ebeln IN it_docs ( sign = 'I' option = 'EQ' low = ls_ebeln-ebeln ) ).

*    Get Objects
    SELECT *
            FROM smyotree
            INTO TABLE lt_user_objects
              WHERE user_name = lv_user
              AND   objkey   IN lt_ebeln.

    CREATE OBJECT lo_myfi_objects EXPORTING im_uname = lv_user.

    LOOP AT it_docs ASSIGNING <docs>.
      LOOP AT lt_user_objects INTO ls_user_objects WHERE objkey = <docs>-ebeln.

        ls_objs_delete-guid = ls_user_objects-guid.
        APPEND ls_objs_delete TO lt_objs_delete.
        CLEAR: ls_user_objects, ls_objs_delete.
      ENDLOOP.

    ENDLOOP.
    lo_myfi_objects->if_myobjects_model~delete_objects( it_del = lt_objs_delete ).
  ENDMETHOD.


  METHOD determine_approver.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_UTILITIES~DETERMIN_APPROVER
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used to determine the approver of a MyFi
*                     document
* AUTHOR:             Stephen Ning (290977SCN)
* CREATE DATE:        26.08.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          S 6000002096: MyFi Purchasing (Release 2.2)
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 22.07.20 290977SCN RD2K919977 DS-11-32-07-01 Created
* 21/09/20 290977SCN RD2K919977 DS-11-32-07-01 S 6000002096: MyFi Purchasing (Release 2.2)
*-----------------------------------------------------------------------
    DATA: ls_ebeln    TYPE ebeln,
          lv_objectid TYPE cdhdr-objectid,
          lv_tablekey TYPE cdpos-tabkey,
          lt_cdred    TYPE TABLE OF cdred.

    SELECT SINGLE * FROM  ztmfp_doc_header
           WHERE  zmfp_doc_id  = @iv_ebeln
           INTO @DATA(ls_doc_header).

    IF ls_doc_header-category EQ zif_mfp_constants=>gc_myfi_doc_type-l4l_po.
      ls_ebeln = ls_doc_header-ref_id.
    ELSE.
      ls_ebeln = iv_ebeln.
    ENDIF.

    SELECT SINGLE frgke FROM ekko INTO @DATA(lv_frgke) WHERE ebeln EQ @ls_ebeln.

    IF lv_frgke EQ '2' OR lv_frgke EQ '3' OR lv_frgke EQ '5'.

      lv_objectid = ls_ebeln.

      CALL FUNCTION 'CHANGEDOCUMENT_READ'
        EXPORTING
          objectclass                = 'EINKBELEG'
          objectid                   = lv_objectid
          tablename                  = 'EKKO'
        TABLES
          editpos                    = lt_cdred
        EXCEPTIONS
          no_position_found          = 1
          wrong_access_to_archive    = 2
          time_zone_conversion_error = 3
          OTHERS                     = 4.

      DELETE lt_cdred WHERE fname NE 'FRGKE'.
      SORT lt_cdred BY changenr DESCENDING.

      LOOP AT  lt_cdred INTO DATA(ls_cdred).
        IF ( ls_cdred-f_old EQ 1 AND ls_cdred-f_new EQ 5 ) OR
           ( ls_cdred-f_old EQ 4 AND ls_cdred-f_new EQ 2 ) OR
           ( ls_cdred-f_old EQ 4 AND ls_cdred-f_new EQ 3 ).
          rv_userid = ls_cdred-username.
        ENDIF.

      ENDLOOP.
    ENDIF.
  ENDMETHOD.


  METHOD display_allowed.
*----------------------------------------------------------------------*
* METHOD ID:          DISPLAY_ALLOWED
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method checks if an MFP document can be displayed
*                     in the UI5 application - i.e. hasn't been changed in
*                     the GUI.
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        12.06.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 12.06.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
* 22.07.20 290977SCN RD2K919533 DS-11-32-07-01 checked that document is in header table as well
*-----------------------------------------------------------------------
    DATA: ls_return  TYPE bapiret2,
          lv_message TYPE bapiret2-message.
    SELECT SINGLE changed_in_gui FROM ztmfp_doc_header WHERE zmfp_doc_id EQ @iv_ebeln INTO @DATA(lv_changed).
    IF lv_changed EQ abap_true OR sy-subrc NE 0.
      CLEAR: ls_return.
      MESSAGE e010(zmfp) INTO lv_message.
      ls_return-message = lv_message.
      MESSAGE e011(zmfp) INTO lv_message.
      ls_return-message = |{ ls_return-message }  { lv_message }|.
      ls_return-type = 'E'.
      APPEND ls_return TO rt_return.
    ENDIF.

  ENDMETHOD.


  method duplicate_check.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_Utilities~DUPLICATE_CHECK
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2.2).
*                     This method is used for MyFi Documents
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        27.08.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000002096 - MyFi Purchasing (Release 2.2)
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 21/09/20 290977SCN RD2K919977 DS-11-32-07-01 S 6000002096: MyFi Purchasing (Release 2.2)
*-----------------------------------------------------------------------
    data: lt_return      type bapiret2_t,
          ls_return      type bapiret2,
          lv_bapi_amount type bapicurr_d,
          lv_sap_amount  type bapicurr_d.

*--- convert amount to sap internal format
    lv_bapi_amount = iv_ktwrt.
    call function 'CURRENCY_AMOUNT_BAPI_TO_SAP'
      exporting
        currency              = iv_waers
        bapi_amount           = lv_bapi_amount
      importing
        sap_amount            = lv_sap_amount
      exceptions
        bapi_amount_incorrect = 1
        others                = 2.

    if sy-subrc <> 0.
      ls_return-type = sy-msgty.
      ls_return-id = sy-msgid.
      ls_return-number = sy-msgno.
      ls_return-message_v1 = sy-msgv1.
      ls_return-message_v2 = sy-msgv2.
      ls_return-message_v3 = sy-msgv3.
      ls_return-message_v4 = sy-msgv4.
      append ls_return to et_return.
    endif.

*--- lookup ekko for duplicates
    select ebeln from ekko
                 into @data(lt_docs)
                 where ebeln  ne @iv_ebeln and
                       bsart  eq @iv_bsart and
                       lifnr  eq @iv_lifnr and
                       ktwrt  eq @lv_sap_amount and
                       waers  eq @iv_waers and
                       kdatb  eq @iv_kdatb and
                       kdate  eq @iv_kdate.

      message w165(zmfp) with lt_docs into ls_return-message.
      ls_return-type = sy-msgty.
      ls_return-id = sy-msgid.
      ls_return-number = sy-msgno.
      ls_return-message_v1 = sy-msgv1.
      append ls_return to et_return.
    endselect.
    if ls_return is not initial.
      message w166(zmfp) into ls_return-message.
      ls_return-type = sy-msgty.
      ls_return-id = sy-msgid.
      ls_return-number = sy-msgno.
      append ls_return to et_return.
    else.
      message s014(zmfp) into ls_return-message.
      ls_return-type = sy-msgty.
      ls_return-id = sy-msgid.
      ls_return-number = sy-msgno.
      append ls_return to et_return.
    endif.
  endmethod.


  METHOD duplicate_check_w_account.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_Utilities~DUPLICATE_CHECK
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2.4).
*                     This method is used for MyFi Documents to perform additional
*                     duplicate check for line item account assignment
*
* AUTHOR:             Dathri Yellamarthy
* CREATE DATE:        21.01.2021
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000002250 - MyFi Purchasing (Release 2.4)
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------

*-----------------------------------------------------------------------
    DATA: lt_return TYPE bapiret2_t,
          ls_return TYPE bapiret2,
          ls_string TYPE string,
          lv_count  TYPE i,
          lr_vendor TYPE RANGE OF lfa1-lifnr.


    SELECT SINGLE stceg FROM lfa1 INTO @DATA(lv_stceg) WHERE lifnr = @iv_lifnr.
    IF sy-subrc IS INITIAL AND NOT lv_stceg IS INITIAL.
      SELECT DISTINCT lifnr FROM lfa1 INTO TABLE @DATA(lt_vendor) WHERE stceg = @lv_stceg.
      IF sy-subrc IS INITIAL.
        lr_vendor = VALUE #( FOR ls_vendor IN lt_vendor ( VALUE #( sign = 'I' option = 'EQ' low = ls_vendor-lifnr ) ) ).
      ELSE.
        lr_vendor = VALUE #( sign = 'I' option = 'EQ' ( low = iv_lifnr ) ) .
      ENDIF.
    ELSE.
      lr_vendor = VALUE #( sign = 'I' option = 'EQ' ( low = iv_lifnr ) ) .
    ENDIF.

    IF NOT lr_vendor IS INITIAL.
*--- lookup ekko for duplicates
      SELECT DISTINCT ekko~ebeln, ekkn~ebelp, ekkn~netwr, ekkn~prctr
        FROM ekko INNER JOIN ekkn ON ekko~ebeln = ekkn~ebeln
        JOIN ekpo ON ekpo~ebeln = ekkn~ebeln AND
        ekpo~ebelp = ekkn~ebelp
                   INTO TABLE @DATA(lt_docs)
                   WHERE ekko~ebeln  NE @iv_ebeln AND
                         ekko~bsart  EQ @iv_bsart AND
                         ekko~lifnr  IN @lr_vendor AND
                         ekko~kdate  GE  @sy-datum AND
                         ekkn~prctr  EQ @iv_prctr AND
                         ekpo~loekz  NE 'L'.

      IF sy-subrc IS INITIAL.
        CLEAR : ls_string, lv_count.
        SORT lt_docs BY ebeln.
        DELETE ADJACENT DUPLICATES FROM lt_docs COMPARING ebeln.
        lv_count = lines( lt_docs ).
        LOOP AT lt_docs INTO DATA(ls_docs).
          CONCATENATE ls_string ls_docs-ebeln INTO ls_string SEPARATED BY space.
        ENDLOOP.

        IF lv_count LE '3'. " upto 3 outline agreements
          DATA(lv_msg) = | { TEXT-dup }  { TEXT-001 } { ls_string } |.
        ELSE.
          lv_msg = | { TEXT-dup }  { TEXT-001 } '1/2' |.
        ENDIF.

        MESSAGE w169(zmfp).
        APPEND VALUE #( message = lv_msg
                        type    = sy-msgty
                        id      = sy-msgid
                        number  = sy-msgno ) TO et_return.


        IF lv_count GT '3'.   " if number of agreements found are more then 3
          lv_msg = | '2/2' { ls_string } |.
          APPEND VALUE #( message = lv_msg
                          type    = sy-msgty
                          id      = sy-msgid
                          number  = sy-msgno ) TO et_return.
        ENDIF.

      ENDIF.
    ENDIF.
  ENDMETHOD.


  METHOD export_header.
*----------------------------------------------------------------------*
* METHOD ID:          EXPORT_HEADER
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method exports the Doc Header to memory for
*                     later use.
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        12.06.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 12.06.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
*-----------------------------------------------------------------------
    DATA: ls_ptab TYPE zsmfp_memory_header,
          lt_ptab TYPE STANDARD TABLE OF zsmfp_memory_header.

    ls_ptab-name = name.
    ls_ptab-value = value.
    APPEND ls_ptab TO lt_ptab.

    EXPORT lt_ptab = lt_ptab TO MEMORY ID id.
  ENDMETHOD.


  METHOD get_archive_id.
*----------------------------------------------------------------------*
* METHOD ID:          GET_ARCHIVE_ID
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method maps the system to the atchive ID for
*                     attachments.
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        12.06.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 12.06.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
*-----------------------------------------------------------------------

    CASE sy-sysid(2).
      WHEN 'RD'.
        rv_archiv_id = 'I3'.
      WHEN 'RT'.
        rv_archiv_id = 'I2'.
      WHEN 'PD'.
        rv_archiv_id = 'I1'.
      WHEN OTHERS.
        rv_archiv_id = 'I3'.
    ENDCASE.


  ENDMETHOD.


  METHOD get_budget_exchangerate.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_Utilities~GET_BUDGET_EXCHANGERATE
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2.4).
*                     This method is used for MyFi Documents to derive exchange rate
*                     from Purchase order

* AUTHOR:             Dathri Yellamarthy
* CREATE DATE:        21.01.2021
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000002250 - MyFi Purchasing (Release 2.4)
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------

*-----------------------------------------------------------------------

    DATA: lt_cdpos TYPE TABLE OF cdpos.
* Get change log to see if there is any recent change to exchange rate in the document

*sort the derived exchange rates by date and get the most recent exchange rate
    IF NOT it_ebeln IS INITIAL.
      SELECT ebeln, aedat, wkurs FROM ekko INTO TABLE @DATA(lt_ekko) WHERE ebeln IN @it_ebeln.
* sort by change date
      SORT lt_ekko BY aedat DESCENDING.

* Get change details for exchange rate
      SELECT objectid, changenr, value_new, value_old FROM cdpos INTO CORRESPONDING FIELDS OF TABLE @lt_cdpos WHERE
        objectclas = 'EINKBELEG' AND
           objectid IN @it_ebeln AND
           tabname = 'EKKO' AND
             fname = 'WKURS'.

      IF sy-subrc IS INITIAL.

        SELECT objectid, changenr, udate, utime FROM cdhdr INTO TABLE @DATA(lt_cdhdr) FOR ALL ENTRIES IN @lt_cdpos
          WHERE objectclas = 'EINKBELEG'
            AND objectid   = @lt_cdpos-objectid
            AND changenr   = @lt_cdpos-changenr.

        IF sy-subrc IS INITIAL.

          SORT lt_cdhdr DESCENDING BY udate utime.
          READ TABLE lt_cdhdr INTO DATA(ls_cdhdr) INDEX 1.

          IF sy-subrc IS INITIAL.
            READ TABLE lt_cdpos INTO DATA(ls_cdpos) WITH KEY changenr = ls_cdhdr-changenr.
            IF sy-subrc IS INITIAL.

              rv_budget_exchange_rate = ls_cdpos-value_new.

            ENDIF.
          ENDIF.
        ENDIF.

      ELSE.
        READ TABLE lt_ekko INTO DATA(ls_ekko) INDEX 1.
        IF sy-subrc IS INITIAL. rv_budget_exchange_rate = ls_ekko-wkurs. ENDIF.
      ENDIF.

    ENDIF.
  ENDMETHOD.


  METHOD get_currency_factor.
*-----------------------------------------------------------------------------------------
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used to derive currency factor for currency
*
* AUTHOR:       Dathri Yellamarthy
* CREATE DATE:  16.04.2021
*
* ACTIVITY:     AD-11-32-07 - Self Service Purchasing App
* DEV SCRIPT:   DS-11-32-17-01 - Self Service Purchasing App
*-----------------------------------------------------------------------------------------
* VERSION CONTROL:
*
* Date       Author    CTS Req    SCR        Description
* ---------- --------- ---------- ---------- ---------------------------------------------
* 16.04.21   210983DY  RD2K920923 6000002348: MyFi Purchasing (May Defects)
*-----------------------------------------------------------------------------------------


    SELECT SINGLE ffact FROM tcurf INTO @DATA(lv_factor) WHERE kurst = 'M'
      AND fcurr = @iv_currency AND tcurr = 'AUD'.
    IF sy-subrc IS INITIAL.
      rv_factor = lv_factor.
    ENDIF.

  ENDMETHOD.


  METHOD get_date_from_ts.
*----------------------------------------------------------------------*
* METHOD ID:          GET_DATE_FROM_TS
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method converts a timestamp into a standard date.
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        12.06.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 12.06.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
*-----------------------------------------------------------------------

    DATA: tz           TYPE timezone VALUE 'UTC',
          sytzone      TYPE string,
          lv_time      TYPE sy-uzeit,
          lv_timestamp TYPE timestampl.

    lv_timestamp = iv_timestamp.
    IF sy-tzone GT 0.
      sytzone = trunc( sy-tzone / 3600 ).
      CONCATENATE tz '+' sytzone INTO tz.
    ELSEIF  sy-tzone = 0.
    ELSEIF  sy-tzone LT 0.
      sytzone = trunc( sy-tzone / 3600 ).
      CONCATENATE tz '-' sytzone INTO tz.
    ENDIF.

    CONVERT TIME STAMP lv_timestamp TIME ZONE tz
      INTO DATE rv_date TIME lv_time.

  ENDMETHOD.


  METHOD get_delegation_level.
*----------------------------------------------------------------------*
* METHOD ID:          GET_DELEGATION_LEVEL
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method retreives delegation levels for the
*                     delegate selection.
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        12.06.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 12.06.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
*-----------------------------------------------------------------------
    DATA: lv_limit      TYPE dec16_3,
          lt_delg_level TYPE TABLE OF t777w.

    SELECT * FROM  t777w INTO TABLE @DATA(lt_limits) WHERE subty = '0070'.
    REPLACE ALL OCCURRENCES OF '$' IN TABLE lt_limits WITH ''.
    REPLACE ALL OCCURRENCES OF ',' IN TABLE lt_limits WITH ''.

*    delete lt_limits where htext lt iv_amount.
    LOOP AT lt_limits ASSIGNING FIELD-SYMBOL(<fs_limit>).
      IF <fs_limit>-htext CO '0123456789 '.
        lv_limit = <fs_limit>-htext.
        IF iv_amount LE lv_limit.
          APPEND <fs_limit> TO lt_delg_level.
        ENDIF.
      ENDIF.
    ENDLOOP.
    rt_delg_level = lt_delg_level.
  ENDMETHOD.


  METHOD get_doc_header_status.
*----------------------------------------------------------------------*
* METHOD ID:          GET_DOC_HEADER_STATUS
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method retreives the document header status.
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        12.06.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 12.06.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
*-----------------------------------------------------------------------

* Returns the status of a MyFi Document from the Header table

    SELECT SINGLE status
      INTO ev_status
      FROM ztmfp_doc_header
      WHERE zmfp_doc_id = iv_zmfp_doc_id.

    ev_return_code = sy-subrc.

  ENDMETHOD.


  METHOD get_doc_value.

*----------------------------------------------------------------------*
* METHOD ID:          GET_DOC_VALUE
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2.2).
*                     This method calculates the AUD value of a purchasing document.
*
* AUTHOR:             Stephen Ning (290977SCN)
* CREATE DATE:        21.09.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000002096 - MyFi Purchasing Release 2.2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 21/09/20 290977SCN RD2K919977 DS-11-32-07-01 S 6000002096: MyFi Purchasing (Release 2.2)
* 13/01/22  210983DY RD2K922296 6000002623: MyFi Applications (February Release)

*-----------------------------------------------------------------------

    DATA: lv_amount    TYPE effwr,
          lv_forex_amt TYPE string.

    SELECT SINGLE bstyp, ktwrt, waers, wkurs FROM ekko INTO @DATA(ls_doc) WHERE ebeln EQ @iv_ebeln.
    IF ls_doc-bstyp EQ zif_mfp_constants=>gc_doc_type-oa.
      lv_amount = ls_doc-ktwrt.
    ELSE.
      lv_amount = zcl_mfp_utilities=>get_po_total_values( iv_ebeln = iv_ebeln ).
    ENDIF.
    IF ls_doc-waers EQ 'AUD'.
      rv_value = lv_amount.
    ELSE.
      lv_forex_amt = lv_amount.

      SELECT SINGLE currdec INTO @DATA(lv_decimals) FROM  tcurx
                   WHERE  currkey = @ls_doc-waers.

      CALL FUNCTION 'Z_CURRENCY_IN_DECIMAL'
        EXPORTING
          iv_amount   = lv_forex_amt
          iv_currency = ls_doc-waers
        IMPORTING
          ev_amount   = lv_forex_amt.

      CASE lv_decimals.
        WHEN 3.
          lv_forex_amt = lv_forex_amt * 100.
        WHEN OTHERS.
      ENDCASE.

      CALL FUNCTION 'CONVERT_TO_LOCAL_CURRENCY'
        EXPORTING
          date             = sy-datum
          foreign_amount   = lv_forex_amt
          foreign_currency = ls_doc-waers
          local_currency   = 'AUD'
          rate             = ls_doc-wkurs
        IMPORTING
          local_amount     = lv_amount
        EXCEPTIONS
          no_rate_found    = 1
          overflow         = 2
          no_factors_found = 3
          no_spread_found  = 4
          derived_2_times  = 5
          OTHERS           = 6.

      rv_value = lv_amount.
    ENDIF.

  ENDMETHOD.


  METHOD get_gls_with_commitments.
*----------------------------------------------------------------------*
* METHOD ID:          get_gls_with_commitments
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2.3).
*
* AUTHOR:             Stephen Ning (290977SCN)
* CREATE DATE:        26.10.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000002172 - MyFi Purchasing Release 2.2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 26/10/20 290977SCN RD2K919656 DS-11-32-07-01 S 6000002172: MyFi Purchasing (Release 2.3)
*-----------------------------------------------------------------------
    DATA: ls_shlp_desc   TYPE shlp_descr,
          lt_ddshretval  TYPE TABLE OF ddshretval,
          lt_output      TYPE STANDARD TABLE OF seahlpres,
          ls_commitments TYPE v_fmci_f4,
          lt_commitments TYPE TABLE OF v_fmci_f4,
          ls_ddshselopt  TYPE ddshselopt,
          lt_gl_accounts TYPE zcl_zedm_searchhelp_mpc=>tt_refdata,
          lv_fipex       TYPE fipex,
          lv_saknr       TYPE saknr.

    lt_gl_accounts = it_gl_accounts.
    CLEAR et_gl_accounts.

    CALL FUNCTION 'F4IF_GET_SHLP_DESCR'
      EXPORTING
        shlpname = 'FIPEX_2'
        shlptype = 'SH'
      IMPORTING
        shlp     = ls_shlp_desc.
    .
    ls_ddshselopt-shlpname = 'FIPEX_2'.
    ls_ddshselopt-option = 'EQ'.
    ls_ddshselopt-sign = 'I'.

    ls_ddshselopt-shlpfield = 'FIVOR'.
    ls_ddshselopt-low = '30'.
    APPEND ls_ddshselopt TO ls_shlp_desc-selopt.

    ls_ddshselopt-shlpfield = 'POTYP'.
    ls_ddshselopt-low = '3'.
    APPEND ls_ddshselopt TO ls_shlp_desc-selopt.

    ls_ddshselopt-shlpfield = 'FIKRS'.
    ls_ddshselopt-low = 'FM01'.
    APPEND ls_ddshselopt TO ls_shlp_desc-selopt.

    ls_ddshselopt-shlpfield = 'FIPEX'.
    LOOP AT lt_gl_accounts INTO DATA(ls_gl_account).
      CALL FUNCTION 'CONVERSION_EXIT_ALPHA_OUTPUT'
        EXPORTING
          input  = ls_gl_account-key
        IMPORTING
          output = lv_fipex.
      ls_ddshselopt-low = lv_fipex.
      APPEND ls_ddshselopt TO ls_shlp_desc-selopt.
    ENDLOOP.

    CALL FUNCTION 'DD_SHLP_GET_HELPVALUES'
      TABLES
        output_values = lt_output
      CHANGING
        shlp          = ls_shlp_desc.

    LOOP AT lt_output INTO DATA(ls_output).
      CLEAR ls_gl_account.
      MOVE ls_output-string TO ls_commitments.
      CALL FUNCTION 'CONVERSION_EXIT_ALPHA_INPUT'
        EXPORTING
          input  = ls_commitments-fipex
        IMPORTING
          output = lv_saknr.
      READ TABLE lt_gl_accounts INTO ls_gl_account WITH KEY key = lv_saknr.
      IF sy-subrc EQ 0.
        APPEND ls_gl_account TO et_gl_accounts.
      ENDIF.
    ENDLOOP.

  ENDMETHOD.


  METHOD get_gos_attachments.
*----------------------------------------------------------------------*
* METHOD ID:          GET_GOS_ATTACHMENTS
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method retrieves GOS attachments for a purchasing
*                     document
*
*
* AUTHOR:             Dathri Yellamarthy (210983DY)
* CREATE DATE:        23/11/2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000002172: MyFi Purchasing (Release 2.3)
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*----------------------------------------------------------------------- *
*
*-------------------------------------------------------------------------


    DATA: lv_instid TYPE gos_s_obj-instid,
          lt_typeid TYPE RANGE OF gos_s_obj-typeid.

    lv_instid = iv_document && '%'.
    lt_typeid = VALUE #( sign = 'I' option = 'EQ' ( low = 'BUS2014' ) ).

    SELECT DISTINCT instid_a, typeid_a, catid_a FROM srgbtbrel
      WHERE instid_a LIKE @lv_instid AND
            typeid_a IN @lt_typeid AND
            catid_a = 'BO'
      INTO TABLE @DATA(lt_gos_attachments).

    LOOP AT lt_gos_attachments ASSIGNING FIELD-SYMBOL(<fs_gos>).

      TRY.
          DATA(lo_gos) = cl_gos_api=>create_instance( EXPORTING is_object = VALUE gos_s_obj( instid = <fs_gos>-instid_a
            typeid = <fs_gos>-typeid_a
            catid = <fs_gos>-catid_a ) ).
        CATCH cx_gos_api INTO DATA(lx_gos_api).

      ENDTRY.
      IF NOT lo_gos IS INITIAL.
        TRY.
            DATA(lt_attach_list) = lo_gos->get_atta_list( ).

          CATCH cx_gos_api INTO lx_gos_api .

        ENDTRY.
        IF NOT lt_attach_list IS INITIAL.
          DELETE lt_attach_list WHERE tech_type = 'ZSSP_OA'.
          DELETE lt_attach_list WHERE atta_cat = 'ARL'.
*          DELETE lt_attach_list WHERE filesize is INITIAL.
          APPEND LINES OF lt_attach_list TO et_attach_list.
        ENDIF.
      ENDIF.

    ENDLOOP.

  ENDMETHOD.


  METHOD get_line_total.
*----------------------------------------------------------------------*
* METHOD ID:          GET_LINE_TOTAL
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method calculates the gross line amount.
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        12.06.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 12.06.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
*-----------------------------------------------------------------------

    DATA: lv_net_amt TYPE wrbtr.

    lv_net_amt = iv_net_amt.
    zcl_mfp_utilities=>calculate_tax(
          EXPORTING
            iv_bukrs = iv_comp_code                 " Company Code
            iv_waers = iv_currency                " Currency Key
            iv_mwskz = iv_tax_code                 " Sales Tax Code
            iv_wrbtr = lv_net_amt                 " Amount in document currency
            iv_koart = 'M'              " Account Type
          RECEIVING
            rv_wmwst = DATA(lv_wmwst)                 " Amount in document currency
        ).
    rv_gross_amt = lv_net_amt + lv_wmwst.

  ENDMETHOD.


  METHOD get_mime_connect_for_doc.
*----------------------------------------------------------------------*
* METHOD ID:          GET_MIME_CONNECT_FOR_DOC
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method gets the archivelink documents (attachments)
*                     for an MFP document.
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        12.06.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 12.06.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
*-----------------------------------------------------------------------
    DATA: lv_doc_id      TYPE saeobjid,
          lt_file_attrib TYPE TABLE OF toaat,
          lt_connections TYPE toav0_t,
          ls_attachment  TYPE zsmfp_doc_att,
          lt_attachments TYPE zmfp_attachment_tt.

    lv_doc_id = iv_doc_id.
    CHECK lv_doc_id IS NOT INITIAL.
    CALL FUNCTION 'ARCHIV_GET_CONNECTIONS'
      EXPORTING
        object_id       = lv_doc_id
      TABLES
        connections     = lt_connections
        file_attributes = lt_file_attrib
      EXCEPTIONS
        nothing_found   = 1
        OTHERS          = 2.
    IF sy-subrc NE 0.

    ENDIF.

    LOOP AT lt_connections INTO DATA(ls_connection).

      SELECT SINGLE objecttext FROM toasp INTO @DATA(lv_objecttxt) WHERE ar_object = @ls_connection-ar_object AND
                                                                                 language  = @sy-langu.

      READ TABLE lt_file_attrib WITH KEY arc_doc_id = ls_connection-arc_doc_id INTO DATA(ls_file_att).
      ls_attachment-archiv_id = ls_connection-archiv_id.
      ls_attachment-file_name = ls_file_att-filename.
      ls_attachment-attachmentguid = ls_attachment-arc_doc_id = ls_connection-arc_doc_id.
      ls_attachment-zmfp_doc_id = iv_doc_id.
      ls_attachment-ar_object = ls_connection-ar_object.
      ls_attachment-sap_object = ls_connection-sap_object.

      IF ls_attachment-file_name IS INITIAL.
        ls_attachment-file_name = lv_objecttxt.
      ENDIF.
      APPEND ls_attachment TO lt_attachments.
    ENDLOOP.
    et_attachments = lt_attachments.

  ENDMETHOD.


  METHOD get_myfi_docs.
*----------------------------------------------------------------------*
* METHOD ID:          GET_MYFI_DOCS
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method calls the method that retrieves the
*                     objects (documents) for a user.
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        12.06.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 12.06.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
*-----------------------------------------------------------------------
    DATA: lo_myfi_objects TYPE REF TO cl_myobjects_model,
          ls_objtyp_ebeln TYPE zif_mfp_constants=>ty_s_objtyp_ebeln,
          lt_objects      TYPE sgo_t_tre,
          ls_object       TYPE smyotrees,
          lv_user         TYPE uname.

    IF iv_user IS INITIAL.
      lv_user = sy-uname.
    ELSE.
      lv_user = iv_user.
    ENDIF.
    CREATE OBJECT lo_myfi_objects EXPORTING im_uname = lv_user.

    CALL METHOD zcl_mfp_utilities=>get_myfi_objects
      EXPORTING
        io_myfi_objects = lo_myfi_objects
      RECEIVING
        rt_myfi_objects = lt_objects.

    LOOP AT lt_objects  INTO ls_object.

      ls_objtyp_ebeln-ebeln = ls_object-objkey.
      ls_objtyp_ebeln-objtyp = ls_object-objtype.
      IF ls_object-folder EQ zif_mfp_constants=>gc_object_folder .
        APPEND ls_objtyp_ebeln TO et_docs_posted.
      ELSEIF ls_object-folder EQ zif_mfp_constants=>gc_object_folder_drafts.
        APPEND ls_objtyp_ebeln TO et_docs_draft.
      ENDIF.
    ENDLOOP.
  ENDMETHOD.


  METHOD GET_MYFI_OBJECT.
*----------------------------------------------------------------------*
* METHOD ID:          GET_MYFI_OBJECT
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used to retrieve a user's assigned
*                     documents (objects).
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        12.06.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 12.06.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
*-----------------------------------------------------------------------
    DATA: lt_user_objects TYPE sgo_t_tre.

    lt_user_objects = get_myfi_objects( io_myfi_objects = io_myfi_objects ) .
    READ TABLE lt_user_objects WITH KEY objkey = iv_ebeln objtype = iv_objtyp INTO rs_user_object.
  ENDMETHOD.


  METHOD get_myfi_objects.
*----------------------------------------------------------------------*
* METHOD ID:          GET_MYFI_OBJECTS
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used to retrieve a user's assigned
*                     documents (objects).
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        12.06.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 12.06.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
*-----------------------------------------------------------------------
    TRY.
        io_myfi_objects->if_myobjects_model~get_objects(
          RECEIVING
            re_objects                = rt_myfi_objects                 " Transfer Table for MyObjects
          EXCEPTIONS
            node_definition_not_exist = 1                " This Node Does Not Exist
            objecttype_not_allowed    = 2                " This node does not allow the object type
            filter_node_not_exist     = 3                " The User Does Not Have the Node
            personalisation_error     = 4                " Error Accessing Personalization Data
            db_error                  = 5                " DB Error when Reading
            OTHERS                    = 6
        ).
    ENDTRY.

    DELETE rt_myfi_objects WHERE folder NE zif_mfp_constants=>gc_object_folder and
                                 folder NE zif_mfp_constants=>gc_object_folder_drafts.
  ENDMETHOD.


  METHOD get_myfi_objects_draft.
*----------------------------------------------------------------------*
* METHOD ID:          GET_MYFI_OBJECTS_DRAFT
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used to retrieve a user's assigned
*                     draft documents (objects).
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        12.06.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 12.06.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
*-----------------------------------------------------------------------
    TRY.
        io_myfi_objects->if_myobjects_model~get_objects(
          RECEIVING
            re_objects                = rt_myfi_objects                 " Transfer Table for MyObjects
          EXCEPTIONS
            node_definition_not_exist = 1                " This Node Does Not Exist
            objecttype_not_allowed    = 2                " This node does not allow the object type
            filter_node_not_exist     = 3                " The User Does Not Have the Node
            personalisation_error     = 4                " Error Accessing Personalization Data
            db_error                  = 5                " DB Error when Reading
            OTHERS                    = 6
        ).
    ENDTRY.

    DELETE rt_myfi_objects WHERE folder NE zif_mfp_constants=>gc_object_folder_drafts.

  ENDMETHOD.


  METHOD get_next_doc_num.
*----------------------------------------------------------------------*
* METHOD ID:          GET_NEXT_DOC_NUM
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method gets the next PO or OA document number.
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        12.06.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 12.06.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
*-----------------------------------------------------------------------
    DATA: lv_nr TYPE nrobj.

    CASE iv_category.
      WHEN zif_mfp_constants=>gc_doc_type-po.
        lv_nr = 'P0'.
      WHEN zif_mfp_constants=>gc_doc_type-oa.
        lv_nr = 'C0'.
      WHEN OTHERS.
        RETURN.
    ENDCASE.

    CALL FUNCTION 'NUMBER_GET_NEXT'
      EXPORTING
        nr_range_nr = lv_nr
        object      = zif_mfp_constants=>e_changelog-mmobjectclass
      IMPORTING
        number      = rv_ebeln.
  ENDMETHOD.


  method get_next_request_num.
*----------------------------------------------------------------------*
* METHOD ID:          GET_NEXT_REQUEST_NUM
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method gets the next Request ID document number.
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        12.06.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 12.06.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
*-----------------------------------------------------------------------

    data:
      lv_range_nr        type inri-nrrangenr.

    lv_range_nr = '50'.

    call function 'NUMBER_GET_NEXT'
      exporting
        nr_range_nr             = lv_range_nr
        object                  = 'ZFSS'
      importing
        number                  = rv_request_id
      exceptions
        interval_not_found      = 1
        number_range_not_intern = 2
        object_not_found        = 3
        quantity_is_0           = 4
        quantity_is_not_1       = 5
        interval_overflow       = 6
        buffer_overflow         = 7
        others                  = 8.

* Need to handle exceptions

  endmethod.


  METHOD get_nps_costcentres.
*----------------------------------------------------------------------*
* METHOD ID:          GET_NPS_COSTCENTRES
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2.2).
*                     This method returns list of NPS specific costcentres
*
* AUTHOR:             Dathri Yellamarthy(210983DY)
* CREATE DATE:        10.10.2023
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          S 6000003027: MyFi Continuous Improvement November Rel
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 10/10/23 210983DY RD2K924373 DS-11-32-07-01 6000003027: MyFi Continuous Improvement November Rel
*-----------------------------------------------------------------------

    SELECT kostl, datbi, bukrs, abtei FROM csks INTO TABLE @rt_nps_costcentres
      WHERE kokrs = 'CA01' AND bukrs = '1000' AND
      abtei = '1111'.

  ENDMETHOD.


  METHOD get_oa_details.
*----------------------------------------------------------------------*
* METHOD ID:          GET_OA_DETAILS
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method gets the contract details via a BAPI call.
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        12.06.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 12.06.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
*-----------------------------------------------------------------------
    DATA ls_ekko TYPE ekko.

    CALL FUNCTION 'ME_EKKO_SINGLE_READ'
      EXPORTING
        pi_ebeln         = iv_ebeln
*       PI_BYPASSING_BUFFER       =
*       PI_REFRESH_BUFFER         =
      IMPORTING
        po_ekko          = ls_ekko
      EXCEPTIONS
        no_records_found = 1
        OTHERS           = 2.
    IF sy-subrc <> 0.
* Implement suitable error handling here
    ENDIF.

    IF ls_ekko-bstyp = zif_mfp_constants=>gc_doc_type-oa.
      CALL FUNCTION 'BAPI_CONTRACT_GETDETAIL'
        EXPORTING
          purchasingdocument    = ls_ekko-ebeln
          item_data             = iv_get_items
          account_data          = iv_get_account
          condition_data        = iv_get_conditions
          text_data             = iv_get_texts
          partner_data          = iv_get_partner
          release_data          = iv_get_release
        IMPORTING
          header                = es_header
        TABLES
          item                  = et_item
          account               = et_account
          delivery_address      = et_delivery_address
          item_cond_validity    = et_item_cond_validity
          item_condition        = et_item_condition
          item_cond_scale_value = et_item_cond_scale_value
          item_cond_scale_quan  = et_item_cond_scale_quan
          item_text             = et_item_text
          header_text           = et_header_text
          head_cond_validity    = et_head_cond_validity
          head_condition        = et_head_condition
          head_cond_scale_val   = et_head_cond_scale_val
          head_cond_scale_quan  = et_head_cond_scale_quan
          partner               = et_partner
          release_docu          = et_release_docu
          extensionout          = et_extensionout
          return                = et_return.
    ENDIF.
  ENDMETHOD.


  METHOD get_pernr_from_user.
*----------------------------------------------------------------------*
* METHOD ID:          GET_PERNR_FROM_USER
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method gets the PERNR for a user ID.
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        12.06.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 12.06.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
* 30/11/20 210983DY  RD2K919656 DS-11-32-07-01 S 6000002172: MyFi Purchasing (Release 2.3)
*                                              Remove leading zeros for a PERNR
*-----------------------------------------------------------------------


    SELECT SINGLE pernr FROM pa0105 WHERE usrid EQ @iv_user AND subty EQ '0001' AND begda LE @sy-datum AND endda GE @sy-datum INTO @rv_pernr.


    IF NOT rv_pernr IS INITIAL.
      IF NOT  rv_pernr = iv_user.
        rv_pernr = iv_user.
      ENDIF.
      SHIFT rv_pernr LEFT DELETING LEADING '0'.
    ENDIF.

  ENDMETHOD.


  METHOD get_porg_from_ccode.
*----------------------------------------------------------------------*
* METHOD ID:          GET_PORG_FROM_CCODE
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method gets the purchasing organisation based
*                     on the company code.
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        12.06.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 12.06.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
*-----------------------------------------------------------------------
    DATA: lt_t001w TYPE TABLE OF t001w,
          ls_t001w TYPE t001w.

    CALL FUNCTION 'K_WERKS_OF_KOKRS'
      EXPORTING
        bukrs     = bukrs
      TABLES
        itab_001w = lt_t001w.
    IF sy-subrc EQ 0.
      LOOP AT lt_t001w INTO ls_t001w.
        SELECT SINGLE ekorg FROM t024w WHERE werks = @ls_t001w-werks INTO @ekorg.
        CONTINUE.
      ENDLOOP.
    ENDIF.
  ENDMETHOD.


  METHOD get_po_consumption.
*----------------------------------------------------------------------*
* METHOD ID:          GET_PO_CONSUMPTION
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2.2).
*                     This method retrieves the PO consumption summary data.
*
* AUTHOR:             Stephen Ning (290977SCN)
* CREATE DATE:        21.09.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000002096 - MyFi Purchasing Release 2.2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 21/09/20 290977SCN RD2K919977 DS-11-32-07-01 S 6000002096: MyFi Purchasing (Release 2.2)
*-----------------------------------------------------------------------

    DATA: lv_dr_cr      TYPE i.

    LOOP AT it_ekbe INTO DATA(ls_ekbe).

      IF ls_ekbe-db_cr_ind EQ 'H'.
        lv_dr_cr = -1.
      ELSE.
        lv_dr_cr = 1.
      ENDIF.

      CASE ls_ekbe-hist_type.
        WHEN 'E'. "GRs
          es_po_con_summ-totaldelivered = es_po_con_summ-totaldelivered + ( ls_ekbe-val_forcur * lv_dr_cr ).
        WHEN 'Q'. "IRs
          es_po_con_summ-totalinvoiced = es_po_con_summ-totalinvoiced + ( ls_ekbe-val_forcur * lv_dr_cr ).
        WHEN OTHERS.
      ENDCASE.

    ENDLOOP.

  ENDMETHOD.


  METHOD get_po_consumption_summary.
*----------------------------------------------------------------------*
* METHOD ID:          GET_PO_CONSUMPTION_SUMMARY
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2.2).
*                     This method retrieves the linked PO consumption summary data for an
*                     OA MFP document.
*
* AUTHOR:             Stephen Ning (290977SCN)
* CREATE DATE:        21.09.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000002096 - MyFi Purchasing Release 2.2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 21/09/20 290977SCN RD2K919977 DS-11-32-07-01 S 6000002096: MyFi Purchasing (Release 2.2)
* 18.12.2023 210983DY RD2K924523,
*                     RD2K924651  6000003043 MyFi Continuous Improvement February Release
*          fix issue with net price calculations
*-----------------------------------------------------------------------

    DATA: lt_ekbe           TYPE bapiekbe_tp,
          lt_ekbe_temp      TYPE bapiekbe_tp,
          lt_item           TYPE bapimepoitem_tp,
          lt_item_po_detail TYPE bapiekpo_tp,
          ls_header         TYPE bapimepoheader,
          lv_tax_value      TYPE wrbtr,
          lv_value          TYPE wrbtr,
          lv_total_value    TYPE ktwrt,
          ls_po_summary     TYPE zcl_zedm_mfp_mpc=>ts_consumptionsummary.

    CLEAR: es_po_con_summ.
    lv_total_value = iv_total_fcurr.

    IF iv_ebeln IS NOT INITIAL.
      CALL FUNCTION 'BAPI_PO_GETDETAIL1'
        EXPORTING
          purchaseorder = iv_ebeln
        IMPORTING
          poheader      = ls_header
        TABLES
          pohistory     = lt_ekbe
          poitem        = lt_item.

      CALL FUNCTION 'BAPI_PO_GETDETAIL'
        EXPORTING
          purchaseorder = iv_ebeln                 " Purchase Order Number
          items         = abap_true
*         history       = abap_true
        TABLES
          po_items      = lt_item_po_detail.
*          po_item_history = lt_ekbe.
    ENDIF.

* Get data from EKAB
    SELECT konnr, ebeln, ebelp, netwr
          FROM ekab INTO TABLE @DATA(lt_ekab)
          WHERE konnr EQ @ls_header-agreement
            AND ebeln EQ @iv_ebeln
          ORDER BY ebeln ASCENDING.

    es_po_con_summ-parentnumber = iv_ebeln.
    es_po_con_summ-currency = iv_currency.
    es_po_con_summ-purchasinggroup = iv_ekgrp.
    CONVERT DATE iv_createdate INTO TIME STAMP es_po_con_summ-createddate TIME ZONE 'UTC' .
    es_po_con_summ-totalordered = zcl_mfp_utilities=>convert_curr_format( iv_amount = lv_total_value iv_curr = iv_currency ).

    LOOP AT lt_item INTO DATA(ls_item) WHERE delete_ind NE zif_mfp_constants=>gc_lock_type-deleted.

      READ TABLE lt_item_po_detail INTO DATA(ls_item_po_detail) WITH KEY po_item = ls_item-po_item
                                                                         del_compl = abap_true.
      IF sy-subrc IS INITIAL.
        DATA(lv_deliv_compl) = abap_true.
      ENDIF.

      CLEAR ls_po_summary.
      IF ls_item-ret_item = abap_true.
        ls_item-quantity = ls_item-quantity * -1.
      ENDIF.
      lt_ekbe_temp = lt_ekbe.
      DELETE lt_ekbe_temp WHERE po_item NE ls_item-po_item.
      IF lt_ekbe_temp IS NOT INITIAL.

        get_po_consumption(
          EXPORTING
            it_ekbe        = lt_ekbe_temp
          IMPORTING
            es_po_con_summ = ls_po_summary
            ).
        es_po_con_summ-totaldelivered = es_po_con_summ-totaldelivered + ls_po_summary-totaldelivered.
        es_po_con_summ-totalinvoiced = es_po_con_summ-totalinvoiced + ls_po_summary-totalinvoiced.

      ENDIF.

      IF ls_item-final_inv EQ abap_false.
        IF ls_item-no_more_gr EQ abap_true.
          IF ls_item-gr_ind EQ abap_true.
            es_po_con_summ-tobeinvoiced = es_po_con_summ-tobeinvoiced + ( ls_po_summary-totaldelivered - ls_po_summary-totalinvoiced ).
          ELSE.
            es_po_con_summ-tobeinvoiced = es_po_con_summ-tobeinvoiced + ( ( ls_item-quantity * ls_item-net_price ) - ls_po_summary-totalinvoiced ).
          ENDIF.
        ELSE.
          es_po_con_summ-tobeinvoiced = es_po_con_summ-tobeinvoiced + ( ( ls_item-quantity * ls_item-net_price ) - ls_po_summary-totalinvoiced ).
        ENDIF.
      ENDIF.

      IF ls_item-gr_ind EQ abap_true AND ls_item-no_more_gr EQ abap_false.
        es_po_con_summ-tobedelivered = es_po_con_summ-tobedelivered + ( ls_item-quantity * ls_item-net_price ) - ls_po_summary-totaldelivered.
      ENDIF.
*      IF ls_item-no_more_gr EQ abap_false.
*        es_po_con_summ-tobedelivered = es_po_con_summ-tobedelivered - ls_po_summary-totaldelivered.
*      ELSE.
**        CLEAR es_po_con_summ-tobedelivered.
*      ENDIF.

      lv_value = ls_item-net_price * ls_item-quantity.

* Clear Value if item has delivery completed, Zero receipts
* and IR is initial
      IF lv_deliv_compl = abap_true AND lt_ekbe_temp IS INITIAL
        AND ls_item-ir_ind = abap_false.
        CLEAR lv_value.
      ENDIF.

* Clear value if Netorder value from EKAB for that particular line item is zero.
      READ TABLE lt_ekab INTO DATA(ls_ekab) WITH KEY ebeln = iv_ebeln
                                                     ebelp = ls_item-po_item.
      IF sy-subrc IS INITIAL AND ls_ekab-netwr = '0.00'.
        CLEAR lv_value.
      ENDIF.

      zcl_mfp_utilities=>calculate_tax(
         EXPORTING
           iv_bukrs = ls_header-comp_code  " Company Code
*           iv_waers = ls_                 " Currency Key
           iv_mwskz = ls_item-tax_code     " Sales Tax Code
           iv_wrbtr = lv_value             " Amount in document currency
           iv_koart = 'S'                  " Account Type
         RECEIVING
           rv_wmwst = lv_tax_value             " Amount in document currency
             ).

      lv_total_value = lv_value + lv_tax_value.
      es_po_con_summ-contracttotalordered = es_po_con_summ-contracttotalordered + lv_total_value.
      CLEAR lv_deliv_compl.
    ENDLOOP.
  ENDMETHOD.


  METHOD get_po_details.
*----------------------------------------------------------------------*
* METHOD ID:          GET_PO_DETAILS
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method gets PO detsils via a BAPI call.
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        12.06.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 12.06.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
*-----------------------------------------------------------------------
    DATA: ls_po_header TYPE bapiekkol,
          ls_ekpo      TYPE ekpo,
          ls_po_item   TYPE bapiekpo,
          ls_ekkn      TYPE ekkn,
          ls_account   TYPE bapiekkn,
          lt_return    TYPE TABLE OF bapireturn.
    CLEAR: et_ekpo, et_ekkn.
    CALL FUNCTION 'BAPI_PO_GETDETAIL'
      EXPORTING
        purchaseorder              = iv_ebeln                 " Purchase Order Number
        items                      = abap_true              " Also Provide Item Data
        account_assignment         = abap_true            " Also Provide Account Assignment Data
        schedules                  = abap_true            " Also Provide Schedule Lines
        history                    = abap_true            " Also Provide PO History
        item_texts                 = abap_true            " Also Provide Item Texts
        header_texts               = abap_true            " Also Provide Header Texts
        services                   = abap_true            " Also Provide Services and Limits
        confirmations              = abap_true            " Also Provide Confirmations
        service_texts              = abap_true            " Also Provide Service Texts
        extensions                 = abap_true            " Also Provide Customer's Own Fields
      IMPORTING
        po_header                  = es_header
        po_address                 = es_address
      TABLES
        po_header_texts            = et_header_text             " PO Header Texts
        po_items                   = et_items                 " Purchase Order Items
        po_item_account_assignment = et_account                 " Account Assignment Data for Item
        po_item_schedules          = et_schedule                 " Schedule Lines for Item
        po_item_confirmations      = et_ven_conf                 " Confirmations for Item
        po_item_texts              = et_item_text                 " Texts for Item
        po_item_history            = et_grir                 " PO History for Item
        po_item_history_totals     = et_totals                 " PO History for Item: Totals
        po_item_limits             = et_limits                 " Limits
        po_item_contract_limits    = et_cont_limits                 " Limits with Contract Reference
        po_item_services           = et_service                 " Services
        po_item_srv_accass_values  = et_service_account                 " Value/Link to Service Account Assignment
        return                     = lt_return                " Return Messages
        po_services_texts          = et_long_text                " Long Texts for Service Line
        extensionout               = et_extensionout.                  " Reference Structure for BAPI Parameters EXTENSIONIN/EXTENSIO

    MOVE-CORRESPONDING lt_return TO et_return.
    LOOP AT et_items INTO ls_po_item.
      ls_ekpo = bapiekpo_2ekpo( is_po_items = ls_po_item ).
      APPEND ls_ekpo TO et_ekpo.
    ENDLOOP.
    LOOP AT et_account INTO ls_account.
      ls_ekkn = bapiekkn_2ekkn( is_bapiekkn = ls_account ).
      APPEND ls_ekkn TO et_ekkn.
    ENDLOOP.
  ENDMETHOD.


METHOD get_po_pdf.
*----------------------------------------------------------------------*
* METHOD ID:          GET_PO_PDF
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     It generates the PO PDF to be attached to an email.
*                     the requester.
*                     This method is a copy of the GET_PO_PDF method
*                     written by Fred Chelashaw on 3 Dec 2019 (RD2K918562)
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        12.06.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 12.06.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
*-----------------------------------------------------------------------
  DATA:
    lt_otf        TYPE otf_t_itcoo,
    lt_lines      TYPE tlinet,
    ls_lines      TYPE tline,
    lv_buffer     TYPE string,
    ls_attachment TYPE soli.

  TRY.
*--- create pdf of PO & convert to BCS attachment format
      CALL FUNCTION 'ECP_PO_OTF_CREATE'
        EXPORTING
          purchase_order = i_ebeln
        TABLES
          otf            = lt_otf
        EXCEPTIONS
          otf_error      = 1
          OTHERS         = 2.
      IF sy-subrc <> 0.
        RAISE EXCEPTION TYPE cx_bo_temporary.
        RETURN.
      ENDIF.

      IF lt_otf is not INITIAL.
        CALL FUNCTION 'CONVERT_OTF'
          EXPORTING
            format        = 'PDF'
            max_linewidth = 132
          TABLES
            otf           = lt_otf
            lines         = lt_lines.
        IF sy-subrc <> 0.
          RAISE EXCEPTION TYPE cx_bo_temporary.
          RETURN.
        ENDIF.
      ENDIF.
    CATCH cx_bo_temporary.
  ENDTRY.
  LOOP AT lt_lines INTO ls_lines.
    TRANSLATE ls_lines USING '~'.
    CONCATENATE lv_buffer ls_lines INTO lv_buffer.
  ENDLOOP.

  TRANSLATE lv_buffer USING '~'.

  DO.
    ls_attachment  = lv_buffer.
    APPEND ls_attachment TO rt_attachment.
    SHIFT lv_buffer LEFT BY 255 PLACES.
    IF lv_buffer IS INITIAL.
      EXIT.
    ENDIF.
  ENDDO.

ENDMETHOD.


  METHOD get_po_total_values.
*----------------------------------------------------------------------*
* METHOD ID:          GET_PO_TOTAL_VALUES
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method calculates the total amount for a PO.
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        12.06.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 12.06.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
*10/06/21 210983DY  RD2K921235  DS-11-32-07-01 S 6000002393: June DFSS release for MyFi Purchasing
*                               Additional logic to ignore deleted line item value from PO Total value
*-----------------------------------------------------------------------
    SELECT a~bukrs, a~netwr, a~mwskz, b~waers FROM ekpo AS a
      INNER JOIN ekko AS b ON a~ebeln EQ b~ebeln
       WHERE a~ebeln EQ @iv_ebeln AND
             a~loekz EQ @space INTO @DATA(ls_cal_tax).
      zcl_mfp_utilities=>calculate_tax(
        EXPORTING
          iv_bukrs = ls_cal_tax-bukrs                 " Company Code
          iv_waers =  ls_cal_tax-waers                " Currency Key
          iv_mwskz = ls_cal_tax-mwskz                 " Sales Tax Code
          iv_wrbtr = ls_cal_tax-netwr                 " Amount in document currency
          iv_koart = 'M'              " Account Type
        RECEIVING
          rv_wmwst = DATA(lv_wmwst)                 " Amount in document currency
      ).
      ev_effwr = ls_cal_tax-netwr + lv_wmwst + ev_effwr.

    ENDSELECT.

  ENDMETHOD.


  METHOD get_prf_change_url.
*----------------------------------------------------------------------*
* METHOD ID:          GET_PRF_CHANGE_URL
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method generates the PRF URL for change mode.
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        12.06.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 12.06.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
* 09.09.24 210983DY RD2K925318 6000003170: MyFi Read-Only
*                           Made changes to Display Edit PRF only for exemption user's
* 21.03.25 210983DY  RD2K925877  S 6000003235: MyFi access after ERP T1B
*                    Enable MyFi based on flags that are controlled with
*                    a maintenance transaction
*-----------------------------------------------------------------------

    DATA: lt_urls       TYPE zgrp_t_data_transfer_struc,
          lv_prf_change TYPE boole_d,
          lv_url        TYPE string,
          lt_agrname    TYPE RANGE OF agr_users-agr_name,
          lt_users      TYPE RANGE OF agr_users-uname.

    lv_prf_change = abap_true.
    SELECT * FROM ztfss_myfi_block INTO TABLE @DATA(lt_myfi_block).
    IF sy-subrc IS INITIAL.

      lt_agrname = VALUE #( FOR ls_exemption IN lt_myfi_block WHERE ( exemptiontype = |ROLE| AND enablesubmit = |X| ) ( sign = 'I'
                                                                 option = 'EQ'
                                                                 low = ls_exemption-exemptionvalue ) ).

      lt_users = VALUE #( FOR ls_exemption IN lt_myfi_block WHERE ( exemptiontype = |USER| AND enablesubmit = |X| ) ( sign = 'I'
                                                     option = 'EQ'
                                                     low = ls_exemption-exemptionvalue ) ).

*   Check if entry for wf-batch exemption value exists
      DATA(lv_batchuser) = VALUE #( lt_myfi_block[ exemptiontype = |USER| exemptionvalue = |WF-BATCH| ]-exemptionvalue OPTIONAL ).
      IF lv_batchuser = 'WF-BATCH'.

* Check if loggedone user is in exemption list of users
        IF line_exists( lt_users[ low = sy-uname ] ).
          DATA(lv_user_exempt) = abap_true.
          lv_prf_change = abap_true.
        ELSE.
* check if user has one of the exemption roles assigned
          IF NOT lt_agrname IS INITIAL.
            SELECT * FROM agr_users INTO TABLE @DATA(lt_agr_users) "#EC CI_GENBUFF
           WHERE agr_name IN @lt_agrname
           AND   uname EQ @sy-uname
           AND   from_dat <= @sy-datum
           AND   to_dat   >= @sy-datum
           AND   exclude  NE @abap_true.
            IF lt_agr_users IS INITIAL.
              lv_user_exempt = abap_false.
              lv_prf_change = abap_false.
            ENDIF.
          ENDIF.
        ENDIF.

      ENDIF.

    ENDIF.

    SELECT SINGLE * FROM zgrp_c_header WHERE doc_no = @iv_ebeln AND src_doc_typ = @iv_grp_doc_type INTO @DATA(ls_grp_header).

    IF sy-subrc EQ 0 AND ls_grp_header-status NE zif_grp_constants=>gc_status-blocked AND ls_grp_header-status NE zif_grp_constants=>gc_status-published AND
          ls_grp_header-status NE zif_grp_constants=>gc_status-below_threshold.
      zcl_prf_called_from_bapi=>before_bapi_call( ).
      zcl_grp_assist=>trigger_grp_capture(
        EXPORTING
          iv_hdr_key = ls_grp_header-header_key
          iv_doc_no = ls_grp_header-doc_no
          iv_co_code = ls_grp_header-compcode
          iv_doc_type = ls_grp_header-src_doc_typ
          iv_open_in_change_mode = abap_false
          iv_trigger_scrn        = abap_false
*          iv_check_only          = abap_true
*        iv_powl_trg            = abap_false
        IMPORTING
*        et_return              =
          et_trigger_urls        = lt_urls
*        es_header_det          =                  " Header table of GRP
      ).

      LOOP AT lt_urls INTO DATA(ls_url).
        lv_url = |{ lv_url }{ ls_url-data }|.
      ENDLOOP.
      IF lv_prf_change = abap_true.
        REPLACE REGEX 'APPL_RUN_MODE=03' IN lv_url WITH 'APPL_RUN_MODE=02'.
      ENDIF.

      rv_url = lv_url.
    ENDIF.


  ENDMETHOD.


  METHOD get_prf_display_url.
*----------------------------------------------------------------------*
* METHOD ID:          GET_PRF_DISPLAY_URL
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method generates the PRF URL for display mode.
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        12.06.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 12.06.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
*-----------------------------------------------------------------------
    DATA: lt_urls TYPE zgrp_t_data_transfer_struc,
          lv_url  TYPE string.

    SELECT SINGLE * FROM zgrp_c_header WHERE doc_no = @iv_ebeln AND src_doc_typ = @iv_grp_doc_type INTO @DATA(ls_grp_header).

    IF sy-subrc EQ 0.
      zcl_prf_called_from_bapi=>before_bapi_call( ).
      zcl_grp_assist=>trigger_grp_capture(
        EXPORTING
          iv_hdr_key = ls_grp_header-header_key
          iv_doc_no = ls_grp_header-doc_no
          iv_co_code = ls_grp_header-compcode
          iv_doc_type = ls_grp_header-src_doc_typ
          iv_open_in_change_mode = abap_false
          iv_trigger_scrn        = abap_false
*          iv_check_only          = abap_true
*        iv_powl_trg            = abap_false
        IMPORTING
*        et_return              =
          et_trigger_urls        = lt_urls
*        es_header_det          =                  " Header table of GRP
      ).

      LOOP AT lt_urls INTO DATA(ls_url).
        lv_url = |{ lv_url }{ ls_url-data }|.
      ENDLOOP.

      rv_url = lv_url.
    ENDIF.

  ENDMETHOD.


  METHOD get_sensitive_ekkn.
*----------------------------------------------------------------------*
* METHOD ID:          GET_SENSITIVE_EKKN
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used to retrieve the sensitive field
*                     data for cost assignments - used to test if changes
*                     to these have occurred in the UI5 app.
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        12.06.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 12.06.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
* 21.10.20 290977SCN RD2K919656 DS-11-32-07-01 S 6000002172: MyFi Purchasing (Release 2.3)
*-----------------------------------------------------------------------

    DATA: ls_ekkn_totals TYPE zsmfp_ekkn_totals,
          ls_temp_ekkn   TYPE ekkn,
          ls_ekkn        TYPE ekkn,
          is_ekpo        TYPE ekpo,
          lv_effwr       TYPE effwr.

    FIELD-SYMBOLS: <ls_ekkn_temp_total> TYPE zsmfp_ekkn_totals.

    LOOP AT it_ekkn INTO ls_ekkn where loekz ne zif_mfp_constants=>gc_lock_type-deleted.
      "Get Total Value of EKKN Line
      CLEAR ls_ekkn_totals.
      CLEAR lv_effwr.
      READ TABLE it_ekpo WITH KEY ebeln = ls_ekkn-ebeln ebelp = ls_ekkn-ebelp INTO is_ekpo.
      IF is_ekpo-loekz EQ zif_mfp_constants=>gc_lock_type-deleted.
        lv_effwr = 0.
      ELSE.
        lv_effwr = is_ekpo-effwr.
      ENDIF.
      IF ls_ekkn-vproz GT 0.
        ls_ekkn_totals-effwr_new = lv_effwr * ls_ekkn-vproz / 100.
      ELSE.
        ls_ekkn_totals-effwr_new = lv_effwr.
      ENDIF.

      IF is_aa_combo-gl EQ abap_true.
        ls_temp_ekkn-sakto = ls_ekkn-sakto.
        ls_ekkn_totals-acc_assign = | { ls_ekkn_totals-acc_assign }'GL-{ ls_ekkn-sakto }' | .
      ENDIF.
      IF is_aa_combo-cc EQ abap_true.
        ls_temp_ekkn-kostl = ls_ekkn-kostl.
        ls_ekkn_totals-acc_assign = | { ls_ekkn_totals-acc_assign }'CC-{ ls_ekkn-kostl }' | .
      ENDIF.
      IF is_aa_combo-io EQ abap_true.
        ls_temp_ekkn-aufnr = ls_ekkn-aufnr.
        ls_ekkn_totals-acc_assign = | { ls_ekkn_totals-acc_assign }'IO-{ ls_ekkn-aufnr }' | .
      ENDIF.
      IF is_aa_combo-wbs EQ abap_true.
        ls_temp_ekkn-ps_psp_pnr = ls_ekkn-ps_psp_pnr.
        ls_ekkn_totals-acc_assign = | { ls_ekkn_totals-acc_assign }'WBS-{ ls_ekkn-ps_psp_pnr }' | .
      ENDIF.
      IF is_aa_combo-esp EQ abap_true.
        ls_temp_ekkn-zzesp = ls_ekkn-zzesp.
        ls_ekkn_totals-acc_assign = | { ls_ekkn_totals-acc_assign }'ESP-{ ls_ekkn-zzesp }' | .
      ENDIF.
      IF is_aa_combo-asset EQ abap_true.
        ls_temp_ekkn-anln1 = ls_ekkn-anln1.
        ls_ekkn_totals-acc_assign = | { ls_ekkn_totals-acc_assign }'ASSET-{ ls_ekkn-anln1 }' | .
      ENDIF.

      CONDENSE ls_ekkn_totals-acc_assign.
** check if combo exists in lt_ekkn_tested
      READ TABLE rt_ekkn
            WITH KEY
                acc_assign = ls_ekkn_totals-acc_assign
            ASSIGNING <ls_ekkn_temp_total> .
      IF <ls_ekkn_temp_total> IS ASSIGNED.
        <ls_ekkn_temp_total>-effwr_new = <ls_ekkn_temp_total>-effwr_new + ls_ekkn_totals-effwr_new.  " Assuming same currencies on all line items.
        UNASSIGN <ls_ekkn_temp_total>.
      ELSE.
        APPEND ls_ekkn_totals TO rt_ekkn.
      ENDIF.
    ENDLOOP.


  ENDMETHOD.


  METHOD get_status_desc.
*----------------------------------------------------------------------*
* METHOD ID:          GET_STATUS_DESC
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method retrieves the statis description.
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        12.06.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 12.06.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
*-----------------------------------------------------------------------
    DATA: lt_status_desc TYPE TABLE OF dd07v,
          ls_status_desc TYPE dd07v.

    CALL FUNCTION 'DD_DOMVALUES_GET'
      EXPORTING
        domname   = 'ZMFP_DOCUMENT_STATUS'
        text      = abap_true
*       LANGU     = ' '
*       BYPASS_BUFFER        = ' '
*     IMPORTING
*       RC        =
      TABLES
        dd07v_tab = lt_status_desc
*     EXCEPTIONS
*       WRONG_TEXTFLAG       = 1
*       OTHERS    = 2
      .
    IF sy-subrc <> 0.
* Implement suitable error handling here
    ENDIF.

    READ TABLE lt_status_desc INTO ls_status_desc WITH KEY domvalue_l = iv_status.
    rv_status_desc = ls_status_desc-ddtext.

  ENDMETHOD.


  METHOD get_uom.
*----------------------------------------------------------------------*
* METHOD ID:          GET_UOM
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2.2).
*                     This method retrieves a commercial unit of measure
*
* AUTHOR:             Stephen Ning (290977SCN)
* CREATE DATE:        21.09.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000002096 - MyFi Purchasing Release 2.2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 21/09/20 290977SCN RD2K919977 DS-11-32-07-01 S 6000002096: MyFi Purchasing (Release 2.2)
*-----------------------------------------------------------------------
    SELECT SINGLE t~mseh3 AS key
                  FROM t006 AS m
                  LEFT OUTER JOIN t006a AS t
                    ON m~msehi = t~msehi AND t~spras = sy-langu
                  INTO ev_uom_convert
                  WHERE m~msehi EQ iv_uom.
  ENDMETHOD.


  METHOD get_user_delegation.
*----------------------------------------------------------------------*
* METHOD ID:          GET_USER_DELEGATION
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method retrieves the delegation for a user.
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        12.06.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 12.06.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
* 16.06.20 290977SCN RD2K919514 DS-11-32-07-01 changed
*          070667JPS
* 21/09/20 290977SCN RD2K919977 DS-11-32-07-01 S 6000002096: MyFi Purchasing (Release 2.2)
* 15/06/21 210983DY  RD2K921236 DS-11-32-07-01 S 6000002416: DFG BAR 2021-13 S23 Variable Delegation
* 25/01/22  210983DY RD2K922364   6000002623: MyFi Applications (February Release)
*-----------------------------------------------------------------------
    DATA: lv_usrid TYPE sysid.
    lv_usrid = iv_userid.

    DATA: lt_subtype TYPE RANGE OF subtyp,
          lv_num_71  TYPE p,
          lv_num_70  TYPE p.

    lt_subtype = VALUE #( sign = 'I' option = 'EQ' ( low = '0070' )
                                                   ( low = '0071' ) ).

    SELECT
       a~plans, d~subty, d~htext FROM pa0001 AS a
      INNER JOIN pa0105 AS b ON a~pernr EQ b~pernr
      INNER JOIN hrp1010 AS c ON a~plans = c~objid
      INNER JOIN t777w AS d ON ( c~hilfm = d~hilfm AND
      c~subty = d~subty )
      INTO TABLE @DATA(lt_t777w)
      WHERE b~usrid EQ @lv_usrid AND
            a~begda LE @sy-datum AND
            a~endda GE @sy-datum AND
            b~begda LE @sy-datum AND
            b~endda GE @sy-datum AND
            c~begda LE @sy-datum AND
            c~endda GE @sy-datum AND
            c~subty IN @lt_subtype AND
            d~langu EQ 'E'      AND
            d~subty IN @lt_subtype.
    IF NOT sy-subrc IS INITIAL.

* check if user id exists, in very few cases, user id and pernr are not identical, in such scenarios
* derive relevant User ID

      SELECT SINGLE usrid INTO @lv_usrid FROM pa0105 WHERE pernr EQ @lv_usrid AND subty EQ '0001' AND begda LE @sy-datum AND endda GE @sy-datum.
      IF sy-subrc IS INITIAL.

        SELECT
        d~subty, d~htext FROM pa0001 AS a
              INNER JOIN pa0105 AS b ON a~pernr EQ b~pernr
              INNER JOIN hrp1010 AS c ON a~plans = c~objid
              INNER JOIN t777w AS d ON ( c~hilfm = d~hilfm AND
              c~subty = d~subty )
              INTO CORRESPONDING FIELDS OF TABLE @lt_t777w
              WHERE b~usrid EQ @lv_usrid AND
                    a~begda LE @sy-datum AND
                    a~endda GE @sy-datum AND
                    b~begda LE @sy-datum AND
                    b~endda GE @sy-datum AND
                    c~begda LE @sy-datum AND
                    c~endda GE @sy-datum AND
                    c~subty IN @lt_subtype AND
                    d~langu EQ 'E'       AND
                    d~subty IN @lt_subtype.

      ENDIF.

    ENDIF.

    IF NOT lt_t777w IS INITIAL.

      DELETE lt_t777w WHERE subty NOT IN lt_subtype.
      IF line_exists( lt_t777w[ subty = '0071' ] ).

        DATA(lv_amount_71) = lt_t777w[ subty = '0071' ]-htext.

        REPLACE ALL OCCURRENCES OF '$' IN lv_amount_71 WITH ''.
        REPLACE ALL OCCURRENCES OF ',' IN lv_amount_71 WITH ''.
        IF lv_amount_71 CO '0123456789 '.
          lv_amount_71 = lv_amount_71.
        ELSE.
          lv_amount_71 = 99999999999.
        ENDIF.

        CALL FUNCTION 'MOVE_CHAR_TO_NUM'
          EXPORTING
            chr             = lv_amount_71
          IMPORTING
            num             = lv_num_71
          EXCEPTIONS
            convt_no_number = 1
            convt_overflow  = 2
            OTHERS          = 3.
        IF NOT sy-subrc IS INITIAL.

        ENDIF.
      ENDIF.
      IF line_exists( lt_t777w[ subty = '0070' ] ).
        DATA(lv_amount_70) = lt_t777w[ subty = '0070' ]-htext.

        REPLACE ALL OCCURRENCES OF '$' IN lv_amount_70 WITH ''.
        REPLACE ALL OCCURRENCES OF ',' IN lv_amount_70 WITH ''.
        IF lv_amount_70 CO '0123456789 '.
          lv_amount_70 = lv_amount_70.
        ELSE.
          lv_amount_70 = 99999999999.
        ENDIF.

        CALL FUNCTION 'MOVE_CHAR_TO_NUM'
          EXPORTING
            chr             = lv_amount_70
          IMPORTING
            num             = lv_num_70
          EXCEPTIONS
            convt_no_number = 1
            convt_overflow  = 2
            OTHERS          = 3.
        IF NOT sy-subrc IS INITIAL.

        ENDIF.
      ENDIF.

    ENDIF.

    IF lv_num_71 GT lv_num_70.

      DATA(lv_amount) = lv_num_71.
    ELSE.
      lv_amount = lv_num_70.

    ENDIF.

    rv_delegation_limit = lv_amount.



  ENDMETHOD.


  METHOD get_vendor_currency.
*----------------------------------------------------------------------*
* METHOD ID:          GET_VENDOR_CURRENCY
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method retrieves order currency for Vendor
*
*
* AUTHOR:             Dathri Yellamarthy (210983DY)
* CREATE DATE:        08/07/2022
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          S 6000002777: MyFi Continuous Improvement August Release
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*----------------------------------------------------------------------- *
* 19.05.2023 210983DY RD2K923926  6000002940: BAR 2023-06Re-purposing of company code 3000
*                                 Change mapping for cc 3000 to purch org 3000
* 12.04.2024 210983DY RD2K924833 6000003103: Safety Regulator MyFi Changes
*-------------------------------------------------------------------------


    DATA: lv_purch_org TYPE ekorg.
    ev_permitted_payee = abap_false.

* Map Company Code to Purchasing Org
*    lv_purch_org = COND char4(
*     WHEN iv_company = '1000' OR iv_company = '2000' THEN '1000'
*     WHEN iv_company = '3000' THEN '3000'
*     WHEN iv_company = '4100' OR iv_company = '4200' OR iv_company = '4300' THEN '4000'
*     WHEN iv_company = '5000' OR iv_company = '5300' THEN '5000'
*     WHEN iv_company = '6000' THEN '6000'
*     ).

    SELECT SINGLE a~ekorg INTO @lv_purch_org
         FROM t024w AS a
         INNER JOIN t001w AS b
         ON b~werks EQ a~werks
         INNER JOIN t001k AS c
         ON c~bwkey EQ b~bwkey
         WHERE c~bukrs EQ @iv_company.

*  Get Order currency for Vendor
    SELECT SINGLE waers FROM lfm1 INTO @ev_currency WHERE lifnr = @iv_vendor AND
                                                          ekorg = @lv_purch_org.

*  Check if Vendor has Permitted Payees
    SELECT SINGLE lifnr FROM lfza INTO @DATA(lv_permitted_payee) WHERE lifnr = @iv_vendor.
    IF sy-subrc IS INITIAL. ev_permitted_payee = abap_true. ENDIF.


  ENDMETHOD.


  METHOD get_vendor_name.
*----------------------------------------------------------------------*
* METHOD ID:          GET_VENDOR_NAME
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method retrieves the delegation for a user.
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        12.06.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 12.06.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
* 30.08.22 010965MI  RD2K923068 DS-11-32-07-01 	S 6000002812: MyFi Continuous Improvement October - Performance
*-----------------------------------------------------------------------
    IF iv_lifnr IS NOT INITIAL.
      SELECT SINGLE name1 FROM lfa1 WHERE lifnr EQ @iv_lifnr INTO @rv_name1.
    ELSE.
      CLEAR rv_name1.
    ENDIF.
  ENDMETHOD.


  METHOD import_header.
*----------------------------------------------------------------------*
* METHOD ID:          IMPORT_HEADER
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method retrieves the document header from
*                     memory.
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        12.06.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 12.06.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
*-----------------------------------------------------------------------

    DATA: ls_ptab TYPE zsmfp_memory_header,
          lt_ptab TYPE STANDARD TABLE OF zsmfp_memory_header.

    ls_ptab-name = name.
    ls_ptab-value = value.
    APPEND ls_ptab TO lt_ptab.
    IMPORT lt_ptab = lt_ptab FROM MEMORY ID id.

    READ TABLE lt_ptab INTO ls_ptab INDEX 1.
    value = ls_ptab-value.

  ENDMETHOD.


  METHOD is_asa_empl.
*----------------------------------------------------------------------*
* METHOD ID:          IA_ASA_EMPL
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2.2).
*                     This method checks if logged on user is authorized to process ASA
*                     documents
*
* AUTHOR:             Dathri Yellamarthy(210983DY)
* CREATE DATE:        10.10.2023
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          S 6000003027: MyFi Continuous Improvement November Rel
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 10/10/23 210983DY RD2K924373 DS-11-32-07-01 6000003027: MyFi Continuous Improvement November Rel
*-----------------------------------------------------------------------

    CONSTANTS : c_stype          TYPE otype VALUE 'S',
                lc_fss_para_name TYPE rvari_vnam VALUE 'ZFSS_MYFI_ASA_AUTHS'.

    DATA: lt_resul       TYPE TABLE OF objec,
          lt_agrname     TYPE RANGE OF agr_users-agr_name,
          lt_resul_struc TYPE TABLE OF struc.

* Check if logged-on user is from Systeam or MyFi Team
* Get the roles maintained under parameter 'ZFSS_MYFI_ASA_AUTHS' in Txn STVARVC
    SELECT * INTO TABLE @DATA(lt_tvarv) FROM tvarvc WHERE name EQ @lc_fss_para_name.
    IF sy-subrc IS INITIAL.
      lt_agrname = VALUE #( FOR ls_varv IN lt_tvarv ( sign = 'I'
                                                              option = 'EQ'
                                                              low = ls_varv-low ) ).
      SELECT * FROM agr_users INTO TABLE @DATA(lt_agr_users) "#EC CI_GENBUFF
          WHERE agr_name IN @lt_agrname
          AND  uname EQ @sy-uname
          AND   from_dat <= @sy-datum
          AND   to_dat   >= @sy-datum
          AND   exclude  NE @abap_true.

      IF sy-subrc IS INITIAL.
        rs_asa_empl-is_fo_empl = abap_true.
        EXIT.
      ENDIF.
    ENDIF.

* Get org units maintained in config table for ASA
    SELECT * FROM ztfss_mfp_asa INTO TABLE @DATA(lt_asa_org).

* Get PERNR of logged-on user
    SELECT SINGLE pernr FROM pa0105 INTO @DATA(lv_pernr) WHERE usrid = @sy-uname AND subty = '0001'.
    IF sy-subrc IS INITIAL.
*  Get Position of the user
      SELECT SINGLE plans FROM pa0001 INTO @DATA(lv_plans) WHERE pernr = @lv_pernr
        AND endda GE @sy-datum
        AND begda LE @sy-datum.
    ENDIF.
* Get reporting org structure of position
    IF NOT lv_plans IS INITIAL.
      CALL FUNCTION 'RH_STRUC_GET'
        EXPORTING
          act_otype       = c_stype
          act_objid       = lv_plans
          act_wegid       = 'P-S-O-O'
          act_begda       = sy-datum
          act_endda       = sy-datum
          authority_check = ' '
        TABLES
          result_objec    = lt_resul
          result_struc    = lt_resul_struc
        EXCEPTIONS
          OTHERS          = 3.
* Check if any of the returned org units are part of config table
      LOOP AT lt_asa_org INTO DATA(ls_asa_org).
        READ TABLE lt_resul_struc INTO DATA(ls_struc) WITH KEY objid = ls_asa_org-orgunit.
        IF sy-subrc IS INITIAL.
          CASE ls_asa_org-emp_type.
            WHEN 'ASA'.
              rs_asa_empl-is_asa_empl = abap_true.
              EXIT.
            WHEN 'NPS'.
              rs_asa_empl-is_fo_empl = abap_true.
              EXIT.
            WHEN OTHERS.
          ENDCASE.
        ENDIF.
      ENDLOOP.

    ENDIF.
  ENDMETHOD.


  METHOD is_l4l.
*----------------------------------------------------------------------*
* METHOD ID:          IS_L4L
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method determines if a contract is a like-for-like
*                     contract.
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        12.06.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 12.06.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
*-----------------------------------------------------------------------

    IF iv_ebeln IS NOT INITIAL.
      SELECT SINGLE category FROM ztmfp_doc_header WHERE zmfp_doc_id = @iv_ebeln INTO @iv_category.
    ENDIF.
    IF iv_category EQ zif_mfp_constants=>gc_myfi_doc_type-l4l_oa OR iv_category EQ zif_mfp_constants=>gc_myfi_doc_type-l4l_po and iv_category is not initial.
      rv_l4l = abap_true.
    ENDIF.
  ENDMETHOD.


  METHOD is_myfi.
*----------------------------------------------------------------------*
* METHOD ID:          IS_MYFI
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method determines if a document is an MFP one.
.
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        12.06.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 12.06.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
*-----------------------------------------------------------------------

    DATA: ls_doc_header TYPE ztmfp_doc_header.

    SELECT SINGLE * FROM  ztmfp_doc_header
                   WHERE  zmfp_doc_id  = @iv_doc_num " AND
*                          changed_in_gui = @abap_false
                    INTO  @DATA(iv_record).

    IF iv_record IS NOT INITIAL.
      is_myfi = abap_true.
    ENDIF.
  ENDMETHOD.


method is_myfi_compatible.
*----------------------------------------------------------------------------------------*
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5 application. It
*                     checks if the document (PO or OA) is displayable and/or editable in
*                     MyFi Purchasing
*
* AUTHOR:             220977FKC
* CREATE DATE:        19.11.2020
*
* ACTIVITY:           AD-11-32-07 - MyFi (Self Service) Purchasing
* DEV SCRIPT:         DS-11-32-07-01 - Self Service Purchasing
*-----------------------------------------------------------------------------------------
* VERSION CONTROL
*
* Date       Author    CTS Req    CR         Description
*-----------------------------------------------------------------------------------------
* 19.11.2020 220977FKC RD2K920274 6000002172 MyFi Purchasing (Release 2.3)
* 23.02.2021 220977FKC RD2K920554 6000002250 MyFi Purchasing (Release 2.4) - Enable PO's
*                                            with no OA in MyFi,
*                                            Turn off check for multi currency agreements
* 01.04.2021 220977FKC RD2K920896 6000002310 MyFi Purchasing (April Defects), OData msg
*                                            issue, updated to use context message manger
* 05/11/21 210983DY  RD2K922034 DS-11-32-07-01 S6000002550: MyFi Applications (December Release)
*                    Additional code to enable Multi Account Assignment
*----------------------------------------------------------------------------------------*

  constants:
    lc_knttp_asset_unknown  type knttp value 'X'.

  data:
    ls_textid            type scx_t100key,
    l_bapi_msg           type bapi_msg,
    l_message            type string,
    lo_message_container type ref to /iwbep/if_message_container,
    l_ebeln              type ebeln,
    l_multi_curr_oa      type abap_bool,
    ls_lineitem          type zcl_zedm_mfp_mpc=>ts_lineitem.

*--- document id (ebeln)
  if is_po_deep is not initial.
    l_ebeln = is_po_deep-po_number.
  elseif is_oa_deep is not initial.
    l_ebeln = is_oa_deep-contractnumber.
  else.
    return.
  endif.

*--- read document info
  select single bstyp, bsart, unsez
    from ekko
    into (@data(l_bstyp), @data(l_bsart), @data(l_unsez))
    where ebeln = @l_ebeln.

  if ( l_bstyp = zif_mfp_constants=>gc_mm_doc_cat-oa and l_bsart = zif_mfp_constants=>gc_mm_doc_type-oa )
  or ( l_bstyp = zif_mfp_constants=>gc_mm_doc_cat-po and l_bsart = zif_mfp_constants=>gc_mm_doc_type-po ).

*===> PO checks
    if is_po_deep is not initial.

*--- check that PO has an OA
      if is_po_deep-agreement is not initial.

*--- lookup additional OA details
        select single bsart, waers
          from ekko
          into (@data(l_oa_bsart), @data(l_oa_waers))
          where ebeln = @is_po_deep-agreement.

*--- check that the OA is not a value contract
        if l_oa_bsart ne zif_mfp_constants=>gc_mm_doc_type-oa.
          message e043(zmfp) with is_po_deep-agreement into l_bapi_msg.
          l_message = append_message( i_message = l_message i_append = l_bapi_msg ).
        endif.

*--- check that the OA does not have multiple currencies
* Turn off multiple currency check for now
***        l_multi_curr_oa = multi_currency_oa(
***          i_ebeln = is_po_deep-agreement
***          i_waers = l_oa_waers ).
***
***        if l_multi_curr_oa = abap_true.
***          message e041(zmfp) with is_po_deep-agreement into l_bapi_msg.
***          l_message = append_message( i_message = l_message i_append = l_bapi_msg ).
***        endif.

      endif.

*--- editing specific PO checks:
      if i_action = zif_mfp_constants=>gc_action-odata-edit.


*--- check 'our ref' is initial
        if is_po_deep-islegacy = abap_true
        and l_unsez is not initial.
          message e046(zmfp) with text-edt into l_bapi_msg.
          l_message = append_message( i_message = l_message i_append = l_bapi_msg ).
        endif.

*--- multi acc assignment
**        loop at is_po_deep-purchaseorderlis into ls_lineitem
**        where distrib is not initial.
**          message e044(zmfp) into l_bapi_msg.
**          l_message = append_message( i_message = l_message i_append = l_bapi_msg ).
**          exit. "finish as soon as one is found
**        endloop.

*--- check for acc assignment asset unknown
**        read table is_po_deep-purchaseorderlis into ls_lineitem
**          with key acctasscat = lc_knttp_asset_unknown.
**        if sy-subrc = 0.
**          message e045(zmfp) into l_bapi_msg.
**          l_message = append_message( i_message = l_message i_append = l_bapi_msg ).
**        endif.

      endif.

    endif.

*===> OA checks
    if is_oa_deep is not initial.

* Turn off multiple currency check for now - 210983DY
*--- multi currency check
***      l_multi_curr_oa = multi_currency_oa(
***        i_ebeln = is_oa_deep-contractnumber
***        i_waers = is_oa_deep-currency ).
***
***      IF l_multi_curr_oa = abap_true.
***        MESSAGE e040(zmfp) INTO l_bapi_msg.
***        l_message = append_message( i_message = l_message i_append = l_bapi_msg ).
***      ENDIF.

*--- editing specific checks
      if i_action = zif_mfp_constants=>gc_action-odata-edit.

*--- check 'our ref' is initial
        if is_oa_deep-islegacy = abap_true
        and l_unsez is not initial.
          message e046(zmfp) with text-edt into l_bapi_msg.
          l_message = append_message( i_message = l_message i_append = l_bapi_msg ).
        endif.

*--- check for acc assignment asset unknown
**        read table is_oa_deep-contractlis into ls_lineitem
**          with key acctasscat = lc_knttp_asset_unknown.
**        if sy-subrc = 0.
**          message e045(zmfp) into l_bapi_msg.
**          l_message = append_message( i_message = l_message i_append = l_bapi_msg ).
**        endif.
      endif.

    endif.

  else.
    message e032(zmfp) into l_bapi_msg.
    l_message = append_message( i_message = l_message i_append = l_bapi_msg ).
  endif.

*===> raise exception if message is populated
  if l_message is not initial.
    if i_action = zif_mfp_constants=>gc_action-odata-edit.
      message e031(zmfp) with l_ebeln into l_bapi_msg.
    else.
      message e030(zmfp) with l_ebeln into l_bapi_msg.
    endif.
    ls_textid-msgid = sy-msgid.
    ls_textid-msgno = sy-msgno.
    ls_textid-attr1 = sy-msgv1.
    ls_textid-attr2 = sy-msgv2.
    ls_textid-attr3 = sy-msgv3.
    ls_textid-attr4 = sy-msgv4.

*--- add message container setup
    if io_context is not initial.
      l_bapi_msg = l_message.
      lo_message_container = io_context->get_message_container( ).
      lo_message_container->add_message_text_only(
        iv_msg_type = /iwbep/if_message_container=>gcs_message_type-error
        iv_msg_text = l_bapi_msg
        iv_add_to_response_header = abap_true ).
    endif.

    raise exception type /iwbep/cx_mgw_busi_exception
      exporting
        textid            = ls_textid
        message_unlimited = l_message.
  endif.

endmethod.


  METHOD is_non_deleteable_line.
*----------------------------------------------------------------------*
* METHOD ID:          IS_NON_DELETEABLE_LINE
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2.2).
*                     This method checks if a line is deletable.
*
* AUTHOR:             Stephen Ning (290977SCN)
* CREATE DATE:        21.09.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000002096 - MyFi Purchasing Release 2.2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 21/09/20 290977SCN RD2K919977 DS-11-32-07-01 S 6000002096: MyFi Purchasing (Release 2.2)
*-----------------------------------------------------------------------

    rv_non_deleteable = abap_false.
    READ TABLE it_po_history_totals INTO DATA(ls_total) WITH KEY po_item = iv_ebelp serial_no = '00'.
      IF ls_total-deliv_qty NE 0 OR ls_total-iv_qty NE 0.
        rv_non_deleteable = abap_true.
      ENDIF.
  ENDMETHOD.


  METHOD is_po_copyable.
*----------------------------------------------------------------------*
* METHOD ID:          IS_PO_COPYABLE
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2.3).
*                     This method sets po copyable flag based on OA Consumption value
*
*
* AUTHOR:             Dathri Yellamarthy (210983DY)
* CREATE DATE:        23/11/2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000002172: MyFi Purchasing (Release 2.3)
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*----------------------------------------------------------------------- *
*
*-------------------------------------------------------------------------



    DATA: lv_total            TYPE val_forcurr,
          lv_total_ordered    TYPE p LENGTH 12 DECIMALS 4,
          lv_total_value      TYPE p LENGTH 15 DECIMALS 9,
          lv_unassigned_value TYPE p LENGTH 15 DECIMALS 9,
          ls_po_summary       TYPE zcl_zedm_mfp_mpc=>ts_consumptionsummary.

    IF NOT iv_oa_doc IS INITIAL.
* Get currency and Total Value
      SELECT ebeln, waers, ktwrt FROM ekko INTO TABLE @DATA(lt_contract_values) WHERE ebeln EQ @iv_oa_doc.
      IF NOT lt_contract_values IS INITIAL.
        SELECT ebeln, netwr, konnr
           FROM ekab
           INTO TABLE @DATA(lt_ekab)
                                   WHERE konnr EQ @iv_oa_doc
                                ORDER BY ebeln ASCENDING.

        LOOP AT lt_ekab INTO DATA(ls_ekab).
          IF ls_po_summary-contractnumber IS INITIAL.
            ls_po_summary-contractnumber = ls_ekab-konnr.
          ENDIF.

          AT END OF ebeln.
            SUM.
            lv_total = ls_ekab-netwr.
            SELECT SINGLE ekgrp, aedat, waers FROM ekko INTO @DATA(ls_ekko) WHERE ebeln EQ @ls_ekab-ebeln.

            CALL METHOD zcl_mfp_utilities=>get_po_consumption_summary
              EXPORTING
                iv_ebeln       = ls_ekab-ebeln
                iv_ekgrp       = ls_ekko-ekgrp
                iv_createdate  = ls_ekko-aedat
                iv_currency    = ls_ekko-waers
                iv_total_fcurr = lv_total
              IMPORTING
                es_po_con_summ = ls_po_summary.

            APPEND ls_po_summary TO gt_oa_po_consumption.

            lv_total_ordered = lv_total_ordered + ls_po_summary-totalordered.

            CLEAR: lv_total, ls_po_summary.
          ENDAT.
        ENDLOOP.

        lv_total_value = zcl_mfp_utilities=>convert_curr_format( iv_amount = lt_contract_values[ 1 ]-ktwrt
                                                                       iv_curr   = lt_contract_values[ 1 ]-waers ) .

        lv_unassigned_value = lv_total_value - lv_total_ordered.

        IF lv_unassigned_value LE '0'.
          iv_copyable = abap_false.
        ELSE.
          iv_copyable = abap_true.
        ENDIF.

      ENDIF.
    ENDIF.


  ENDMETHOD.


  METHOD is_processed_by_myfi.
*----------------------------------------------------------------------*
* METHOD ID:          IS_PROCESSED_BY_MYFI
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method determines if a document has been
*                     processed by the MyFi Purchasing application.
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        12.06.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 12.06.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
*-----------------------------------------------------------------------

    zcl_mfp_utilities=>import_header(
        EXPORTING
          id    =  zcl_mfp_utilities=>gc_memory_id_header                  " Memory ID for EXPORT/IMPORT memory ID
        IMPORTING
          value =  DATA(ls_doc_header)                  " Self Service Purchasing UI5 Application Document Header
      ).

    IF ls_doc_header IS NOT INITIAL.
      ev_myfi_process = abap_true.
** Check if old or new cekko.
      SELECT SINGLE unsez FROM ekko WHERE ebeln = @ls_doc_header-zmfp_doc_id INTO @DATA(lv_unsez).

      IF ls_doc_header-selected_delegate IS NOT INITIAL AND lv_unsez NE is_cekko-unsez.
        ev_release_required = abap_true.
      ENDIF.
    ENDIF.

  ENDMETHOD.


  METHOD is_vendor_prepymnt_exempt.
    SELECT SINGLE prepay_exempt FROM ztmfp_vndrs_prpy INTO @DATA(lv_prepay_exempt) WHERE lifnr = @iv_lifnr.
    IF sy-subrc IS INITIAL AND NOT lv_prepay_exempt IS INITIAL.
      is_prepay_exempt = abap_true.
    ENDIF.
  ENDMETHOD.


  METHOD log_myfi_action.
*----------------------------------------------------------------------*
* METHOD ID:          LOG_MYFI_ACTION
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method logs a user action in the SAP
*           Application Log.
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        12.06.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 12.06.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
* 19.06.20 290977SCN RD2K919517 DS-11-32-07-01 S 6000001863: MyFi
*          070667JPS                           Purchasing Release 2_ECC
*                                              DEFECTS II.  Corrected
*                                              message handling.
*-----------------------------------------------------------------------

    DATA: application_log TYPE REF TO zcl_mfp_bal_log_wrapper,
          lv_text         TYPE string,
          l_return        TYPE bapiret2,
          ls_ext_no       TYPE balnrext,
          lv_action       TYPE string.

    lv_action = iv_action.
    ls_ext_no = iv_doc_number.
    application_log = zcl_mfp_bal_log_wrapper=>get_instance(
                         iv_object        = zif_mfp_constants=>gc_log-object-actions
                         iv_subobject     = iv_action
                         iv_description   = ls_ext_no  ).

    l_return-type       = 'I'.
    l_return-id         = zif_mfp_constants=>gc_mfp_package.
    l_return-number     = '999'.
    l_return-message_v1  = iv_message.


    CALL METHOD application_log->add_bapi_message
      EXPORTING
        return = l_return.
    CALL METHOD application_log->persist_log.

  ENDMETHOD.


  METHOD log_myfi_bapi.
* METHOD ID:          LOG_MYFI_BAPI
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method logs bapi messages.
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        09.06.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 16.06.20 290977SCN RD2K919514 DS-11-32-07-01 Created
*          070667JPS
*-----------------------------------------------------------------------

    DATA: application_log TYPE REF TO zcl_mfp_bal_log_wrapper,
          lv_text         TYPE string,
          l_return        TYPE bapiret2,
          ls_ext_no       TYPE balnrext,
          lv_action       TYPE string.
    ls_ext_no = iv_doc_number.

    application_log = zcl_mfp_bal_log_wrapper=>get_instance(
                     iv_object        = zif_mfp_constants=>gc_log-object-bapi
                     iv_subobject     = iv_action
                     iv_description   = ls_ext_no  ).


    CALL METHOD application_log->add_bapi_messages
      EXPORTING
        return = it_return.                 " Return table
    CALL METHOD application_log->persist_log.
  ENDMETHOD.


  METHOD log_myfi_data.
*----------------------------------------------------------------------*
* METHOD ID:          LOG_MYFI_DATA
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method logs a document’s data in the SAP
*           Application Log.
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        12.06.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 12.06.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
* 16.06.20 290977SCN RD2K919514 DS-11-32-07-01 changed
*          070667JPS
*-----------------------------------------------------------------------

    DATA: application_log TYPE REF TO zcl_mfp_bal_log_wrapper,
          lv_text         TYPE string,
          l_return        TYPE bapiret2,
          ls_ext_no       TYPE balnrext.

    ls_ext_no = iv_doc_number.

    application_log = zcl_mfp_bal_log_wrapper=>get_instance(
                         iv_object        = zif_mfp_constants=>gc_log-object-data
                         iv_subobject     = iv_sub_obj
                         iv_description   = ls_ext_no  ).

    l_return-type       = iv_log_type.
    l_return-id         = zif_mfp_constants=>gc_mfp_package.
    l_return-number     = '999'.
    l_return-message_v1  = |Doc:{ iv_doc_number }|.

    CALL METHOD application_log->add_bapi_message
      EXPORTING
        return = l_return.
    CALL METHOD application_log->persist_log.

  ENDMETHOD.


  METHOD log_myfi_event.
*----------------------------------------------------------------------*
* METHOD ID:          LOG_MYFI_EVENT
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method logs events in the SAP Application Log.
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        12.06.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 12.06.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
* 16.06.20 290977SCN RD2K919514 DS-11-32-07-01 changed
*          070667JPS
*-----------------------------------------------------------------------

    DATA: application_log TYPE REF TO zcl_mfp_bal_log_wrapper,
          lv_text         TYPE string,
          l_return        TYPE bapiret2,
          ls_ext_no       TYPE balnrext,
          lv_event        TYPE string.

    lv_event = iv_sub_obj.
    ls_ext_no = iv_doc_number.

    application_log = zcl_mfp_bal_log_wrapper=>get_instance(
                         iv_object        = zif_mfp_constants=>gc_log-object-workflow
                         iv_subobject     = iv_sub_obj
                         iv_description   = ls_ext_no  ).

    l_return-type       = 'I'.
    l_return-id         = zif_mfp_constants=>gc_mfp_package.
    l_return-number     = '999'.
    l_return-message_v1  = |Event:{ lv_event }|.
    l_return-message_v2  = |Doc:{ iv_doc_number }|.
    l_return-message_v3  = |User:{ iv_user_id }|.

    CALL METHOD application_log->add_bapi_message
      EXPORTING
        return = l_return.
    CALL METHOD application_log->persist_log.

  ENDMETHOD.


  METHOD map_admindtl_prf_header.
*----------------------------------------------------------------------*
* METHOD ID:          MAP_ADMINDTL_PRF_HEADER
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used to prepare the SON and indigenous
*                     contractor data for storage in the PRF record.
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        12.06.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 12.06.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
*-----------------------------------------------------------------------
    CONSTANTS: BEGIN OF zgrp_fields_const,
                 fiscal_yr          TYPE name_komp VALUE 'ERP_FISCAL_YEAR',
                 vendor_id          TYPE name_komp VALUE 'ERP_VENDOR_ID',
                 vendor_name        TYPE name_komp VALUE 'ERP_VENDOR_NAM',
                 vendor_vatno       TYPE name_komp VALUE 'ERP_VENDOR_VATNO',
                 total_amount_value TYPE name_komp VALUE 'ERP_TOTAL_CONTRACT_VAL',
                 total_value_curr   TYPE name_komp VALUE 'ERP_TOTAL_VAL_CURR',
                 ctr_strt_dt        TYPE name_komp VALUE 'ERP_CTR_START_DT',
                 ctr_end_dt         TYPE name_komp VALUE 'ERP_CTR_END_DT',
                 po_grp             TYPE name_komp VALUE 'ERP_PO_GRP',
                 day_calc_ref       TYPE name_komp VALUE 'ERP_DAY_CALC_REF',
                 co_code            TYPE name_komp VALUE 'ITEM_CO_CODE',
                 del_ind            TYPE name_komp VALUE 'DELETION_STATUS_FLAG',
                 item_amount_value  TYPE name_komp VALUE 'CONTRACT_VALUE',
                 gl_account         TYPE name_komp VALUE 'GL_ACCOUNT',
                 material_group     TYPE name_komp VALUE 'MATERIAL_GRP',
                 release_status     TYPE name_komp VALUE 'RELEASE_STATUS', "2623667
                 son_id             TYPE name_komp VALUE 'SON_ID', "MyFI Additional Fields
                 son_mul            TYPE name_komp VALUE 'SON_MUL', "MyFI Additional Fields
                 ind_bus            TYPE name_komp VALUE 'IND_BUS', "MyFI Additional Fields
                 ind_sub            TYPE name_komp VALUE 'IND_SUB', "MyFI Additional Fields
               END OF zgrp_fields_const,
               lc_header_index TYPE char1 VALUE 1.

    DATA: lv_indi_contract TYPE zzctrwithindig.
    DATA: lv_indi_sub        TYPE zzindigsubqtn,
          ls_struc_line_item TYPE zgrp_s_data_transfer_struc,
          lt_header_data     TYPE zgrp_t_data_transfer_struc,
          lt_item_data       TYPE zgrp_t_data_transfer_struc.


    .   "Check to see if MyFI contains SON
    "SON ID
    ls_struc_line_item-tableindex = 0.
    ls_struc_line_item-fieldname = zgrp_fields_const-son_id.
    ls_struc_line_item-data = is_contract-sonid.
    APPEND ls_struc_line_item TO lt_item_data.
    ls_struc_line_item-tableindex = 1.
    APPEND ls_struc_line_item TO lt_item_data.
    CLEAR ls_struc_line_item.

    "SON MUL
    ls_struc_line_item-tableindex = 0.
    ls_struc_line_item-fieldname = zgrp_fields_const-son_mul.
    IF is_contract-sonid IS INITIAL.
      ls_struc_line_item-data = 'N'.
    ELSE.
      ls_struc_line_item-data = 'Y'.
    ENDIF.
    APPEND ls_struc_line_item TO lt_item_data.
    ls_struc_line_item-tableindex = 1.
    APPEND ls_struc_line_item TO lt_item_data.
    CLEAR ls_struc_line_item.

    IF is_admindtl-indigenous_outcome EQ 'S'.
      lv_indi_contract = 'Y'.
    ELSE.
      lv_indi_contract = 'N'.
    ENDIF.

    "Indigenous Business
    ls_struc_line_item-tableindex = 0.
    ls_struc_line_item-fieldname = zgrp_fields_const-ind_bus.
    ls_struc_line_item-data = lv_indi_contract. " UPDATE to get DATA from MyFi
    APPEND ls_struc_line_item TO lt_item_data.
    ls_struc_line_item-tableindex = 1.
    APPEND ls_struc_line_item TO lt_item_data.
    CLEAR ls_struc_line_item.

    IF is_admindtl-is_indig_subcontract EQ abap_true.
      lv_indi_sub = 'Y'.
    ELSE.
      lv_indi_sub = 'N'.
    ENDIF.

    "Indigenous Subcontractor
    ls_struc_line_item-tableindex = 0.
    ls_struc_line_item-fieldname = zgrp_fields_const-ind_sub.
    ls_struc_line_item-data = lv_indi_sub. " UPDATE to get DATA from MyFi
    APPEND ls_struc_line_item TO lt_item_data.
    ls_struc_line_item-tableindex = 1.
    APPEND ls_struc_line_item TO lt_item_data.
    CLEAR ls_struc_line_item.


    APPEND LINES OF lt_item_data TO ct_item_data.


  ENDMETHOD.


  method multi_currency_oa.
*-----------------------------------------------------------------------------------------
* DESCRIPTION:  Utility method that returns true if specified OA has mulitple currencies
*               i.e. if OA has more currencies than specified in I_WAERS
*
* AUTHOR:       Fred Chelashaw
* CREATE DATE:  10.11.2020
*
* ACTIVITY:     AD-11-32-07 - Self Service Purchasing App
* DEV SCRIPT:   DS-11-32-07-01 - MyFi Purchasing (Self Service Purchasing) App
*-----------------------------------------------------------------------------------------
* VERSION CONTROL:
*
* Date       Author    CTS Req    SCR        Description
* ---------- --------- ---------- ---------- ---------------------------------------------
* 10.11.2020 220977FKC RD2K919656 6000002172 MyFi Purchasing (Release 2.3)
*-----------------------------------------------------------------------------------------

    data:
      lc_inital_waers type waers,
      lr_knumh        type range of knumh,
      l_count         type i.

    field-symbols:
      <ls_knumh> like line of lr_knumh.

*--- get condition record numbers
*    note: cannot use sql join to KONP table below because A016 a pool-table
    select knumh as low
      from a016
      into corresponding fields of table lr_knumh
      where kappl = 'M'
      and kschl = 'PB00'
      and evrtn = i_ebeln
      and datbi >= sy-datum
      and datab <= sy-datum.

*--- check condition items forcurrencies not
    if lr_knumh is not initial.
      loop at lr_knumh assigning <ls_knumh>.
        <ls_knumh>-sign = rs_c_range_sign-including.
        <ls_knumh>-option = rs_c_range_opt-equal.
      endloop.

      select count( * )
        from konp
        into l_count
        where knumh in lr_knumh
          and loevm_ko ne abap_true
          and ( konwa ne i_waers and konwa ne lc_inital_waers ).
    endif.

*--- if at least one currency is different from OA currency then multi
    if l_count > 0.
      r_multi_currency = abap_true.
    else.
      r_multi_currency = abap_false.
    endif.

  endmethod.


  METHOD ok_for_myfi.
*----------------------------------------------------------------------*
* METHOD ID:          OK_FOR_MYFI
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method checks if a document can be opened in the
*                     MFP application.
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        12.06.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 12.06.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
* 22.07.20 290977SCN RD2K919533 DS-11-32-07-01 Update linked PO or OA if document is a L4L
*-----------------------------------------------------------------------

    DATA:
      lv_objid            TYPE cdhdr-objectid,
      ls_header_old       TYPE LINE OF yztmfp_doc_headers,
      lt_header_old       TYPE yztmfp_doc_headers,
      lt_header_new       TYPE yztmfp_doc_headers,
      ls_header_update    TYPE ztmfp_doc_header,
      lv_change_indicator TYPE cdchngindh VALUE 'U'.


    SELECT SINGLE * FROM ztmfp_doc_header
      WHERE zmfp_doc_id EQ @iv_ebeln AND
            changed_in_gui = @abap_true
      INTO @DATA(ls_changing_header_data).
    CHECK sy-subrc EQ 0.
    MOVE-CORRESPONDING ls_changing_header_data TO ls_header_old.
    ls_header_old-kz = lv_change_indicator.
    APPEND ls_header_old TO lt_header_old.
    ls_changing_header_data-changed_in_gui = ls_header_old-changed_in_gui = abap_false.
    APPEND ls_header_old TO lt_header_new.

    IF sy-subrc EQ 0.
      UPDATE ztmfp_doc_header FROM ls_changing_header_data.

      lv_objid = ls_header_old-zmfp_doc_id.
      CALL FUNCTION 'ZMFP_CHANGELOG_WRITE_DOCUMENT'
        EXPORTING
          objectid                = lv_objid
          tcode                   = sy-tcode
          utime                   = sy-uzeit
          udate                   = sy-datum
          username                = sy-uname
          object_change_indicator = lv_change_indicator
          upd_ztmfp_doc_header    = lv_change_indicator
        TABLES
          xztmfp_doc_header       = lt_header_new
          yztmfp_doc_header       = lt_header_old.
    ENDIF.

    IF ls_changing_header_data-category EQ zif_mfp_constants=>gc_myfi_doc_type-l4l_oa OR ls_changing_header_data-category EQ zif_mfp_constants=>gc_myfi_doc_type-l4l_po.

      SELECT SINGLE * FROM ztmfp_doc_header
            WHERE zmfp_doc_id EQ @ls_header_old-ref_id AND
                  changed_in_gui = @abap_true
            INTO @ls_changing_header_data.
      CHECK sy-subrc EQ 0.
      MOVE-CORRESPONDING ls_changing_header_data TO ls_header_old.
      ls_header_old-kz = lv_change_indicator.
      APPEND ls_header_old TO lt_header_old.
      ls_changing_header_data-changed_in_gui = ls_header_old-changed_in_gui = abap_false.
      APPEND ls_header_old TO lt_header_new.

      IF sy-subrc EQ 0.
        UPDATE ztmfp_doc_header FROM ls_changing_header_data.

        lv_objid = ls_header_old-zmfp_doc_id.
        CALL FUNCTION 'ZMFP_CHANGELOG_WRITE_DOCUMENT'
          EXPORTING
            objectid                = lv_objid
            tcode                   = sy-tcode
            utime                   = sy-uzeit
            udate                   = sy-datum
            username                = sy-uname
            object_change_indicator = lv_change_indicator
            upd_ztmfp_doc_header    = lv_change_indicator
          TABLES
            xztmfp_doc_header       = lt_header_new
            yztmfp_doc_header       = lt_header_old.
      ENDIF.
    ENDIF.

  ENDMETHOD.


  METHOD save_myfip_oa_trigger.
*----------------------------------------------------------------------*
* METHOD ID:          SAVE_MYFIP_OA_TRIGGER
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used in the PRF generation for a
*                     contract.  It calls class zcl_grp_bapi_util.
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        12.06.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 12.06.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
*-----------------------------------------------------------------------


    CONSTANTS: BEGIN OF zgrp_fields_const,
                 fiscal_yr          TYPE name_komp VALUE 'ERP_FISCAL_YEAR',
                 vendor_id          TYPE name_komp VALUE 'ERP_VENDOR_ID',
                 vendor_name        TYPE name_komp VALUE 'ERP_VENDOR_NAM',
                 vendor_vatno       TYPE name_komp VALUE 'ERP_VENDOR_VATNO',
                 total_amount_value TYPE name_komp VALUE 'ERP_TOTAL_CONTRACT_VAL',
                 total_value_curr   TYPE name_komp VALUE 'ERP_TOTAL_VAL_CURR',
                 ctr_strt_dt        TYPE name_komp VALUE 'ERP_CTR_START_DT',
                 ctr_end_dt         TYPE name_komp VALUE 'ERP_CTR_END_DT',
                 po_grp             TYPE name_komp VALUE 'ERP_PO_GRP',
                 day_calc_ref       TYPE name_komp VALUE 'ERP_DAY_CALC_REF',
                 co_code            TYPE name_komp VALUE 'ITEM_CO_CODE',
                 del_ind            TYPE name_komp VALUE 'DELETION_STATUS_FLAG',
                 item_amount_value  TYPE name_komp VALUE 'CONTRACT_VALUE',
                 gl_account         TYPE name_komp VALUE 'GL_ACCOUNT',
                 material_group     TYPE name_komp VALUE 'MATERIAL_GRP',
                 release_status     TYPE name_komp VALUE 'RELEASE_STATUS', "2623667
                 son_id             TYPE name_komp VALUE 'SON_ID', "MyFI Additional Fields
                 son_mul            TYPE name_komp VALUE 'SON_MUL', "MyFI Additional Fields
                 ind_bus            TYPE name_komp VALUE 'IND_BUS', "MyFI Additional Fields
                 ind_sub            TYPE name_komp VALUE 'IND_SUB', "MyFI Additional Fields
               END OF zgrp_fields_const,
               lc_header_index TYPE char1 VALUE 1.

*    TYPES: lty_t_ekkn TYPE STANDARD TABLE OF uekkn.

    DATA:ls_struc_line_item  TYPE zgrp_s_data_transfer_struc,
         lv_name1            TYPE lfa1-name1,
         lv_name2            TYPE lfa1-name2,
         lv_abn              TYPE lfa1-stceg,
         lv_ktokk            TYPE lfa1-ktokk,               "2565744
         lv_lcurr            TYPE waers,
         lv_rate             TYPE wkurs,
         lv_amt              TYPE zgrp_s_item-total_contract_val,
         lv_sakto            TYPE ekkn-sakto,
         lv_sakto_save       TYPE ekkn-sakto,
         lv_matkl_save       TYPE ekkn-sakto,
*         lt_grp_c_trig       TYPE STANDARD TABLE OF zgrp_c_trig,
         gt_ekpo             TYPE meout_t_ekpo,
         lt_header_data      TYPE zgrp_t_data_transfer_struc,
         lt_item_data        TYPE zgrp_t_data_transfer_struc,
         lv_trigger_grp_appl TYPE xfeld,
         lv_dtype_code       TYPE zgrp_regm_doc_type,
*         wa_grp_c_trig       TYPE zgrp_c_trig,
         lo_trigger          TYPE REF TO zcl_grp_bapi_util,
         lv_fiscal_year      TYPE zgrp_s_header-fiscal_year,
         lt_error            TYPE bapiret2_t,
         lt_t16fb            TYPE STANDARD TABLE OF t16fb.  "2623667

    FIELD-SYMBOLS: <ls_po_item> TYPE ekpo,
                   <lt_ekkn>    TYPE meout_t_ekkn,
                   <ls_ekkn>    TYPE ekkn.


    gt_ekpo = it_ekpo.
    lt_header_data = ct_header_data.
    lt_item_data = ct_item_data.
    lv_trigger_grp_appl = cv_trigger_grp_appl.
    lv_dtype_code = cv_dtype_code.

    FIELD-SYMBOLS: <lt_ekpo>    TYPE meout_t_ekpo.

    ASSIGN it_ekpo TO <lt_ekpo>.
    CHECK <lt_ekpo> IS ASSIGNED.

    ASSIGN it_ekkn TO <lt_ekkn>.
    CHECK <lt_ekkn> IS ASSIGNED.

    " Prepare Financial year

    CALL FUNCTION 'BAPI_GRP_GET_FISCAL_YEAR'
      EXPORTING
        iv_company_code = im_ekko-bukrs
        iv_date         = im_ekko-aedat
      IMPORTING
        ev_fiscal_year  = lv_fiscal_year
      TABLES
        return          = lt_error.

    ls_struc_line_item-tableindex = lc_header_index.
    ls_struc_line_item-fieldname = zgrp_fields_const-fiscal_yr.
    ls_struc_line_item-data = lv_fiscal_year.
    APPEND ls_struc_line_item TO lt_header_data.


    " Prepare Vendor details
    "Vendor Number
    ls_struc_line_item-tableindex = lc_header_index.
    ls_struc_line_item-fieldname = zgrp_fields_const-vendor_id.
    ls_struc_line_item-data = im_ekko-lifnr.
    APPEND ls_struc_line_item TO lt_header_data.
    CLEAR ls_struc_line_item.

    "Vendor Name
    SELECT SINGLE name1 name2 ktokk stceg FROM lfa1 INTO (lv_name1,  lv_name2, lv_ktokk, lv_abn) WHERE lifnr = im_ekko-lifnr. "Added KTOKK 2565744
    CONCATENATE lv_name1 lv_name2 INTO ls_struc_line_item-data SEPARATED BY space.
    ls_struc_line_item-tableindex = lc_header_index.
    ls_struc_line_item-fieldname = zgrp_fields_const-vendor_name.
    APPEND ls_struc_line_item TO lt_header_data.
    CLEAR ls_struc_line_item.

    "Vendor TAX Registration Number
    ls_struc_line_item-tableindex = lc_header_index.
    ls_struc_line_item-fieldname = zgrp_fields_const-vendor_vatno.
    ls_struc_line_item-data = lv_abn.
    APPEND ls_struc_line_item TO lt_header_data.
    CLEAR ls_struc_line_item.

    "Contract Start Date
    ls_struc_line_item-tableindex = lc_header_index.
    ls_struc_line_item-fieldname = zgrp_fields_const-ctr_strt_dt.
    ls_struc_line_item-data = im_ekko-kdatb.
    APPEND ls_struc_line_item TO lt_header_data.
    CLEAR ls_struc_line_item.

    "Contract end Date
    ls_struc_line_item-tableindex = lc_header_index.
    ls_struc_line_item-fieldname = zgrp_fields_const-ctr_end_dt.
    ls_struc_line_item-data = im_ekko-kdate.
    APPEND ls_struc_line_item TO lt_header_data.
    CLEAR ls_struc_line_item.

    "Puchase Organization
    ls_struc_line_item-tableindex = lc_header_index.
    ls_struc_line_item-fieldname = zgrp_fields_const-po_grp.
    ls_struc_line_item-data = im_ekko-ekgrp.
    APPEND ls_struc_line_item TO lt_header_data.
    CLEAR ls_struc_line_item.

    "Powl Day calculation reference
    ls_struc_line_item-tableindex = lc_header_index.
    ls_struc_line_item-fieldname = zgrp_fields_const-day_calc_ref.
    ls_struc_line_item-data = im_ekko-kdate.
    APPEND ls_struc_line_item TO lt_header_data.
    CLEAR ls_struc_line_item.

    "Release Status of Record                                                    "SOC 2623667
    ls_struc_line_item-tableindex = lc_header_index.
    ls_struc_line_item-fieldname = zgrp_fields_const-release_status.
    IF im_ekko-frgke IS INITIAL.
      ls_struc_line_item-data = abap_true.
    ELSE.
      SELECT * FROM t16fb INTO TABLE lt_t16fb WHERE kzfre = abap_true.
      READ TABLE lt_t16fb WITH KEY frgke = im_ekko-frgke TRANSPORTING NO FIELDS.
      IF sy-subrc = 0.
        ls_struc_line_item-data = abap_true.
      ELSE.
        ls_struc_line_item-data = abap_false.
      ENDIF.
    ENDIF.
    APPEND ls_struc_line_item TO lt_header_data.
    CLEAR ls_struc_line_item.                                                    "EOC 2623667

    "Setting other values for application
    lv_lcurr = im_ekko-waers.
    lv_rate = im_ekko-wkurs.

    "Process Item details
    LOOP AT <lt_ekpo> ASSIGNING <ls_po_item> WHERE loekz NE zif_mfp_constants=>gc_lock_type-deleted.
      " Check if PO Currency is same as default currency (e.g. 'AUD')
      IF lv_lcurr EQ lv_local_curr.
        "then use actual currency value
        lv_amt = <ls_po_item>-effwr.
      ELSE.
        "convert currency as per the exchange rate
        CALL FUNCTION 'CONVERT_TO_LOCAL_CURRENCY'
          EXPORTING
            date             = sy-datum
            foreign_amount   = <ls_po_item>-effwr
            foreign_currency = lv_lcurr
            local_currency   = lv_local_curr
            rate             = lv_rate
*           type_of_rate     = 'M'
          IMPORTING
            local_amount     = lv_amt
          EXCEPTIONS
            no_rate_found    = 1
            overflow         = 2
            no_factors_found = 3
            no_spread_found  = 4
            derived_2_times  = 5
            OTHERS           = 6.
        IF sy-subrc <> 0.
          " Will be handled later as the process is likely to change soon.
        ENDIF.
      ENDIF.

      "Company Code details for each line item
      ls_struc_line_item-tableindex = <ls_po_item>-ebelp.
      ls_struc_line_item-fieldname = zgrp_fields_const-co_code.
      ls_struc_line_item-data = <ls_po_item>-bukrs.
      APPEND ls_struc_line_item TO lt_item_data.
      CLEAR ls_struc_line_item.

      "Contract value
      ls_struc_line_item-tableindex = <ls_po_item>-ebelp.
      ls_struc_line_item-fieldname = zgrp_fields_const-item_amount_value.
      ls_struc_line_item-data = lv_amt.
      APPEND ls_struc_line_item TO lt_item_data.
      CLEAR ls_struc_line_item.

      "Material Group
      ls_struc_line_item-tableindex = <ls_po_item>-ebelp.
      ls_struc_line_item-fieldname = zgrp_fields_const-material_group.
      ls_struc_line_item-data = <ls_po_item>-matkl.
      APPEND ls_struc_line_item TO lt_item_data.
      IF lv_matkl_save IS INITIAL.
        lv_matkl_save = <ls_po_item>-matkl.
      ENDIF.
      CLEAR ls_struc_line_item.


      "GL Account
      IF <lt_ekkn> IS ASSIGNED.
        READ TABLE <lt_ekkn> ASSIGNING <ls_ekkn> WITH KEY ebeln = <ls_po_item>-ebeln
                                                           ebelp = <ls_po_item>-ebelp.
        IF sy-subrc = 0.
          IF <ls_ekkn> IS ASSIGNED.
            lv_sakto = <ls_ekkn>-sakto.
            ls_struc_line_item-tableindex = <ls_po_item>-ebelp.
            ls_struc_line_item-fieldname = zgrp_fields_const-gl_account.
            ls_struc_line_item-data = lv_sakto.
            APPEND ls_struc_line_item TO lt_item_data.
            IF lv_sakto_save IS INITIAL.
              lv_sakto_save = lv_sakto.
            ENDIF.
            CLEAR ls_struc_line_item.
            UNASSIGN <ls_ekkn>.
          ENDIF.
        ENDIF.
      ENDIF.
    ENDLOOP.

    "Convert the total amount if Conversion is necessary
    " Amount Currency and conversion rate if applicable is assigned before the loop for each item.
    IF lv_lcurr EQ lv_local_curr.
      "then use actual currency value
      lv_total_amt = im_ekko-ktwrt.
    ELSE.
      "convert currency as per the exchange rate
      CALL FUNCTION 'CONVERT_TO_LOCAL_CURRENCY'
        EXPORTING
          date             = sy-datum
          foreign_amount   = im_ekko-ktwrt
          foreign_currency = lv_lcurr
          local_currency   = lv_local_curr
          rate             = lv_rate
*         type_of_rate     = 'M'
        IMPORTING
          local_amount     = lv_total_amt
        EXCEPTIONS
          no_rate_found    = 1
          overflow         = 2
          no_factors_found = 3
          no_spread_found  = 4
          derived_2_times  = 5
          OTHERS           = 6.
      IF sy-subrc <> 0.
        " Will be handled later as the process is likely to change soon.
      ENDIF.
    ENDIF.

    "Material Group
    ls_struc_line_item-tableindex = 0.
    ls_struc_line_item-fieldname = zgrp_fields_const-material_group.
    ls_struc_line_item-data = lv_matkl_save.
    APPEND ls_struc_line_item TO lt_item_data.
    CLEAR ls_struc_line_item.

    "GL Account
    ls_struc_line_item-tableindex = 0.
    ls_struc_line_item-fieldname = zgrp_fields_const-gl_account.
    ls_struc_line_item-data = lv_sakto_save.
    APPEND ls_struc_line_item TO lt_item_data.
    CLEAR ls_struc_line_item.

    "Co-Code Details
    ls_struc_line_item-tableindex = 0.
    ls_struc_line_item-fieldname = zgrp_fields_const-co_code.
    ls_struc_line_item-data = im_ekko-bukrs.
    APPEND ls_struc_line_item TO lt_item_data.
    CLEAR ls_struc_line_item.

    "Contract value of header capture
    ls_struc_line_item-tableindex = 0.
    ls_struc_line_item-fieldname = zgrp_fields_const-item_amount_value.
    ls_struc_line_item-data = lv_total_amt.
    APPEND ls_struc_line_item TO lt_item_data.
    CLEAR ls_struc_line_item.

    "Total value of PO
    ls_struc_line_item-tableindex = lc_header_index.
    ls_struc_line_item-fieldname = zgrp_fields_const-total_amount_value.
    ls_struc_line_item-data = lv_total_amt.
    APPEND ls_struc_line_item TO lt_header_data.
    CLEAR ls_struc_line_item.

*    IF 1 = 0.   "Check to see if MyFI contains SON
*      "SON ID
*      ls_struc_line_item-tableindex = 0.
*      ls_struc_line_item-fieldname = zgrp_fields_const-son_id.
*      ls_struc_line_item-data = 'SON12345'.
*      APPEND ls_struc_line_item TO lt_item_data.
*      CLEAR ls_struc_line_item.
*
*      "SON MUL
*      ls_struc_line_item-tableindex = 0.
*      ls_struc_line_item-fieldname = zgrp_fields_const-son_mul.
*      ls_struc_line_item-data = 'Y'.
*      APPEND ls_struc_line_item TO lt_item_data.
*      CLEAR ls_struc_line_item.
*    ENDIF.

*    "Indigenous Business
*    ls_struc_line_item-tableindex = 0.
*    ls_struc_line_item-fieldname = zgrp_fields_const-ind_bus.
*    ls_struc_line_item-data = 'Y'. " UPDATE to get DATA from MyFi
*    APPEND ls_struc_line_item TO lt_item_data.
*    CLEAR ls_struc_line_item.
*
*    "Indigenous Subcontractor
*    ls_struc_line_item-tableindex = 0.
*    ls_struc_line_item-fieldname = zgrp_fields_const-ind_sub.
*    ls_struc_line_item-data = 'Y'. " UPDATE to get DATA from MyFi
*    APPEND ls_struc_line_item TO lt_item_data.
*    CLEAR ls_struc_line_item.


    CREATE OBJECT lo_trigger.
    CALL METHOD lo_trigger->check_doc_type
      EXPORTING
        i_docno       = im_ekko-ebeln
        i_bsart       = im_ekko-bsart
        i_supplier    = im_ekko-lifnr
        i_accgrp      = lv_ktokk
        i_header_data = lt_header_data
        i_item_data   = lt_item_data
        i_borobj      = zif_mfp_constants=>gc_bor-bus2014
      IMPORTING
        safety_catch  = cv_trigger_grp_appl
        doctype       = cv_dtype_code.

    ct_header_data =  lt_header_data.
    ct_item_data = lt_item_data.


  ENDMETHOD.


METHOD save_myfip_po_trigger.
*-----------------------------------------------------------------------------------------
* DESCRIPTION:  This method is used in the PRF generation for a purchase order (PO) i.e.
*               for PO's that do not have an outline agreement (OA) because where a PO has
*               an OA PRF is on the OA.
*
* AUTHOR:       Fred Chelashaw
* CREATE DATE:  16.02.2021
*
* ACTIVITY:     AD-11-32-07 - Self Service Purchasing App
* DEV SCRIPT:   DS-11-32-17-01 - Self Service Purchasing App
*-----------------------------------------------------------------------------------------
* VERSION CONTROL:
*
* Date       Author    CTS Req    SCR        Description
* ---------- --------- ---------- ---------- ---------------------------------------------
* 16.02.2021 220977FKC RD2K920554 6000002250 MyFi Purchasing (Release 2.4)
* 25.03.2021 220977FKC RD2K920877 6000002325 MyFi Purchasing (Edit Legacy PRF Issue): use
*                                            gross (tax inclusive) amount for PRF instead
*                                            of net value.
* 16.04.21 210983DY RD2K920923  DS-11-32-07-01 S 6000002348: MyFi Purchasing (May Release)
*                               Additional logic to calculate net amount
* 27/04/22 210983DY RD2K922655 DS-11-32-07-01 S 6000002692: MyFi Applications (May Release)
*                              Additional Logic to handle Returns Item for PO
*-----------------------------------------------------------------------------------------

  CONSTANTS:
    BEGIN OF zgrp_fields_const,
      fiscal_yr          TYPE name_komp VALUE 'ERP_FISCAL_YEAR',
      vendor_id          TYPE name_komp VALUE 'ERP_VENDOR_ID',
      vendor_name        TYPE name_komp VALUE 'ERP_VENDOR_NAM',
      vendor_vatno       TYPE name_komp VALUE 'ERP_VENDOR_VATNO',
      total_amount_value TYPE name_komp VALUE 'ERP_TOTAL_CONTRACT_VAL',
      total_value_curr   TYPE name_komp VALUE 'ERP_TOTAL_VAL_CURR',
      ctr_strt_dt        TYPE name_komp VALUE 'ERP_CTR_START_DT',
      ctr_end_dt         TYPE name_komp VALUE 'ERP_CTR_END_DT',
      po_grp             TYPE name_komp VALUE 'ERP_PO_GRP',
      day_calc_ref       TYPE name_komp VALUE 'ERP_DAY_CALC_REF',
      co_code            TYPE name_komp VALUE 'ITEM_CO_CODE',
      del_ind            TYPE name_komp VALUE 'DELETION_STATUS_FLAG',
      item_amount_value  TYPE name_komp VALUE 'CONTRACT_VALUE',
      gl_account         TYPE name_komp VALUE 'GL_ACCOUNT',
      material_group     TYPE name_komp VALUE 'MATERIAL_GRP',
      release_status     TYPE name_komp VALUE 'RELEASE_STATUS',
      son_id             TYPE name_komp VALUE 'SON_ID', "MyFI Additional Fields
      son_mul            TYPE name_komp VALUE 'SON_MUL', "MyFI Additional Fields
      ind_bus            TYPE name_komp VALUE 'IND_BUS', "MyFI Additional Fields
      ind_sub            TYPE name_komp VALUE 'IND_SUB', "MyFI Additional Fields
    END OF zgrp_fields_const,
    lc_header_index TYPE char1 VALUE 1.

  DATA:
    ls_struc_line_item  TYPE zgrp_s_data_transfer_struc,
    lv_name1            TYPE lfa1-name1,
    lv_name2            TYPE lfa1-name2,
    lv_abn              TYPE lfa1-stceg,
    lv_ktokk            TYPE lfa1-ktokk,
    lv_lcurr            TYPE waers,
    lv_rate             TYPE wkurs,
    lv_amt              TYPE zgrp_s_item-total_contract_val,
    l_net_amt	          TYPE /bcv/sin_dec16_3,
    l_gross_amt         TYPE /bcv/sin_dec16_3,
    l_foreign_amt_st    TYPE string,
    l_foreign_amt       TYPE string,
    lv_sakto            TYPE ekkn-sakto,
    lv_sakto_save       TYPE ekkn-sakto,
    lv_matkl_save       TYPE ekkn-sakto,
    gt_ekpo             TYPE me_ekpo,
    lt_header_data      TYPE zgrp_t_data_transfer_struc,
    lt_item_data        TYPE zgrp_t_data_transfer_struc,
    lv_trigger_grp_appl TYPE xfeld,
    lv_dtype_code       TYPE zgrp_regm_doc_type,
    lo_trigger          TYPE REF TO zcl_grp_bapi_util,
    lv_fiscal_year      TYPE zgrp_s_header-fiscal_year,
    lt_error            TYPE bapiret2_t,
    lt_t16fb            TYPE STANDARD TABLE OF t16fb.       "2623667

  FIELD-SYMBOLS:
    <ls_po_item> TYPE ekpo,
    <lt_ekkn>    TYPE me_ekkn,
    <ls_ekkn>    TYPE ekkn.

  gt_ekpo = it_ekpo.
  lt_header_data = ct_header_data.
  lt_item_data = ct_item_data.
  lv_trigger_grp_appl = cv_trigger_grp_appl.
  lv_dtype_code = cv_dtype_code.

  FIELD-SYMBOLS: <lt_ekpo>    TYPE meout_t_ekpo.

  ASSIGN it_ekpo TO <lt_ekpo>.
  CHECK <lt_ekpo> IS ASSIGNED.

  ASSIGN it_ekkn TO <lt_ekkn>.
  CHECK <lt_ekkn> IS ASSIGNED.

  " Prepare Financial year
  CALL FUNCTION 'BAPI_GRP_GET_FISCAL_YEAR'
    EXPORTING
      iv_company_code = im_ekko-bukrs
      iv_date         = im_ekko-aedat
    IMPORTING
      ev_fiscal_year  = lv_fiscal_year
    TABLES
      return          = lt_error.

  ls_struc_line_item-tableindex = lc_header_index.
  ls_struc_line_item-fieldname = zgrp_fields_const-fiscal_yr.
  ls_struc_line_item-data = lv_fiscal_year.
  APPEND ls_struc_line_item TO lt_header_data.

  " Prepare Vendor details
  "Vendor Number
  ls_struc_line_item-tableindex = lc_header_index.
  ls_struc_line_item-fieldname = zgrp_fields_const-vendor_id.
  ls_struc_line_item-data = im_ekko-lifnr.
  APPEND ls_struc_line_item TO lt_header_data.
  CLEAR ls_struc_line_item.

  "Vendor Name
  SELECT SINGLE name1 name2 ktokk stceg FROM lfa1 INTO (lv_name1,  lv_name2, lv_ktokk, lv_abn) WHERE lifnr = im_ekko-lifnr. "Added KTOKK 2565744
  CONCATENATE lv_name1 lv_name2 INTO ls_struc_line_item-data SEPARATED BY space.
  ls_struc_line_item-tableindex = lc_header_index.
  ls_struc_line_item-fieldname = zgrp_fields_const-vendor_name.
  APPEND ls_struc_line_item TO lt_header_data.
  CLEAR ls_struc_line_item.

  "Vendor TAX Registration Number
  ls_struc_line_item-tableindex = lc_header_index.
  ls_struc_line_item-fieldname = zgrp_fields_const-vendor_vatno.
  ls_struc_line_item-data = lv_abn.
  APPEND ls_struc_line_item TO lt_header_data.
  CLEAR ls_struc_line_item.

  "Puchase Organization
  ls_struc_line_item-tableindex = lc_header_index.
  ls_struc_line_item-fieldname = zgrp_fields_const-po_grp.
  ls_struc_line_item-data = im_ekko-ekgrp.
  APPEND ls_struc_line_item TO lt_header_data.
  CLEAR ls_struc_line_item.

  "Powl Day calculation reference
  ls_struc_line_item-tableindex = lc_header_index.
  ls_struc_line_item-fieldname = zgrp_fields_const-day_calc_ref.
  ls_struc_line_item-data = im_ekko-kdate.
  APPEND ls_struc_line_item TO lt_header_data.
  CLEAR ls_struc_line_item.

  "Release Status of Record                                                    "SOC 2623667
  ls_struc_line_item-tableindex = lc_header_index.
  ls_struc_line_item-fieldname = zgrp_fields_const-release_status.
  IF im_ekko-frgke IS INITIAL.
    ls_struc_line_item-data = abap_true.
  ELSE.
    SELECT * FROM t16fb INTO TABLE lt_t16fb WHERE kzfre = abap_true.
    READ TABLE lt_t16fb WITH KEY frgke = im_ekko-frgke TRANSPORTING NO FIELDS.
    IF sy-subrc = 0.
      ls_struc_line_item-data = abap_true.
    ELSE.
      ls_struc_line_item-data = abap_false.
    ENDIF.
  ENDIF.
  APPEND ls_struc_line_item TO lt_header_data.
  CLEAR ls_struc_line_item.                                                    "EOC 2623667

  "Setting other values for application
  lv_lcurr = im_ekko-waers.
  lv_rate = im_ekko-wkurs.

  "Process Item details
  LOOP AT <lt_ekpo> ASSIGNING <ls_po_item> WHERE loekz NE zif_mfp_constants=>gc_lock_type-deleted.

*--- get line gross value (PRF uses tax inclusive amount)
*    l_net_amt = <ls_po_item>-effwr.
    l_net_amt =  <ls_po_item>-menge * <ls_po_item>-netpr.
    IF <ls_po_item>-retpo = abap_true.
      l_net_amt = l_net_amt * -1.
    ENDIF.
    l_gross_amt = zcl_mfp_utilities=>get_line_total(
      iv_currency  = lv_lcurr
      iv_comp_code = <ls_po_item>-bukrs
      iv_net_amt   = l_net_amt
      iv_tax_code  = <ls_po_item>-mwskz ).

*--- convert to local currency
    IF lv_lcurr EQ lv_local_curr.
      "then use actual currency value
      lv_amt = l_gross_amt.
    ELSE.
      "convert currency as per the exchange rate
      l_foreign_amt_st = l_gross_amt.
      CALL FUNCTION 'Z_CURRENCY_IN_DECIMAL'
        EXPORTING
          iv_amount   = l_foreign_amt_st
          iv_currency = lv_lcurr
        IMPORTING
          ev_amount   = l_foreign_amt.
      CALL FUNCTION 'CONVERT_TO_LOCAL_CURRENCY'
        EXPORTING
          date             = sy-datum
          foreign_amount   = l_foreign_amt
          foreign_currency = lv_lcurr
          local_currency   = lv_local_curr
          rate             = lv_rate
        IMPORTING
          local_amount     = lv_amt
        EXCEPTIONS
          no_rate_found    = 1
          overflow         = 2
          no_factors_found = 3
          no_spread_found  = 4
          derived_2_times  = 5
          OTHERS           = 6.
      IF sy-subrc <> 0.
        " Will be handled later as the process is likely to change soon.
      ENDIF.
    ENDIF.

    ADD lv_amt TO lv_total_amt.

    "Company Code details for each line item
    ls_struc_line_item-tableindex = <ls_po_item>-ebelp.
    ls_struc_line_item-fieldname = zgrp_fields_const-co_code.
    ls_struc_line_item-data = <ls_po_item>-bukrs.
    APPEND ls_struc_line_item TO lt_item_data.
    CLEAR ls_struc_line_item.

    "Contract value
    ls_struc_line_item-tableindex = <ls_po_item>-ebelp.
    ls_struc_line_item-fieldname = zgrp_fields_const-item_amount_value.
    ls_struc_line_item-data = lv_amt.
    APPEND ls_struc_line_item TO lt_item_data.
    CLEAR ls_struc_line_item.

    "Material Group
    ls_struc_line_item-tableindex = <ls_po_item>-ebelp.
    ls_struc_line_item-fieldname = zgrp_fields_const-material_group.
    ls_struc_line_item-data = <ls_po_item>-matkl.
    APPEND ls_struc_line_item TO lt_item_data.
    IF lv_matkl_save IS INITIAL.
      lv_matkl_save = <ls_po_item>-matkl.
    ENDIF.
    CLEAR ls_struc_line_item.

    "GL Account
    IF <lt_ekkn> IS ASSIGNED.
      READ TABLE <lt_ekkn> ASSIGNING <ls_ekkn> WITH KEY
        ebeln = <ls_po_item>-ebeln
        ebelp = <ls_po_item>-ebelp.
      IF sy-subrc = 0.
        IF <ls_ekkn> IS ASSIGNED.
          lv_sakto = <ls_ekkn>-sakto.
          ls_struc_line_item-tableindex = <ls_po_item>-ebelp.
          ls_struc_line_item-fieldname = zgrp_fields_const-gl_account.
          ls_struc_line_item-data = lv_sakto.
          APPEND ls_struc_line_item TO lt_item_data.
          IF lv_sakto_save IS INITIAL.
            lv_sakto_save = lv_sakto.
          ENDIF.
          CLEAR ls_struc_line_item.
          UNASSIGN <ls_ekkn>.
        ENDIF.
      ENDIF.
    ENDIF.
  ENDLOOP.

  "Material Group
  ls_struc_line_item-tableindex = 0.
  ls_struc_line_item-fieldname = zgrp_fields_const-material_group.
  ls_struc_line_item-data = lv_matkl_save.
  APPEND ls_struc_line_item TO lt_item_data.
  CLEAR ls_struc_line_item.

  "GL Account
  ls_struc_line_item-tableindex = 0.
  ls_struc_line_item-fieldname = zgrp_fields_const-gl_account.
  ls_struc_line_item-data = lv_sakto_save.
  APPEND ls_struc_line_item TO lt_item_data.
  CLEAR ls_struc_line_item.

  "Co-Code Details
  ls_struc_line_item-tableindex = 0.
  ls_struc_line_item-fieldname = zgrp_fields_const-co_code.
  ls_struc_line_item-data = im_ekko-bukrs.
  APPEND ls_struc_line_item TO lt_item_data.
  CLEAR ls_struc_line_item.

  "Contract value of header capture
  ls_struc_line_item-tableindex = 0.
  ls_struc_line_item-fieldname = zgrp_fields_const-item_amount_value.
  ls_struc_line_item-data = lv_total_amt.
  APPEND ls_struc_line_item TO lt_item_data.
  CLEAR ls_struc_line_item.

  "Total value of PO
  ls_struc_line_item-tableindex = lc_header_index.
  ls_struc_line_item-fieldname = zgrp_fields_const-total_amount_value.
  ls_struc_line_item-data = lv_total_amt.
  APPEND ls_struc_line_item TO lt_header_data.
  CLEAR ls_struc_line_item.

  CREATE OBJECT lo_trigger.
  CALL METHOD lo_trigger->check_doc_type
    EXPORTING
      i_docno       = im_ekko-ebeln
      i_bsart       = im_ekko-bsart
      i_supplier    = im_ekko-lifnr
      i_accgrp      = lv_ktokk
      i_header_data = lt_header_data
      i_item_data   = lt_item_data
      i_borobj      = zif_mfp_constants=>gc_bor-bus2012
    IMPORTING
      safety_catch  = cv_trigger_grp_appl
      doctype       = cv_dtype_code.

  ct_header_data = lt_header_data.
  ct_item_data = lt_item_data.

ENDMETHOD.


  METHOD transfer_connection_of_mime.
*----------------------------------------------------------------------*
* METHOD ID:          TRANSFER_CONNECTION_OF_MIME
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used to transfer an attachment from
*                     a draft record to a posted OA or PO.
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        12.06.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 12.06.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
*-----------------------------------------------------------------------

    DATA: lt_attachments TYPE zmfp_attachment_tt,
          ls_attachment  TYPE zsmfp_doc_att,
          ls_transfer    TYPE zsmfp_arch_connect,
          lv_sap_object  TYPE saeanwdid,
          lv_ar_object   TYPE saeobjart.

    get_mime_connect_for_doc(
      EXPORTING
        iv_doc_id      = iv_sending_doc_id                  " Purchasing Document Number
      IMPORTING
        et_attachments = lt_attachments                 " SAP ArchiveLink: Link Table (Table)
    ).

    LOOP AT lt_attachments INTO ls_attachment.
      CLEAR ls_transfer.
      IF iv_receiving_obj_typ IS NOT INITIAL.
        ls_transfer-sap_object = iv_receiving_obj_typ.
      ELSE.
        ls_transfer-sap_object = ls_attachment-sap_object.
      ENDIF.
      IF ls_attachment-sap_object EQ zif_mfp_constants=>gc_bor-bus2012.
        ls_transfer-ar_object = zif_mfp_constants=>gc_ar_type-po.
      ELSE.
        ls_transfer-ar_object = zif_mfp_constants=>gc_ar_type-oa.
      ENDIF.
      ls_transfer-object_id = iv_receiving_doc_id.
      ls_transfer-arc_doc_id = ls_attachment-attachmentguid.

      connect_mime_to_doc(
        EXPORTING
          is_attachment = ls_transfer
      ).
    ENDLOOP.

  ENDMETHOD.


  method translate_mm_status_to_mfp.
*-----------------------------------------------------------------------------------------
* DESCRIPTION:  Utility method to translate MM release indicator to MyFi Purchasing status
* NOTES:
*
* AUTHOR:       Fred Chelashaw
* CREATE DATE:  10.11.2020
*
* ACTIVITY:     AD-11-32-07 - Self Service Purchasing App
* DEV SCRIPT:   DS-11-32-07-01 - MyFi Purchasing (Self Service Purchasing) App
*-----------------------------------------------------------------------------------------
* VERSION CONTROL:
*
* Date       Author    CTS Req    SCR        Description
* ---------- --------- ---------- ---------- ---------------------------------------------
* 10.11.2020 220977FKC RD2K919656 6000002172 MyFi Purchasing (Release 2.3)
*-----------------------------------------------------------------------------------------

    case i_rel_ind.
      when zif_mfp_constants=>gc_mm_doc_status-oa_released
      or zif_mfp_constants=>gc_mm_doc_status-po_released.
        r_mfp_status = zif_mfp_constants=>gc_doc_status-approved.
      when zif_mfp_constants=>gc_mm_doc_status-req_del_appr.
        r_mfp_status = zif_mfp_constants=>gc_doc_status-awaiting_approval.
      when zif_mfp_constants=>gc_mm_doc_status-req_prf_comp.
        r_mfp_status = zif_mfp_constants=>gc_doc_status-awaiting_prf.
      when zif_mfp_constants=>gc_mm_doc_status-new.
        r_mfp_status = zif_mfp_constants=>gc_doc_status-new_doc.
    endcase.

  endmethod.


  METHOD trigger_myfip_grp_capture.
*----------------------------------------------------------------------*
* METHOD ID:          TRIGGER_MYFIP_GRP_CAPTURE
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used to retrieve the URLs when a PRF
*                     is triggered.
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        12.06.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 12.06.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
*-----------------------------------------------------------------------

* Copy of ZCL_GRP_ASSIST / method TRIGGER_GRP_CAPTURE

* Needed to trigger GRP for Outline Agreements that are created / changed via a BAPI

    " Read the required data based on doc type
    " Populate in the internal doc_type data table



    CONSTANTS: BEGIN OF grp_fields_const,
*                 fiscal_yr          TYPE name_komp VALUE 'ERP_FISCAL_YEAR',
*                 vendor_id          TYPE name_komp VALUE 'ERP_VENDOR_ID',
*                 vendor_name        TYPE name_komp VALUE 'ERP_VENDOR_NAM',
*                 vendor_vatno       TYPE name_komp VALUE 'ERP_VENDOR_VATNO',
*                 total_amount_value TYPE name_komp VALUE 'ERP_TOTAL_CONTRACT_VAL',
                 total_value_curr TYPE name_komp VALUE 'ERP_TOTAL_VAL_CURR',
*                 ctr_strt_dt        TYPE name_komp VALUE 'ERP_CTR_START_DT',
*                 ctr_end_dt         TYPE name_komp VALUE 'ERP_CTR_END_DT',
*                 po_grp             TYPE name_komp VALUE 'ERP_PO_GRP',
*                 day_calc_ref       TYPE name_komp VALUE 'ERP_DAY_CALC_REF',
*                 del_ind            TYPE name_komp VALUE 'DELETION_STATUS_FLAG',
*                 item_amount_value  TYPE name_komp VALUE 'CONTRACT_VALUE',
               END OF grp_fields_const,
               lc_header_index TYPE char1 VALUE 1.

    DATA: lr_grp_log          TYPE REF TO zcl_grp_bal_log_wrapper,
          lt_header_data      TYPE zgrp_t_data_transfer_struc,
          lt_item_data        TYPE zgrp_t_data_transfer_struc,
          lt_return           TYPE bapiret2_t,
          ls_return           TYPE bapiret2,
          ls_struc_line_item  TYPE zbapi_grp_s_data_transfr_struc,
          lv_dtype_code       TYPE zgrp_regm_doc_type,
          lv_doc_no_val       TYPE zgrp_doc_no,
          lv_co_code_val      TYPE zgrp_co_code,
          lv_cntry_code       TYPE land1,
          lv_trigger_grp_appl TYPE xfeld,
          lv_amt              TYPE zgrp_s_item-total_contract_val,
          lv_total_amt        TYPE zgrp_s_item-total_contract_val,
          lv_local_curr       TYPE waers,
          lt_trigger_urls     TYPE zgrp_t_data_transfer_struc,
          lx_root             TYPE REF TO cx_mmpur_root.

    DATA: ls_header_det  TYPE zgrp_c_header.
    DATA: ls_ekko        TYPE ekko.
    DATA: ls_temp_header TYPE meout_header.

    DATA: ls_temp_ekpo   TYPE meout_item.
    DATA: lt_ekpo        TYPE meout_t_ekpo.
    DATA: ls_ekpo        TYPE ekpo.
    DATA: ls_bapi_ekpo   TYPE bapimeoutitem.

    DATA: lt_ekkn        TYPE meout_t_ekkn.
    DATA: ls_bapi_ekkn   TYPE bapimeoutaccount.
    DATA: ls_ekkn        TYPE ekkn.
    DATA: ls_ekxn        TYPE exkn.

    lv_doc_no_val = iv_ebeln.
    IF zcl_grp_activation_switch=>grp_process( ) = abap_false.
      RETURN. "   return_if_grp_not_active.
    ENDIF.

    TRY.
        CALL METHOD cl_bapi_meout_mapping=>map2i_header
          EXPORTING
            bapimeoutheader = is_ekko
          RECEIVING
            meout_header    = ls_temp_header.
      CATCH cx_mmpur_root INTO lx_root.
        RETURN.
    ENDTRY.
    MOVE-CORRESPONDING ls_temp_header TO ls_ekko.

    LOOP AT it_ekpo INTO ls_bapi_ekpo.
      TRY.
          CALL METHOD cl_bapi_meout_mapping=>map2i_item
            EXPORTING
              bapimeoutitem = ls_bapi_ekpo
            RECEIVING
              meout_item    = ls_temp_ekpo.
        CATCH cx_mmpur_root INTO lx_root.
          RETURN.
      ENDTRY.
      MOVE-CORRESPONDING ls_temp_ekpo TO ls_ekpo.
      APPEND ls_ekpo TO lt_ekpo.

    ENDLOOP.

    LOOP AT it_ekkn INTO ls_bapi_ekkn.
      TRY.
          CALL METHOD cl_bapi_meout_mapping=>map2i_exkn
            EXPORTING
              bapimeoutaccount = ls_bapi_ekkn
            RECEIVING
              exkn             = ls_ekxn.
        CATCH cx_mmpur_root INTO lx_root.
          RETURN.
      ENDTRY.
      MOVE-CORRESPONDING ls_ekxn TO ls_ekkn.
      APPEND ls_ekkn TO lt_ekkn.
    ENDLOOP.

    CLEAR lv_total_amt.

    DATA: lr_assist TYPE REF TO zcl_grp_assist.
    CREATE OBJECT lr_assist.

    " Get reporting currency
    CALL FUNCTION 'BAPI_GRP_GET_REPORTING_CURR'
      IMPORTING
        ev_currency_code = lv_local_curr.

    "Total value Currency
    ls_struc_line_item-tableindex = lc_header_index.
    ls_struc_line_item-fieldname = grp_fields_const-total_value_curr.
    ls_struc_line_item-data = lv_local_curr.
    APPEND ls_struc_line_item TO lt_header_data.
    CLEAR ls_struc_line_item.

    lv_trigger_grp_appl = abap_false.

    lv_co_code_val = ls_ekko-bukrs.
    SELECT SINGLE land1 INTO lv_cntry_code FROM t001 WHERE bukrs = lv_co_code_val.

    CALL METHOD map_admindtl_prf_header
      EXPORTING
        is_admindtl    = is_admindtl
        is_contract    = is_contract
      CHANGING
        ct_header_data = lt_header_data                " Data Contents of the tables Fields
        ct_item_data   = lt_item_data.                " Data Contents of the tables Fields


    CALL METHOD zcl_mfp_utilities=>save_myfip_oa_trigger(
      EXPORTING
        im_ekko             = ls_ekko
        it_ekpo             = lt_ekpo
        it_ekkn             = lt_ekkn
        lv_local_curr       = lv_local_curr
      CHANGING
        ct_header_data      = lt_header_data
        ct_item_data        = lt_item_data
        cv_trigger_grp_appl = ev_trigger_appl
        cv_dtype_code       = lv_dtype_code
        lv_total_amt        = lv_total_amt ).

    CHECK ev_trigger_appl = abap_true.

    IF lt_header_data IS NOT INITIAL.
      CALL METHOD zcl_grp_assist=>trigger_grp_capture
        EXPORTING
          iv_country             = lv_cntry_code            " Country Key
          iv_co_code             = lv_co_code_val           " Co-Code
          iv_doc_type            = lv_dtype_code            " Regime Document type
          iv_doc_no              = lv_doc_no_val            " Source Document number
          iv_open_in_change_mode = abap_true                " Application mode
          iv_trigger_scrn        = abap_false
          it_header_data         = lt_header_data
          it_items_data          = lt_item_data
*         iv_hdr_key             = iv_hdr_key
        IMPORTING
          es_header_det          = ls_header_det
          et_trigger_urls        = lt_trigger_urls
          et_return              = et_return.             " Return Parameter

      et_trigger_urls = lt_trigger_urls.
    ENDIF.

  ENDMETHOD.


  METHOD update_myfi_status_gui.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_UTILITIES~UPDATE_MYFI_STATUS_GUI
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2.3).
*                     This method is used for updating GUI Flag and MyFi Status
*
* AUTHOR:             Dathri Yellamarthy
* CREATE DATE:        14.12.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000002172: MyFi Purchasing (Release 2.3)
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
*
*-----------------------------------------------------------------------
    DATA: lv_old_status       TYPE zmfp_status,
          lv_mm_status        TYPE frgke,
          lv_doc_type         TYPE zmfp_category,
          ls_new_doc_header   TYPE ztmfp_doc_header,
          lv_change_indicator TYPE cdchngindh VALUE 'U',
          lt_header_old       TYPE yztmfp_doc_headers,
          lt_header_new       TYPE yztmfp_doc_headers,
          ls_header_old       TYPE yztmfp_doc_header,
          ls_header_new       TYPE yztmfp_doc_header,
          lv_user             TYPE uname,
          objectid            TYPE cdhdr-objectid,
          lv_message          TYPE char50.

    lv_user = sy-uname.
    lv_doc_type = iv_myfi_doc_type.
    lv_old_status = iv_old_status.

    lv_mm_status = iv_rel_indicator.


    SELECT SINGLE * FROM ztmfp_doc_header
                        WHERE zmfp_doc_id = @iv_ebeln
                         INTO @DATA(ls_old_doc_header).
    CHECK sy-subrc = 0.
    IF iv_old_status    IS INITIAL. lv_old_status = ls_old_doc_header-status. ENDIF.
    IF iv_myfi_doc_type IS INITIAL. lv_doc_type = ls_old_doc_header-category. ENDIF.

    ls_new_doc_header = ls_old_doc_header.

    ev_new_status = zcl_mfp_document=>decide_new_status(
      EXPORTING
        iv_action        = iv_action
        iv_myfi_doc_type = lv_doc_type
        iv_old_status    = lv_old_status
        iv_mm_status     = lv_mm_status
        iv_ebeln         = iv_ebeln ).

    CHECK ev_new_status IS NOT INITIAL.
    ls_new_doc_header-status = ev_new_status.

* Update User with selected delegate from table ztmfp_doc_header
    IF ev_new_status EQ zif_mfp_constants=>gc_doc_status-approved AND
      NOT ls_old_doc_header-status = zif_mfp_constants=>gc_doc_status-approved.
      lv_user = sy-uname.
      ls_new_doc_header-released_on = sy-datum.
      ls_new_doc_header-released_at = sy-uzeit.
    ENDIF.

    IF ls_new_doc_header NE ls_old_doc_header.
      ls_new_doc_header-changed_on = sy-datum.
      ls_new_doc_header-changed_at = sy-uzeit.

      UPDATE ztmfp_doc_header FROM ls_new_doc_header.
      COMMIT WORK AND WAIT.

      MOVE-CORRESPONDING ls_old_doc_header TO ls_header_old.
      MOVE-CORRESPONDING ls_new_doc_header TO ls_header_new.

      APPEND ls_header_old TO lt_header_old.
      APPEND ls_header_new TO lt_header_new.
      objectid = iv_ebeln.
      CALL FUNCTION 'ZMFP_CHANGELOG_WRITE_DOCUMENT'
        EXPORTING
          objectid                = objectid
          tcode                   = zif_mfp_constants=>gc_tcode
          utime                   = sy-uzeit
          udate                   = sy-datum
          username                = lv_user
          object_change_indicator = lv_change_indicator
          upd_ztmfp_doc_header    = lv_change_indicator
        TABLES
          xztmfp_doc_header       = lt_header_new
          yztmfp_doc_header       = lt_header_old.
    ENDIF.

  ENDMETHOD.


  METHOD user_search.
*----------------------------------------------------------------------*
* METHOD ID:          USER_SEARCH
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used to perform the Searchhelp user
*                     search for contact details.
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        12.06.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 12.06.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
* 01.09.20 290977SCN RD2K919977 DS-11-32-07-01 Changed - User title from PA not USER
* 21/09/20 290977SCN RD2K919977 DS-11-32-07-01 S 6000002096: MyFi Purchasing (Release 2.2)
* 02/08/22 010965MI  RD2K922968 DS-11-32-07-01 S 6000002805: MyFi Continuous Improvement
*-----------------------------------------------------------------------



*



    delegate_search(
      exporting
        is_userid_range   = is_userid_range
        is_amount_range   = is_amount_range
        is_currency_range = is_currency_range
        is_first_range    = is_first_range
        is_last_range     = is_last_range
        is_eid_range      = is_eid_range
        is_ses_range      = is_ses_range
        i_read_telnr      = abap_true
        i_max_rows        = i_max_rows
      importing
        et_employee_data  = et_employee_data ).

*    DATA: lt_userlist         TYPE TABLE OF user_addr, "tt_delegatae_detail,
*          lt_userid_range     TYPE mmpurui_range_tty,
*          lt_amount_range     TYPE mmpurui_range_tty,
*          lt_currency_range   TYPE mmpurui_range_tty,
*          lt_first_range      TYPE mmpurui_range_tty,
*          lt_last_range       TYPE mmpurui_range_tty,
*          lt_eid_range        TYPE mmpurui_range_tty,
*          lt_start_date_range TYPE mmpurui_range_tty,
*          lt_end_date_range   TYPE mmpurui_range_tty,
*          ls_date_range       TYPE mmpurui_range_sty,
*          lt_ses_range        TYPE mmpurui_range_tty,
*          es_employee_data    TYPE zcl_zedm_searchhelp_mpc=>ts_employee,
*          lt_users            TYPE tt_users,
*          ls_odata_employee   TYPE zcl_zedm_searchhelp_mpc=>ts_employee,
*          lv_userid           TYPE sysid.
*
*
*    FIELD-SYMBOLS <fs_range> TYPE mmpurui_range_sty.
*
*    MOVE-CORRESPONDING is_userid_range-select_options TO lt_userid_range.
*    LOOP AT lt_userid_range ASSIGNING <fs_range>.
*      TRANSLATE <fs_range>-low TO UPPER CASE.
*    ENDLOOP.
*    IF <fs_range> IS ASSIGNED.
*      UNASSIGN <fs_range>.
*    ENDIF.
*
*    MOVE-CORRESPONDING is_first_range-select_options TO lt_first_range.
*    LOOP AT lt_first_range ASSIGNING <fs_range>.
*      TRANSLATE <fs_range>-low TO UPPER CASE.
*    ENDLOOP.
*    IF <fs_range> IS ASSIGNED.
*      UNASSIGN <fs_range>.
*    ENDIF.
*
*    MOVE-CORRESPONDING is_last_range-select_options TO lt_last_range.
*    LOOP AT lt_last_range ASSIGNING <fs_range>.
*      TRANSLATE <fs_range>-low TO UPPER CASE.
*    ENDLOOP.
*    IF <fs_range> IS ASSIGNED.
*      UNASSIGN <fs_range>.
*    ENDIF.
*
*    MOVE-CORRESPONDING is_eid_range-select_options TO lt_eid_range.
*    LOOP AT lt_eid_range ASSIGNING <fs_range>.
*      TRANSLATE <fs_range>-low TO UPPER CASE.
*    ENDLOOP.
*    IF <fs_range> IS ASSIGNED.
*      UNASSIGN <fs_range>.
*    ENDIF.
*
*    SELECT a~bname, a~name_first, a~name_last, a~name_text, c~tel_number, d~smtp_addr FROM user_addrs AS a
*      INNER JOIN user_addr_idad3 AS b ON a~bname EQ b~bname
*      LEFT OUTER JOIN adr2 AS c ON b~addrnumber EQ c~addrnumber AND b~persnumber EQ c~persnumber
*      LEFT OUTER JOIN adr6 AS d ON b~addrnumber EQ d~addrnumber AND b~persnumber EQ d~persnumber
*      INTO CORRESPONDING FIELDS OF TABLE @lt_users
*      WHERE a~bname IN @lt_userid_range
*        AND a~mc_namelas IN @lt_last_range
*        AND a~mc_namefir IN @lt_first_range.
*
*    SORT lt_users DESCENDING BY bname.
*    DELETE ADJACENT DUPLICATES FROM lt_users.
*    DESCRIBE TABLE lt_users LINES DATA(lv_lines).
*    LOOP AT lt_users INTO DATA(ls_user).
*      es_employee_data-userid = ls_user-bname.
*      es_employee_data-firstname = ls_user-name_first.
*      es_employee_data-surname = ls_user-name_last.
*      es_employee_data-email = ls_user-smtp_addr.
*      es_employee_data-phone = ls_user-tel_number.
*      es_employee_data-username = ls_user-name_text.
*      CONDENSE es_employee_data-phone NO-GAPS.
*
*      IF lv_lines = 1.
*        lv_userid = ls_user-bname.
*        SELECT SINGLE a~bukrs, c~titel FROM pa0001 AS a
*                      INNER JOIN pa0105      AS b ON a~pernr EQ b~pernr
*                      LEFT OUTER JOIN pa0002 AS c ON a~pernr EQ c~pernr
*          INTO @DATA(ls_pers_data)
*          WHERE b~usrid EQ @lv_userid AND
*                b~begda LE @sy-datum AND
*                b~endda GE @sy-datum and
*                c~begda LE @sy-datum AND
*                c~endda GE @sy-datum.
*        es_employee_data-companycode = ls_pers_data-bukrs.
*
*      ENDIF.
*      es_employee_data-fullname = |{ ls_pers_data-titel } { ls_user-name_first } { ls_user-name_last }|.
*      APPEND es_employee_data TO et_employee_data.
*    ENDLOOP.

  ENDMETHOD.


  METHOD validate_deliverydate.

    DATA: lv_fiscal_year TYPE gjahr,
          lv_period      TYPE monat,
          lv_period_fi   TYPE perbl,
          lv_datum       TYPE datum.

    lv_datum = iv_delivery_date.
* Check delivery date is within factory calender
    CALL FUNCTION 'DATE_CONVERT_TO_FACTORYDATE'
      EXPORTING
*       CORRECT_OPTION               = '+'
        date                         = lv_datum
        factory_calendar_id          = 'AU'
      EXCEPTIONS
        calendar_buffer_not_loadable = 1
        correct_option_invalid       = 2
        date_after_range             = 3
        date_before_range            = 4
        date_invalid                 = 5
        factory_calendar_not_found   = 6
        OTHERS                       = 7.
    IF sy-subrc <> 0.
* Implement suitable error handling here
      rs_invalid_dates-deliv_date = abap_true.
*      RETURN.
    ENDIF.

    CALL FUNCTION 'FI_PERIOD_DETERMINE'
      EXPORTING
        i_budat        = lv_datum "iv_delivery_date
        i_bukrs        = '1000'
      IMPORTING
        e_gjahr        = lv_fiscal_year
        e_monat        = lv_period
      EXCEPTIONS
        fiscal_year    = 1
        period         = 2
        period_version = 3
        posting_period = 4
        special_period = 5
        version        = 6
        posting_date   = 7
        OTHERS         = 8.
    IF sy-subrc <> 0.
* Implement suitable error handling here
    ENDIF.

    lv_period_fi = lv_period.
* Check for posting period validity
    CALL FUNCTION 'FM_OPEN_INTERVAL_CHECK'
      EXPORTING
        i_fiscal_year     = lv_fiscal_year
        i_period          = lv_period_fi
        i_fmarea          = 'FM01'
        i_ledger          = '9A'
        i_valuetype       = '51'
      EXCEPTIONS
        fm_update_blocked = 1
        input_error       = 2
        OTHERS            = 3.
    IF sy-subrc <> 0.
      rs_invalid_dates-budget_date = abap_true.
* Implement suitable error handling here
    ENDIF.




  ENDMETHOD.
ENDCLASS.