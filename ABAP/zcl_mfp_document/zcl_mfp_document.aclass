  method zif_myfi_document~get_myfi_details.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_DOCUMENT~zif_myfi_document~get_myfi_details
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for MyFi Documents
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
* 04.12.20 220977FKC RD2K920504 DS-11-32-07-01 6000002172: MyFi Purchasing (Release 2.3)
*                                              Incorporate legacy (non-MyFi docs)
*-----------------------------------------------------------------------

    if me->gv_is_legacy ne abap_true.

      select single * from ztmfp_admin_detl
                      into corresponding fields of me->zif_myfi_document~old_adm_dtl
                      where  zmfp_doc_id  = me->zif_myfi_document~source_doc_num.
      select        * from  ztmfp_strings
                      into table me->zif_myfi_document~old_strings
                      where  zmfp_doc_id  = me->zif_myfi_document~source_doc_num.
      select        * from ztmfp_indigsub
                      into table me->zif_myfi_document~old_inidigsub
                      where  zmfp_doc_id  = me->zif_myfi_document~source_doc_num.
      select *        from ztmfp_prepmnt
                      into table me->zif_myfi_document~old_prepmnts
                      where  zmfp_doc_id  = me->zif_myfi_document~source_doc_num.

      if me->gv_draft_indicator eq abap_true.

        select single string_data from ztmfp_strings
        where zmfp_doc_id eq @me->zif_myfi_document~source_doc_num and
              string_type eq @zif_mfp_constants=>gc_string_type-json into
              @me->gs_deep_entity.

      else.

        select        * from  ztmfp_appstrings as a
                        into table me->zif_myfi_document~approval_strings
                        where  a~zmfp_doc_id  = me->zif_myfi_document~source_doc_num
                        and    timestamp    = ( select max( timestamp ) from ztmfp_appstrings as b
                                                                        where  a~zmfp_doc_id  = me->zif_myfi_document~source_doc_num  ).
      endif.

    endif.

  endmethod.


  METHOD zif_myfi_document~get_new_status.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_DOCUMENT~zif_myfi_document~get_new_status
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for MyFi Documents
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
* 22.07.20 290977SCN RD2K919533 DS-11-32-07-01 Updated importing parameters for decide_new_status
*-----------------------------------------------------------------------
    decide_new_status(
      EXPORTING
        iv_action        = me->zif_myfi_document~gv_useraction                 " MyFi Purchasing App Action ID
        iv_myfi_doc_type = me->zif_myfi_document~new_doc_header-category       " MyFi Purchasing UI5 Application Document Category
        iv_old_status    = me->zif_myfi_document~old_doc_header-status         " MyFi Purchasing UI5 Application Document Status
        iv_mm_status     = me->gv_mm_status                                    " Release Indicator: Purchasing Document
        iv_ebeln         = me->zif_myfi_document~posting_doc_num
      RECEIVING
        rv_new_status    = rv_status
    ).

  ENDMETHOD.


  METHOD zif_myfi_document~handle_action.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_DOCUMENT~zif_myfi_document~handle_action
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for MyFi Documents
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
* 21/09/20 290977SCN RD2K919977 DS-11-32-07-01 S 6000002096: MyFi Purchasing (Release 2.2)
* 03/03/21 210983DY  RD2K920554 DS-11-32-07-01 S 6000002250: MyFi Purchasing (Release 2.4 )
*                               Additional logic to handle PO Close
* 16.04.21 210983DY RD2K920923  DS-11-32-07-01 S 6000002348: MyFi Purchasing (May Release)
*                               Additional logic to handle
*                              Un-assignment of a Document - MyFi(May Release)
*-----------------------------------------------------------------------
    CASE me->zif_myfi_document~gv_useraction.
      WHEN zif_mfp_constants=>gc_action-odata-draft.        "10  Save Draft
        me->zif_myfi_document~save_draft( ).
      WHEN zif_mfp_constants=>gc_action-odata-validate.     "30	Validate
        me->zif_myfi_document~validate( ).
      WHEN zif_mfp_constants=>gc_action-odata-create.       "40	Submit
        me->zif_myfi_document~create( ).
      WHEN zif_mfp_constants=>gc_action-odata-change.
        me->zif_myfi_document~change( ).                    "50	Change
        me->assign_document( iv_assignee = sy-uname ).
      WHEN zif_mfp_constants=>gc_action-odata-read.
        me->zif_myfi_document~read_data( ).
*  Assign document to User's object
        me->assign_document( iv_assignee = sy-uname ).
      WHEN zif_mfp_constants=>gc_action-odata-edit.         "80	Edit
        me->recall_approval( ).
        me->zif_myfi_document~read_data( ).                 "99	Read
        me->assign_document( iv_assignee = sy-uname ).
      WHEN zif_mfp_constants=>gc_action-odata-reassign.
        me->zif_myfi_document~save_draft( ).
        unassign_document( ).
      WHEN zif_mfp_constants=>gc_action-odata-duplicate_chk. "25 Duplicate Check
        me->zif_myfi_document~duplicate_chk( ).
      WHEN zif_mfp_constants=>gc_action-odata-po_close.     "60 PO Close
        me->zif_myfi_document~change( ).
      WHEN zif_mfp_constants=>gc_action-odata-unassign.     "22 Un assign
        me->zif_myfi_document~read_data( ).
        unassign_document( ).
      WHEN OTHERS.
    ENDCASE.
  ENDMETHOD.


