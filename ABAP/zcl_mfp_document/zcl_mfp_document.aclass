  METHOD create_new_doc_header.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_DOCUMENT~create_new_doc_header
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for MyFi Documents
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
*-----------------------------------------------------------------------
    IF zcl_mfp_utilities=>is_myfi( iv_doc_num = me->zif_myfi_document~source_doc_num ) EQ abap_false or me->zif_myfi_document~source_doc_num is initial.
      me->zif_myfi_document~new_doc_header-create_date = sy-datum.
      me->zif_myfi_document~new_doc_header-status = iv_status.
      me->zif_myfi_document~new_doc_header-category = me->gv_doc_type.
*    ELSE.
*      me->zif_myfi_document~new_doc_header = me->zif_myfi_document~old_doc_header.
    ENDIF.
  ENDMETHOD.


  method CREATE_STRING.
  endmethod.


  METHOD decide_new_status.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_DOCUMENT~decide_new_status
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for MyFi Documents
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
* 22.07.20 290977SCN RD2K919533 DS-11-32-07-01 Included Status Application Logging
*-----------------------------------------------------------------------
    DATA: ls_status_decision TYPE zsmfp_status_decision,
          lr_admin_data      TYPE REF TO if_fdt_admin_data,
          lr_function        TYPE REF TO  if_fdt_function,
          lr_context         TYPE REF TO if_fdt_context,
          lr_fdt_result      TYPE REF TO if_fdt_result,
          lrx_fdt            TYPE REF TO cx_fdt,
          lv_id              TYPE if_fdt_types=>id,
          ls_return          TYPE bapiret2,
          lv_message         TYPE char50.

    ls_status_decision-action = iv_action.
    ls_status_decision-mm_status = iv_mm_status.
    ls_status_decision-myfi_doc_type = iv_myfi_doc_type.
    ls_status_decision-old_status = iv_old_status.

    TRY .
        cl_fdt_factory=>get_instance_generic( EXPORTING iv_id = zif_mfp_constants=>gc_brf_guid-status
                                              IMPORTING eo_instance = lr_admin_data ).
        lr_function ?= lr_admin_data.
        lr_context ?= lr_function->get_process_context( ).
        lr_context->set_value( iv_name = 'ZSMFP_STATUS_DECISION' ia_value =  ls_status_decision ).
        lr_function->process( EXPORTING io_context = lr_context
                              IMPORTING eo_result  = lr_fdt_result ).
        lr_fdt_result->get_value( IMPORTING ea_value = rv_new_status ).

      CATCH cx_fdt INTO lrx_fdt.
        ls_return-type = zcl_grp_bapi_util=>gc_error_msg.
        ls_return-id = zcl_grp_bapi_util=>gc_msg_class.
        ls_return-number = '080'.
        ls_return-message_v1 = lrx_fdt->get_object_name( lv_id ).
        ls_return-message_v2 = lrx_fdt->if_message~get_text( ).
        MESSAGE ID ls_return-id TYPE ls_return-type NUMBER ls_return-number INTO ls_return-message WITH ls_return-message_v1 ls_return-message_v2.
*        APPEND ls_return TO et_return.
    ENDTRY.

        lv_message = |A:{ iv_action } OS:{ iv_old_status } MS:{ iv_mm_status } NS:{ rv_new_status }|.

    CALL METHOD zcl_mfp_utilities=>log_myfi_action
      EXPORTING
        iv_doc_number = iv_ebeln
        iv_action     = zif_mfp_constants=>gc_log-sub_obj-action-status
        iv_user_id    = sy-uname
        iv_message    = lv_message.


  ENDMETHOD.


  METHOD delegate_required.
  ENDMETHOD.


  METHOD exchangerate_deviation.
*----------------------------------------------------------------------*
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for MyFi Documents to display message
*                     for exchange rate deviation
*
* AUTHOR:             Dathri Yellamarthy (210983DY)
* CREATE DATE:        02.03.2021
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000002250 - MyFi Purchasing Release 2.4
*-----------------------------------------------------------------------

    DATA : iv_wkurs_int    TYPE ukurs_curr,
           lv_kurs1        TYPE tcurr-ukurs,
           lv_kurs2        TYPE tcurr-ukurs,
           cv_percent1 TYPE p,
           lv_rate         TYPE char20.
    IF iv_currency <> 'AUD'.
      SELECT * FROM tcurr UP TO 1 ROWS INTO @DATA(ls_tcurr)
                WHERE      kurst     =   'M'
                AND        fcurr     =   @iv_currency
                AND        tcurr     =   'AUD'
                ORDER BY   gdatu     ASCENDING.
* Refer to CONVERSION_EXIT_INVDT_OUTPUT, why ascending is selected.
* gdatu dictionary definition is a character not date.
      ENDSELECT.

      IF sy-subrc = 0.
        DATA(lv_tableexchangerate)   =   ls_tcurr-ukurs.
      ENDIF.

    ENDIF.
    IF NOT lv_tableexchangerate IS INITIAL.

      iv_wkurs_int = iv_wkurs.
      DATA(lv_percent1) = abs( ( iv_wkurs - lv_tableexchangerate ) * 100 / iv_wkurs ).
*      cv_percent1 = abs(  ( iv_wkurs - lv_tableexchangerate )  * 100 / iv_wkurs ).
*      cv_percent = cv_percent1.
      cv_percent = lv_percent1.

      IF cv_percent GT '05'.
        MESSAGE w050(zmfp) INTO es_return-message WITH iv_wkurs lv_tableexchangerate iv_lineitem.
        es_return-type = 'W'.
      ENDIF.
    ENDIF.


  ENDMETHOD.


  METHOD EXPORT_HEADER.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_DOCUMENT~EXPORT_HEADER
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for MyFi Documents
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
*-----------------------------------------------------------------------
    DATA: ls_ptab TYPE zsmfp_memory_header,
          lt_ptab TYPE STANDARD TABLE OF zsmfp_memory_header.

    ls_ptab-name = name.
    ls_ptab-value = value.
    APPEND ls_ptab TO lt_ptab.

    EXPORT lt_ptab = lt_ptab TO MEMORY ID id.
  ENDMETHOD.


  METHOD get_account_assignment.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_DOCUMENT_PO~zif_myfi_document~validate
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for MyFi Documents
*
* AUTHOR:             Dathri Yellamarthy
* CREATE DATE:        05.11.2021
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000002550: MyFi Applications (December Release)
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 05/11/21 210983DY  RD2K922034 DS-11-32-07-01 S6000002550: MyFi Applications (December Release)
*                    Additional code to enable Multi Account Assignment
* 18.08.22 210983DY RD2K923033 DS-11-32-07-01 S 6000002805: MyFi Continuous Improvement September Release
* 10/01/23  210983DY RD2K923348,
*                    RD2K923485,
*                    RD2K923509 S 6000002854: MyFi Continuous Improvement December Rel
*          Additional logic to handle Account assignment validation for locked objects
*         Pass lock flag against account assignment object to UI
* 03072023 210983DY RD2K923919 6000002957 MyFi Continuous Improvement -
*    Account assignment correction for Cost Centre and Project
*-----------------------------------------------------------------------

    DATA: ls_odata_assignments TYPE zcl_zedm_mfp_mpc=>ts_accountassignment,
          lt_gl                TYPE /iwbep/t_cod_select_options,
          lt_costcenter        TYPE /iwbep/t_cod_select_options,
          lt_asset             TYPE /iwbep/t_cod_select_options,
          lt_order             TYPE /iwbep/t_cod_select_options,
          lt_wbs               TYPE /iwbep/t_cod_select_options,
          ls_cc_assignments    TYPE zsfss_mfp_asa_cc.

    SELECT *
          FROM ekkn
          INTO TABLE @DATA(lt_account_assignments)
         WHERE ebeln = @iv_document.

* Range for GL's
    lt_gl = VALUE /iwbep/t_cod_select_options( FOR ls_accnt IN lt_account_assignments ( sign = 'I'
                                                    option = 'EQ'
                                                    low = ls_accnt-sakto ) ).

    lt_costcenter = VALUE /iwbep/t_cod_select_options( FOR ls_accnt IN lt_account_assignments ( sign = 'I'
                                                     option = 'EQ'
                                                     low = ls_accnt-kostl ) ).

    lt_wbs = VALUE /iwbep/t_cod_select_options( FOR ls_accnt IN lt_account_assignments ( sign = 'I'
                                                    option = 'EQ'
                                                    low = ls_accnt-ps_psp_pnr ) ).

    lt_order = VALUE /iwbep/t_cod_select_options( FOR ls_accnt IN lt_account_assignments ( sign = 'I'
                                                        option = 'EQ'
                                                        low = ls_accnt-aufnr ) ).

    lt_asset = VALUE /iwbep/t_cod_select_options( FOR ls_accnt IN lt_account_assignments ( sign = 'I'
                                                        option = 'EQ'
                                                        low = ls_accnt-anln1 ) ).

    IF NOT lt_gl IS INITIAL.
      SELECT saknr, txt50 FROM skat INTO TABLE @DATA(lt_gl_names)
         WHERE spras = @sy-langu AND
                  ktopl = 'COA' AND
                  saknr IN @lt_gl.
* Get Status of GL's
      SELECT a~saknr, a~xloev, a~xspeb, b~xloeb, b~xspeb AS deletion INTO TABLE @DATA(lt_gl_status)
        FROM ska1 AS a INNER JOIN skb1 AS b ON a~saknr = b~saknr
        WHERE a~ktopl = 'COA'
          AND a~saknr IN @lt_gl.

    ENDIF.

    IF NOT lt_costcenter IS INITIAL.
      SELECT kostl, ltext FROM cskt INTO TABLE @DATA(lt_costcenter_names)  WHERE spras = @sy-langu AND
      kokrs = 'CA01' AND kostl IN @lt_costcenter AND datbi GE @sy-datlo.

      SELECT * FROM csks INTO TABLE @DATA(lt_cc_details)  WHERE kokrs EQ 'CA01'
                               AND kostl IN @lt_costcenter AND datbi GE @sy-datlo.
    ENDIF.

    IF NOT lt_wbs IS INITIAL.

      SELECT pspnr, post1, objnr, prctr, fkstl FROM prps INTO TABLE @DATA(lt_wbs_name) WHERE pspnr IN @lt_wbs.
      IF sy-subrc IS INITIAL.
*   Get status of WBS
        SELECT objnr, stat, inact FROM jest INTO TABLE @DATA(lt_wbs_status) FOR ALL ENTRIES IN @lt_wbs_name
                WHERE objnr = @lt_wbs_name-objnr AND inact NE 'X'.
      ENDIF.
    ENDIF.

    IF NOT lt_order IS INITIAL.
      SELECT aufnr, ktext, objnr, kostl FROM aufk INTO TABLE @DATA(lt_order_name) WHERE aufnr IN @lt_order AND
      auart = 'A000' AND
      kokrs = 'CA01'.
      IF sy-subrc IS INITIAL.
*   Get status of Internal order
        SELECT objnr, stat, inact FROM jest INTO TABLE @DATA(lt_order_status) FOR ALL ENTRIES IN @lt_order_name
                WHERE objnr = @lt_order_name-objnr AND inact NE 'X'.
      ENDIF.
    ENDIF.

    IF NOT lt_asset IS INITIAL.

      SELECT a~anln1, a~anln2, a~xloev AS locked, a~xspeb AS locked_postings, a~deakt AS deactivation_date,
         a~txt50, b~bdatu AS date_valid, b~kostl
    INTO TABLE @DATA(lt_asset_name)
    FROM anla AS a
         INNER JOIN anlz AS b ON b~bukrs = a~bukrs
                             AND b~anln1 = a~anln1
                             AND b~anln2 = a~anln2
   WHERE a~anln1 IN @lt_asset.
    ENDIF.

    LOOP AT lt_account_assignments INTO DATA(ls_account_assignment).
      ls_odata_assignments-parentnumber = ls_account_assignment-ebeln.
      CALL FUNCTION 'CONVERSION_EXIT_ALPHA_OUTPUT'
        EXPORTING
          input  = ls_account_assignment-ebelp
        IMPORTING
          output = ls_odata_assignments-linenumber.

      CALL FUNCTION 'CONVERSION_EXIT_ALPHA_OUTPUT'
        EXPORTING
          input  = ls_account_assignment-zekkn
        IMPORTING
          output = ls_odata_assignments-assignment_item.


      IF ls_account_assignment-loekz = 'X'.
        ls_odata_assignments-isdeleted = abap_true.
      ELSE.
        ls_odata_assignments-isdeleted = abap_false.
      ENDIF.

* ASA Check
      ls_cc_assignments-ebeln = ls_account_assignment-ebeln.
      ls_cc_assignments-ebelp = ls_odata_assignments-linenumber.

*        *      Pass percentage only if quantity is initial
      READ TABLE it_lineitems INTO DATA(ls_lineitems) WITH KEY parentnumber = ls_account_assignment-ebeln
                                                               linenumber = ls_odata_assignments-linenumber.
      IF sy-subrc IS INITIAL.
        IF ls_lineitems-distrib = '1'.
          ls_odata_assignments-quantity = ls_account_assignment-menge.
        ELSEIF ls_lineitems-distrib = '2'.
          ls_odata_assignments-vproz = ls_account_assignment-vproz.
        ELSEIF ls_lineitems-distrib = '3'.
          ls_odata_assignments-amount = ls_account_assignment-netwr.
        ENDIF.
      ENDIF.

* Clear cost centre value for account assignment Project
      IF ls_lineitems-acctasscat = 'P'.
        CLEAR ls_account_assignment-kostl.
      ENDIF.
* GL Account
      ls_odata_assignments-gl_account = ls_account_assignment-sakto.
      IF NOT ls_account_assignment-sakto IS INITIAL .
        READ TABLE lt_gl_names INTO DATA(ls_gl) WITH KEY saknr = ls_account_assignment-sakto.
        IF sy-subrc IS INITIAL.
          ls_odata_assignments-gl_account_text = ls_gl-txt50.

          READ TABLE lt_gl_status INTO DATA(ls_gl_status) WITH KEY saknr = ls_account_assignment-sakto.
          IF sy-subrc IS INITIAL AND (
             NOT ls_gl_status-deletion IS INITIAL OR
            NOT ls_gl_status-xspeb IS INITIAL OR
            NOT ls_gl_status-xloev IS INITIAL OR
            NOT ls_gl_status-xloeb IS INITIAL ).
            ls_odata_assignments-islocked = abap_true.
            ls_odata_assignments-isgllocked = abap_true.
          ENDIF.

        ENDIF.
      ENDIF.

* Cost Center
      ls_odata_assignments-costcenter = ls_account_assignment-kostl.
      IF NOT ls_account_assignment-kostl IS INITIAL.
        ls_cc_assignments-kostl = ls_account_assignment-kostl.
        READ TABLE lt_costcenter_names INTO DATA(ls_costcenter) WITH KEY kostl = ls_account_assignment-kostl.
        IF sy-subrc IS INITIAL.
          ls_odata_assignments-costcenter_name = ls_costcenter-ltext.
        ENDIF.
        READ TABLE lt_cc_details INTO DATA(ls_cc_details) WITH KEY kostl = ls_account_assignment-kostl.
        IF sy-subrc IS INITIAL.
          IF ls_cc_details-bkzkp = abap_true OR ls_cc_details-bkzks = abap_true OR ls_cc_details-bkzer = abap_true OR
                     ls_cc_details-bkzob = abap_true OR ls_cc_details-pkzkp = abap_true OR ls_cc_details-pkzks = abap_true OR
                     ls_cc_details-pkzer = abap_true.
            ls_odata_assignments-islocked = abap_true.
            ls_odata_assignments-iscclocked = abap_true.
          ENDIF.
        ENDIF.
      ENDIF.

* Asset
      ls_odata_assignments-fund = ls_account_assignment-geber.
      ls_odata_assignments-asset_no = ls_account_assignment-anln1.
      ls_odata_assignments-sub_number = ls_account_assignment-anln2.
      READ TABLE lt_asset_name INTO DATA(ls_asset_name) WITH KEY anln1 = ls_account_assignment-anln1
                                                                 anln2 = ls_account_assignment-anln2.
      IF sy-subrc IS INITIAL.
        ls_odata_assignments-asset_name = ls_asset_name-txt50.
        ls_cc_assignments-kostl = ls_asset_name-kostl.               " ASA - Cost centre for Asset
        IF NOT ls_asset_name-locked IS INITIAL OR NOT ls_asset_name-locked_postings IS INITIAL
          OR NOT ls_asset_name-deactivation_date = '00000000' OR
          NOT ls_asset_name-date_valid GE sy-datlo.
          ls_odata_assignments-islocked = abap_true.
          ls_odata_assignments-isassetlocked = abap_true.
        ENDIF.
      ENDIF.

* WBS
* Clear WBS value for account assignment Cost Centre
      IF ls_lineitems-acctasscat = 'K'.
        CLEAR ls_account_assignment-ps_psp_pnr.
      ENDIF.
      CALL FUNCTION 'CONVERSION_EXIT_ABPSP_OUTPUT'
        EXPORTING
          input  = ls_account_assignment-ps_psp_pnr
        IMPORTING
          output = ls_odata_assignments-wbs_element.
      IF NOT ls_account_assignment-ps_psp_pnr IS INITIAL.
        READ TABLE lt_wbs_name INTO DATA(ls_wbs) WITH KEY pspnr = ls_account_assignment-ps_psp_pnr.
        IF sy-subrc IS INITIAL.
          ls_odata_assignments-wbs_name = ls_wbs-post1.
          ls_cc_assignments-kostl = ls_wbs-fkstl.  " ASA - Cost centre for WBS
          ls_cc_assignments-prctr = ls_wbs-prctr.  " ASA - Profit centre for WBS

          LOOP AT lt_wbs_status INTO DATA(ls_wbs_status) WHERE objnr = ls_wbs-objnr.
            IF ls_wbs_status-stat = 'I0043' "Locked and active status record
                                 OR   ls_wbs_status-stat = 'I0045'        "Technically completed and active status record
                                 OR  ls_wbs_status-stat  = 'I0046'        "Closed and active status record
                                 OR   ls_wbs_status-stat = 'I0076'."Deletion Flag and active status record
              ls_odata_assignments-islocked = abap_true.
              ls_odata_assignments-iswbslocked = abap_true.
              EXIT.
            ENDIF.
          ENDLOOP.
        ENDIF.
      ENDIF.

* Internal Orders
      ls_odata_assignments-orderid = ls_account_assignment-aufnr.
      IF NOT ls_account_assignment-aufnr IS INITIAL.
        READ TABLE lt_order_name INTO DATA(ls_order) WITH KEY aufnr = ls_account_assignment-aufnr.
        IF sy-subrc IS INITIAL.
          ls_odata_assignments-ordername = ls_order-ktext.
          ls_cc_assignments-kostl = ls_order-kostl.    " ASA - Cost Centre for Order
          LOOP AT lt_order_status INTO DATA(ls_order_status) WHERE objnr = ls_order-objnr.
            IF ls_order_status-stat = 'I0043' "Locked and active status record
                                 OR   ls_order_status-stat = 'I0045'        "Technically completed and active status record
                                 OR  ls_order_status-stat  = 'I0046'        "Closed and active status record
                                 OR   ls_order_status-stat = 'I0076'."Deletion Flag and active status record
              ls_odata_assignments-islocked = abap_true.
              ls_odata_assignments-isorderlocked = abap_true.
              EXIT.
            ENDIF.
          ENDLOOP.

        ENDIF.

      ENDIF.
      APPEND ls_odata_assignments TO et_assignments.
      APPEND ls_cc_assignments TO et_cc_assignments.
      CLEAR ls_odata_assignments.
    ENDLOOP.

  ENDMETHOD.


 METHOD get_approval_history.
*----------------------------------------------------------------------*
* METHOD ID:          GET_APPROVAL_HISTORY
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method retrieves approvers of purchasing document
*
*
* AUTHOR:             Dathri Yellamarthy (210983DY)
* CREATE DATE:        23/11/2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000002172: MyFi Purchasing (Release 2.3)
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*----------------------------------------------------------------------- *
*06/07/22 210983DY  RD2K922923  S6000002777: MyFi Continuous Improvement August Release
*-------------------------------------------------------------------------


   DATA: lt_container TYPE TABLE OF swr_cont.
   DATA: ls_approvallog TYPE zsmfp_approvals,
         lt_approvallog TYPE ztmfp_approvals,
         lt_typeid      TYPE RANGE OF sww_wi2obj-typeid,
         lt_task        TYPE RANGE OF sww_wi2obj-wi_rh_task,
         lt_catid       TYPE RANGE OF sww_wi2obj-catid.

   DATA(lt_wf_log) = NEW zcl_mfp_workflow_approval( )->read_data( iv_document = iv_object ).



   LOOP AT lt_wf_log INTO DATA(ls_wf_log).

     ls_approvallog-parentnumber = ls_wf_log-zmfp_doc_id.
     ls_approvallog-approverid = ls_wf_log-approver.
     ls_approvallog-approvaldate = ls_wf_log-action_date.
     ls_approvallog-approvaltime = ls_wf_log-action_time.
     ls_approvallog-action = ls_wf_log-action.
     ls_approvallog-recipient = ls_wf_log-recipient.
     ls_approvallog-requestor = ls_wf_log-requestor.

     APPEND ls_approvallog TO lt_approvallog.
     CLEAR : ls_approvallog.

   ENDLOOP.

* Retrieve Title and Name for User ID
   IF NOT lt_approvallog IS INITIAL.
     SELECT  a~pernr, a~usrid, b~nachn, b~vorna, b~cname, b~titel FROM pa0105 AS a
                           INNER JOIN pa0002 AS b ON a~pernr EQ b~pernr
               INTO TABLE @DATA(lt_pers_data) FOR ALL ENTRIES IN @lt_approvallog
               WHERE a~usrid = @lt_approvallog-approverid AND
                     a~begda LE @sy-datum AND
                     a~endda GE @sy-datum AND
                     b~begda LE @sy-datum AND
                     b~endda GE @sy-datum.

     IF sy-subrc IS INITIAL.

       LOOP AT lt_approvallog ASSIGNING FIELD-SYMBOL(<fs_log>).

         READ TABLE lt_pers_data INTO DATA(ls_pers_data) WITH KEY usrid = <fs_log>-approverid.
         IF sy-subrc IS INITIAL.
           <fs_log>-approvername = |{ ls_pers_data-titel } { ls_pers_data-vorna } { ls_pers_data-nachn } |..
           <fs_log>-approverid = ls_pers_data-pernr.
         ENDIF.
       ENDLOOP.
     ENDIF.

   ENDIF.
   SORT lt_approvallog DESCENDING BY approvaldate approvaltime.
   rt_apprval = lt_approvallog.

 ENDMETHOD.


  METHOD get_cc_accountassignments.
*----------------------------------------------------------------------*
* METHOD ID:          GET_CC_ACCOUNTASSIGNMENTS
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2.2).
*                     This method returns list of Cost centre assignments
*
* AUTHOR:             Dathri Yellamarthy(210983DY)
* CREATE DATE:        10.10.2023
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          S 6000003027: MyFi Continuous Improvement November Rel
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 10/10/23 210983DY RD2K924373,
*                   RD2K924447  DS-11-32-07-01 6000003027: MyFi Continuous Improvement November Rel
*-----------------------------------------------------------------------

    DATA: ls_odata_assignments TYPE zcl_zedm_mfp_mpc=>ts_accountassignment,
          lt_gl                TYPE /iwbep/t_cod_select_options,
          lt_costcenter        TYPE /iwbep/t_cod_select_options,
          lt_asset             TYPE /iwbep/t_cod_select_options,
          lt_order             TYPE /iwbep/t_cod_select_options,
          lt_wbs               TYPE /iwbep/t_cod_select_options,
          ls_cc_assignments    TYPE zsfss_mfp_asa_cc.


    lt_costcenter = VALUE /iwbep/t_cod_select_options( FOR ls_accnt IN it_accountassignments ( sign = 'I'
                                                     option = 'EQ'
                                                     low = ls_accnt-costcenter  ) ).

    lt_wbs = VALUE /iwbep/t_cod_select_options( FOR ls_accnt IN it_accountassignments ( sign = 'I'
                                                    option = 'EQ'
                                                    low = ls_accnt-wbs_element ) ).

    lt_order = VALUE /iwbep/t_cod_select_options( FOR ls_accnt IN it_accountassignments ( sign = 'I'
                                                        option = 'EQ'
                                                        low = ls_accnt-orderid ) ).

    lt_asset = VALUE /iwbep/t_cod_select_options( FOR ls_accnt IN it_accountassignments ( sign = 'I'
                                                        option = 'EQ'
                                                        low = ls_accnt-asset_no ) ).

    DELETE lt_order WHERE low IS INITIAL.
    DELETE lt_costcenter WHERE low IS INITIAL.
    DELETE lt_wbs WHERE low IS INITIAL.
    DELETE lt_asset WHERE low IS INITIAL.

    IF NOT lt_costcenter IS INITIAL.
      SELECT kostl, ltext FROM cskt INTO TABLE @DATA(lt_costcenter_names)  WHERE spras = @sy-langu AND
      kokrs = 'CA01' AND kostl IN @lt_costcenter AND datbi GE @sy-datlo.
    ENDIF.

    IF NOT lt_wbs IS INITIAL.
      SELECT pspnr, post1, objnr, prctr, fkstl FROM prps INTO TABLE @DATA(lt_wbs_name) WHERE posid IN @lt_wbs.
    ENDIF.

    IF NOT lt_order IS INITIAL.
      SELECT aufnr, ktext, objnr, kostv FROM aufk INTO TABLE @DATA(lt_order_name) WHERE aufnr IN @lt_order AND
      auart = 'A000' AND
      kokrs = 'CA01'.
    ENDIF.

    IF NOT lt_asset IS INITIAL.

      SELECT a~anln1, a~anln2, a~xloev AS locked, a~xspeb AS locked_postings, a~deakt AS deactivation_date,
         a~txt50, b~bdatu AS date_valid, b~kostl
    INTO TABLE @DATA(lt_asset_name)
    FROM anla AS a
         INNER JOIN anlz AS b ON b~bukrs = a~bukrs
                             AND b~anln1 = a~anln1
                             AND b~anln2 = a~anln2
   WHERE a~anln1 IN @lt_asset.
    ENDIF.

    LOOP AT it_accountassignments INTO DATA(ls_account_assignment).

* ASA Check
      ls_cc_assignments-ebeln = ls_account_assignment-parentnumber.
      ls_cc_assignments-ebelp = ls_account_assignment-linenumber.

* Cost Center
*      ls_odata_assignments-costcenter = ls_account_assignment-costcenter.
      IF NOT ls_account_assignment-costcenter IS INITIAL.
        ls_cc_assignments-kostl = ls_account_assignment-costcenter.

      ENDIF.

* Asset

      READ TABLE lt_asset_name INTO DATA(ls_asset_name) WITH KEY anln1 = ls_account_assignment-asset_no
                                                                 anln2 = ls_account_assignment-sub_number.
      IF sy-subrc IS INITIAL.
        ls_cc_assignments-kostl = ls_asset_name-kostl.               " ASA - Cost centre for Asset
      ENDIF.

* WBS
      CALL FUNCTION 'CONVERSION_EXIT_ABPSP_INPUT'
        EXPORTING
          input  = ls_account_assignment-wbs_element
        IMPORTING
          output = ls_account_assignment-wbs_element. "ls_odata_assignments-wbs_element.
      IF NOT ls_account_assignment-wbs_element IS INITIAL.
        READ TABLE lt_wbs_name INTO DATA(ls_wbs) WITH KEY pspnr = ls_account_assignment-wbs_element.
        IF sy-subrc IS INITIAL.

          ls_cc_assignments-kostl = ls_wbs-fkstl.  " ASA - Cost centre for WBS
          ls_cc_assignments-prctr = ls_wbs-prctr.  " ASA - Profit centre for WBS

        ENDIF.
      ENDIF.
* Internal Orders
      IF NOT ls_account_assignment-orderid IS INITIAL.
        READ TABLE lt_order_name INTO DATA(ls_order) WITH KEY aufnr = ls_account_assignment-orderid.
        IF sy-subrc IS INITIAL.
          ls_cc_assignments-kostl = ls_order-kostv.    " ASA - Cost Centre for Order
        ENDIF.
      ENDIF.
      APPEND ls_cc_assignments TO et_cc_assignments.
      CLEAR ls_cc_assignments.
    ENDLOOP.

  ENDMETHOD.


  METHOD get_changelog.
*----------------------------------------------------------------------*
* METHOD ID:          GET_CHANGELOG
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method retrieves change log for a document
*
*
* AUTHOR:             Dathri Yellamarthy (210983DY)
* CREATE DATE:        23/11/2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000002172: MyFi Purchasing (Release 2.3)
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*----------------------------------------------------------------------- *
** 03/03/21 210983DY  RD2K920554 DS-11-32-07-01 S 6000002250: MyFi Purchasing (Release 2.4 )
*                 Additional logic to display amount values
* 04.08.21 210983DY RD2K921440  DS-11-32-07-01 S6000002451: MyFi Purchasing (August Release)
*                                              Display User name for User ID
* 06/07/22 210983DY  RD2K922923  S6000002777: MyFi Continuous Improvement August Release
*-------------------------------------------------------------------------


    DATA: ls_changelog    TYPE zsmfp_changelog,
          lv_item         TYPE ebelp,
          lv_tdobject     TYPE ttxid-tdobject,
          lt_tabname      TYPE RANGE OF dd02t-tabname,
          lt_domname      TYPE RANGE OF dd07t-domname,
          lt_userid       TYPE RANGE OF pa0105-usrid,
          lt_tdobj        TYPE RANGE OF ttxid-tdobject,
          lt_objectclas   TYPE RANGE OF cdhdr-objectclas,
          lt_id           TYPE RANGE OF ttxid-tdid,
          lt_fname        TYPE RANGE OF cdpos-fname,
          lt_cdred        TYPE TABLE OF cdred,
          ls_decimal      TYPE bapi1090_1,
          ls_bapireturn   TYPE bapireturn,
          lv_value_old    TYPE string,
          lv_value_old_c  TYPE char20,
          lv_value_new    TYPE string,
          lv_decimals     TYPE currdec,
          lv_amount       TYPE bapicurr_d,
          lv_amount_dec3  TYPE p DECIMALS 3,
          lv_amount_dec2  TYPE p DECIMALS 2,
          lv_indi_unknown TYPE char1.

* Range for Tables
    lt_tabname = VALUE #( sign = 'I' option = 'EQ' ( low = 'EKKO' )
                                                   ( low = 'EKPO' )
                                                   ( low = 'EKEK' )
                                                   ( low = 'EKET' )
                                                   ( low = 'EKES' )
                                                   ( low = 'EKKN' )
                                                   ( low = 'EKPA' )
                                                   ( low = 'ZTMFP_PREPMNT' )
                                                   ( low = 'ZTMFP_ADMIN_DETL' )
                                                   ( low = 'ZTMFP_INDIGSUB' )
                                                   ( low = 'ZTMFP_DOC_HEADER' ) ).

* Range for Domain names

    lt_domname = VALUE #( sign = 'I' option = 'EQ' ( low = 'ZMFP_DOCUMENT_STATUS' )
    ( low = 'ZMFP_APP_TRI_STATE_FLAG' )
    ( low = 'ZMFP_CATEGORY' )
    ( low = 'ZMFP_INDIG_OUTCOME' )
    ( low = 'ZMFP_INDIG_OUTCOME_TM' )
     ).

* Range of fieldnames that are excluded
    lt_fname = VALUE #( sign = 'E' option = 'EQ' ( low = 'FRGZU' )
                                                 ( low = 'PROCSTAT' ) ( low = 'AEDAT' ) ).

* Range for Object
    lt_tdobj = VALUE #( sign = 'I' option = 'EQ' ( low = 'EKKO' )
                                                  ( low = 'EKPO' ) ).
* Range for ObjectClass
    lt_objectclas = VALUE #( sign = 'I' option = 'EQ' ( low = 'EINKBELEG' )
                                                  ( low = 'ZMFP_CHANGELOG' ) ).


* Range for TextId
    lt_id = VALUE #( sign = 'I' option = 'BT' ( low = 'K01'  high = 'K20' ) " Header Text ID's
                                              ( low = 'F01' high = 'F20' ) ). " Item Text ID's

* Fetch description for TextID's
    SELECT tdobject, tdid, tdtext FROM ttxit INTO TABLE @DATA(lt_text)
       WHERE tdspras = @sy-langu AND tdobject IN @lt_tdobj
                                AND tdid IN @lt_id.

* Fetch Table Name and Description's
    SELECT tabname, ddtext FROM dd02t INTO TABLE @DATA(lt_tab_desc)
       WHERE tabname IN @lt_tabname
         AND ddlanguage = 'E'.

* Fetch Fixed domain values
    SELECT domname, ddtext, domvalue_l FROM dd07t INTO TABLE @DATA(lt_dom_desc)
       WHERE domname IN @lt_domname
         AND ddlanguage = 'E'.

* Fetch Description for Release Indicators
    SELECT frgke, frget FROM t16fe INTO TABLE @DATA(lt_rel_text) WHERE spras = @sy-langu.

    SELECT * FROM tcurx INTO TABLE @DATA(lt_currency).

    IF NOT sy-subrc IS INITIAL.

    ENDIF.

* Fetch records from Change Header table
    SELECT  * FROM cdhdr INTO TABLE @DATA(lt_header)
                    WHERE objectclas IN @lt_objectclas
                     AND   objectid   =  @iv_object
                     AND   udate      LE  @sy-datum
                     ORDER BY utime DESCENDING.
    IF sy-subrc IS INITIAL.

      IF NOT lt_header IS INITIAL.

        lt_userid = VALUE #( FOR ls_user IN lt_header ( sign = 'I'
                                                        option = 'EQ'
                                                        low = ls_user-username ) ).
        SORT lt_userid BY low.
        DELETE ADJACENT DUPLICATES FROM lt_userid COMPARING low.
* * Retrieve Title and Name for User ID
        SELECT  a~pernr, a~usrid, b~nachn, b~vorna, b~cname, b~titel FROM pa0105 AS a
                             INNER JOIN pa0002 AS b ON a~pernr EQ b~pernr
                 INTO TABLE @DATA(lt_pers_data)
                 WHERE a~subty = '0001' AND
          a~endda GE @sy-datum AND
          a~begda LE @sy-datum AND
          a~usrid IN @lt_userid AND
          b~begda LE @sy-datum AND
          b~endda GE @sy-datum.

      ENDIF.
* Fetch records for Change Item table
      SELECT *  FROM cdpos INTO TABLE @DATA(lt_cdpos)
        FOR ALL ENTRIES IN @lt_header
                  WHERE objectclas IN @lt_objectclas
                   AND  objectid   = @iv_object
                   AND  changenr   = @lt_header-changenr
                   AND tabname     IN @lt_tabname
                   AND fname       IN @lt_fname.

      IF sy-subrc IS INITIAL.

        SELECT tabname, fieldname, scrtext_l FROM ddftx INTO TABLE @DATA(lt_flabels)
          FOR ALL ENTRIES IN @lt_cdpos WHERE tabname = @lt_cdpos-tabname AND
                                            fieldname = @lt_cdpos-fname AND
                                            ddlanguage = @sy-langu.
        IF sy-subrc IS INITIAL.
          SORT lt_flabels BY tabname.
        ENDIF.

        LOOP AT lt_header INTO DATA(ls_header).
          CLEAR : ls_changelog.

          MOVE-CORRESPONDING ls_header TO ls_changelog.
          LOOP AT lt_cdpos INTO DATA(ls_cdpos) WHERE objectid = ls_header-objectid
                                                 AND changenr = ls_header-changenr.
            CHECK ls_cdpos-value_old NE space OR ls_cdpos-value_new NE space OR ls_cdpos-chngind = 'I'.
            lv_item = lv_item + 1.
            MOVE-CORRESPONDING ls_cdpos TO ls_changelog.
            IF ls_cdpos-chngind = 'I' OR
               ls_cdpos-chngind = 'J'.
              ls_changelog-chngind = abap_true. " Entered, Sent to UI as boolean value
            ELSE.
              ls_changelog-chngind = abap_false. "Changed
            ENDIF.
            ls_changelog-udate = ls_header-udate.
            ls_changelog-utime = ls_header-utime.
            ls_changelog-username = ls_header-username.
            READ TABLE lt_pers_data INTO DATA(ls_pers_data) WITH KEY usrid = ls_changelog-username.
            IF sy-subrc IS INITIAL.
              ls_changelog-fullname = |{ ls_pers_data-titel } { ls_pers_data-vorna } { ls_pers_data-nachn } |.
*              CONCATENATE ls_pers_data-titel ls_pers_data-cname INTO ls_changelog-fullname SEPARATED BY space.
            ENDIF.
            ls_changelog-ebeln = ls_cdpos-objectid.
            ls_changelog-sequence = lv_item.
            ls_changelog-ebelp = ls_cdpos-tabkey+13(5).

            IF NOT ls_cdpos-cuky_old IS INITIAL.

              READ TABLE lt_currency INTO DATA(ls_currency) WITH KEY currkey = ls_cdpos-cuky_old.
              IF NOT sy-subrc IS INITIAL.
                lv_decimals = '2'.
              ELSE.
                lv_decimals = ls_currency-currdec.
              ENDIF.
              CASE lv_decimals.
                WHEN '2'.
                  CLEAR lv_amount_dec2.
                  lv_amount_dec2 = ls_cdpos-value_old.
                  WRITE lv_amount_dec2 TO ls_changelog-f_old CURRENCY ls_cdpos-cuky_old.
                WHEN '3'.
                  CLEAR : lv_value_old, lv_amount, lv_amount_dec3.
                  lv_value_old = ls_cdpos-value_old.
                  lv_amount = ls_cdpos-value_old.
                  DATA(lv_value) = zcl_mfp_document=>convert_currency_decimal( iv_waers = ls_cdpos-cuky_old iv_netwr = lv_amount ).
                  lv_value_old = lv_value.
                  SHIFT lv_value_old LEFT DELETING LEADING space.
                  CALL FUNCTION 'Z_CURRENCY_IN_DECIMAL'
                    EXPORTING
                      iv_amount   = lv_value_old
                      iv_currency = ls_cdpos-cuky_old
                    IMPORTING
                      ev_amount   = lv_value_old.
                  lv_amount_dec3 = lv_value_old.

                  WRITE lv_amount_dec3 TO ls_changelog-f_old CURRENCY ls_cdpos-cuky_old.

                WHEN OTHERS.
                  CLEAR : lv_value_old, lv_amount.
                  lv_value_old = ls_cdpos-value_old.
                  lv_amount = ls_cdpos-value_old. "move text value to amount field
                  lv_value = zcl_mfp_document=>convert_currency_decimal( iv_waers = ls_cdpos-cuky_old iv_netwr = lv_amount ).
                  lv_value_old = lv_value. " move value into string field
                  SHIFT lv_value_old LEFT DELETING LEADING space.
                  CALL FUNCTION 'Z_CURRENCY_IN_DECIMAL'
                    EXPORTING
                      iv_amount   = lv_value_old
                      iv_currency = ls_cdpos-cuky_old
                    IMPORTING
                      ev_amount   = lv_value_old.
                  ls_changelog-f_old = zcl_mfp_document=>convert_text_currency( iv_waers = ls_cdpos-cuky_old iv_netwr = lv_value_old ).
                  REPLACE '.' WITH ',' INTO ls_changelog-f_old.
              ENDCASE.
            ELSE.
              ls_changelog-f_old = ls_cdpos-value_old.
            ENDIF.
            CLEAR :  lv_decimals, ls_currency.

            IF NOT ls_cdpos-cuky_new IS INITIAL.

              READ TABLE lt_currency INTO ls_currency WITH KEY currkey = ls_cdpos-cuky_new.
              IF NOT sy-subrc IS INITIAL.
                lv_decimals = '2'.
              ELSE.
                lv_decimals = ls_currency-currdec.
              ENDIF.

              CASE lv_decimals.
                WHEN '2'.
                  CLEAR lv_amount_dec2.
                  lv_amount_dec2 = ls_cdpos-value_new.
                  WRITE lv_amount_dec2 TO ls_changelog-f_new CURRENCY ls_cdpos-cuky_new.

                WHEN '3'.

                  CLEAR : lv_value_new, lv_amount, lv_amount_dec3.
*                  lv_value_new = ls_cdpos-value_new.
                  lv_amount = ls_cdpos-value_new.
                  lv_value = zcl_mfp_document=>convert_currency_decimal( iv_waers = ls_cdpos-cuky_new iv_netwr = lv_amount ).
                  lv_value_new = lv_value.
                  SHIFT lv_value_new LEFT DELETING LEADING space.
                  CALL FUNCTION 'Z_CURRENCY_IN_DECIMAL'
                    EXPORTING
                      iv_amount   = lv_value_new
                      iv_currency = ls_cdpos-cuky_new
                    IMPORTING
                      ev_amount   = lv_value_new.

                  lv_amount_dec3 = lv_value_new.
                  WRITE lv_amount_dec3 TO ls_changelog-f_new CURRENCY ls_cdpos-cuky_new.

                WHEN OTHERS.
                  CLEAR : lv_value_new, lv_amount.
                  lv_value_new = ls_cdpos-value_new.
                  lv_amount = ls_cdpos-value_new.
                  lv_value = zcl_mfp_document=>convert_currency_decimal( iv_waers = ls_cdpos-cuky_new iv_netwr = lv_amount ).
                  lv_value_new = lv_value.
                  CALL FUNCTION 'Z_CURRENCY_IN_DECIMAL'
                    EXPORTING
                      iv_amount   = lv_value_new
                      iv_currency = ls_cdpos-cuky_new
                    IMPORTING
                      ev_amount   = lv_value_new.

                  SHIFT lv_value_new LEFT DELETING LEADING space.
                  ls_changelog-f_new = zcl_mfp_document=>convert_text_currency( iv_waers = ls_cdpos-cuky_new iv_netwr = lv_value_new ).
                  REPLACE '.' WITH ',' INTO ls_changelog-f_new.

              ENDCASE.

            ELSE.

              ls_changelog-f_new = ls_cdpos-value_new.
            ENDIF.


            READ TABLE lt_flabels INTO DATA(ls_field_labels) WITH KEY tabname = ls_cdpos-tabname
                                                                      fieldname = ls_cdpos-fname.
            IF sy-subrc IS INITIAL.
*              ls_changelog-ftext = ls_field_labels-scrtext_m.
              ls_changelog-ftext = ls_field_labels-scrtext_l.
            ELSE.
              IF NOT ls_changelog-ebelp IS INITIAL. " to differentiate Header and Item
                lv_tdobject = 'EKPO'.
              ELSE.
                lv_tdobject = 'EKKO'.
              ENDIF.
              READ TABLE lt_text INTO DATA(ls_text) WITH KEY tdobject = lv_tdobject
                                                               tdid   = ls_cdpos-fname+0(4).
              IF sy-subrc IS INITIAL.
                ls_changelog-ftext = ls_text-tdtext.
                ls_cdpos-tabname = lv_tdobject.
              ELSE.
                ls_changelog-ftext = ls_cdpos-fname.
              ENDIF.
            ENDIF.

            IF ls_changelog-ftext = 'KEY'. CLEAR ls_changelog-ftext. ENDIF.
            IF ls_changelog-fname = 'FRGKE'.
              READ TABLE lt_rel_text INTO DATA(ls_rel_text) WITH KEY frgke = ls_changelog-f_old.
              IF sy-subrc IS INITIAL. ls_changelog-f_old = ls_rel_text-frget. ENDIF.
              READ TABLE lt_rel_text INTO ls_rel_text WITH KEY frgke = ls_changelog-f_new.
              IF sy-subrc IS INITIAL. ls_changelog-f_new = ls_rel_text-frget.ENDIF.
            ENDIF.

            IF ls_cdpos-tabname = 'ZTMFP_DOC_HEADER' AND ls_changelog-fname = 'STATUS'.

              TRY.
                  ls_changelog-f_old = lt_dom_desc[ domname = 'ZMFP_DOCUMENT_STATUS'
                                                                domvalue_l = ls_changelog-f_old ]-ddtext.
                CATCH cx_sy_itab_line_not_found.

              ENDTRY.

              TRY.
                  ls_changelog-f_new = lt_dom_desc[ domname = 'ZMFP_DOCUMENT_STATUS'
                                                 domvalue_l = ls_changelog-f_new ]-ddtext.
                CATCH cx_sy_itab_line_not_found.

              ENDTRY.

            ENDIF.

            IF ls_cdpos-tabname = 'ZTMFP_DOC_HEADER' AND ls_changelog-fname = 'CATEGORY'.
              TRY.
                  ls_changelog-f_old = lt_dom_desc[ domname = 'ZMFP_CATEGORY'
                                             domvalue_l = ls_changelog-f_old ]-ddtext.
                CATCH cx_sy_itab_line_not_found.
              ENDTRY.
              TRY.
                  ls_changelog-f_new = lt_dom_desc[ domname = 'ZMFP_CATEGORY'
                                                  domvalue_l = ls_changelog-f_new ]-ddtext.
                CATCH cx_sy_itab_line_not_found.
              ENDTRY.
            ENDIF.

            IF ls_cdpos-tabname = 'ZTMFP_ADMIN_DETL' AND
              ( ls_changelog-fname = 'IS_ENDORSED_PROCEED' OR
               ls_changelog-fname = 'IS_ICT_SW_HW' OR
               ls_changelog-fname = 'IS_CONSULTANCY' OR
               ls_changelog-fname = 'IS_RATE_GT_4500' OR
               ls_changelog-fname = 'IS_SECRETARY_ADVISED' OR
               ls_changelog-fname = 'IS_INDIG_IDENTIFIED' OR
               ls_changelog-fname = 'IS_INDIG_QUOTE' OR
               ls_changelog-fname = 'IS_SP020' OR
               ls_changelog-fname = 'IS_PREPAYMENT' ) .

              READ TABLE lt_dom_desc INTO DATA(ls_domname) WITH KEY domname = 'ZMFP_APP_TRI_STATE_FLAG'
                                                     domvalue_l = ls_changelog-f_old.
              IF sy-subrc IS INITIAL. ls_changelog-f_old = ls_domname-ddtext. ENDIF.
              READ TABLE lt_dom_desc INTO ls_domname WITH KEY domname = 'ZMFP_APP_TRI_STATE_FLAG'
                                                     domvalue_l = ls_changelog-f_new.
              IF sy-subrc IS INITIAL. ls_changelog-f_new = ls_domname-ddtext. ENDIF.
            ENDIF.

            IF ls_cdpos-tabname = 'ZTMFP_ADMIN_DETL' AND ls_changelog-fname = 'OUTCOMES_OR_TIME'.

              READ TABLE lt_dom_desc INTO ls_domname WITH KEY domname = 'ZMFP_INDIG_OUTCOME_TM'
                                                     domvalue_l = ls_changelog-f_old.
              IF sy-subrc IS INITIAL. ls_changelog-f_old = ls_domname-ddtext. ENDIF.
              READ TABLE lt_dom_desc INTO ls_domname WITH KEY domname = 'ZMFP_INDIG_OUTCOME_TM'
                                                     domvalue_l = ls_changelog-f_new.
              IF sy-subrc IS INITIAL. ls_changelog-f_new = ls_domname-ddtext. ENDIF.
            ENDIF.

            IF ls_cdpos-tabname = 'ZTMFP_ADMIN_DETL' AND ls_changelog-fname = 'IS_INDIG_SUBCONTRACT'.

              ls_changelog-f_old = SWITCH #( ls_changelog-f_old
              WHEN 'Y' THEN 'Yes'
              WHEN 'N' THEN 'No'
              WHEN 'U' THEN 'Unknown'
              ELSE 0 ).

              ls_changelog-f_new = SWITCH #( ls_changelog-f_new
              WHEN 'Y' THEN 'Yes'
              WHEN 'N' THEN 'No'
              WHEN 'U' THEN 'Unknown'
              ELSE 0 ).



            ENDIF.


            ls_changelog-tabname = SWITCH #( ls_cdpos-tabname
                                   WHEN 'EKKO' THEN 'Header'
                                   WHEN 'EKPO' THEN 'Item'
                                   WHEN 'EKKN' THEN 'Account Assignment'
                                   WHEN 'EKEK' THEN 'Scheduling Agreement'
                                   WHEN 'EKET' THEN 'Schedule Lines'
                                   WHEN 'EKES' THEN 'Vendor Confirmations'
                                   WHEN 'EKPA' THEN 'Partner Roles'
                                   WHEN 'ZTMFP_ADMIN_DETL' THEN 'MyFi Admin Details'
                                   WHEN 'ZTMFP_INDIGSUB' THEN 'Indigenous Subcontractor Details'
                                   WHEN 'ZTMFP_DOC_HEADER' THEN 'MyFi Doc Header'
                                   WHEN 'ZTMFP_PREPMNT' THEN 'PrePayment'
             ).




            APPEND ls_changelog TO rt_changelog.
            CLEAR : ls_changelog, ls_cdpos.
          ENDLOOP.

        ENDLOOP.

      ENDIF.
    ENDIF.


  ENDMETHOD.


