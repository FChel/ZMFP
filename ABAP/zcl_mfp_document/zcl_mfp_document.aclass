  method zif_myfi_document~read_data.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_DOCUMENT~zif_myfi_document~read_data
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for MyFi Documents
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
* 30.11.20 220977FKC RD2K920449 DS-11-32-07-01 6000002172: MyFi Purchasing (Release 2.3)
*                                              Enable legacy i.e. non-myfi created docs
*-----------------------------------------------------------------------
    if me->zif_myfi_document~old_doc_header-status eq zif_mfp_constants=>gc_doc_status-draft
    and me->gv_is_legacy ne abap_true.
      me->gv_draft_indicator = abap_true.
    endif.

    me->zif_myfi_document~get_myfi_details( ).
    if me->gv_draft_indicator eq abap_false.
      me->zif_myfi_document~get_mm_details( ).
    endif.
    me->get_consumption( ).
    me->zif_myfi_document~fill_deep_entity( ).
    zif_myfi_document~fill_attachment_entityset( ).
  endmethod.


  METHOD zif_myfi_document~reassign_doc.
 ENDMETHOD.


  METHOD zif_myfi_document~save_draft.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_DOCUMENT~zif_myfi_document~save_draft
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for MyFi Documents
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
*-----------------------------------------------------------------------
    me->zif_myfi_document~update_myfi_tables( ).
    me->assign_document( ).
    me->zif_myfi_document~fill_attachment_entityset( ).

    CALL METHOD zcl_mfp_utilities=>log_myfi_action
      EXPORTING
        iv_doc_number = me->zif_myfi_document~posting_doc_num
        iv_action     = zif_mfp_constants=>gc_log-sub_obj-action-draft
        iv_user_id    = sy-uname .


  ENDMETHOD.


  METHOD zif_myfi_document~update_admin_table.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_DOCUMENT~zif_myfi_document~update_admin_table
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for MyFi Documents
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
* 20/05/21 210983DY  RD2K921041 DS-11-32-07-01 S6000002393: June DFSS release for MyFi Purchasing
*                               Additional code to restrict user to chose payment justification text from dropdown
*-----------------------------------------------------------------------
    SELECT SINGLE * FROM ztmfp_admin_detl INTO @DATA(ls_old_admin) WHERE zmfp_doc_id EQ @me->zif_myfi_document~posting_doc_num.
    CLEAR: ls_old_admin-zmfp_doc_id, ls_old_admin-mandt.
    IF ls_old_admin-pay_term_just_dd IS INITIAL.
      CLEAR ls_old_admin-pay_term_just.
    ELSE.
      ls_old_admin-pay_term_just = zcl_mfp_document=>get_payment_justification_text( iv_payment_just_code = ls_old_admin-pay_term_just_dd ).
    ENDIF.
    MOVE-CORRESPONDING ls_old_admin TO me->zif_myfi_document~old_adm_dtl.

    IF me->zif_myfi_document~new_adm_dtl = me->zif_myfi_document~old_adm_dtl OR me->zif_myfi_document~gv_useraction EQ zif_mfp_constants=>gc_action-odata-create_l4l_po.
      RETURN.
    ENDIF.

    MOVE-CORRESPONDING me->zif_myfi_document~new_adm_dtl TO es_new_data ##ENH_OK.
    MOVE-CORRESPONDING me->zif_myfi_document~old_adm_dtl TO es_old_data ##ENH_OK.

    MOVE-CORRESPONDING es_new_data TO es_new_data_update.
    es_new_data_update-zmfp_doc_id = me->zif_myfi_document~posting_doc_num ##ENH_OK.


    CASE iv_change_indicator.
      WHEN 'I'.
        INSERT ztmfp_admin_detl FROM es_new_data_update.
      WHEN 'U'.
        MODIFY ztmfp_admin_detl FROM es_new_data_update.
      WHEN 'D'.
        DELETE FROM ztmfp_admin_detl WHERE zmfp_doc_id = me->zif_myfi_document~posting_doc_num.
      WHEN OTHERS.
    ENDCASE.
  ENDMETHOD.


  method ZIF_MYFI_DOCUMENT~UPDATE_APPROVAL_STRINGS.
  endmethod.


  method ZIF_MYFI_DOCUMENT~UPDATE_ATTACHMENTS_TABLE.
  endmethod.


  method zif_myfi_document~update_doc_header.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_DOCUMENT~zif_myfi_document~update_doc_header
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for MyFi Documents
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
* 01.12.20 220977FKC RD2K920465 DS-11-32-07-01 6000002172: MyFi Purchasing (Release 2.3)
*                                              Enable legacy (i.e. non myfi documents)
*-----------------------------------------------------------------------
    data:
      ls_header_new type yztmfp_doc_header,
      ls_header_old type yztmfp_doc_header.

    if me->zif_myfi_document~source_doc_num ne me->zif_myfi_document~posting_doc_num and me->zif_myfi_document~source_doc_num is not initial.
      me->zif_myfi_document~new_doc_header-ref_id = me->zif_myfi_document~source_doc_num.
    endif.

    if me->zif_myfi_document~new_doc_header = me->zif_myfi_document~old_doc_header.
      return.
    endif.

    move-corresponding me->zif_myfi_document~new_doc_header to ls_header_new.
    ls_header_new-changed_on = sy-datum.
    ls_header_new-changed_at = sy-uzeit.
    append ls_header_new to et_new_data.

    move-corresponding me->zif_myfi_document~old_doc_header to ls_header_old.
    append ls_header_old to et_old_data.

    move-corresponding ls_header_new to es_new_data_update.
    es_new_data_update-zmfp_doc_id = me->zif_myfi_document~posting_doc_num.

    case iv_change_indicator.
      when 'I'.
        insert ztmfp_doc_header from es_new_data_update.
      when 'U'.
        modify ztmfp_doc_header from es_new_data_update.
      when 'D'.
        delete from ztmfp_doc_header where zmfp_doc_id = me->zif_myfi_document~posting_doc_num.
      when others.
    endcase.

  endmethod.


  METHOD zif_myfi_document~update_indisub.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_DOCUMENT~zif_myfi_document~update_indisub
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for MyFi Documents
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
*-----------------------------------------------------------------------
    DATA: lt_update_new TYPE zmfp_indigsub_tty,
          ls_record     TYPE ztmfp_indigsub,
          lv_success    TYPE xfeld,
          lt_temp_new   TYPE zmfp_indigsub_tty,
          lt_temp_old   TYPE zmfp_indigsub_tty,
          ls_old_data   TYPE yztmfp_indigsub,
          ls_new_data   TYPE yztmfp_indigsub.

    FIELD-SYMBOLS: <record> TYPE ztmfp_indigsub.

    SELECT * FROM ztmfp_indigsub INTO @DATA(ls_indigsub) WHERE zmfp_doc_id EQ @me->zif_myfi_document~posting_doc_num.
      CLEAR: ls_indigsub-zmfp_doc_id, ls_indigsub-mandt.
      APPEND ls_indigsub TO me->zif_myfi_document~old_inidigsub.
    ENDSELECT.

    IF me->zif_myfi_document~new_inidigsub = me->zif_myfi_document~old_inidigsub OR me->zif_myfi_document~gv_useraction EQ zif_mfp_constants=>gc_action-odata-create_l4l_po.
      RETURN.
    ENDIF.

    lt_temp_old = me->zif_myfi_document~old_inidigsub.
    lt_temp_new = me->zif_myfi_document~new_inidigsub.

    LOOP AT lt_temp_old ASSIGNING FIELD-SYMBOL(<fs_old>).
      <fs_old>-zmfp_doc_id = me->zif_myfi_document~posting_doc_num.
      MOVE-CORRESPONDING <fs_old> TO ls_old_data.
      APPEND ls_old_data TO et_old_data.
      <fs_old>-deletion_flag = abap_true.
    ENDLOOP.
    LOOP AT lt_temp_new ASSIGNING FIELD-SYMBOL(<fs_new>).
      <fs_new>-zmfp_doc_id = me->zif_myfi_document~posting_doc_num.
      MODIFY lt_temp_old FROM <fs_new> TRANSPORTING contractorabn contractorname sequence deletion_flag zmfp_doc_id WHERE sequence = <fs_new>-sequence .
      IF sy-subrc <> 0.
        APPEND <fs_new> TO lt_temp_old.
      ENDIF.
    ENDLOOP.

    MOVE-CORRESPONDING lt_temp_old TO et_new_data.
    et_new_data_update = lt_temp_old.

    CASE iv_change_indicator.
      WHEN 'I'.
        INSERT ztmfp_indigsub   FROM TABLE et_new_data_update.
      WHEN 'U'.
        MODIFY ztmfp_indigsub   FROM TABLE et_new_data_update.
      WHEN 'D'.
        DELETE FROM  ztmfp_indigsub  WHERE zmfp_doc_id = me->zif_myfi_document~posting_doc_num.
      WHEN OTHERS.
    ENDCASE.


  ENDMETHOD.


  METHOD zif_myfi_document~update_myfi_tables.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_DOCUMENT~zif_myfi_document~update_myfi_tables
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for MyFi Documents
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
* 03/03/21 210983DY  RD2K920554 DS-11-32-07-01 S 6000002250: MyFi Purchasing (Release 2.4 )
*                               Additional logic to handle changelog updates
*-----------------------------------------------------------------------
    DATA:
      ls_admin_new        TYPE yztmfp_admin_detl,
      ls_admin_old        TYPE yztmfp_admin_detl,
      lt_admin_new        TYPE TABLE OF yztmfp_admin_detl,
      lt_admin_old        TYPE TABLE OF yztmfp_admin_detl,
      lv_objid            TYPE cdhdr-objectid,
      ls_admin_update     TYPE ztmfp_admin_detl,
      lt_header_old       TYPE yztmfp_doc_headers,
      lt_header_new       TYPE yztmfp_doc_headers,
      ls_header_update    TYPE ztmfp_doc_header,
      ls_prepmnts_new     TYPE yztmfp_prepmnt,
      ls_prepmnts_old     TYPE yztmfp_prepmnt,
      lt_prepmnts_new     TYPE TABLE OF yztmfp_prepmnt,
      lt_prepmnts_old     TYPE TABLE OF yztmfp_prepmnt,
      lt_prepmnt_update   TYPE TABLE OF ztmfp_prepmnt,
      lt_indigsub_old	    TYPE yztmfp_indigsub_tty,
      lt_indigsub_new	    TYPE yztmfp_indigsub_tty,
      lt_indigsub_update  TYPE zmfp_indigsub_tty,
      lv_change_indicator TYPE cdchngindh,
      lv_doc_num          TYPE ebeln,
      lv_log_subobj       TYPE balsubobj,
      lv_log_type         TYPE bapi_mtype.

    lv_objid =  me->zif_myfi_document~posting_doc_num.

    IF me->zif_myfi_document~source_doc_num IS INITIAL AND me->zif_myfi_document~posting_doc_num IS NOT INITIAL.
      lv_change_indicator = 'I'.
    ELSEIF me->zif_myfi_document~source_doc_num IS NOT INITIAL AND me->zif_myfi_document~posting_doc_num IS NOT INITIAL.
      lv_change_indicator = 'U'.
    ELSE.
      lv_change_indicator = 'D'.
    ENDIF.

    zif_myfi_document~update_doc_header(
      EXPORTING
        iv_change_indicator = lv_change_indicator
      IMPORTING
        et_old_data        = lt_header_old                 " Change Document Table Type; Generated by RSSCD000
        et_new_data        = lt_header_new                 " Change Document Table Type; Generated by RSSCD000
        es_new_data_update = ls_header_update                 " MyFi Purchasing UI5 Application Document Header Tabl
    ).

    zif_myfi_document~update_admin_table(
      EXPORTING
        iv_change_indicator = lv_change_indicator
      IMPORTING
        es_old_data        =  ls_admin_old                " Change Document Structure; Generated by RSSCD000
        es_new_data        =  ls_admin_new                " Change Document Table Type; Generated by RSSCD000
        es_new_data_update =  ls_admin_update               " MyFi Purchasing UI5 App - Purch Doc Admin Details
    ).
    APPEND ls_admin_old TO lt_admin_old.
    APPEND ls_admin_new TO lt_admin_new.

    zif_myfi_document~update_prepmnt_table(
      EXPORTING
        iv_change_indicator = lv_change_indicator
      IMPORTING
        et_old_data        =  lt_prepmnts_old                " Change Document Structure; Generated by RSSCD000
        et_new_data        =  lt_prepmnts_new                " Change Document Table Type; Generated by RSSCD000
        et_new_data_update =  lt_prepmnt_update              " MyFi Purchasing UI5 App - Purch Doc Admin Details
        ).

    zif_myfi_document~update_indisub(
      EXPORTING
        iv_change_indicator = lv_change_indicator
      IMPORTING
         et_old_data        = lt_indigsub_old                 " Change Document Structure; Generated by RSSCD000
         et_new_data        = lt_indigsub_new                 " Change Document Table Type; Generated by RSSCD000
         et_new_data_update = lt_indigsub_update                 " MyFi Purchasing UI5 App - Purch Doc Admin Details
        ).

    me->zif_myfi_document~in_strings( ).

    CASE lv_change_indicator.
      WHEN 'I'.
        INSERT ztmfp_strings    FROM TABLE me->zif_myfi_document~new_strings.
        lv_log_subobj = zif_mfp_constants=>gc_log-sub_obj-data-insert.
      WHEN 'U'.
        DELETE FROM ztmfp_strings    WHERE zmfp_doc_id = me->zif_myfi_document~posting_doc_num.
        MODIFY ztmfp_strings    FROM TABLE me->zif_myfi_document~new_strings.
        lv_log_subobj = zif_mfp_constants=>gc_log-sub_obj-data-update.
      WHEN 'D'.
        DELETE FROM ztmfp_strings    WHERE zmfp_doc_id = me->zif_myfi_document~posting_doc_num.
        lv_log_subobj = zif_mfp_constants=>gc_log-sub_obj-data-delete.
      WHEN OTHERS.
    ENDCASE.

    IF sy-subrc <> 0.
      lv_log_type = zif_mfp_constants=>gc_log-type-error.
    ELSE.
      lv_log_type = zif_mfp_constants=>gc_log-type-success.
    ENDIF.

    CALL METHOD zcl_mfp_utilities=>log_myfi_data
      EXPORTING
        iv_doc_number = me->zif_myfi_document~posting_doc_num
        iv_user_id    = sy-uname
        iv_log_type   = lv_log_type
        iv_sub_obj    = lv_log_subobj.

    CALL FUNCTION 'ZMFP_CHANGELOG_WRITE_DOCUMENT'
      EXPORTING
        objectid                = lv_objid
        tcode                   = zif_mfp_constants=>gc_tcode
        utime                   = sy-uzeit
        udate                   = sy-datum
        username                = sy-uname
*       planned_change_number   = space
        object_change_indicator = lv_change_indicator
*       planned_or_real_changes = space
*       no_change_pointers      = space
        upd_ztmfp_admin_detl    = lv_change_indicator
        upd_ztmfp_doc_header    = lv_change_indicator
        upd_ztmfp_indigsub      = lv_change_indicator
        upd_ztmfp_prepmnt       = lv_change_indicator
      TABLES
        xztmfp_doc_header       = lt_header_new
        yztmfp_doc_header       = lt_header_old
        xztmfp_admin_detl       = lt_admin_new
        yztmfp_admin_detl       = lt_admin_old
        xztmfp_indigsub         = lt_indigsub_new
        yztmfp_indigsub         = lt_indigsub_old
        xztmfp_prepmnt          = lt_prepmnts_new
        yztmfp_prepmnt          = lt_prepmnts_old.

    COMMIT WORK AND WAIT.


    .
  ENDMETHOD.


  METHOD zif_myfi_document~update_old_doc_header.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_DOCUMENT~zif_myfi_document~update_old_doc_header
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for MyFi Documents
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
* 16.06.20 290977SCN RD2K919514 DS-11-32-07-01 changed
*          070667JPS
*-----------------------------------------------------------------------
    DATA:
      lv_objid            TYPE cdhdr-objectid,
      lt_header_old       TYPE yztmfp_doc_headers,
      lt_header_new       TYPE yztmfp_doc_headers,
      ls_header_update    TYPE ztmfp_doc_header,
      lv_change_indicator TYPE cdchngindh VALUE 'U',
      lv_doc_num          TYPE ebeln.

    SELECT SINGLE * FROM ztmfp_doc_header WHERE zmfp_doc_id EQ @iv_source_doc_num INTO @ls_header_update.
    APPEND ls_header_update TO lt_header_old.
    ls_header_update-ref_id = iv_posting_doc_num.
    IF ls_header_update-status EQ zif_mfp_constants=>gc_doc_status-draft.
      ls_header_update-status = zif_mfp_constants=>gc_doc_status-posted_draft.
    ENDIF.
    APPEND ls_header_update TO lt_header_new.

    MODIFY ztmfp_doc_header FROM ls_header_update.
    lv_objid = ls_header_update-zmfp_doc_id.
    CALL FUNCTION 'ZMFP_CHANGELOG_WRITE_DOCUMENT'
      EXPORTING
        objectid                = lv_objid
        tcode                   = zif_mfp_constants=>gc_tcode
        utime                   = sy-uzeit
        udate                   = sy-datum
        username                = sy-uname
        object_change_indicator = lv_change_indicator
        upd_ztmfp_doc_header    = lv_change_indicator
      TABLES
        xztmfp_doc_header       = lt_header_new
        yztmfp_doc_header       = lt_header_old.

    COMMIT WORK AND WAIT.

  ENDMETHOD.


  METHOD zif_myfi_document~update_prepmnt_table.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_DOCUMENT~zif_myfi_document~update_prepmnt_table
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for MyFi Documents
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
* 03/03/21 210983DY  RD2K920554 DS-11-32-07-01 S 6000002250: MyFi Purchasing (Release 2.4 )
*                     Additional logic for update of prepayment table
*-----------------------------------------------------------------------
    SELECT * FROM ztmfp_prepmnt INTO @DATA(ls_prepay) WHERE zmfp_doc_id EQ @me->zif_myfi_document~posting_doc_num.

      CLEAR: ls_prepay-mandt.
* Clear zmfp_doc_id only if it is not same as posting doc num
      IF ls_prepay-zmfp_doc_id NE me->zif_myfi_document~posting_doc_num. CLEAR ls_prepay-zmfp_doc_id. ENDIF.
      APPEND ls_prepay TO me->zif_myfi_document~old_prepmnts.
    ENDSELECT.
    IF me->zif_myfi_document~new_prepmnts = me->zif_myfi_document~old_prepmnts OR me->zif_myfi_document~gv_useraction EQ zif_mfp_constants=>gc_action-odata-create_l4l_po.
      RETURN.
    ENDIF.

    MOVE-CORRESPONDING me->zif_myfi_document~old_prepmnts TO et_old_data.

    LOOP AT me->zif_myfi_document~new_prepmnts ASSIGNING FIELD-SYMBOL(<fs_new>).
      <fs_new>-zmfp_doc_id = me->zif_myfi_document~posting_doc_num.
    ENDLOOP.

    MOVE-CORRESPONDING me->zif_myfi_document~new_prepmnts TO et_new_data.
    et_new_data_update = me->zif_myfi_document~new_prepmnts.

    CASE iv_change_indicator.
      WHEN 'I'.
        INSERT ztmfp_prepmnt    FROM TABLE et_new_data_update.
      WHEN 'U'.
        MODIFY ztmfp_prepmnt    FROM TABLE et_new_data_update.
      WHEN 'D'.
        DELETE FROM ztmfp_prepmnt    WHERE zmfp_doc_id = me->zif_myfi_document~posting_doc_num.
      WHEN OTHERS.
    ENDCASE.


  ENDMETHOD.


  method ZIF_MYFI_DOCUMENT~UPDATE_STRINGS.



  endmethod.


  METHOD zif_myfi_document~validate.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_DOCUMENT~zif_myfi_document~validate
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for MyFi Documents
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
* 19.06.20 290977SCN RD2K919517 DS-11-32-07-01 S 6000001863: MyFi
*          070667JPS                           Purchasing Release 2_ECC
*                                              DEFECTS II.  Passed the
*                                              correct document number
*                                              to the utilities method.
* 21.10.20 290977SCN RD2K919656 DS-11-32-07-01 S 6000002172: MyFi Purchasing (Release 2.3)
*-----------------------------------------------------------------------

    DATA: ls_doc_header TYPE ztmfp_doc_header.

    CALL METHOD zcl_mfp_utilities=>log_myfi_action
      EXPORTING
        iv_doc_number = me->zif_myfi_document~source_doc_num
        iv_action     = zif_mfp_constants=>gc_log-sub_obj-action-valid
        iv_user_id    = sy-uname.

    MOVE-CORRESPONDING me->zif_myfi_document~old_doc_header TO ls_doc_header.
    ls_doc_header-zmfp_doc_id = me->zif_myfi_document~source_doc_num.
    IF ls_doc_header-status EQ zif_mfp_constants=>gc_doc_status-approved.
      CLEAR ls_doc_header-selected_delegate.
    ENDIF.
    zcl_mfp_document=>export_header(
            EXPORTING
              id    =  zcl_mfp_utilities=>gc_memory_id_header                  " Memory ID for EXPORT/IMPORT memory ID
              value =  ls_doc_header                  " Self Service Purchasing UI5 Application Document Header
          ).

    delegate_required( ).

  ENDMETHOD.
ENDCLASS.