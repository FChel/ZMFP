  endmethod.


  METHOD unassign_document.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_DOCUMENT~unassign_document
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for MyFi Documents
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
* 16.04.21 210983DY RD2K920923 6000002348: MyFi Purchasing (May Defects)
*                  Additional logic to handle Un-assignment of a Document
* 20/05/21 210983DY  RD2K921041 DS-11-32-07-01 S6000002393: June DFSS release for MyFi Purchasing
*                               Additional code to unassign PO and OA for L4L scenario
*-----------------------------------------------------------------------
    DATA: lt_docs	      TYPE zif_mfp_constants=>ty_t_objtyp_ebeln,
          ls_docs       TYPE zif_mfp_constants=>ty_s_objtyp_ebeln,
          ls_doc_header TYPE ztmfp_doc_header,
          ls_return     TYPE bapiret2.

    ls_docs-ebeln = me->zif_myfi_document~source_doc_num.
    CHECK ls_docs-ebeln IS NOT INITIAL.
    MOVE-CORRESPONDING me->zif_myfi_document~new_doc_header TO ls_doc_header.
    IF ls_doc_header-category IS INITIAL.
      MOVE-CORRESPONDING me->zif_myfi_document~old_doc_header TO ls_doc_header.
    ENDIF.

    CASE ls_doc_header-category.
      WHEN zif_mfp_constants=>gc_myfi_doc_type-l4l_oa OR zif_mfp_constants=>gc_myfi_doc_type-myfi_oa OR zif_mfp_constants=>gc_myfi_doc_type-leg_oa.
        ls_docs-objtyp = zif_mfp_constants=>gc_bor-bus2014.
      WHEN zif_mfp_constants=>gc_myfi_doc_type-l4l_po OR zif_mfp_constants=>gc_myfi_doc_type-myfi_po OR zif_mfp_constants=>gc_myfi_doc_type-leg_po.
        ls_docs-objtyp = zif_mfp_constants=>gc_bor-bus2012.
      WHEN OTHERS.
    ENDCASE.

    APPEND ls_docs TO lt_docs.

    CLEAR ls_docs.

* For L4L Scenario get associated PO and unassign it from user's list
    IF ls_doc_header-category = zif_mfp_constants=>gc_myfi_doc_type-l4l_oa.
      ls_docs-ebeln = ls_doc_header-ref_id.
      IF NOT ls_docs-ebeln IS INITIAL.
        SELECT SINGLE category INTO @DATA(lv_category) FROM ztmfp_doc_header WHERE zmfp_doc_id = @ls_docs-ebeln.
        IF sy-subrc IS INITIAL.
          CASE lv_category.
            WHEN zif_mfp_constants=>gc_myfi_doc_type-l4l_oa OR zif_mfp_constants=>gc_myfi_doc_type-myfi_oa OR zif_mfp_constants=>gc_myfi_doc_type-leg_oa.
              ls_docs-objtyp = zif_mfp_constants=>gc_bor-bus2014.
            WHEN zif_mfp_constants=>gc_myfi_doc_type-l4l_po OR zif_mfp_constants=>gc_myfi_doc_type-myfi_po OR zif_mfp_constants=>gc_myfi_doc_type-leg_po.
              ls_docs-objtyp = zif_mfp_constants=>gc_bor-bus2012.
            WHEN OTHERS.
          ENDCASE.
          APPEND ls_docs TO lt_docs.
        ENDIF.
      ENDIF.
    ENDIF.


    CALL METHOD zcl_mfp_utilities=>delete_user_object
      EXPORTING
        it_docs = lt_docs
        iv_user = sy-uname.
    IF sy-subrc IS INITIAL.

      MESSAGE s047(zmfp) WITH ls_docs-ebeln INTO ls_return-message.
      ls_return-type = sy-msgty.
      APPEND ls_return TO gt_return.
      CLEAR ls_return.

    ENDIF.
  ENDMETHOD.


  METHOD validate_einv_paymentterm.

    DATA: ls_changelog TYPE cdred,
          lt_changelog TYPE TABLE OF cdred,
          lv_rel_val   TYPE ekko-rlwrt,
          lv_einv_val  TYPE ekko-rlwrt.

    lv_einv_val = '1000000.00'.

    SELECT  * FROM cdhdr INTO TABLE @DATA(lt_header)
                    WHERE objectclas = 'EINKBELEG'
                     AND   objectid   =  @iv_ebeln
                     AND   udate      LE  @sy-datum
                     ORDER BY utime DESCENDING.

    IF sy-subrc IS INITIAL.
* Fetch records for Change Item table
      SELECT *  FROM cdpos INTO TABLE @DATA(lt_cdpos)
        FOR ALL ENTRIES IN @lt_header
                  WHERE objectclas = 'EINKBELEG'
                   AND  objectid   = @iv_ebeln
                   AND  changenr   = @lt_header-changenr
                   AND tabname     = 'EKKO'
                   AND fname       = 'RLWRT'.

      IF sy-subrc IS INITIAL.

        LOOP AT lt_header INTO DATA(ls_header).

          MOVE-CORRESPONDING ls_header TO ls_changelog.

          LOOP AT lt_cdpos INTO DATA(ls_cdpos) WHERE objectid = ls_header-objectid
                                                 AND changenr = ls_header-changenr.

            MOVE-CORRESPONDING ls_cdpos TO ls_changelog.
            MOVE ls_cdpos-value_old TO ls_changelog-f_old.
            MOVE ls_cdpos-value_new TO ls_changelog-f_new.
            APPEND ls_changelog TO lt_changelog.
            CLEAR : ls_changelog.
          ENDLOOP.

*ls_changelog-


        ENDLOOP.

        SORT lt_changelog BY udate utime.

        READ TABLE lt_changelog INTO ls_changelog INDEX 1.
        IF sy-subrc IS INITIAL.

          lv_rel_val = ls_changelog-f_new.
        ENDIF.
      ENDIF.

    ENDIF.

    IF lv_rel_val LT lv_einv_val.
      rv_valid = abap_true.
    ELSE.
      rv_valid = abap_false.
    ENDIF.

  ENDMETHOD.


  method ZIF_MYFI_DOCUMENT~BAPI_CREATE.
  endmethod.


  method ZIF_MYFI_DOCUMENT~BAPI_READ.
  endmethod.


  METHOD zif_myfi_document~change.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_DOCUMENT~zif_myfi_document~change
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for MyFi Documents
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
* 30.05.20 290977SCN RD2K919533 DS-11-32-07-01 Updated importing parameters for 'decide_new_status'.
* 21.10.20 290977SCN RD2K919656 DS-11-32-07-01 S 6000002172: MyFi Purchasing (Release 2.3)
* 20.10.2022 210983DY RD2K923161  6000002831: MyFi Continuous Improvement November Release
*              Amended logic to to stop triggering workflow for action 'CLOSE' by
*              clearing Delegate name from Memory ID for export
*-----------------------------------------------------------------------
    DATA: lv_success    TYPE boole_d,
          ls_doc_header TYPE ztmfp_doc_header.

    MOVE-CORRESPONDING me->zif_myfi_document~new_doc_header TO ls_doc_header.
    ls_doc_header-zmfp_doc_id = me->zif_myfi_document~source_doc_num.
    me->zif_myfi_document~posting_doc_num = me->zif_myfi_document~source_doc_num.

    IF check_delegate( ) = abap_true.

      CALL METHOD zcl_mfp_utilities=>log_myfi_action
        EXPORTING
          iv_doc_number = me->zif_myfi_document~posting_doc_num
          iv_action     = zif_mfp_constants=>gc_log-sub_obj-action-change
          iv_user_id    = sy-uname.
* For Close action, clear Delegate name from Memory
      IF me->zif_myfi_document~gv_useraction = zif_mfp_constants=>gc_action-odata-po_close.
        CLEAR: ls_doc_header-selected_delegate.
      ENDIF.
      zcl_mfp_document=>export_header(
        EXPORTING
          id    =  zcl_mfp_utilities=>gc_memory_id_header                  " Memory ID for EXPORT/IMPORT memory ID
          value =  ls_doc_header                  " Self Service Purchasing UI5 Application Document Header
      ).
      me->zif_myfi_document~bapi_change( IMPORTING ev_success = lv_success ).
      IF lv_success EQ abap_true.
        IF me->gv_is_legacy = abap_true.
          me->zif_myfi_document~new_doc_header-is_legacy = abap_true.
          me->zif_myfi_document~new_doc_header-status = zcl_mfp_utilities=>translate_mm_status_to_mfp( gv_mm_status ).
        ELSE.
          decide_new_status(
            EXPORTING
              iv_action        = zif_mfp_constants=>gc_action-odata-change              " MyFi Purchasing App Action ID
              iv_myfi_doc_type = me->zif_myfi_document~new_doc_header-category          " MyFi Purchasing UI5 Application Document Category
              iv_old_status    = me->zif_myfi_document~old_doc_header-status            " MyFi Purchasing UI5 Application Document Status
              iv_mm_status     = gv_mm_status                                           " Release Indicator: Purchasing Document
              iv_ebeln         = me->zif_myfi_document~posting_doc_num
            RECEIVING
              rv_new_status    = me->zif_myfi_document~new_doc_header-status ).         " MyFi Purchasing UI5 Application Document Status
        ENDIF.
        CLEAR me->zif_myfi_document~new_doc_header-changed_in_gui.
        me->zif_myfi_document~update_myfi_tables( ).
        IF sy-uname NE 'WF-BATCH'.
          CALL METHOD me->assign_document
            EXPORTING
              iv_assignee = sy-uname.
        ENDIF.
      ENDIF.
    ENDIF.
  ENDMETHOD.


  METHOD zif_myfi_document~create.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_DOCUMENT~zif_myfi_document~create
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for MyFi Documents
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
* 19.06.20 290977SCN RD2K919517 DS-11-32-07-01 S 6000001863: MyFi
*          070667JPS                           Purchasing Release 2_ECC
*                                              DEFECTS II.  Moved the
*                                              submit action to further
*                                              down in the code.  Updated importing parameters for 'decide_new_status'.
* 21/09/20 290977SCN RD2K919977 DS-11-32-07-01 S 6000002096: MyFi Purchasing (Release 2.2)
*-----------------------------------------------------------------------
    DATA: lv_success    TYPE boole_d,
          ls_doc_header TYPE ztmfp_doc_header.

    IF check_delegate( ) EQ abap_true.

*      IF me->zif_myfi_document~new_doc_header-category = zif_mfp_constants=>gc_myfi_doc_type-l4l_po.
        MOVE-CORRESPONDING me->zif_myfi_document~new_doc_header TO ls_doc_header.
*        ls_doc_header-zmfp_doc_id = me->zif_myfi_document~source_doc_num.
*        CLEAR ls_doc_header-selected_delegate.
        zcl_mfp_document=>export_header(
            EXPORTING
              id    =  zcl_mfp_utilities=>gc_memory_id_header                  " Memory ID for EXPORT/IMPORT memory ID
              value =  ls_doc_header  ).                " Self Service Purchasing UI5 Application Document Header
*      ENDIF.
      me->zif_myfi_document~bapi_create( IMPORTING ev_success = lv_success ).

      CALL METHOD zcl_mfp_utilities=>log_myfi_action
        EXPORTING
          iv_doc_number = me->zif_myfi_document~posting_doc_num
          iv_action     = zif_mfp_constants=>gc_log-sub_obj-action-submit
          iv_user_id    = sy-uname.

      IF lv_success EQ abap_true.
        decide_new_status(
             EXPORTING
               iv_action        = zif_mfp_constants=>gc_action-odata-create
               iv_myfi_doc_type = me->zif_myfi_document~new_doc_header-category
               iv_old_status    = me->zif_myfi_document~old_doc_header-status
               iv_mm_status     = gv_mm_status
               iv_ebeln         = me->zif_myfi_document~posting_doc_num
             RECEIVING
               rv_new_status    = me->zif_myfi_document~new_doc_header-status
           ).
        clear me->zif_myfi_document~new_doc_header-changed_in_gui.
        me->zif_myfi_document~update_myfi_tables( ).
        IF me->zif_myfi_document~source_doc_num IS NOT INITIAL.
          me->zif_myfi_document~update_old_doc_header(
            EXPORTING
              iv_source_doc_num  = me->zif_myfi_document~source_doc_num
              iv_posting_doc_num = me->zif_myfi_document~posting_doc_num
          ).
          me->unassign_document( ).
        ENDIF.
        me->assign_document( ).
      ENDIF.
    ENDIF.
  ENDMETHOD.


  METHOD zif_myfi_document~fill_attachment_entityset.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_DOCUMENT~zif_myfi_document~fill_attachment_entityset
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for MyFi Documents
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
*-----------------------------------------------------------------------
    DATA:
      ls_attachment_data     TYPE zsmfp_doc_att,
      lt_attachment_data     TYPE TABLE OF zsmfp_doc_att,
      ls_attachments_ent_set TYPE zcl_zedm_mfp_mpc=>ts_attachment,
      ls_url                 TYPE saeuri,
      lv_doc_num             TYPE ebeln.

    IF me->zif_myfi_document~posting_doc_num IS NOT INITIAL.
      lv_doc_num = me->zif_myfi_document~posting_doc_num.
    ELSE.
      lv_doc_num = me->zif_myfi_document~source_doc_num.
    ENDIF.

    CALL METHOD zcl_mfp_utilities=>get_mime_connect_for_doc
      EXPORTING
        iv_doc_id      = lv_doc_num
      IMPORTING
        et_attachments = lt_attachment_data.

    LOOP AT lt_attachment_data INTO ls_attachment_data.
      CLEAR ls_attachments_ent_set.
      MOVE-CORRESPONDING ls_attachment_data TO ls_attachments_ent_set.

      CALL FUNCTION 'SCMS_AO_URL_READ'
        EXPORTING
          arc_id        = ls_attachment_data-archiv_id
          doc_id        = ls_attachment_data-arc_doc_id
          document_type = ls_attachment_data-mime_type
          pdf_mode      = space
        IMPORTING
          url           = ls_url
        EXCEPTIONS
          error         = 1
          OTHERS        = 2.

      IF sy-subrc NE 0.
        CONTINUE.
*      CLEAR entity.
*      ls_textid-msgid = sy-msgid.
*      ls_textid-msgno = sy-msgno.
*      ls_textid-attr1 = sy-msgv1.
*      ls_textid-attr2 = sy-msgv2.
*      ls_textid-attr3 = sy-msgv3.
*      ls_textid-attr4 = sy-msgv4.
*      RAISE EXCEPTION TYPE /iwbep/cx_mgw_busi_exception
*        EXPORTING
*          textid = ls_textid.
      ELSE.
        ls_attachments_ent_set-sourceuri = ls_url.
        APPEND ls_attachments_ent_set TO et_attachments_ent_set.
      ENDIF.
    ENDLOOP.
  ENDMETHOD.


