  METHOD get_ekko.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_DOCUMENT~get_ekko
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for MyFi Documents
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
*-----------------------------------------------------------------------
    SELECT SINGLE *
             FROM ekko
             INTO rs_ekko
            WHERE ebeln  = iv_ebeln.
  ENDMETHOD.


  METHOD get_ekpo.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_DOCUMENT~GET_EKPO
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for MyFi Documents
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
* 21.10.20 290977SCN RD2K919656 DS-11-32-07-01 S 6000002172: MyFi Purchasing (Release 2.3)
*-----------------------------------------------------------------------
    DATA: lv_amount TYPE ktwrt,
          lt_a016   TYPE STANDARD TABLE OF a016.

    SELECT * FROM  ekpo
             INTO TABLE rt_ekpo
             WHERE  ebeln  = iv_ebeln.

* Get currency for each condition record for OA
    SELECT * FROM a016 AS a
      INTO TABLE lt_a016 WHERE evrtn = iv_ebeln AND
                                      datab LE sy-datum AND
                                      datbi GE sy-datum.
    IF NOT lt_a016 IS INITIAL.
      SELECT knumh, kopos, konwa FROM konp INTO TABLE @DATA(lt_konp) FOR ALL ENTRIES IN @lt_a016
        WHERE knumh = @lt_a016-knumh.
    ENDIF.

    SELECT SINGLE waers FROM ekko INTO @DATA(lv_waers) WHERE ebeln EQ @iv_ebeln.


    LOOP AT rt_ekpo ASSIGNING FIELD-SYMBOL(<ekpo>) .
      lv_amount = <ekpo>-effwr.

      READ TABLE lt_a016 INTO DATA(ls_a016) WITH KEY evrtn = iv_ebeln
                                                     evrtp = <ekpo>-ebelp.
      IF sy-subrc IS INITIAL.
        READ TABLE lt_konp INTO DATA(ls_konp) WITH KEY knumh = ls_a016-knumh.
        IF sy-subrc IS INITIAL.
          lv_waers = ls_konp-konwa.
        ENDIF.
      ENDIF.

      zcl_mfp_utilities=>convert_curr_format(
        EXPORTING
          iv_amount = lv_amount                 " Target Value for Header Area per Distribution
          iv_curr   = lv_waers                 " Currency Key
        RECEIVING
          rv_amount = lv_amount                 " Target Value for Header Area per Distribution
      ).
      <ekpo>-effwr = lv_amount.
    ENDLOOP.
  ENDMETHOD.


  METHOD get_field_mappings.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_DOCUMENT~get_field_mapping
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for MyFi Documents
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
*-----------------------------------------------------------------------
    DATA: lr_admin_data         TYPE REF TO if_fdt_admin_data,
          lr_function           TYPE REF TO  if_fdt_function,
          lr_context            TYPE REF TO if_fdt_context,
          lr_fdt_result         TYPE REF TO if_fdt_result,
          lrx_fdt               TYPE REF TO cx_fdt,
          lv_id                 TYPE if_fdt_types=>id,
          ls_return             TYPE bapiret2.

    TRY .
        cl_fdt_factory=>get_instance_generic( EXPORTING iv_id = zif_mfp_constants=>gc_brf_guid-mapping
                                              IMPORTING eo_instance = lr_admin_data ).
        lr_function ?= lr_admin_data.
        lr_context ?= lr_function->get_process_context( ).
        lr_context->set_value( iv_name = 'DOC_TYPE' ia_value =  iv_doc_type ).
        lr_function->process( EXPORTING io_context = lr_context
                              IMPORTING eo_result  = lr_fdt_result ).
        lr_fdt_result->get_value( IMPORTING ea_value = et_mappings ).

      CATCH cx_fdt INTO lrx_fdt.
        ls_return-type = zcl_grp_bapi_util=>gc_error_msg.
        ls_return-id = zcl_grp_bapi_util=>gc_msg_class.
        ls_return-number = '080'.
        ls_return-message_v1 = lrx_fdt->get_object_name( lv_id ).
        ls_return-message_v2 = lrx_fdt->if_message~get_text( ).
        MESSAGE ID ls_return-id TYPE ls_return-type NUMBER ls_return-number INTO ls_return-message WITH ls_return-message_v1 ls_return-message_v2.
*        APPEND ls_return TO et_return.
    ENDTRY.

  ENDMETHOD.


  METHOD get_payment_justification_text.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_DOCUMENT_CONTRACT~in_admin_details
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for MyFi Documents
*
* AUTHOR:             Dathri Yellamarthy (210983DY)
* CREATE DATE:        20.05.2021
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000002393: June DFSS release for MyFi Purchasing
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
* 20/05/21 210983DY  RD2K921041 DS-11-32-07-01 S6000002393: June DFSS release for MyFi Purchasing
*                               Method to derive drop down values for Payment Justification
*-----------------------------------------------------------------------

    DATA: lt_values TYPE TABLE OF dd07v.

    CALL FUNCTION 'GET_DOMAIN_VALUES'
      EXPORTING
        domname         = 'ZMFP_PMT_TERM_JUSTIFICATION_DD'
        text            = 'X'
*       FILL_DD07L_TAB  = ' '
      TABLES
        values_tab      = lt_values
*       VALUES_DD07L    =
      EXCEPTIONS
        no_values_found = 1
        OTHERS          = 2.
    IF sy-subrc <> 0.
* Implement suitable error handling here
    ELSE.
      READ TABLE lt_values INTO DATA(ls_value) WITH KEY domvalue_l = iv_payment_just_code.
      IF sy-subrc IS INITIAL.
        ev_text = ls_value-ddtext.
      ENDIF.
    ENDIF.

  ENDMETHOD.


  METHOD get_pgrp_name.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_DOCUMENT~get_pgrp_name
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for MyFi Documents
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
*-----------------------------------------------------------------------
    SELECT SINGLE eknam FROM  t024
      WHERE  ekgrp  = @me->zif_myfi_document~old_ekko-ekgrp
      INTO @gv_pur_grp_name.

  ENDMETHOD.


  METHOD get_ref_number.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_DOCUMENT~get_ref_number
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for MyFi Documents
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
*-----------------------------------------------------------------------
    DATA: lv_counter TYPE i.

    SELECT SINGLE unsez FROM ekko WHERE ebeln EQ @iv_ebeln INTO @ev_ref_no.
    IF ev_ref_no CO '0123456789 '.
      lv_counter = ev_ref_no+10.
      lv_counter = lv_counter + 1.
      IF lv_counter = 100. lv_counter = 01. ENDIF.
      ev_ref_no = |{ iv_ebeln }{ lv_counter }|.
    ELSE.
      ev_ref_no = |{ iv_ebeln }01|.
    ENDIF.
  ENDMETHOD.


  METHOD IMPORT_HEADER.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_DOCUMENT~IMPORT_HEADER
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for MyFi Documents
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
*-----------------------------------------------------------------------
    DATA: ls_ptab TYPE zsmfp_memory_header,
          lt_ptab TYPE STANDARD TABLE OF zsmfp_memory_header.

    ls_ptab-name = name.
    ls_ptab-value = value.
    APPEND ls_ptab TO lt_ptab.
    IMPORT lt_ptab = lt_ptab FROM MEMORY ID id.

    READ TABLE lt_ptab INTO ls_ptab INDEX 1.
    value = ls_ptab-value.

  ENDMETHOD.


  METHOD is_asset_changed.
*----------------------------------------------------------------------*
* METHOD ID:          IS_ASSET_CHANGED
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method check if Asset is changed
*
*
* AUTHOR:             Dathri Yellamarthy (210983DY)
* CREATE DATE:        18/08/2022
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000002805: MyFi Continuous Improvement September Release
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*----------------------------------------------------------------------- *
* 18.08.22 210983DY RD2K922968 DS-11-32-07-01 S 6000002805: MyFi Continuous Improvement September Release
*                     Check if PO line with Asset is Changed/Deleted
*-------------------------------------------------------------------------



    DATA: lt_lines   TYPE TABLE OF tline,
          lt_tabname TYPE RANGE OF dd02t-tabname,
          lt_fname   TYPE RANGE OF cdpos-fname,
          lv_objname TYPE tdobname.
    lv_objname = 'ZFSS_MYFI_ASSET_NOTIF_EMAIL'.
*Check if document has any Asset Account Assignment

    SELECT ebeln, ebelp, knttp FROM ekpo INTO TABLE @DATA(lt_ekpo) WHERE ebeln = @iv_document AND knttp = 'A'.
    IF sy-subrc IS INITIAL.

      lt_tabname = VALUE #( sign = 'I' option = 'EQ' ( low = 'EKKO' )
                                                     ( low = 'EKKN' )
                                                     ( low = 'EKPO' )
                                                      ).

      lt_fname = VALUE #( sign = 'I' option = 'EQ' ( low = 'KEY' )
                                                 ( low = 'ANLN1' )
                                                 ( low = 'LOEKZ' )
                                                 ).
* Fetch records from Change Header table
      SELECT  * FROM cdhdr INTO TABLE @DATA(lt_header)
                      WHERE objectclas  =  'EINKBELEG'
                       AND   objectid   =  @iv_document
                       AND   username     NE 'WF-BATCH'
                       AND   udate      =  @sy-datum
                       ORDER BY utime DESCENDING.

      IF sy-subrc IS INITIAL.

        READ TABLE lt_header INTO DATA(ls_header) INDEX 1.
* Fetch records for Change Item table
        SELECT *  FROM cdpos INTO TABLE @DATA(lt_cdpos)
*          FOR ALL ENTRIES IN @lt_header
                    WHERE objectclas = 'EINKBELEG'
                     AND  objectid   = @iv_document
                     AND  changenr   = @ls_header-changenr
                     AND tabname     IN @lt_tabname "= 'EKKN'
                     AND fname       IN @lt_fname. "= 'ANLN1'.

        LOOP AT lt_cdpos INTO DATA(ls_cdpos).
          IF ls_cdpos-fname = 'ANLN1'.
            IF ls_cdpos-value_new NE ls_cdpos-value_old.
              ev_asset_changed = abap_true.
              EXIT.
            ENDIF.
          ELSE.
            IF ls_cdpos-fname = 'KEY' AND ls_cdpos-chngind = 'I'.
              ev_asset_changed = abap_true.
              EXIT.
            ENDIF.
          ENDIF.
        ENDLOOP.

        LOOP AT lt_cdpos INTO ls_cdpos WHERE tabname ='EKPO' AND fname = 'LOEKZ'.
          DATA(lv_item_no) = ls_cdpos-tabkey+13(5).
          READ TABLE lt_ekpo INTO DATA(ls_ekpo) WITH KEY ebeln = iv_document ebelp = lv_item_no.
          IF sy-subrc IS INITIAL.
            ev_asset_deleted = abap_true.

          ENDIF.
        ENDLOOP.

        IF ev_asset_changed = abap_true OR ev_asset_deleted = abap_true.

          CALL FUNCTION 'READ_TEXT'
            EXPORTING
*             CLIENT                  = SY-MANDT
              id                      = 'ST'
              language                = sy-langu
              name                    = lv_objname
              object                  = 'TEXT'
            TABLES
              lines                   = lt_lines
            EXCEPTIONS
              id                      = 1
              language                = 2
              name                    = 3
              not_found               = 4
              object                  = 5
              reference_check         = 6
              wrong_access_to_archive = 7
              OTHERS                  = 8.
          IF sy-subrc <> 0.
* Implement suitable error handling here
          ELSE.
            ev_asset_email = lt_lines[ 1 ]-tdline.
          ENDIF.
        ENDIF.
      ENDIF.
    ENDIF.
  ENDMETHOD.


  METHOD log_update_indisub.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_DOCUMENT~log_update_indisub
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for MyFi Documents
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
*-----------------------------------------------------------------------
    DATA:lt_indigsub_old TYPE STANDARD TABLE OF yztmfp_indigsub,
         lt_indigsub_new TYPE STANDARD TABLE OF yztmfp_indigsub,
         ls_indigsub     TYPE yztmfp_indigsub,
         lv_objid        TYPE cdhdr-objectid,
         lv_tcode        TYPE cdhdr-tcode,
         lv_utime        TYPE cdhdr-utime,
         lv_udate        TYPE cdhdr-udate,
         lv_uname        TYPE cdhdr-username,
         ls_data         TYPE ztmfp_indigsub,
         lt_data         TYPE TABLE OF ztmfp_indigsub.


    lv_objid = me->zif_myfi_document~source_doc_num.
    ls_data-zmfp_doc_id = me->zif_myfi_document~source_doc_num.
    lv_tcode = 'MYFI'.
*    lv_utime = me->zif_myfi_document~gv_save_time.
*    lv_udate = me->zif_myfi_document~gv_save_date.
    lv_uname = sy-uname.

    MOVE-CORRESPONDING it_old_data TO lt_indigsub_old.
    MOVE-CORRESPONDING it_new_data TO lt_indigsub_new.

    CASE iv_change_indicator.
      WHEN 'I'.
        CALL FUNCTION 'ZMFP_CHANGELOG_WRITE_DOCUMENT'
          EXPORTING
            objectid           = lv_objid
            tcode              = lv_tcode
            utime              = lv_utime
            udate              = lv_udate
            upd_ztmfp_indigsub = iv_change_indicator
          TABLES
            xztmfp_indigsub    = lt_indigsub_new.

        INSERT ztmfp_indigsub FROM TABLE it_new_data.

        IF sy-subrc = 0.
          CLEAR es_return.
          ev_success = abap_true.
        ELSE.
          es_return-id = sy-msgid.
          es_return-type = sy-msgty.
          es_return-number = sy-msgno.
          es_return-message_v1 = sy-msgv1.
          es_return-message_v2 = sy-msgv2.
          es_return-message_v3 = sy-msgv3.
          es_return-message_v4 = sy-msgv4.
          ev_success = abap_false.
        ENDIF.

      WHEN 'U'.
        CALL FUNCTION 'ZMFP_CHANGELOG_WRITE_DOCUMENT'
          EXPORTING
            objectid           = lv_objid
            tcode              = lv_tcode
            utime              = lv_utime
            udate              = lv_udate
            upd_ztmfp_indigsub = iv_change_indicator
          TABLES
            xztmfp_indigsub    = lt_indigsub_new
            yztmfp_indigsub    = lt_indigsub_old.

        MODIFY ztmfp_indigsub FROM TABLE it_new_data.

        IF sy-subrc = 0.
          CLEAR es_return.
          ev_success = abap_true.
        ELSE.
          es_return-id = sy-msgid.
          es_return-type = sy-msgty.
          es_return-number = sy-msgno.
          es_return-message_v1 = sy-msgv1.
          es_return-message_v2 = sy-msgv2.
          es_return-message_v3 = sy-msgv3.
          es_return-message_v4 = sy-msgv4.
          ev_success = abap_false.
        ENDIF.

      WHEN 'D'.

        CALL FUNCTION 'ZMFP_CHANGELOG_WRITE_DOCUMENT'
          EXPORTING
            objectid           = lv_objid
            tcode              = lv_tcode
            utime              = lv_utime
            udate              = lv_udate
            upd_ztmfp_indigsub = iv_change_indicator
          TABLES
            yztmfp_indigsub    = lt_indigsub_old.

        DELETE ztmfp_indigsub FROM TABLE lt_indigsub_old.

        IF sy-subrc = 0.
          CLEAR es_return.
          ev_success = abap_true.
        ELSE.
          es_return-id = sy-msgid.
          es_return-type = sy-msgty.
          es_return-number = sy-msgno.
          es_return-message_v1 = sy-msgv1.
          es_return-message_v2 = sy-msgv2.
          es_return-message_v3 = sy-msgv3.
          es_return-message_v4 = sy-msgv4.
          ev_success = abap_false.
        ENDIF.
    ENDCASE.
  ENDMETHOD.


  METHOD map_bapi_2_odata.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_DOCUMENT~map_bapi_2_odata
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for MyFi Documents
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
* 30.08.22 010965MI  RD2K923068 DS-11-32-07-01 	S 6000002812: MyFi Continuous Improvement October - Performance
*-----------------------------------------------------------------------

    DATA: ls_header_mapping TYPE zsmfp_field_mapping,
          lv_timestamp      TYPE timestampl,
          lv_date           TYPE dats.

    FIELD-SYMBOLS: <data>  TYPE any,
                   <value> TYPE any.

    data(lv_out_structure) = cl_abap_typedescr=>describe_by_data( p_data = es_data )->get_relative_name( ).
    data(lv_in_structure) = cl_abap_typedescr=>describe_by_data( p_data = is_sending_structure )->get_relative_name( ).

    ASSIGN ls_header_mapping-odata_field TO FIELD-SYMBOL(<odata_fieldname>).
    ASSIGN ls_header_mapping-abap_field TO FIELD-SYMBOL(<abap_fieldname>).

    LOOP AT gt_doc_mapping INTO ls_header_mapping WHERE odata_entity EQ lv_out_structure AND abap_struc EQ lv_in_structure.
      ASSIGN COMPONENT <abap_fieldname> OF STRUCTURE is_sending_structure TO <value>.
      ASSIGN COMPONENT <odata_fieldname> OF STRUCTURE es_data TO <data>.
      IF <data> IS ASSIGNED AND <value> IS ASSIGNED.

        CASE ls_header_mapping-bend2odata.
          WHEN 'DIRECT'.
            <data> = <value>.
          WHEN 'CONVERT_TO_TIMESTAMP'.
            CONVERT DATE <value> INTO TIME STAMP lv_timestamp TIME ZONE 'UTC'.
            <data> = lv_timestamp.
          WHEN 'CONVERT_TEXT_TO_TIMESTAMP'.
            lv_date = |{ <value>+6(4) }{ <value>+3(2) }{ <value>(2) }|.
            CONVERT DATE lv_date INTO TIME STAMP lv_timestamp TIME ZONE 'UTC'.
            <data> = lv_timestamp.
          WHEN 'ALPHA_OUTPUT'.
            CALL FUNCTION 'CONVERSION_EXIT_ALPHA_OUTPUT'
              EXPORTING
                input  = <value>
              IMPORTING
                output = <data>.
          WHEN OTHERS.
        ENDCASE.
        UNASSIGN: <data>, <value>.
      ENDIF.
    ENDLOOP.


  ENDMETHOD.


  METHOD map_odata_2_bapi.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_DOCUMENT~map_odata_2_bapi
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for MyFi Documents
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
* 01.12.20 220977FKC RD2K920465 DS-11-32-07-01 6000002172: MyFi Purchasing (Release 2.3)
*                                              Enable legacy (i.e. non myfi documents)
* 30.08.22 010965MI  RD2K923068 DS-11-32-07-01 	S 6000002812: MyFi Continuous Improvement October - Performance
*-----------------------------------------------------------------------

    DATA: ls_header_mapping TYPE zsmfp_field_mapping,
          lv_date           TYPE dats.

    FIELD-SYMBOLS: <data>        TYPE any,
                   <value>       TYPE any,
                   <xvalue>      TYPE any,
                   <change_flag> TYPE boole_d.

    DATA(lv_out_structure) = cl_abap_typedescr=>describe_by_data( p_data = es_data )->get_relative_name( ).
    DATA(lv_in_structure) = cl_abap_typedescr=>describe_by_data( p_data = is_sending_structure )->get_relative_name( ).

    ASSIGN ls_header_mapping-odata_field TO FIELD-SYMBOL(<odata_fieldname>).
    ASSIGN ls_header_mapping-abap_field TO FIELD-SYMBOL(<abap_fieldname>).

    LOOP AT gt_doc_mapping INTO ls_header_mapping WHERE abap_struc EQ lv_out_structure AND odata_entity EQ lv_in_structure.
      ASSIGN COMPONENT <odata_fieldname> OF STRUCTURE is_sending_structure TO <value>.
      IF <value> IS ASSIGNED.
        IF <value> IS INITIAL AND me->gv_draft_indicator EQ abap_true.
          CONTINUE.
        ENDIF.
      ENDIF.
      ASSIGN COMPONENT <abap_fieldname> OF STRUCTURE es_data TO <data>.
      IF <data> IS ASSIGNED AND <value> IS ASSIGNED.
        CASE ls_header_mapping-odata2bend.
          WHEN 'DIRECT'.
            <data> = <value>.
          WHEN 'CONVERT_FROM_TIMESTAMP'.
            lv_date = zcl_mfp_utilities=>get_date_from_ts( EXPORTING iv_timestamp = <value> ).
            <data> = lv_date.
          WHEN 'ALPHA_INPUT'.
            CALL FUNCTION 'CONVERSION_EXIT_ALPHA_INPUT'
              EXPORTING
                input  = <value>
              IMPORTING
                output = <data>.
          WHEN OTHERS.
        ENDCASE.

        IF is_sending_x_structure EQ abap_true.
          CASE <abap_fieldname>.
            WHEN 'PO_ITEM' OR 'ITEM_NO' OR 'SCHED_LINE'.
              ASSIGN COMPONENT |{ <abap_fieldname> }X| OF STRUCTURE es_data_x TO <change_flag>.
              ASSIGN COMPONENT <abap_fieldname> OF STRUCTURE es_data_x TO <xvalue>.
              <xvalue> = <data>.
            WHEN 'DIFF_INV'.
              IF <data> NE me->zif_myfi_document~old_ekko-lifre.
                ASSIGN COMPONENT <abap_fieldname> OF STRUCTURE es_data_x TO <change_flag>.
              ENDIF.
            WHEN OTHERS.
              ASSIGN COMPONENT <abap_fieldname> OF STRUCTURE es_data_x TO <change_flag>.
          ENDCASE.
          <change_flag> = abap_true.
        ENDIF.

        UNASSIGN: <data>, <value>.
      ENDIF.
    ENDLOOP.
  ENDMETHOD.


  METHOD message_handler.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_DOCUMENT~message_handler
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for MyFi Documents
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
* 21/09/20 290977SCN RD2K919977 DS-11-32-07-01 S 6000002096: MyFi Purchasing (Release 2.2)
* 21.10.20 290977SCN RD2K919656 DS-11-32-07-01 S 6000002172: MyFi Purchasing (Release 2.3)
*-----------------------------------------------------------------------
    DATA: ls_return     TYPE bapiret2,
          lt_return     TYPE bapiret2_t,
          lr_context    TYPE REF TO if_fdt_context,
          lr_admin_data TYPE REF TO if_fdt_admin_data,
          lr_function   TYPE REF TO  if_fdt_function,
          lr_fdt_result TYPE REF TO if_fdt_result,
          lrx_fdt       TYPE REF TO cx_root.

    APPEND LINES OF it_return TO lt_return.
    SORT lt_return ASCENDING BY number message_v1 message_v2 message_v3 message_v4.
    DELETE ADJACENT DUPLICATES FROM lt_return.

    TRY .
        cl_fdt_factory=>get_instance_generic( EXPORTING iv_id = zif_mfp_constants=>gc_brf_guid-messages
                                              IMPORTING eo_instance = lr_admin_data ).
        lr_function ?= lr_admin_data.
        lr_context ?= lr_function->get_process_context( ).
        lr_context->set_value( iv_name = 'IT_RETURN' ia_value = it_return ).
        lr_function->process( EXPORTING io_context = lr_context
                              IMPORTING eo_result  = lr_fdt_result ).
        lr_fdt_result->get_value( IMPORTING ea_value = lt_return ).
      CATCH cx_fdt cx_sy_move_cast_error cx_sy_ref_is_initial INTO lrx_fdt.
    ENDTRY.

    LOOP AT lt_return ASSIGNING FIELD-SYMBOL(<fs_message>).
*      IF <fs_message>-type EQ 'S' OR <fs_message>-type EQ 'E' OR <fs_message>-type EQ 'W'.
*        ls_return-type = <fs_message>-type.
*        ls_return-message = <fs_message>-message.
*        APPEND ls_return TO rt_return.
*      ENDIF.
      CLEAR <fs_message>-id.
    ENDLOOP.


    rt_return = lt_return.
  ENDMETHOD.


  METHOD move_attachments.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_DOCUMENT~move_attachments
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for MyFi Documents
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
*-----------------------------------------------------------------------
    DATA: lt_attachments TYPE zmfp_attachment_tt,
          ls_attach      TYPE zsmfp_arch_connect.

    CALL METHOD zcl_mfp_utilities=>get_mime_connect_for_doc
      EXPORTING
        iv_doc_id      = iv_sending_doc
      IMPORTING
        et_attachments = lt_attachments.

    LOOP AT lt_attachments INTO DATA(ls_attachment).
      MOVE-CORRESPONDING ls_attachment TO ls_attach.
      ls_attach-object_id  = iv_receiving_doc.
      ls_attach-filename   = ls_attachment-file_name.
      ls_attach-descr      = ls_attachment-file_name.
      ls_attach-creator    = sy-uname.
      IF iv_receiving_doc_type IS NOT INITIAL. ls_attach-sap_object = iv_receiving_doc_type. ENDIF.
      CALL METHOD zcl_mfp_utilities=>connect_mime_to_doc
        EXPORTING
          is_attachment = ls_attach.
    ENDLOOP.
  ENDMETHOD.


  METHOD recall_approval.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_DOCUMENT~recall_approval
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for MyFi Documents
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
*-----------------------------------------------------------------------
    zcl_mfp_oa=>update_myfi_status(
      EXPORTING
        iv_ebeln         = me->zif_myfi_document~source_doc_num                 " Purchasing Document Number
        iv_action        = zif_mfp_constants=>gc_action-odata-change                 " MyFi Purchasing App Action ID
      IMPORTING
        ev_new_status    =  DATA(lv_new_status)                " MyFi Purchasing UI5 Application Document Status
    ).

    me->zif_myfi_document~old_doc_header-status = lv_new_status.

  ENDMETHOD.


