CLASS ZCL_MFP_DOCUMENT IMPLEMENTATION.


  METHOD assign_document.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_DOCUMENT~assign_document
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for MyFi Documents
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
* 06/07/22 210983DY  RD2K922923 DS-11-32-07-01 S6000002777:MyFi Continuous Improvement
*                                              August Release
*-----------------------------------------------------------------------
    DATA: lt_docs       TYPE zif_mfp_constants=>ty_t_objtyp_ebeln,
          ls_docs       TYPE zif_mfp_constants=>ty_s_objtyp_ebeln,
          lv_folder     TYPE smyo_node,
          ls_doc_header TYPE ztmfp_doc_header.

*    CHECK sy-uname NE 'WF-BATCH' OR iv_assignee IS NOT INITIAL.
    IF iv_assignee IS INITIAL.
      iv_assignee = sy-uname.
    ENDIF.

    CHECK iv_assignee NE 'WF-BATCH'.

    ls_docs-ebeln = me->zif_myfi_document~posting_doc_num.
    IF ls_docs-ebeln IS INITIAL.
      ls_docs-ebeln = me->zif_myfi_document~source_doc_num.
    ENDIF.
    CHECK ls_docs-ebeln IS NOT INITIAL.
    MOVE-CORRESPONDING me->zif_myfi_document~new_doc_header TO ls_doc_header.
    IF ls_doc_header-category IS INITIAL.
      MOVE-CORRESPONDING me->zif_myfi_document~old_doc_header TO ls_doc_header.
    ENDIF.

    IF ls_doc_header-status EQ zif_mfp_constants=>gc_action-odata-draft.
      lv_folder = zif_mfp_constants=>gc_object_folder_drafts.
    ELSE.
      lv_folder = zif_mfp_constants=>gc_object_folder.
    ENDIF.

    CASE ls_doc_header-category.
      WHEN zif_mfp_constants=>gc_myfi_doc_type-l4l_oa OR zif_mfp_constants=>gc_myfi_doc_type-myfi_oa OR zif_mfp_constants=>gc_myfi_doc_type-leg_oa.
        ls_docs-objtyp = zif_mfp_constants=>gc_bor-bus2014.
      WHEN zif_mfp_constants=>gc_myfi_doc_type-l4l_po OR zif_mfp_constants=>gc_myfi_doc_type-myfi_po OR zif_mfp_constants=>gc_myfi_doc_type-leg_po.
        ls_docs-objtyp = zif_mfp_constants=>gc_bor-bus2012.
      WHEN OTHERS.
    ENDCASE.
    CHECK ls_docs-objtyp IS NOT INITIAL.
    APPEND ls_docs TO lt_docs.

    CALL METHOD zcl_mfp_utilities=>add_user_objects
      EXPORTING
        iv_user   = iv_assignee
        iv_folder = lv_folder
        it_docs   = lt_docs.

  ENDMETHOD.


  method CHECK_DELEGATE.
  endmethod.


  METHOD check_invoice_approver_email.
*----------------------------------------------------------------------*
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for MyFi Documents to validate
*                     Invoice Approver email deom delivery address line 1
*
* AUTHOR:             Dathri Yellamarthy (210983DY)
* CREATE DATE:        02.03.2021
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000002250 - MyFi Purchasing Release 2.4
*-----------------------------------------------------------------------

    IF NOT iv_email IS INITIAL.
* Check if email entered exists in table /ors/usermap or zfvim_poc_mapng
      SELECT COUNT(*) FROM /ors/usermap
           WHERE email = iv_email.

      IF NOT sy-subrc IS INITIAL.

        SELECT COUNT(*) FROM zfvim_poc_mapng
              WHERE poc_email = iv_email.
        IF NOT sy-subrc IS INITIAL.

          MESSAGE e102(zmfp) WITH iv_email INTO es_return-message.
          es_return-type = sy-msgty.
        ENDIF.
      ENDIF.
    ENDIF.

ENDMETHOD.


  METHOD convert_alpha_input.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_DOCUMENT~convert_alpha_input
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for MyFi Documents
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
*-----------------------------------------------------------------------
    DATA: lv_data TYPE REF TO data.
    FIELD-SYMBOLS: <fs_data> TYPE data.

    CREATE DATA lv_data TYPE (propname).
    ASSIGN lv_data->* TO <fs_data>.

    CALL FUNCTION 'CONVERSION_EXIT_ALPHA_INPUT'
      EXPORTING
        input  = value
      IMPORTING
        output = <fs_data>.

    value = <fs_data>.
  ENDMETHOD.


  METHOD convert_currency_decimal.

    CALL FUNCTION 'BAPI_CURRENCY_CONV_TO_EXTERNAL'
      EXPORTING
        currency        = iv_waers
        amount_internal = iv_netwr
      IMPORTING
        amount_external = ev_netwr.

  ENDMETHOD.


  METHOD convert_text_currency.

    CALL FUNCTION 'PSSV_TEXT_INTO_FIELD_CURRENCY'
      EXPORTING
        i_amount       = iv_netwr
        i_currency     = iv_waers
      IMPORTING
        e_amount       = ev_netwr
      EXCEPTIONS
        wrong_amount   = 1
        wrong_currency = 2
        wrong_decimal  = 3
        OTHERS         = 4.
    IF sy-subrc <> 0.
* Implement suitable error handling here
    ENDIF.



  ENDMETHOD.


