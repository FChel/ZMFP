*-----------------------------------------------------------------------
    result = me->lpor.
  ENDMETHOD.


  METHOD bi_persistent~refresh ##needed.
  ENDMETHOD.


  METHOD calculate_deadline_date.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_PO~CALCULATE_DEADLINE_DATE
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for PO Workflows for MyFi
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
*-----------------------------------------------------------------------
    CASE gs_ztmfp_doc_header-status.
      WHEN zif_mfp_constants=>gc_doc_status-draft.
        gv_deadline = sy-datum + 30.
      WHEN OTHERS.
    ENDCASE.

  ENDMETHOD.


  METHOD check_appr_auth.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_PO~check_appr_auth
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for PO Workflows for MyFi
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
*-----------------------------------------------------------------------
    zcl_mfp_utilities=>auth_check(
      EXPORTING
        iv_application = zif_mfp_constants=>gc_service_guid-approver_app                 " Program, transaction or function module name
        iv_userid      = iv_userid                 " User Name
      RECEIVING
        rv_authorised  = ev_authorised                 " Data element for domain BOOLE: TRUE (='X') and FALSE (=' ')
    ).

  ENDMETHOD.


  METHOD CHECK_ASSET_CHANGED.
*----------------------------------------------------------------------*
* METHOD ID:          CHECK_ASSET_CHANGED
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method check if Asset is changed
*
*
* AUTHOR:             Dathri Yellamarthy (210983DY)
* CREATE DATE:        18/08/2022
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000002805: MyFi Continuous Improvement September Release
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*----------------------------------------------------------------------- *
* 18.08.22 210983DY RD2K922968 DS-11-32-07-01 S 6000002805: MyFi Continuous Improvement September Release
*                     Check if PO line with Asset is Changed/Deleted
*-------------------------------------------------------------------------

    CALL METHOD zcl_mfp_document=>is_asset_changed
      EXPORTING
        iv_document      = iv_document
      IMPORTING
        ev_asset_changed = ev_asset_changed
        ev_asset_deleted = ev_asset_deleted
        ev_asset_email   = ev_asset_email.

  ENDMETHOD.


  METHOD complete_recall_workitem.
*----------------------------------------------------------------------*
* METHOD ID:          COMPLETE_RECALL_WORKITEM
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2.2).
*                     This method is used to get a users details.
*
* AUTHOR:             Dathri Yellamarthy (210983DY)
* CREATE DATE:        05.07.2021
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          S6000002419: MyFi Purchasing (July Release)
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 05.07.2021 210983DY RD2K921312 DS-11-32-07-01 S6000002419: MyFi Purchasing (July Release)
*-----------------------------------------------------------------------

    DATA: lt_worklist TYPE TABLE OF swr_wihdr,
          ls_object   TYPE sibflporb,
          lv_return   TYPE sysubrc..
    ls_object-catid = 'CL'.
    ls_object-typeid = c_classname.
    ls_object-instid = iv_ebeln.

    CALL FUNCTION 'SAP_WAPI_WORKITEMS_TO_OBJECT'
      EXPORTING
        object_por      = ls_object
        top_level_items = ' '
      TABLES
        worklist        = lt_worklist.

    READ TABLE lt_worklist INTO DATA(ls_worklist) WITH KEY wi_rh_task = 'TS90600430'.
    IF sy-subrc IS INITIAL.

      CALL FUNCTION 'SAP_WAPI_WORKITEM_COMPLETE'
        EXPORTING
          workitem_id = ls_worklist-wi_id
        IMPORTING
          return_code = lv_return.

    ENDIF.


  ENDMETHOD.


  METHOD constructor.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_PO~constructor
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for PO Workflows for MyFi
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
* 03/03/21 210983DY  RD2K920554 DS-11-32-07-01 S 6000002250: MyFi Purchasing (Release 2.4 )
*                               Additional logic to handle header commnets and approval comments
*-----------------------------------------------------------------------
    DATA: lo_mfp_po TYPE REF TO zcl_mfp_document_po.
    DATA: lt_split_lines TYPE STANDARD TABLE OF string.
    DATA: l_frgke TYPE frgke.
    TRY.
        lpor-catid = 'CL'.
        lpor-typeid = c_classname.
        lpor-instid = iv_ebeln.

        SELECT SINGLE * FROM ztmfp_doc_header
                       WHERE zmfp_doc_id  = @iv_ebeln
                        INTO @me->gs_ztmfp_doc_header.
        IF sy-subrc = 0.
          gv_ebeln = gs_ztmfp_doc_header-zmfp_doc_id.
        ELSE.
          SELECT SINGLE ebeln frgke
            FROM ekko
            INTO (gs_ztmfp_doc_header-zmfp_doc_id, l_frgke)
            where ebeln = iv_ebeln
              and bsart = zif_mfp_constants=>gc_mm_doc_type-po.
          IF sy-subrc = 0.
            gs_ztmfp_doc_header-status = zcl_mfp_utilities=>translate_mm_status_to_mfp(
              l_frgke ).
            gv_ebeln = gs_ztmfp_doc_header-zmfp_doc_id.
          ELSE.
            RAISE EXCEPTION TYPE cx_bo_find_error.
          ENDIF.
        ENDIF.
        CREATE OBJECT lo_mfp_po TYPE zcl_mfp_document_po
          EXPORTING
            iv_ebeln         = gv_ebeln
            iv_action        = '99'
            iv_myfi_doc_type = me->gs_ztmfp_doc_header-category.

        IF lo_mfp_po->gv_draft_indicator EQ abap_false.
          bus2012-instid = gv_ebeln.
          IF sy-subrc <> 0.
            RAISE EXCEPTION TYPE cx_bo_find_error.
          ENDIF.
        ENDIF.


        calculate_deadline_date( ).
        gv_amt = lo_mfp_po->gs_po_deep-totalvalue.
*        header_comments = lo_mfp_po->gs_po_deep-romancomment.
*        header_comments = lo_mfp_po->gs_po_deep-approvaldetails-valueformoney.
        CLEAR lt_split_lines.
        SPLIT lo_mfp_po->gs_po_deep-approvaldetails-valueformoney AT cl_abap_char_utilities=>newline INTO TABLE lt_split_lines.
        LOOP AT lt_split_lines INTO DATA(lv_string).
          CALL FUNCTION 'CONVERT_STRING_TO_TABLE'
            EXPORTING
              i_string         = lv_string
              i_tabline_length = 80
            TABLES
              et_table         = header_comments.
        ENDLOOP.
        CLEAR lt_split_lines.
        SPLIT lo_mfp_po->gs_po_deep-approvaldetails-commentforapprover AT cl_abap_char_utilities=>newline INTO TABLE lt_split_lines.
        LOOP AT lt_split_lines INTO lv_string.

          CALL FUNCTION 'CONVERT_STRING_TO_TABLE'
            EXPORTING
              i_string         = lv_string
              i_tabline_length = 80
            TABLES
              et_table         = approver_comments.

        ENDLOOP.
*        approver_comments = lo_mfp_po->gs_po_deep-approvaldetails-commentforapprover.
        vendor_name = lo_mfp_po->gs_po_deep-vendorname.
        vendor_num = lo_mfp_po->gs_po_deep-vendor.
        gv_oa_ebeln = lo_mfp_po->gs_po_deep-agreement.

        IF lo_mfp_po->gv_draft_indicator EQ abap_false.
          bus2012-instid = lpor-instid.
        ENDIF.

      CATCH cx_bo_find_error.
    ENDTRY.

  ENDMETHOD.


  METHOD create_event.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_PO~create_event
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for PO Workflows for MyFi
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
*-----------------------------------------------------------------------
    DATA: l_event_container TYPE REF TO if_swf_ifs_parameter_container.
    DATA: l_event           TYPE REF TO if_swf_evt_event.

    CHECK iv_event IS NOT INITIAL.

    CALL METHOD cl_swf_evt_event=>get_instance
      EXPORTING
        im_objcateg = e_lpor-catid
        im_objtype  = e_lpor-typeid
        im_event    = iv_event
        im_objkey   = iv_ebeln
      RECEIVING
        re_event    = l_event.

    l_event_container = l_event->get_event_container( ).

    TRY.
        IF iv_reason IS NOT INITIAL.
          CALL METHOD l_event_container->set
            EXPORTING
              name  = 'REASON'
              value = iv_reason.
        ENDIF.
      CATCH cx_swf_cnt_container ##no_handler.
    ENDTRY.

    TRY.
        IF iv_ebeln IS NOT INITIAL.
          CALL METHOD l_event_container->set
            EXPORTING
              name  = 'PO_NUMBER'
              value = iv_ebeln.
        ENDIF.
      CATCH cx_swf_cnt_container ##no_handler.
    ENDTRY.

    TRY.
        IF iv_recipient IS NOT INITIAL.
          CALL METHOD l_event_container->set
            EXPORTING
              name  = 'RECIPIENT'
              value = iv_recipient.
        ENDIF.
      CATCH cx_swf_cnt_container ##no_handler.
    ENDTRY.

    TRY.
        IF iv_submission_date IS NOT INITIAL.
          CALL METHOD l_event_container->set
            EXPORTING
              name  = 'SUBMISSION_DATE'
              value = iv_submission_date.
        ENDIF.
      CATCH cx_swf_cnt_container ##no_handler.
    ENDTRY.

    TRY.
        l_event->raise( ).
*        is_commit_required = abap_true.
      CATCH cx_swf_evt_invalid_objtype ##no_handler.
      CATCH cx_swf_evt_invalid_event.
*      ROLLBACK WORK.
        RETURN.
    ENDTRY.
*
*    IF iv_commit = abap_true.
*      is_commit_required = abap_false.
    COMMIT WORK. "event recievers triggers via tRFC
*    ENDIF.

    ev_event_raised = abap_true.

  ENDMETHOD.


