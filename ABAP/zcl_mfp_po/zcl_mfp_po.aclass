class ZCL_MFP_PO definition
  public
  create public .

public section.

  interfaces BI_OBJECT .
  interfaces BI_PERSISTENT .
  interfaces IF_WORKFLOW .

  constants C_CLASSNAME type SEOCLSNAME value 'ZCL_MFP_PO' ##NO_TEXT.
  data APPROVER_COMMENTS type CHAR80_T .
  data BUS2012 type SIBFLPORB value ZCL_WF_BOR_TYPES=>BUS2012 ##NO_TEXT.
  data GS_ZTMFP_DOC_HEADER type ZTMFP_DOC_HEADER .
  data GV_AMT type DEC_16_02_S .
  data GV_DEADLINE type DATUM .
  data GV_EBELN type EBELN read-only .
  data GV_OA_EBELN type EBELN .
  data GV_SUBMISSION_DATE type DATUM .
  data HEADER_COMMENTS type CHAR80_T .
  data LPOR type SIBFLPOR .
  data VENDOR_NAME type NAME1 .
  data VENDOR_NUM type LIFNR .

  events DRAFT .
  events REJECT
    exporting
      value(REASON) type STRING .
  events FORWARD
    exporting
      value(RECIPIENT) type SWHACTOR
      value(REASON) type STRING optional .
  events SUBMIT
    exporting
      value(RECIPIENT) type SWHACTOR
      value(REASON) type STRING optional .
  events CHANGE
    exporting
      value(RECIPIENT) type SWHACTOR
      value(REASON) type STRING optional .
  events RECALL .
  events SEND_PO
    exporting
      value(PO_NUMBER) type EBELN
      value(RECIPIENT) type SWHACTOR
      value(SUBMISSION_DATE) type DATUM optional .
  events DRAFT_SUBMITTED .
  events L4L_PO_POSTED .
  events DRAFT_DELETED .
  events ASSET_UNKNOWN .

  methods CONSTRUCTOR
    importing
      value(IV_EBELN) type EBELN
    raising
      CX_BO_FIND_ERROR .
  class-methods CREATE_EVENT
    importing
      !IV_REASON type STRING optional
      !IV_RECIPIENT type SWHACTOR optional
      !IV_EBELN type EBELN
      !IV_EVENT type SWO_EVENT
      !IV_SUBMISSION_DATE type DATUM optional
    exporting
      !EV_EVENT_RAISED type BOOLE_D .
  class-methods CREATE_INSTANCE
    importing
      !IV_EBELN type EBELN
    returning
      value(EO_MFP_DOC) type ref to ZCL_MFP_PO .
  class-methods UPDATE_MYFI_STATUS
    importing
      !IV_EBELN type EBELN
      !IV_ACTION type ZMFP_ACTION
    exporting
      !EV_NEW_STATUS type ZMFP_STATUS
    raising
      CX_BO_TEMPORARY .
  methods CALCULATE_DEADLINE_DATE .
  methods DUMMY .
  class-methods DELETE_DRAFT
    importing
      !IV_EBELN type EBELN
    exporting
      !EV_SUCCESS_FLAG type BOOLE_D .
  methods CHECK_APPR_AUTH
    importing
      !IV_USERID type UNAME
    exporting
      !EV_AUTHORISED type BOOLE_D .
  class-methods GET_PO_PDF
    importing
      !IV_EBELN type EBELN
      !IV_WORKITEMID type SWW_WIID optional
    exporting
      !EV_PO_PDF type SOFM
    raising
      resumable(CX_BO_TEMPORARY) .
  class-methods GET_RELEASE_STATUS
    importing
      !IV_EBELN type EBELN
    exporting
      !EV_REL_INDICATOR type FRGKE
      !EV_SUB_TO_RELEASE type FRGRL .
  class-methods COMPLETE_RECALL_WORKITEM
    importing
      !IV_EBELN type EBELN
    returning
      value(EV_SUCCESS) type BOOLE_D .
  class-methods RELEASE_PO
    importing
      !IV_EBELN type EBELN .
  methods CHECK_ASSET_CHANGED
    importing
      !IV_DOCUMENT type EBELN
    exporting
      !EV_ASSET_CHANGED type BOOLE_D
      !EV_ASSET_EMAIL type AD_SMTPADR
      !EV_ASSET_DELETED type BOOLE_D .
  PROTECTED SECTION.
private section.

  constants:
    BEGIN OF e_lpor,
        catid  TYPE sibflpor-catid VALUE 'CL',
        typeid TYPE sibflpor-typeid VALUE c_classname,
      END OF e_lpor .
ENDCLASS.



CLASS ZCL_MFP_PO IMPLEMENTATION.


  METHOD bi_object~default_attribute_value ##needed.
  ENDMETHOD.


  METHOD bi_object~execute_default_method ##needed.
  ENDMETHOD.


  METHOD bi_object~release ##needed.
  ENDMETHOD.


  METHOD bi_persistent~find_by_lpor.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_PO~bi_persistent~find_by_lpor
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for PO Workflows for MyFi
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
*-----------------------------------------------------------------------
    DATA: lv_ebeln  TYPE ebeln.

    lv_ebeln = lpor-instid.
    IF lpor-catid = e_lpor-catid AND lpor-typeid = e_lpor-typeid.
      TRY.
          CREATE OBJECT result TYPE zcl_mfp_po
            EXPORTING
              iv_ebeln = lv_ebeln.
        CATCH cx_bo_find_error.
      ENDTRY.
    ELSE.
      CLEAR result.
    ENDIF.


  ENDMETHOD.


