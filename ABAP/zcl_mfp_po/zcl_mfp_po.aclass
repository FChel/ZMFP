  METHOD get_po_pdf.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_PO~get_po_pdf
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for PO Workflows for MyFi
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
*-----------------------------------------------------------------------
    DATA: lv_ebeln      TYPE ebeln,
          lt_soli_tab   TYPE soli_tab,
          lt_solix_tab  TYPE solix_tab,
          lv_xstring    TYPE xstring,
          lt_otf        TYPE otf_t_itcoo,
          lt_lines      TYPE tlinet,
          ls_lines      TYPE tline,
          lv_buffer     TYPE string,
          ls_attachment TYPE swr_att_header.

*    TRY.
    lt_soli_tab = zcl_mfp_utilities=>get_po_pdf( i_ebeln =  iv_ebeln ).

    TRY.
        lt_solix_tab = cl_bcs_convert=>soli_to_solix( it_soli = lt_soli_tab ).
      CATCH cx_bcs. " BCS: General Exceptions
    ENDTRY.
    ls_attachment-file_type = 'B'.
    ls_attachment-file_name = |Purchase Order { lv_ebeln }|.
    ls_attachment-file_extension = 'PDF'.
    ls_attachment-language = 'EN'.
    TRY.
        cl_bcs_convert=>solix_to_xstring(
          EXPORTING
            it_solix   = lt_solix_tab                 " Input data
*            iv_size    =                  " Document size
          RECEIVING
            ev_xstring = lv_xstring                 " Output data
        ).

      CATCH cx_bcs. " BCS: General Exceptions
    ENDTRY.

    CALL FUNCTION 'SAP_WAPI_ATTACHMENT_ADD'
      EXPORTING
        workitem_id = iv_workitemid
        att_header  = ls_attachment
*       ATT_TXT     =
        att_bin     = lv_xstring
*       DOCUMENT_OWNER                = SY-UNAME
*       language    = 'EN'
*       DO_COMMIT   = 'X'
*       COMMENT_SEMANTIC              = ' '
*       CHECK_INBOX_RESTRICTION       = ' '
* IMPORTING
*       RETURN_CODE =
*       ATT_ID      =
*       DOC_SIZE    =
* TABLES
*       MESSAGE_LINES                 =
*       MESSAGE_STRUCT                =
      .
    IF sy-subrc <> 0.
      RAISE EXCEPTION TYPE cx_bo_temporary.
    ENDIF.
*      CATCH cx_bo_temporary.
*
*    ENDTRY.
  ENDMETHOD.


  METHOD get_release_status.
*-----------------------------------------------------------------------------------------
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for PO Workflows for MyFi
*
* AUTHOR:       Dathri Yellamarthy
* CREATE DATE:  16.04.2021
*
* ACTIVITY:     AD-11-32-07 - Self Service Purchasing App
* DEV SCRIPT:   DS-11-32-17-01 - Self Service Purchasing App
*-----------------------------------------------------------------------------------------
* VERSION CONTROL:
*
* Date       Author    CTS Req    SCR        Description
* ---------- --------- ---------- ---------- ---------------------------------------------
* 16.04.21 210983DY RD2K920923  DS-11-32-07-01 S 6000002348: MyFi Purchasing (May Release)

*-----------------------------------------------------------------------------------------

    DATA: lv_ebeln          TYPE ebeln,
          lv_rel_indicator  TYPE ekko-frgke,
          lv_sub_to_release TYPE ekko-frgrl.
    CLEAR : lv_rel_indicator, lv_sub_to_release.

    SELECT SINGLE frgke frgrl INTO (lv_rel_indicator , lv_sub_to_release) FROM ekko WHERE ebeln = iv_ebeln.
    IF sy-subrc IS INITIAL.
      ev_rel_indicator = lv_rel_indicator.
      ev_sub_to_release = lv_sub_to_release.
    ENDIF.
  ENDMETHOD.


  METHOD release_po.
    DATA: l_ret_code TYPE sy-subrc,
          lt_return  TYPE TABLE OF bapiret2,
          ls_return  LIKE LINE OF lt_return.

    CALL FUNCTION 'BAPI_PO_RELEASE'
      EXPORTING
        purchaseorder          = iv_ebeln
        po_rel_code            = 'R1'
        use_exceptions         = ' '
        no_commit              = ' '
      IMPORTING
        ret_code               = l_ret_code
      TABLES
        return                 = lt_return
      EXCEPTIONS
        authority_check_fail   = 1
        document_not_found     = 2
        enqueue_fail           = 3
        prerequisite_fail      = 4
        release_already_posted = 5
        responsibility_fail    = 6
        OTHERS                 = 7.
    IF sy-subrc IS INITIAL.
      CALL FUNCTION 'BAPI_TRANSACTION_COMMIT'
        EXPORTING
          wait   = 'X'
        IMPORTING
          return = ls_return.
      IF sy-subrc = 0.
*        cs_entity-is_approved = abap_true.
*        cs_entity-ready_for_approval = abap_false.
*        zcl_mfp_utilities=>log_myfi_event(
*          EXPORTING
*            iv_doc_number = l_ebeln
*            iv_user_id    = sy-uname
*            iv_sub_obj    = zif_mfp_constants=>gc_log-sub_obj-wf-approve ).
*
*        zcl_mfp_workflow_approval=>update_table( imp_approval_log = ls_wf_action ).

      ELSE.
        RAISE EXCEPTION TYPE /iwbep/cx_mgw_busi_exception
          EXPORTING
            message = ls_return-message.
      ENDIF.
    ELSE.
      READ TABLE lt_return INTO ls_return INDEX 1.
      RAISE EXCEPTION TYPE /iwbep/cx_mgw_busi_exception
        EXPORTING
          message = ls_return-message.
    ENDIF.

  ENDMETHOD.


  METHOD update_myfi_status.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_PO~UPDATE_MYFI_STATUS
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for PO Workflows for MyFi
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
* 19.06.20 290977SCN RD2K919517 DS-11-32-07-01 S 6000001863: MyFi
*          070667JPS                           Purchasing Release 2_ECC
*                                              DEFECTS II.  Corrected
*                                              logging of status message.
* 22.07.20 290977SCN RD2K919533 DS-11-32-07-01 Updated importing parameters for decide_new_status
* 21/09/20 290977SCN RD2K919977 DS-11-32-07-01 S 6000002096: MyFi Purchasing (Release 2.2)
* 13/10/20 290977SCN RD2K920238 DS-11-32-07-01 S 6000002096: MyFi Purchasing (Release 2.2)
* 30.11.20 220977FKC RD2K920449 DS-11-32-07-01 6000002172: MyFi Purchasing (Release 2.3)
*                                              Enable legacy i.e. non-myfi created docs
*-----------------------------------------------------------------------
    DATA: lv_old_status       TYPE zmfp_status,
          lv_mm_status        TYPE frgke,
          lv_doc_type         TYPE zmfp_category,
          ls_new_doc_header   TYPE ztmfp_doc_header,
          lv_change_indicator TYPE cdchngindh VALUE 'U',
          lt_header_old       TYPE yztmfp_doc_headers,
          lt_header_new       TYPE yztmfp_doc_headers,
          ls_header_old       TYPE yztmfp_doc_header,
          ls_header_new       TYPE yztmfp_doc_header,
          lv_user             TYPE uname,
          objectid            TYPE cdhdr-objectid,
          lv_message          TYPE char50.

    lv_user = sy-uname.

    SELECT SINGLE frgke FROM ekko
                       WHERE ebeln = @iv_ebeln
                        INTO @lv_mm_status.

    SELECT SINGLE * FROM ztmfp_doc_header
                        WHERE zmfp_doc_id = @iv_ebeln
                         INTO @DATA(ls_old_doc_header).
    CHECK sy-subrc = 0.

    lv_old_status     = ls_old_doc_header-status.
    ls_new_doc_header = ls_old_doc_header.

    zcl_mfp_document=>decide_new_status(
      EXPORTING
        iv_action        = iv_action
        iv_myfi_doc_type = lv_doc_type
        iv_old_status    = lv_old_status
        iv_mm_status     = lv_mm_status
        iv_ebeln         = iv_ebeln
      RECEIVING
        rv_new_status    =  ev_new_status
    ).
    CHECK ev_new_status IS NOT INITIAL.
    ls_new_doc_header-status = ev_new_status.

* Update User with selected delegate from table ztmfp_doc_header
    IF ev_new_status EQ zif_mfp_constants=>gc_doc_status-approved AND
      NOT ls_old_doc_header-status = zif_mfp_constants=>gc_doc_status-approved.
      IF lv_user = 'WF-BATCH'.
        lv_user = ls_old_doc_header-selected_delegate.
      ELSE.
        lv_user = sy-uname.
      ENDIF.
      ls_new_doc_header-released_on = sy-datum.
      ls_new_doc_header-released_at = sy-uzeit.
    ENDIF.

    IF ls_new_doc_header NE ls_old_doc_header.
      ls_new_doc_header-changed_on = sy-datum.
      ls_new_doc_header-changed_at = sy-uzeit.
      UPDATE ztmfp_doc_header FROM ls_new_doc_header.
      COMMIT WORK AND WAIT.
      SELECT SINGLE * FROM ztmfp_doc_header
                      INTO @DATA(ls_updated_header)
                     WHERE zmfp_doc_id EQ @ls_new_doc_header-zmfp_doc_id.

      MOVE-CORRESPONDING ls_old_doc_header TO ls_header_old.
      MOVE-CORRESPONDING ls_updated_header TO ls_header_new.

      APPEND ls_header_old TO lt_header_old.
      APPEND ls_header_new TO lt_header_new.
      objectid = iv_ebeln.
      CALL FUNCTION 'ZMFP_CHANGELOG_WRITE_DOCUMENT'
        EXPORTING
          objectid                = objectid
          tcode                   = zif_mfp_constants=>gc_tcode
          utime                   = sy-uzeit
          udate                   = sy-datum
          username                = lv_user
          object_change_indicator = lv_change_indicator
          upd_ztmfp_doc_header    = lv_change_indicator
        TABLES
          xztmfp_doc_header       = lt_header_new
          yztmfp_doc_header       = lt_header_old.
    ENDIF.

    IF ev_new_status EQ zif_mfp_constants=>gc_doc_status-approved.
      SELECT SINGLE status FROM ztmfp_doc_header
                           INTO @DATA(lv_status)
                          WHERE zmfp_doc_id EQ @iv_ebeln AND
                                     status EQ @zif_mfp_constants=>gc_doc_status-approved.
      IF sy-subrc NE 0.
        RAISE EXCEPTION TYPE cx_bo_temporary.
      ENDIF.
    ENDIF.
  ENDMETHOD.
ENDCLASS.