  METHOD fill_gt_edm_gr_ir.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_DOCUMENT_PO~fill_gt_edm_gr_ir
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for MyFi Documents
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
*-----------------------------------------------------------------------
    DATA:
      ls_consumptiongr TYPE zcl_zedm_mfp_mpc=>ts_consumptiongr, " LINE OF me->gs_po_deep-consumptiongrs.
      lv_line          TYPE i,
      ls_consumptionir TYPE zcl_zedm_mfp_mpc=>ts_consumptionir. " LINE OF me->gs_po_deep-consumptionirs,

    lv_line = 0.

    LOOP AT it_bapiekbe_t INTO DATA(ls_bapiekbe).
      CASE ls_bapiekbe-process_id.
        WHEN zif_mfp_constants=>gc_grir-gr.

          ls_consumptiongr-parentnumber = me->zif_myfi_document~source_doc_num.
          ls_consumptiongr-polinenumber = ls_bapiekbe-po_item.
          lv_line = lv_line + 1.
          ls_consumptiongr-linenumber = lv_line.

          MOVE-CORRESPONDING ls_bapiekbe TO ls_consumptiongr.

          APPEND ls_consumptiongr TO me->gs_po_deep-consumptiongrs.

        WHEN zif_mfp_constants=>gc_grir-ir.

          ls_consumptionir-parentnumber = me->zif_myfi_document~source_doc_num.
          ls_consumptionir-polinenumber = ls_bapiekbe-po_item.
          lv_line = lv_line + 1.
          ls_consumptionir-linenumber = lv_line.

          MOVE-CORRESPONDING ls_bapiekbe TO ls_consumptionir.

          APPEND ls_consumptionir TO me->gs_po_deep-consumptionirs.

        WHEN OTHERS.

      ENDCASE.



    ENDLOOP.
  ENDMETHOD.


