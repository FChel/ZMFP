  METHOD in_delivery_addr.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_DOCUMENT_PO~in_delivery_addr
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for MyFi Documents
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
* 30.11.20 220977FKC RD2K920449 DS-11-32-07-01 6000002172: MyFi Purchasing (Release 2.3)
*                                              Enable legacy i.e. non-myfi created docs
* 03/03/21 210983DY  RD2K920554 DS-11-32-07-01 S 6000002250: MyFi Purchasing (Release 2.4 )
*                Additional code to handle Multi delivery address
* 03.03.2023 210983DY  RD2K923630 6000002898 MyFi Continuous Improvement April Release
*                    Additional code for update of delivery addresses
* 28.08.2023 210983DY RD2K924241   6000002984 MyFi Continuous Improvement September Release
*                      Check for only un-deleted PO items
*-----------------------------------------------------------------------
    DATA: ls_podelivery_addr TYPE bapimepoaddrdelivery.

    LOOP AT gt_poitems INTO DATA(ls_item) WHERE delete_ind IS INITIAL.
      DATA(lv_tabix) = sy-tabix.
      LOOP AT gs_po_deep-deliveryaddresses INTO DATA(ls_podelivery_liaddr) WHERE linenumber = ls_item-po_item.

        CASE ls_podelivery_liaddr-deliverytype.
          WHEN 'NewAddress'.
            CLEAR: ls_podelivery_liaddr-romanaddresscode, ls_podelivery_liaddr-pickuplocation.
          WHEN 'RomanCode'.
*            Get email from address number entered
            SELECT SINGLE remark INTO @DATA(lv_email) FROM adrct WHERE addrnumber = @ls_podelivery_liaddr-romanaddresscode.
            TRANSLATE gs_po_deep-contactdetails-invoicecontactemail TO UPPER CASE.
            TRANSLATE  ls_podelivery_liaddr-invoicecontactemail TO UPPER CASE.
            TRANSLATE lv_email TO UPPER CASE.
*            If email address is changed
            IF lv_tabix = '1' AND
               ls_podelivery_liaddr-invoicecontactemail NE lv_email. "gs_po_deep-contactdetails-invoicecontactemail.
*               gs_po_deep-contactdetails-invoicecontactemail NE lv_email. "gs_po_deep-contactdetails-invoicecontactemail.
              CLEAR : ls_podelivery_liaddr-romanaddresscode.
              IF NOT gs_po_deep-issameaddressforall IS INITIAL.
                DATA(lv_newaddress) = abap_true.
              ENDIF.
            ELSE.
*              CLEAR: ls_podelivery_liaddr-newaddresscity,ls_podelivery_liaddr-newaddresscountry, ls_podelivery_liaddr-newaddressname,
*                    ls_podelivery_liaddr-newaddresspostcode, ls_podelivery_liaddr-newaddressregion, ls_podelivery_liaddr-newaddressstreet,
*                     ls_podelivery_liaddr-pickuplocation.
            ENDIF.
          WHEN 'Pickup'.
            CLEAR: ls_podelivery_liaddr-newaddresscity,ls_podelivery_liaddr-newaddresscountry, ls_podelivery_liaddr-newaddressname,
                   ls_podelivery_liaddr-newaddresspostcode, ls_podelivery_liaddr-newaddressregion, ls_podelivery_liaddr-newaddressstreet,
                   ls_podelivery_liaddr-romanaddresscode.
          WHEN OTHERS.

        ENDCASE.


        me->map_odata_2_bapi(
          EXPORTING
            is_sending_structure = ls_podelivery_liaddr
            is_sending_x_structure = abap_false
          IMPORTING
            es_data              = ls_podelivery_addr
        ).
        IF NOT gs_po_deep-issameaddressforall IS INITIAL AND lv_newaddress = abap_true .
          CLEAR:  ls_podelivery_addr-addr_no.
        ENDIF.

        ls_podelivery_addr-po_item = ls_item-po_item.
        APPEND ls_podelivery_addr TO gt_poaddrdelivery.

      ENDLOOP.
    ENDLOOP.

  ENDMETHOD.


  METHOD in_prepmnt_line.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_DOCUMENT_PO~in_prepmnt_line
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for MyFi Documents
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
* 14.03.2024 210983DY RD2K924772    6000003112: MyFi Continuous Improvement Release 2024
*                 Amended logic for new Prepayment and FMS field changes
*-----------------------------------------------------------------------
    DATA: ls_new_prepmnt TYPE ztmfp_prepmnt,
          ls_bapi_poitem TYPE bapimepoitem,
          lv_po_item     TYPE ebelp,
          lv_exit_flag   TYPE boole_d.

    LOOP AT gs_po_deep-purchaseorderlis INTO DATA(ls_odata_poitem).
      lv_po_item = ls_odata_poitem-linenumber.
      IF is_odata_poitem IS NOT INITIAL.
        ls_odata_poitem = is_odata_poitem.
        lv_po_item = iv_po_item.
        lv_exit_flag = abap_true.
      ENDIF.
      CLEAR ls_new_prepmnt.
      ls_new_prepmnt-zmfp_doc_id = gs_poheader-po_number.
      ls_new_prepmnt-linenumber = lv_po_item.

      ls_new_prepmnt-isprepayment = ls_odata_poitem-isprepayment.
      ls_new_prepmnt-isstraightline = ls_odata_poitem-isstraightline.
      ls_new_prepmnt-purchasetype = ls_odata_poitem-purchasetype.

      IF ls_odata_poitem-prepaymentcompleteddate IS NOT INITIAL.
        ls_new_prepmnt-prepaymentcompleteddate = zcl_mfp_utilities=>get_date_from_ts( EXPORTING iv_timestamp = ls_odata_poitem-prepaymentcompleteddate ).
      ENDIF.
      APPEND ls_new_prepmnt TO me->zif_myfi_document~new_prepmnts.
      IF lv_exit_flag EQ abap_true.
        EXIT.
      ENDIF.
    ENDLOOP.
  ENDMETHOD.


  METHOD is_po_copyable.
*----------------------------------------------------------------------*
* METHOD ID:          IS_PO_COPYABLE
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2.3).
*                     This method sets copyable flag for a PO after checking
*                     consumption value of on OA
* AUTHOR:             Dathri Yellamarthy (210983DY)
* CREATE DATE:        23/11/2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000002172: MyFi Purchasing (Release 2.3)
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*----------------------------------------------------------------------- *
*03/03/21 210983DY  RD2K920554 DS-11-32-07-01 S 6000002250: MyFi Purchasing (Release 2.4 )
*                 Amended logic for PO COpyable Flag
*-------------------------------------------------------------------------


    DATA: lv_total            TYPE val_forcurr,
          lv_total_ordered    TYPE p LENGTH 12 DECIMALS 4,
          lv_total_value      TYPE p LENGTH 15 DECIMALS 9,
          lv_unassigned_value TYPE p LENGTH 15 DECIMALS 9,
          ls_po_summary       TYPE zcl_zedm_mfp_mpc=>ts_consumptionsummary.

* Get currency and Total Value
    SELECT ebeln, waers, ktwrt FROM ekko INTO TABLE @DATA(lt_contract_values) WHERE ebeln EQ @iv_oa_doc.

    SELECT konnr, ebeln, ebelp, netwr, wkurs
       FROM ekab
       INTO TABLE @DATA(lt_ekab)
                               WHERE konnr EQ @iv_oa_doc
                            ORDER BY ebeln ASCENDING.

    DELETE lt_ekab WHERE netwr = '0.00'.
    IF NOT lt_ekab IS INITIAL.
      SELECT ebeln, ebelp, effwr FROM ekpo INTO TABLE @DATA(lt_ekpo) FOR ALL ENTRIES IN @lt_ekab
        WHERE ebeln = @lt_ekab-ebeln AND
              ebelp = @lt_ekab-ebelp.
      IF sy-subrc IS INITIAL.

        LOOP AT lt_ekpo INTO DATA(ls_ekpo).
          lv_total_ordered = lv_total_ordered + ls_ekpo-effwr.
        ENDLOOP.

      ENDIF.
    ENDIF.


    lv_total_value = zcl_mfp_utilities=>convert_curr_format( iv_amount = lt_contract_values[ 1 ]-ktwrt
                                                                   iv_curr   = lt_contract_values[ 1 ]-waers ) .

    lv_unassigned_value = lv_total_value - lv_total_ordered.

    IF lv_unassigned_value LE '0'.

      iv_copyable = abap_false.

    ELSE.

      iv_copyable = abap_true.

    ENDIF.



  ENDMETHOD.


  METHOD map_admindtl_prf.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_DOCUMENT_PO~map_admindtl_prf
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for MyFi Documents
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
* 19.06.20 290977SCN RD2K919517 DS-11-32-07-01 S 6000001863: MyFi
*          070667JPS                           Purchasing Release 2_ECC
*                                              DEFECTS II.  Corrected
*                                              indigenous subcontractor
*                                              mapping.
* 23.02.21 220977FKC RD2K920554 DS-11-32-07-01 6000002250: MyFi Purchasing (Release 2.4)
*                                              Enable PO's with no OA in MyFi
*-----------------------------------------------------------------------
    CONSTANTS: BEGIN OF zgrp_fields_const,
                 fiscal_yr          TYPE name_komp VALUE 'ERP_FISCAL_YEAR',
                 vendor_id          TYPE name_komp VALUE 'ERP_VENDOR_ID',
                 vendor_name        TYPE name_komp VALUE 'ERP_VENDOR_NAM',
                 vendor_vatno       TYPE name_komp VALUE 'ERP_VENDOR_VATNO',
                 total_amount_value TYPE name_komp VALUE 'ERP_TOTAL_CONTRACT_VAL',
                 total_value_curr   TYPE name_komp VALUE 'ERP_TOTAL_VAL_CURR',
                 ctr_strt_dt        TYPE name_komp VALUE 'ERP_CTR_START_DT',
                 ctr_end_dt         TYPE name_komp VALUE 'ERP_CTR_END_DT',
                 po_grp             TYPE name_komp VALUE 'ERP_PO_GRP',
                 day_calc_ref       TYPE name_komp VALUE 'ERP_DAY_CALC_REF',
                 co_code            TYPE name_komp VALUE 'ITEM_CO_CODE',
                 del_ind            TYPE name_komp VALUE 'DELETION_STATUS_FLAG',
                 item_amount_value  TYPE name_komp VALUE 'CONTRACT_VALUE',
                 gl_account         TYPE name_komp VALUE 'GL_ACCOUNT',
                 material_group     TYPE name_komp VALUE 'MATERIAL_GRP',
                 release_status     TYPE name_komp VALUE 'RELEASE_STATUS', "2623667
                 son_id             TYPE name_komp VALUE 'SON_ID', "MyFI Additional Fields
                 son_mul            TYPE name_komp VALUE 'SON_MUL', "MyFI Additional Fields
                 ind_bus            TYPE name_komp VALUE 'IND_BUS', "MyFI Additional Fields
                 ind_sub            TYPE name_komp VALUE 'IND_SUB', "MyFI Additional Fields
               END OF zgrp_fields_const,
               lc_header_index TYPE char1 VALUE 1.

    DATA: lv_indi_contract TYPE zzctrwithindig.
    DATA: lv_indi_sub        TYPE zzindigsubqtn,
          ls_struc_line_item TYPE zgrp_s_data_transfer_struc,
          lt_header_data     TYPE zgrp_t_data_transfer_struc,
          lt_item_data       TYPE zgrp_t_data_transfer_struc.


    .   "Check to see if MyFI contains SON
    "SON ID
    ls_struc_line_item-tableindex = 0.
    ls_struc_line_item-fieldname = zgrp_fields_const-son_id.
    ls_struc_line_item-data = gs_po_deep-sonid.
    APPEND ls_struc_line_item TO lt_item_data.
    ls_struc_line_item-tableindex = 1.
    APPEND ls_struc_line_item TO lt_item_data.
    CLEAR ls_struc_line_item.

    "SON MUL
    ls_struc_line_item-tableindex = 0.
    ls_struc_line_item-fieldname = zgrp_fields_const-son_mul.
    IF gs_po_deep-sonid IS INITIAL.
      ls_struc_line_item-data = 'N'.
    ELSE.
      ls_struc_line_item-data = 'Y'.
    ENDIF.
    APPEND ls_struc_line_item TO lt_item_data.
    ls_struc_line_item-tableindex = 1.
    APPEND ls_struc_line_item TO lt_item_data.
    CLEAR ls_struc_line_item.

    IF is_admindtl-indigenous_outcome EQ 'S'.
      lv_indi_contract = 'Y'.
    ELSE.
      lv_indi_contract = 'N'.
    ENDIF.

    "Indigenous Business
    ls_struc_line_item-tableindex = 0.
    ls_struc_line_item-fieldname = zgrp_fields_const-ind_bus.
    ls_struc_line_item-data = lv_indi_contract. " UPDATE to get DATA from MyFi
    APPEND ls_struc_line_item TO lt_item_data.
    ls_struc_line_item-tableindex = 1.
    APPEND ls_struc_line_item TO lt_item_data.
    CLEAR ls_struc_line_item.

*    IF is_admindtl-is_indig_subcontract EQ abap_true.
*      lv_indi_sub = 'Y'.
*    ELSE.
*      lv_indi_sub = 'N'.is_admindtl-is_indig_subcontract
*    ENDIF.

*    lv_indi_sub = is_admindtl-is_indig_subcontract.
*
*
*    "Indigenous Subcontractor
*    ls_struc_line_item-tableindex = 0.
*    ls_struc_line_item-fieldname = zgrp_fields_const-ind_sub.
*    ls_struc_line_item-data = lv_indi_sub. " UPDATE to get DATA from MyFi
*    APPEND ls_struc_line_item TO lt_item_data.
*    ls_struc_line_item-tableindex = 1.
*    APPEND ls_struc_line_item TO lt_item_data.
*    CLEAR ls_struc_line_item.


    APPEND LINES OF lt_item_data TO ct_item_data.


  ENDMETHOD.


  METHOD message_handler.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_DOCUMENT_PO~MESSAGE_HANDLER
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for MyFi Documents
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        21.10.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 21.10.20 290977SCN RD2K919656 DS-11-32-07-01 S 6000002172: MyFi Purchasing (Release 2.3)
*-----------------------------------------------------------------------
    DATA lt_return TYPE bapiret2_t.
    lt_return =  super->message_handler(
       EXPORTING
         it_return = it_return ).

    LOOP AT lt_return ASSIGNING FIELD-SYMBOL(<return>).
      CASE <return>-parameter.
        WHEN 'POHEADER'.
        WHEN 'POITEM'.
          <return>-message = |Item({ <return>-row }) - { <return>-message }|.
        WHEN 'POSCHEDULE'.
          READ TABLE gt_poschedules INTO DATA(ls_schedule) WITH KEY sched_line = <return>-row.
          CALL FUNCTION 'CONVERSION_EXIT_ALPHA_OUTPUT'
              EXPORTING
                input  = ls_schedule-po_item
              IMPORTING
                output = ls_schedule-po_item.
          <return>-message = |Item({ ls_schedule-po_item }) - { <return>-message }|.
        WHEN OTHERS.

      ENDCASE.
    ENDLOOP.
    rt_return = lt_return.
  ENDMETHOD.


  METHOD out_consumption.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_DOCUMENT_PO~out_consumption
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for MyFi Documents
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
* 04.08.21 210983DY RD2K921440  DS-11-32-07-01 S6000002451: MyFi Purchasing (August Release)
*                                              Display additional fields in consumption tab
* 08.06.2022 210983DY RD2K922841 MyFi Continuous Improvement July Release
*-----------------------------------------------------------------------
    DATA: ls_odata_consumptiongr TYPE zcl_zedm_mfp_mpc=>ts_consumptiongr,
          ls_odata_consumptionir TYPE zcl_zedm_mfp_mpc=>ts_consumptionir,
          lv_prev_gr_po_item     TYPE bapiekbe-po_item,
          lv_prev_ir_po_item     TYPE bapiekbe-po_item,
          lv_gr_linenumber       TYPE integer,
          lv_ir_linenumber       TYPE integer,
          ls_po_item             TYPE bapimepoitem,
          lv_payment_date        TYPE dats,
          lv_timestamp           TYPE timestampl,
          lr_awkey_ir            TYPE RANGE OF awkey.

    FIELD-SYMBOLS : <value> TYPE any.

* Initialise variables
    lv_prev_gr_po_item = '99999'.   " Initialize to some value
    lv_prev_ir_po_item = '99999'.   " Initialize to some value

* Create internal table for Invoice lines only
    DATA(lt_pohistory_ir) = gt_pohistory.
    DELETE lt_pohistory_ir WHERE process_id = zif_mfp_constants=>gc_grir-gr.

    lr_awkey_ir = VALUE #( FOR ls_ir IN lt_pohistory_ir ( sign = 'I'
                                                       option = 'EQ'
                                                       low = |{ ls_ir-mat_doc }{ ls_ir-doc_year }| ) ).
    IF NOT lr_awkey_ir IS INITIAL.



* Get Payment date from Clearing table for Vendor items

      SELECT bukrs, belnr, gjahr, xblnr, awkey  FROM bkpf
              INTO TABLE @DATA(lt_ir)
              WHERE awtyp = 'RMRP' AND
               awkey IN @lr_awkey_ir.


*      SELECT a~bukrs, a~belnr, a~gjahr, a~xblnr, a~awkey, b~augdt FROM bkpf AS a INNER JOIN bsak AS b
*        ON a~bukrs = b~bukrs AND
*           a~gjahr = b~gjahr AND
*           a~belnr = b~belnr INTO TABLE @DATA(lt_ir)
*        WHERE a~awtyp = 'RMRP' AND
*         a~awkey IN @lr_awkey_ir.

      IF sy-subrc IS INITIAL.

        SELECT bukrs, augdt, gjahr, belnr FROM bsak INTO TABLE @DATA(lt_ir_clearingdate)
          FOR ALL ENTRIES IN @lt_ir
          WHERE bukrs = @lt_ir-bukrs AND
                gjahr = @lt_ir-gjahr AND
                belnr = @lt_ir-belnr.

      ELSE.
*        SELECT a~bukrs, a~belnr, a~gjahr, a~xblnr, a~awkey, b~augdt FROM bkpf AS a INNER JOIN bsik AS b
*             ON a~bukrs = b~bukrs AND
*                a~gjahr = b~gjahr AND
*                a~belnr = b~belnr INTO TABLE @lt_ir
*             WHERE  a~awtyp = 'RMRP' AND
*          a~awkey IN @lr_awkey_ir.


      ENDIF.

    ENDIF.

    LOOP AT gt_pohistory INTO DATA(ls_history).
      CASE ls_history-process_id.
        WHEN zif_mfp_constants=>gc_grir-gr.

* Set the line number (i.e. a sequence number of GR rows per PO line item)
          IF ls_history-po_item NE lv_prev_gr_po_item.
            lv_gr_linenumber = 1.
          ELSE.
            lv_gr_linenumber = lv_gr_linenumber + 1.
          ENDIF.
          map_bapi_2_odata(
            EXPORTING
              is_sending_structure = ls_history
            IMPORTING
              es_data              = ls_odata_consumptiongr ).
          ls_odata_consumptiongr-parentnumber = gs_po_deep-po_number.
          ls_odata_consumptiongr-linenumber = lv_gr_linenumber.
          CALL FUNCTION 'CONVERSION_EXIT_ALPHA_OUTPUT'
            EXPORTING
              input  = ls_odata_consumptiongr-linenumber
            IMPORTING
              output = ls_odata_consumptiongr-linenumber.

          CLEAR ls_po_item.

          READ TABLE gt_poitems
           INTO ls_po_item
           WITH KEY po_item = ls_history-po_item.

          IF ls_po_item IS NOT INITIAL.
            ls_odata_consumptiongr-deliv_unit = ls_po_item-po_unit.
          ENDIF.

          IF ls_history-db_cr_ind EQ 'H'.
            ls_odata_consumptiongr-val_forcur = ls_odata_consumptiongr-val_forcur * -1.
            ls_odata_consumptiongr-val_loccur = ls_odata_consumptiongr-val_loccur * -1.
            ls_odata_consumptiongr-quantity = ls_odata_consumptiongr-quantity * -1.
          ENDIF.

          APPEND ls_odata_consumptiongr TO gs_po_deep-consumptiongrs.
          CLEAR ls_odata_consumptiongr.

          lv_prev_gr_po_item = ls_history-po_item.
        WHEN zif_mfp_constants=>gc_grir-ir.

* Set the line number (i.e. a sequence number of IR rows per PO line item)
          IF ls_history-po_item NE lv_prev_ir_po_item.
            lv_ir_linenumber = 1.
          ELSE.
            lv_ir_linenumber = lv_ir_linenumber + 1.
          ENDIF.

          map_bapi_2_odata(
             EXPORTING
               is_sending_structure = ls_history
             IMPORTING
               es_data              = ls_odata_consumptionir ).
          ls_odata_consumptionir-parentnumber = gs_po_deep-po_number.
          ls_odata_consumptionir-linenumber = lv_ir_linenumber.
*          ls_odata_consumptionir-inv_reference = ls_odata_consumptionir-ref_doc_no_long.
          CONCATENATE ls_history-mat_doc ls_history-doc_year INTO DATA(lv_awkey).
          READ TABLE lt_ir INTO DATA(ls_invref) WITH KEY awkey = lv_awkey.
          IF sy-subrc IS INITIAL.
            READ TABLE lt_ir_clearingdate INTO DATA(ls_clearing_date) WITH KEY
                                 bukrs = ls_invref-bukrs
                                 gjahr = ls_invref-gjahr
                                 belnr = ls_invref-belnr.
            IF sy-subrc IS INITIAL.
              ASSIGN ls_clearing_date-augdt TO <value>.
              IF <value> IS ASSIGNED.
                CONVERT DATE <value> INTO TIME STAMP lv_timestamp TIME ZONE 'UTC'.
                ls_odata_consumptionir-payment_date = lv_timestamp.
              ENDIF.
            ENDIF.
            ls_odata_consumptionir-inv_reference = ls_invref-xblnr.
          ENDIF.

          CALL FUNCTION 'CONVERSION_EXIT_ALPHA_OUTPUT'
            EXPORTING
              input  = ls_odata_consumptionir-linenumber
            IMPORTING
              output = ls_odata_consumptionir-linenumber.

          CLEAR ls_po_item.

          READ TABLE gt_poitems
           INTO ls_po_item
           WITH KEY po_item = ls_history-po_item.

          IF ls_po_item IS NOT INITIAL.
            ls_odata_consumptionir-deliv_unit = ls_po_item-po_unit.
          ENDIF.
          IF ls_history-db_cr_ind EQ 'H'.
            ls_odata_consumptionir-val_forcur = ls_odata_consumptionir-val_forcur * -1.
            ls_odata_consumptionir-val_loccur = ls_odata_consumptionir-val_loccur * -1.
            ls_odata_consumptionir-quantity = ls_odata_consumptionir-quantity * -1.
          ENDIF.
          APPEND ls_odata_consumptionir TO gs_po_deep-consumptionirs.
          CLEAR ls_odata_consumptionir.

          lv_prev_ir_po_item = ls_history-po_item.
        WHEN OTHERS.
      ENDCASE.
    ENDLOOP.

    IF gs_po_deep-consumptiongrs IS INITIAL.
      ls_odata_consumptiongr-parentnumber = gs_po_deep-po_number.
      APPEND ls_odata_consumptiongr TO gs_po_deep-consumptiongrs.
    ENDIF.
    IF gs_po_deep-consumptionirs IS INITIAL.
      ls_odata_consumptionir-parentnumber = gs_po_deep-po_number.
      APPEND ls_odata_consumptionir TO gs_po_deep-consumptionirs.
    ENDIF.
  ENDMETHOD.


  METHOD out_schedules ##NEEDED.
  ENDMETHOD.


  METHOD recall_approval.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_DOCUMENT_PO~recall_approval
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for MyFi Documents
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
* 05/11/21 210983DY  RD2K922034 DS-11-32-07-01 S6000002550: MyFi Applications (December Release)
*                    Additional code to enable Multi Account Assignment
*-----------------------------------------------------------------------
    DATA: lv_event_success TYPE boole_d.

    IF me->zif_myfi_document~old_doc_header-status = zif_mfp_constants=>gc_doc_status-awaiting_approval OR
      me->zif_myfi_document~old_doc_header-status = zif_mfp_constants=>gc_doc_status-awaiting_asset OR
       me->zif_myfi_document~old_doc_header-status = zif_mfp_constants=>gc_doc_status-awaiting_prf.

      CALL METHOD zcl_mfp_po=>create_event
        EXPORTING
          iv_ebeln        = me->zif_myfi_document~source_doc_num
          iv_event        = zif_mfp_constants=>gc_event-recall                " Event
        IMPORTING
          ev_event_raised = lv_event_success.

      IF lv_event_success = abap_true.
        CALL METHOD zcl_mfp_utilities=>log_myfi_event
          EXPORTING
            iv_doc_number = me->zif_myfi_document~posting_doc_num
            iv_user_id    = sy-uname
            iv_sub_obj    = zif_mfp_constants=>gc_log-sub_obj-wf-recall.
      ENDIF.
      super->recall_approval( ).
    ENDIF.


  ENDMETHOD.


method trigger_prf.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_DOCUMENT_PO~trigger_prf
* DESCRIPTION:        Trigger PRF for standalone PO (i.e. PO without an OA
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000002250 - MyFi Purchasing (Release 2.4)
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date       Author      CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 23.02.2021 220977FKC   6000002250 DS-11-32-07-01 Initial Version
*-----------------------------------------------------------------------

  data:
    ls_ekko            type ekko,
    lt_ekpo            type me_ekpo,
    lt_ekkn            type me_ekkn,
    l_local_curr       type waers,
    lt_header_data     type zgrp_t_data_transfer_struc,
    ls_header_data     like line of lt_header_data,
    lt_item_data       type zgrp_t_data_transfer_struc,
    l_trigger_grp_appl type xfeld,
    l_dtype_code       type zgrp_regm_doc_type,
    l_total_amt        type zgrp_total_ctr_val,
    l_country          type land1,
    l_grp_doc_no       type zgrp_doc_no,
    ls_header_det      type zgrp_c_header,
    lt_trigger_url     type zgrp_t_data_transfer_struc,
    ls_trigger_url     like line of lt_trigger_url.

*--- stop here if GRP not active
  if zcl_grp_activation_switch=>grp_process( ) ne abap_true.
    return.
  endif.

*--- mapi bapi to sap
  ls_ekko = bapi_2_ekko( is_ekko ).
  lt_ekpo = bapi_2_ekpo( it_ekpo ).
  lt_ekkn = bapi_2_ekkn( it_bapimepoaccount = it_ekkn it_bapiparex = me->gt_extension ).

*--- get local currency
  call function 'BAPI_GRP_GET_REPORTING_CURR'
    importing
      ev_currency_code = l_local_curr.

*--- total value currency
  clear ls_header_data.
  ls_header_data-tableindex = 1.
  ls_header_data-fieldname = 'ERP_TOTAL_VAL_CURR'.
  ls_header_data-data = l_local_curr.
  append ls_header_data to lt_header_data.

*--- admin details
*    CIR524 (S 6000002812 - OCT 2022: Only pass SON on create)
  if iv_creating eq abap_true.
    call method map_admindtl_prf
      exporting
        is_admindtl    = is_admindtl
      changing
        ct_header_data = lt_header_data
        ct_item_data   = lt_item_data.
  endif.

*--- save myfi prf po trigger
  call method zcl_mfp_utilities=>save_myfip_po_trigger(
    exporting
      im_ekko             = ls_ekko
      it_ekpo             = lt_ekpo
      it_ekkn             = lt_ekkn
      lv_local_curr       = l_local_curr
    changing
      ct_header_data      = lt_header_data
      ct_item_data        = lt_item_data
      cv_trigger_grp_appl = l_trigger_grp_appl
      cv_dtype_code       = l_dtype_code
      lv_total_amt        = l_total_amt ).

  if l_trigger_grp_appl = abap_true
  and lt_header_data is not initial.

*--- get country
    select single land1 into l_country
      from t001
      where bukrs = ls_ekko-bukrs.

*--- grp doc no
    l_grp_doc_no = iv_ebeln.

*---
    call method zcl_grp_assist=>trigger_grp_capture
      exporting
        iv_country             = l_country
        iv_co_code             = ls_ekko-bukrs
        iv_doc_type            = l_dtype_code
        iv_doc_no              = l_grp_doc_no
        iv_open_in_change_mode = abap_true
        iv_trigger_scrn        = abap_false
        it_header_data         = lt_header_data
        it_items_data          = lt_item_data
      importing
        es_header_det          = ls_header_det
        et_trigger_urls        = lt_trigger_url.

    loop at lt_trigger_url into ls_trigger_url.
      rt_prf_url = rt_prf_url && ls_trigger_url-data.
    endloop.

  endif.

endmethod.


  METHOD zif_myfi_document~bapi_change.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_DOCUMENT_PO~zif_myfi_document~bapi_change
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for MyFi Documents
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
* 16.06.20 290977SCN RD2K919514 DS-11-32-07-01 changed
*          070667JPS
* 22.07.20 290977SCN RD2K919533 DS-11-32-07-01 Handle blank status indicator
* 21.10.20 290977SCN RD2K919656 DS-11-32-07-01 S 6000002172: MyFi Purchasing (Release 2.3)
* 23.02.21 220977FKC RD2K920554 DS-11-32-07-01 6000002250: MyFi Purchasing (Release 2.4)
*                                              Enable PO's with no OA in MyFi
* 25.03.21 220977FKC RD2K920877 DS-11-32-07-01 6000002325: MyFi Purchasing
*                                              (Edit Legacy PRF Issue): Use tax inclusive
*                                              amount for PRF
* 20.12.22 210983DY  RD2K923348 DS-11-32-07-01 S 6000002854: MyFi Continuous Improvement December Release
*                 CIR 516 - Dont pass line items that are not edited and has Locked cost object to BAPI
* 23.01.23 210983DY RD2K923485  DS-11-32-07-01 S 6000002854: MyFi Continuous Improvement December Release
*                 CIR 516 - Dont pass line items that are not edited and has Locked cost object to BAPI
*-----------------------------------------------------------------------
    DATA: lt_return       TYPE bapiret2_t,
          ls_return       TYPE bapiret2,
          ls_poheader_ret TYPE bapimepoheader.

* Dont pass line items that are not edited and has Locked cost object to BAPI
* UI logic will inhibit users from submitting line items with locked cost objects upon Edit
    IF NOT gv_locked_costobject IS INITIAL.
      LOOP AT gt_poaccounts INTO DATA(ls_accounts) WHERE delete_ind = abap_true.
        DELETE gt_poaccountsx WHERE po_item = ls_accounts-po_item.
        DELETE gt_poitems WHERE po_item = ls_accounts-po_item.
        DELETE gt_poitemsx WHERE po_item = ls_accounts-po_item.
        DELETE gt_poaddrdelivery WHERE po_item = ls_accounts-po_item.
        DELETE gt_poschedules WHERE po_item = ls_accounts-po_item.
        DELETE gt_poschedulesx WHERE po_item = ls_accounts-po_item.
        DELETE gt_potextitems WHERE po_item = ls_accounts-po_item.
        DELETE gt_extension WHERE valuepart1+0(5) = ls_accounts-po_item.
      ENDLOOP.
      DELETE gt_poaccountsx WHERE delete_ind = abap_true.
    ENDIF.

    CALL FUNCTION 'BAPI_PO_CHANGE'
      EXPORTING
        purchaseorder    = gs_poheader-po_number                " Purchasing Document Number
        poheader         = gs_poheader                 " Header Data
        poheaderx        = gs_poheaderx                 " Header Data (Change Parameter)
*       poaddrvendor     =                  " Address of Vendor
*       testrun          =                  " Test Indicator
*       memory_uncomplete      =                  " Hold Purchase Order if Faulty
*       memory_complete  =                  " Hold Purchase Order if NOT Faulty
*       poexpimpheader   =                  " Export Trade: Header Data
*       poexpimpheaderx  =                  " Foreign Trade: Change Bar: Header Data
*       versions         =                  " Version Management
*       no_messaging     =                  " No message determination
*       no_message_req   =                  " No messages necessary
*       no_authority     =                  " No Authorization Check
*       no_price_from_po =                  " No Adoption of Price from Last Document
*       park_uncomplete  =                  " Park Document if Faulty
*       park_complete    =                  " Park Document if NOT Faulty
      IMPORTING
        expheader        = ls_poheader_ret                 " Header Data
*       exppoexpimpheader      =                  " Export Trade: Header Data
      TABLES
        return           = lt_return                 " Return Parameter
        poitem           = gt_poitems                 " Item Data
        poitemx          = gt_poitemsx                 " Item Data (Change Parameter)
        poaddrdelivery   = gt_poaddrdelivery                 " Addresses for Inward Delivery (Item)
        poschedule       = gt_poschedules                 " Delivery Schedule
        poschedulex      = gt_poschedulesx                 " Delivery Schedule (Change Parameter)
        poaccount        = gt_poaccounts                 " Account Assignment Fields
*       poaccountprofitsegment =                  " Reservation Profitability Segment: BAPI_PROFITABILITY_SEGMEN
        poaccountx       = gt_poaccountsx                 " Account Assignment Fields (Change Parameter)
*       pocondheader     =                  " Conditions (Header)
*       pocondheaderx    =                  " Conditions (Header, Change Parameter)
*       pocond           =                  " Conditions (Items)
*       pocondx          =                  " Conditions (Items, Change Parameter)
*       polimits         =                  " External Services: Limits
*       pocontractlimits =                  " External Services: Contract Limits
*       poservices       =                  " External Services: Service Lines
*       posrvaccessvalues      =                  " External Services: Account Assignment Distribution for Servi
*       poservicestext   =                  " External Services: Service Long Text
        extensionin      = gt_extension     " Customer's Own Fields (Import Parameters)
*       extensionout     =                  " Customer's Own Fields (Export Parameters)
*       poexpimpitem     =                  " Foreign Trade: Item Data
*       poexpimpitemx    =                  " Foreign Trade: Change Parameter: Item Data
        potextheader     = gt_poheadertext                 " Header Texts
        potextitem       = gt_potextitems                 " Item Texts
*       allversions      =                  " All Versions (Export Parameter)
        popartner        = gt_popartner                 " Partner
*       pocomponents     =                  " BAPI Structure for Components
*       pocomponentsx    =                  " Update Information for Components in BUS2012 API
*       poshipping       =                  " BAPI Shipping Data for Stock Transport Orders
*       poshippingx      =                  " BAPI Shipping Data Change Parameter
*       poshippingexp    =                  " Export Structure for Shipping Data
        pohistory        = gt_pohistory                 " Transfer Structure for PO History
        pohistory_totals = gt_pohistory_totals                 " Transfer Structure for PO History: Totals
*       poconfirmation   =                  " Transfer Structure: Display/List - Vendor Confirmation
*       serialnumber     =                  " Serial Numbers in Purchase Order BAPIs
*       serialnumberx    =                  " Change Parameter: Serial Number in Purchase Order BAPIs
*       invplanheader    =                  " Invoicing Plan Header Data
*       invplanheaderx   =                  " Invoicing Plan Header Data (Change Parameter)
*       invplanitem      =                  " Invoicing Plan Item Data
*       invplanitemx     =                  " Invoicing Plan Item Data (Change Parameter)
*       pohistory_ma     =                  " Transfer Structure for Purchase Order History Account Assign
      .
    zcl_mfp_utilities=>log_myfi_bapi(
      EXPORTING
        iv_doc_number = gs_poheader-po_number                 " Purchasing Document Number
        iv_action     = zif_mfp_constants=>gc_log-sub_obj-bapi-po_change                 " Application Log: Subobject
        iv_user_id    = sy-uname                 " User Name
        it_return     = lt_return                 " Return table
    ).

    READ TABLE lt_return WITH KEY type = 'S' TRANSPORTING NO FIELDS.
    IF sy-subrc <> 0.
      gt_return = message_handler( it_return = lt_return ).
      CLEAR gs_po_deep.
    ELSE.
      gv_doc_posted_ok = ev_success = abap_true.
      CLEAR: ls_return, gt_return.
      MESSAGE s014(zmfp) INTO ls_return-message.
      ls_return-type = sy-msgty.
      ls_return-id = sy-msgid.
      ls_return-number = sy-msgno.
      APPEND ls_return TO gt_return.
      gt_return = message_handler( it_return = gt_return ).
      ev_success = abap_true.

      me->gs_po_deep-po_number = me->zif_myfi_document~posting_doc_num = me->gs_poheader-po_number .
      CLEAR me->gs_po_deep-prfurledit.

*--- PO's with no OA: when editing trigger if PRF is required
      IF ls_poheader_ret-agreement IS INITIAL.

*---> trigger PRF
        me->gs_po_deep-prfurl = me->gs_po_deep-prfurledit = me->trigger_prf(
          it_ekkn         = gt_poaccounts
          is_admindtl     = me->zif_myfi_document~new_adm_dtl
          iv_ebeln        = me->zif_myfi_document~posting_doc_num
          is_ekko         = ls_poheader_ret
          it_ekpo         = gt_poitems ).

      ENDIF.

      CASE ls_poheader_ret-po_rel_ind.
        WHEN zif_mfp_constants=>gc_mm_doc_status-new.
          IF me->gs_po_deep-prfurl IS INITIAL.
            me->gv_mm_status = zif_mfp_constants=>gc_mm_doc_status-req_del_appr.
          ELSE.
            me->gv_mm_status = zif_mfp_constants=>gc_mm_doc_status-req_prf_comp.
          ENDIF.
        WHEN ''.
          me->gv_mm_status = zif_mfp_constants=>gc_mm_doc_status-po_released.
        WHEN OTHERS.
          me->gv_mm_status = ls_poheader_ret-po_rel_ind.
      ENDCASE.


    ENDIF.
  ENDMETHOD.


  METHOD zif_myfi_document~bapi_create.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_DOCUMENT_PO~zif_myfi_document~bapi_read
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for MyFi Documents
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
* 16.06.20 290977SCN RD2K919514 DS-11-32-07-01 changed
*          070667JPS
* 16.06.20 290977SCN RD2K919514 DS-11-32-07-01 Handle blank rel indicator
* 21.10.20 290977SCN RD2K919656 DS-11-32-07-01 S 6000002172: MyFi Purchasing (Release 2.3)
* 03/03/21 210983DY  RD2K920554 DS-11-32-07-01 S 6000002250: MyFi Purchasing (Release 2.4 )
*          Additional logic to have same line item number for OA and PO for L4L scenario
*-----------------------------------------------------------------------
    DATA:
      lt_return           TYPE bapiret2_t,
      ls_return           TYPE bapiret2,
      lt_prf_trigger_urls TYPE zgrp_t_data_transfer_struc,
      ls_poheader_ret     TYPE bapimepoheader.


    CLEAR: me->gs_poheader-po_number.
*  for BAPI to accept Line item numbers passed in gt_poitems, Pass blank value to field
*  item_intvl in Header
    CLEAR: gs_poheader-item_intvl. " gs_poheaderx-item_intvl.
    CALL FUNCTION 'BAPI_PO_CREATE1'
      EXPORTING
        poheader         = gs_poheader
        poheaderx        = gs_poheaderx
      IMPORTING
        exppurchaseorder = me->gs_poheader-po_number
        expheader        = ls_poheader_ret                  " Header Data
      TABLES
        return           = lt_return
        poitem           = gt_poitems
        poitemx          = gt_poitemsx
        poaddrdelivery   = gt_poaddrdelivery
        poschedule       = gt_poschedules
        poschedulex      = gt_poschedulesx
        poaccount        = gt_poaccounts
        poaccountx       = gt_poaccountsx
        potextheader     = gt_poheadertext
        potextitem       = gt_potextitems
        extensionin      = gt_extension.


    zcl_mfp_utilities=>log_myfi_bapi(
      EXPORTING
        iv_doc_number = me->gs_poheader-po_number                 " Purchasing Document Number
        iv_action     = zif_mfp_constants=>gc_log-sub_obj-bapi-po_create                 " Application Log: Subobject
        iv_user_id    = sy-uname                 " User Name
        it_return     = lt_return                 " Return table
    ).

    READ TABLE lt_return WITH KEY type = 'S' TRANSPORTING NO FIELDS.
    IF sy-subrc <> 0.
      gt_return = message_handler( it_return = lt_return ).
      CLEAR gs_po_deep.
    ELSE.
      gv_doc_posted_ok = ev_success = abap_true.
      CLEAR: ls_return, gt_return.
      MESSAGE s014(zmfp) INTO ls_return-message.
      ls_return-type = sy-msgty.
      ls_return-id = sy-msgid.
      ls_return-number = sy-msgno.
      APPEND ls_return TO gt_return.

      gt_return = message_handler( it_return = gt_return ).
      me->gs_po_deep-po_number = me->zif_myfi_document~posting_doc_num = me->gs_poheader-po_number.
    ENDIF.

    CASE ls_poheader_ret-po_rel_ind.
      WHEN zif_mfp_constants=>gc_mm_doc_status-new.
        me->gv_mm_status = zif_mfp_constants=>gc_mm_doc_status-req_del_appr.
      WHEN ''.
        me->gv_mm_status = zif_mfp_constants=>gc_mm_doc_status-po_released.
      WHEN OTHERS.
        me->gv_mm_status = ls_poheader_ret-po_rel_ind.
    ENDCASE.

  ENDMETHOD.


  METHOD zif_myfi_document~bapi_read.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_DOCUMENT_PO~zif_myfi_document~bapi_read
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for MyFi Documents
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
* 30.11.20 220977FKC RD2K920449 DS-11-32-07-01 6000002172: MyFi Purchasing (Release 2.3)
*                                              Enable legacy i.e. non-myfi created docs
* 23.02.21 220977FKC RD2K920554 DS-11-32-07-01 6000002250: MyFi Purchasing (Release 2.4)
*                                              Enable PO's with no OA in MyFi
*-----------------------------------------------------------------------
    CALL FUNCTION 'BAPI_PO_GETDETAIL1'
      EXPORTING
        purchaseorder      = me->zif_myfi_document~source_doc_num                 " Purchasing Document Number
        account_assignment = abap_true            " Account Assignment Data
        item_text          = abap_true            " Item Text
        header_text        = abap_true            " Header Txt
        delivery_address   = abap_true            " Delivery address
        version            = space            " Version Management
        services           = space            " External Service Data
        serialnumbers      = space            " Serial Numbers
        invoiceplan        = space            " Invoicing Plan
      IMPORTING
        poheader           = gs_poheader                 " Purchase Order Header Data
*       poexpimpheader     =                  " Foreign Trade: Export/Import: Header Data
      TABLES
*       return             =                  " Return Parameter(s)
        poitem             = gt_poitems                 " Purchase Order Item
        poaddrdelivery     = gt_poaddrdelivery                 " Addresses for Inward Delivery (Item)
        poschedule         = gt_poschedules                 " Delivery Schedule
        poaccount          = gt_poaccounts                 " Account Assignment Fields
*       pocondheader       =                  " Conditions (header)
*       pocond             =                  " Conditions (Items)
*       polimits           =                  " External Services: Limits
*       pocontractlimits   =                  " Communication Structure: Contract Limits
*       poservices         =                  " Communication Structure: Create Service Line
*       posrvaccessvalues  =                  " External Services: Account Assignment Distribution for Servi
        potextheader       = gt_poheadertext                 " Header Texts
        potextitem         = gt_potextitems                 " Item Texts
*       poexpimpitem       =                  " Foreign Trade: Item Data
*       pocomponents       =                  " BAPI Structure for Components
*       poshippingexp      =                  " Export Structure for Shipping Data
        pohistory          = gt_pohistory                 " Purchase Order History
        pohistory_totals   = gt_pohistory_totals                 " Purchase Order History - Totals
*       poconfirmation     =                  " Vendor Confirmation
*       allversions        =                  " Version Data
*       popartner          =                  " Partner
*       extensionout       =                  " ExtensionOut
*       serialnumber       =                  " Serial Numbers in Purchase Order BAPIs
*       invplanheader      =                  " Invoicing Plan: Header Data
*       invplanitem        =                  " Invoicing Plan: Item Data
*       pohistory_ma       =                  " Transfer Structure for Purchase Order History Account Assign
      .

    me->zif_myfi_document~old_ekko  = me->get_ekko( iv_ebeln = me->zif_myfi_document~source_doc_num ).
    me->zif_myfi_document~old_ekpo  = me->get_ekpo( iv_ebeln = me->zif_myfi_document~source_doc_num ).
    me->zif_myfi_document~old_ekkn  = me->get_ekkn( iv_ebeln = me->zif_myfi_document~source_doc_num ) .
    me->zif_myfi_document~approval_history = me->get_approval_history(  iv_object = me->zif_myfi_document~source_doc_num ) .
*    me->zif_myfi_document~change_log = me->get_changelog( iv_object = me->zif_myfi_document~source_doc_num ) .


    IF zif_myfi_document~gv_useraction EQ zif_mfp_constants=>gc_action-odata-read.
      CALL METHOD zcl_mfp_utilities=>get_prf_display_url
        EXPORTING
          iv_ebeln        = me->zif_myfi_document~source_doc_num
          iv_grp_doc_type = zif_mfp_constants=>gc_prf_doc_type-po
        RECEIVING
          rv_url          = gs_po_deep-prfurldisplay.

      IF gs_poheader-agreement IS INITIAL.

        CALL METHOD zcl_mfp_utilities=>get_prf_change_url
          EXPORTING
            iv_ebeln        = me->zif_myfi_document~source_doc_num
            iv_grp_doc_type = zif_mfp_constants=>gc_prf_doc_type-po
          RECEIVING
            rv_url          = gs_po_deep-prfurledit.

      ENDIF.

    ENDIF.

  ENDMETHOD.


  METHOD zif_myfi_document~change.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_DOCUMENT_PO~zif_myfi_document~change
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for MyFi Documents
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
* 16.06.20 290977SCN RD2K919514 DS-11-32-07-01 changed
*          070667JPS
* 02.07.20 290977SCN RD2K919643 DS-11-32-07-01 removed R1 release
* 21/09/20 290977SCN RD2K919977 DS-11-32-07-01 S 6000002096: MyFi Purchasing (Release 2.2)
* 16.04.21 210983DY RD2K920923  DS-11-32-07-01 S 6000002348: MyFi Purchasing (May Release)
*                               Additional logic to stop auto approval of legacy PO's when
*                               submitted through MyFi
*05.07.2021 210983DY RD2K921312 DS-11-32-07-01 S6000002419: MyFi Purchasing (July Release)
*                               Additional logic to complete workitem for recall workflow
*                               on 'SUBMIT'
*-----------------------------------------------------------------------
    DATA: lv_delegate      TYPE swhactor,
          lv_event_success TYPE boole_d,
          lt_return        TYPE bapiret2_t.
    create_new_doc_header( ).
    me->zif_myfi_document~handle_odata( ).


    IF gs_po_deep-draftassigneeid IS NOT INITIAL.
      CALL METHOD me->assign_document
        EXPORTING
          iv_assignee = gs_po_deep-draftassigneeid.
    ENDIF.

    super->zif_myfi_document~change( ).
    IF gv_doc_posted_ok EQ abap_true.
      CALL METHOD zcl_mfp_po=>complete_recall_workitem
        EXPORTING
          iv_ebeln   = me->zif_myfi_document~posting_doc_num
         RECEIVING
          ev_success = data(lv_success).

      COMMIT WORK AND WAIT.
      CASE me->zif_myfi_document~new_doc_header-category.
        WHEN zif_mfp_constants=>gc_myfi_doc_type-l4l_po.
          CALL METHOD zcl_mfp_po=>create_event
            EXPORTING
              iv_ebeln        = me->zif_myfi_document~posting_doc_num
              iv_event        = zif_mfp_constants=>gc_event-l4l_po_posted
            IMPORTING
              ev_event_raised = lv_event_success.

          assign_document( iv_assignee = gv_l4l_requestor ).

        WHEN OTHERS.
          IF gv_mm_status NE zif_mfp_constants=>gc_mm_doc_status-po_released.  "me->gs_po_deep-approvaldetails-delegateid IS NOT INITIAL.

* Legacy purchase orders are auto approved, if userid in table ztm_po_namelist is either Blank or 'Z643_SYSTEM'
* To stop them from auto approving, update entry in table with value 'WF-BATCH'
            SELECT SINGLE * FROM  ztm_po_namelist INTO @DATA(ls_po_namelist)
              WHERE ebeln = @me->zif_myfi_document~posting_doc_num.
            IF sy-subrc IS INITIAL.
              IF ls_po_namelist-userid = 'Z643_SYSTEM' OR
                 ls_po_namelist-userid = space.
                ls_po_namelist-userid = 'WF-BATCH'.
                MODIFY ztm_po_namelist FROM  ls_po_namelist.
              ENDIF.
            ENDIF.

            lv_delegate-objid = me->gs_po_deep-approvaldetails-delegateid.
            lv_delegate-otype = |US|.
            CALL METHOD zcl_mfp_po=>create_event
              EXPORTING
                iv_recipient    = lv_delegate
                iv_ebeln        = me->zif_myfi_document~posting_doc_num
                iv_event        = zif_mfp_constants=>gc_event-change
                iv_reason       = me->gs_po_deep-approvaldetails-commentforapprover
              IMPORTING
                ev_event_raised = lv_event_success.

            IF lv_event_success = abap_true.
              CALL METHOD zcl_mfp_utilities=>log_myfi_event
                EXPORTING
                  iv_doc_number = me->zif_myfi_document~posting_doc_num
                  iv_user_id    = sy-uname
                  iv_sub_obj    = zif_mfp_constants=>gc_log-sub_obj-wf-change.
            ENDIF.
          ENDIF.
      ENDCASE.
    ENDIF.

  ENDMETHOD.


  METHOD zif_myfi_document~create.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_DOCUMENT_PO~zif_myfi_document~create
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for MyFi Documents
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
* 16.06.20 290977SCN RD2K919514 DS-11-32-07-01 S 6000001863: MyFi
*          070667JPS                           Purchasing Release 2_ECC
*                                              DEFECTS.  Added locking
*                                              for POs to fix a workflow
*                                              problem.
* 19.06.20 290977SCN RD2K919517 DS-11-32-07-01 S 6000001863: MyFi
*          070667JPS                           Purchasing Release 2_ECC
*                                              DEFECTS II.  Corrected
*                                              commit work logic.
* 22.07.20 290977SCN RD2K919533 DS-11-32-07-01 removed R1 release
* 21/09/20 290977SCN RD2K919977 DS-11-32-07-01 S 6000002096: MyFi Purchasing (Release 2.2)
*-----------------------------------------------------------------------
    DATA: lv_event_success TYPE boole_d,
          lv_delegate      TYPE swhactor,
          lt_return        TYPE bapiret2_t.
*          l_subrc          type sy-subrc.

    me->create_new_doc_header( iv_status = zif_mfp_constants=>gc_doc_status-draft ).
    me->zif_myfi_document~handle_odata( ).
*    me->in_admin_details( ).
    IF gs_po_deep-draftassigneeid IS NOT INITIAL.
      CALL METHOD me->assign_document
        EXPORTING
          iv_assignee = gs_po_deep-draftassigneeid.
    ENDIF.

    super->zif_myfi_document~create( ).
    IF gv_doc_posted_ok EQ abap_true.
*      COMMIT WORK AND WAIT.
      CASE me->zif_myfi_document~new_doc_header-category.
        WHEN zif_mfp_constants=>gc_myfi_doc_type-l4l_po.
          CALL METHOD zcl_mfp_po=>create_event
            EXPORTING
              iv_ebeln        = me->zif_myfi_document~posting_doc_num
              iv_event        = zif_mfp_constants=>gc_event-l4l_po_posted
            IMPORTING
              ev_event_raised = lv_event_success.
          assign_document( iv_assignee = gv_l4l_requestor ).

        WHEN OTHERS.
          lv_delegate-objid = me->gs_po_deep-approvaldetails-delegateid.
          lv_delegate-otype = |US|.
          CALL METHOD zcl_mfp_po=>create_event
            EXPORTING
              iv_recipient    = lv_delegate
              iv_ebeln        = me->zif_myfi_document~posting_doc_num
              iv_event        = zif_mfp_constants=>gc_event-submit
            IMPORTING
              ev_event_raised = lv_event_success.

          IF lv_event_success = abap_true.
            CALL METHOD zcl_mfp_utilities=>log_myfi_event
              EXPORTING
                iv_doc_number = me->zif_myfi_document~posting_doc_num
                iv_user_id    = sy-uname
                iv_sub_obj    = zif_mfp_constants=>gc_log-sub_obj-wf-submit.
          ENDIF.

          IF me->zif_myfi_document~source_doc_num IS NOT INITIAL AND me->zif_myfi_document~source_doc_num NE me->zif_myfi_document~posting_doc_num.
            move_attachments(
              EXPORTING
                iv_sending_doc        =  me->zif_myfi_document~source_doc_num
                iv_receiving_doc      =  me->zif_myfi_document~posting_doc_num ).

            CALL METHOD zcl_mfp_po=>create_event
              EXPORTING
*               iv_recipient    = lv_delegate
                iv_ebeln        = me->zif_myfi_document~source_doc_num
                iv_event        = zif_mfp_constants=>gc_event-draft_submit
*               iv_reason       = me->gs_contract_deep-approvaldetails-commentforapprover
              IMPORTING
                ev_event_raised = lv_event_success.



          ENDIF.
      ENDCASE.
    ENDIF.


  ENDMETHOD.


