  METHOD zif_myfi_document~handle_odata.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_DOCUMENT_PO~zif_myfi_document~handle_odata
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for MyFi Documents
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
* 05/11/21 210983DY  RD2K922034 DS-11-32-07-01 S6000002550: MyFi Applications (December Release)
*                    Additional code to enable Multi Account Assignment
* 03.03.2023 210983DY  RD2K923630 6000002898 MyFi Continuous Improvement April Release
*                    Additional code for toggle of delivery address
*03/07/2023 210983DY RD2K923919 6000002957 MyFi Continuous Improvement -
*   Line item Text updates for deletion of line item text
*-----------------------------------------------------------------------

    IF me->gs_po_deep-isdraft EQ abap_false.

      CALL FUNCTION 'BAPI_PO_GETDETAIL1'
        EXPORTING
          purchaseorder      = me->zif_myfi_document~source_doc_num
          item_text          = abap_true            " Item Text
          account_assignment = abap_true
          delivery_address   = abap_true            " Delivery address
        TABLES
          poitem            = gt_old_poitems
          potextitem         = gt_old_potextitems
          poaccount          = gt_old_poaccounts
          poaddrdelivery     = gt_old_poaddrdelivery.
    ENDIF.
    super->zif_myfi_document~handle_odata( ).
    me->zif_myfi_document~new_doc_header-selected_delegate = gs_po_deep-approvaldetails-delegateid.
    me->zif_myfi_document~new_doc_header-section23 = gs_po_deep-approvaldetails-issection23.
    MOVE-CORRESPONDING gs_po_deep-contactdetails TO me->zif_myfi_document~new_doc_header.
    me->in_admin_details( ). "SON and Payment terms justification
    me->in_delivery_addr( ).
    me->zif_myfi_document~in_phasings( ).
  ENDMETHOD.


  METHOD zif_myfi_document~in_account_assignment ##NEEDED.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_DOCUMENT_PO~ZIF_MYFI_DOCUMENT~IN_ACCOUNT_ASSIGNMENT
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for MyFi Documents
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
* 05/11/21 210983DY  RD2K922034 DS-11-32-07-01 S6000002550: MyFi Applications (December Release)
*                    Additional code to enable Multi Account Assignment
* 10/01/23  210983DY RD2K923348, RD2K923509
*                   RD2K923485 S 6000002854: MyFi Continuous Improvement December Rel
*          Additional logic to handle Account assignment validation for locked objects
*-----------------------------------------------------------------------

    DATA: ls_ci_cobl   TYPE bapi_te_mereqaccounting,
          ls_ci_coblx  TYPE bapi_te_mereqaccountingx,
          ls_csks      TYPE csksv,
          lv_pspnr     TYPE ps_posnr,
          ls_extension TYPE bapiparex.
    CLEAR: gt_poaccounts,gt_poaccountsx, gt_extension.


    DATA: lineassignments  TYPE zcl_zedm_mfp_mpc=>ts_accountassignment,
          ls_bapi_account  TYPE bapimeoutaccount,
          ls_bapi_accountx TYPE bapimeoutaccountx,
          r_descr          TYPE REF TO cl_abap_structdescr,
          wa_comp          TYPE abap_compdescr.

    me->zif_myfi_document~old_ekpo = get_ekpo( iv_ebeln = me->zif_myfi_document~source_doc_num ).

    r_descr ?= cl_abap_typedescr=>describe_by_data( ls_bapi_account ).

    LOOP AT gs_po_deep-accountassignments INTO lineassignments.

      IF NOT lineassignments-asset_no IS INITIAL.

        SELECT SINGLE a~anln1 AS assetnumber

              INTO @DATA(lv_asset)
              FROM anla AS a
                   INNER JOIN anlz AS b ON b~bukrs = a~bukrs
                                       AND b~anln1 = a~anln1
                                       AND b~anln2 = a~anln2
             WHERE a~bukrs = @gs_po_deep-comp_code
               AND a~anln1 = @lineassignments-asset_no    "Asset Number - passed in search criteria
                AND a~anln2 = @lineassignments-sub_number
               AND a~xspeb EQ @space              "Acquisition Lock
               AND a~xloev EQ @space              "Deletion Flag
               AND a~deakt EQ '00000000'         "Deactivation Date
               AND b~bdatu GE @sy-datlo.           "Date validity ends

        IF NOT sy-subrc IS INITIAL.
          DATA(lv_inactive) = abap_true.
        ENDIF.
      ENDIF.

* Check status of Cost object
      IF NOT lineassignments-costcenter IS INITIAL.

        CALL FUNCTION 'RK_KOSTL_READ'
          EXPORTING
            datum              = sy-datum
            kokrs              = 'CA01'
            kostl              = lineassignments-costcenter
          IMPORTING
            xcsksv             = ls_csks
          EXCEPTIONS
            kostl_not_complete = 1
            kostl_not_found    = 2
            text_not_found     = 3
            kokrs_missing      = 4
            OTHERS             = 5.
        IF sy-subrc <> 0.
* Implement suitable error handling here
        ENDIF.

        IF ls_csks-bkzkp = abap_true OR ls_csks-bkzks = abap_true OR ls_csks-bkzer = abap_true OR
           ls_csks-bkzob = abap_true OR ls_csks-pkzkp = abap_true OR ls_csks-pkzks = abap_true OR
           ls_csks-pkzer = abap_true.
          lv_inactive = abap_true.
*          CONTINUE.
        ENDIF.
      ENDIF.
*      ELSE
      IF NOT lineassignments-wbs_element IS INITIAL.

        CALL FUNCTION 'CONVERSION_EXIT_ABPSP_INPUT'
          EXPORTING
            input     = lineassignments-wbs_element
          IMPORTING
            output    = lv_pspnr
          EXCEPTIONS
            not_found = 1
            OTHERS    = 2.
        IF sy-subrc <> 0.
* Implement suitable error handling here
        ELSE.

          SELECT a~posid AS key,
                     a~post1 AS description,
                     c~pspid AS project,
                     c~post1 AS projectdescription
                INTO TABLE @DATA(lt_wbs) "et_entityset
                FROM prps AS a
                     INNER JOIN jest AS b ON b~objnr = a~objnr
                     INNER JOIN proj AS c ON c~pspnr = a~psphi
               WHERE a~posid = @lineassignments-wbs_element "IN lt_wbsnumbr_filter  "WBS Element
                 AND a~belkz EQ 'X'                 "Indicator: Account assignment element
                 AND b~stat EQ 'I0002'              "Released
                 AND b~inact NE 'X'                 "Inactive
                 AND b~objnr NOT IN ( SELECT objnr
                                        FROM jest
                                       WHERE objnr EQ b~objnr
                                         AND ( ( stat = 'I0043' AND inact = @space )       "Locked and active status record
                                          OR   ( stat = 'I0045' AND inact = @space )       "Technically completed and active status record
                                          OR   ( stat = 'I0046' AND inact = @space )       "Closed and active status record
                                          OR   ( stat = 'I0076' AND inact = @space ) ) ).  "Deletion Flag and active status record

          IF NOT sy-subrc IS INITIAL.
            lv_inactive = abap_true.

          ENDIF.
        ENDIF.
      ENDIF.

*      ELSE
      IF NOT lineassignments-orderid IS INITIAL.

        SELECT a~aufnr AS key,
                   a~ktext AS value
              FROM aufk AS a
                   INNER JOIN jest AS b ON b~objnr = a~objnr
              INTO TABLE @DATA(lt_order)
             WHERE a~aufnr = @lineassignments-orderid " "Internal Order Number
               AND a~auart = 'A000'              "Order Type
               AND a~kokrs = 'CA01'              "RD2K918951 - Controlling Area
               AND a~phas1 = 'X'                 "RD2K918951 - 'Release' Status
               AND a~loekz = @space               "RD2K918951 - 'Deletion Flag
               AND b~stat = 'I0002'              "Released Status in JEST
               AND b~inact = @space               "Active Released Status in JEST
               AND b~objnr NOT IN ( SELECT objnr "Ensure that there are no other status that make the IO record unvailable for posting
                                      FROM jest
                                     WHERE objnr EQ b~objnr
                                       AND ( ( stat = 'I0043' AND inact = @space )       "Locked and active status record
                                        OR   ( stat = 'I0045' AND inact = @space )       "Technically completed and active status record
                                        OR   ( stat = 'I0046' AND inact = @space )       "Closed and active status record
                                        OR   ( stat = 'I0076' AND inact = @space ) ) ).  "Deletion Flag and active status record

        IF NOT sy-subrc IS INITIAL.
          lv_inactive = abap_true.
        ENDIF.
      ENDIF.

      IF NOT lineassignments-gl_account IS INITIAL.

        SELECT SINGLE a~saknr INTO @DATA(lv_valid_gl)
        FROM ska1 AS a INNER JOIN skb1 AS b ON a~saknr = b~saknr
        WHERE a~ktopl = 'COA'
          AND a~saknr = @lineassignments-gl_account
            AND a~xloev = @space
            AND a~xspeb = @space
            AND b~bukrs = @gs_po_deep-comp_code
            AND b~xloeb = @space
            AND b~xspeb = @space.
        IF NOT sy-subrc IS INITIAL.
          lv_inactive = abap_true.
        ENDIF.
      ENDIF.


      READ TABLE gt_old_poaccounts INTO DATA(ls_old_oaaccount) WITH KEY po_item = lineassignments-linenumber
                                                                         serial_no = lineassignments-assignment_item.
      IF sy-subrc IS INITIAL.
        MOVE-CORRESPONDING ls_old_oaaccount TO ls_bapi_account.
      ENDIF.
      CLEAR : ls_bapi_account, ls_bapi_accountx.
      MOVE-CORRESPONDING lineassignments TO ls_bapi_account.
      ls_bapi_account-delete_ind = lineassignments-isdeleted.

      IF lv_inactive = abap_true. " When flag for cost object lock is set

* Check for locked or deleted flag and Pass cost object to BAPI when there is a change
        READ TABLE me->zif_myfi_document~old_ekpo INTO DATA(ls_ekpo_old) WITH KEY ebelp = lineassignments-linenumber.

        IF sy-subrc IS INITIAL AND ( ls_ekpo_old-loekz = zif_mfp_constants=>gc_lock_type-blocked OR
             ls_ekpo_old-loekz = zif_mfp_constants=>gc_lock_type-deleted ). " Old Status is Blocked or Deleted.

          READ TABLE gs_po_deep-purchaseorderlis INTO DATA(ls_poitem) WITH KEY linenumber = lineassignments-linenumber.
          IF ls_poitem-status = zif_mfp_constants=>gc_lock_type-blocked OR
                  ls_poitem-status = zif_mfp_constants=>gc_lock_type-deleted. " New status is blocked or deleted
            ls_bapi_account-delete_ind = abap_true.
            ls_bapi_accountx-delete_ind = abap_true.
          ENDIF.
        ELSE.

          ls_bapi_account-delete_ind = abap_true.
          ls_bapi_accountx-delete_ind = abap_true.

        ENDIF.

      ENDIF. " Avoid BAPI error for unchanged lines with blocked cost object
      ls_bapi_account-item_no = lineassignments-linenumber.
      ls_bapi_account-serial_no = lineassignments-assignment_item.
      ls_bapi_account-net_value = lineassignments-amount.
      ls_bapi_account-distr_perc = lineassignments-vproz.

      IF ls_bapi_account-wbs_element = '00000000'.
        CLEAR ls_bapi_account-wbs_element.
      ENDIF.

      READ TABLE gs_po_deep-purchaseorderlis INTO DATA(ls_odata_poitem) WITH KEY linenumber = lineassignments-linenumber.
      IF sy-subrc IS INITIAL." AND lv_inactive IS INITIAL.
        IF ls_odata_poitem-esp IS NOT INITIAL.

          CALL METHOD me->map_odata_2_bapi
            EXPORTING
              is_sending_structure   = ls_odata_poitem
              is_sending_x_structure = abap_false
            IMPORTING
              es_data                = ls_ci_cobl
              es_data_x              = ls_ci_cobl.  "Not needed

          ls_ci_cobl-serial_no = ls_bapi_account-serial_no.

          ls_extension-structure = zif_mfp_constants=>gc_cobl-po.
          ls_extension+30 = ls_ci_cobl.  "Causes a warning in the syntax check
          APPEND ls_extension TO gt_extension.

          ls_ci_coblx-preq_item = ls_ci_cobl-preq_item.
          ls_ci_coblx-serial_no = ls_ci_cobl-serial_no.
          ls_ci_coblx-zzesp = abap_true.

          ls_extension-structure = zif_mfp_constants=>gc_cobl-pox.
          ls_extension+30 = ls_ci_coblx.  "Causes a warning in the syntax check
          APPEND ls_extension TO gt_extension.
        ENDIF.
      ENDIF.


      APPEND ls_bapi_account TO gt_poaccounts.

      LOOP AT r_descr->components INTO wa_comp.
        ASSIGN COMPONENT wa_comp-name OF STRUCTURE ls_bapi_account TO FIELD-SYMBOL(<fs_value>).
        IF sy-subrc = 0 AND <fs_value> IS NOT INITIAL.
          ASSIGN COMPONENT wa_comp-name OF STRUCTURE ls_bapi_accountx TO <fs_value>.
          <fs_value> = abap_true.
        ENDIF.
      ENDLOOP.

      LOOP AT r_descr->components INTO wa_comp WHERE name = 'WBS_ELEMENT'.
        ASSIGN COMPONENT wa_comp-name OF STRUCTURE ls_bapi_account TO <fs_value>.
        IF sy-subrc = 0 AND <fs_value> = '00000000'.
          CLEAR <fs_value>.
          ASSIGN COMPONENT wa_comp-name OF STRUCTURE ls_bapi_accountx TO <fs_value>.
          <fs_value> = abap_false.
        ENDIF.

      ENDLOOP.

      ls_bapi_accountx-item_no    = ls_bapi_account-item_no.
      ls_bapi_accountx-item_nox   = abap_true.
      ls_bapi_accountx-serial_no  = ls_bapi_account-serial_no.
      ls_bapi_accountx-serial_nox = abap_true.
      APPEND ls_bapi_accountx TO gt_poaccountsx.

      CLEAR: lv_inactive.
    ENDLOOP.

    READ TABLE gt_poaccounts TRANSPORTING NO FIELDS WITH KEY delete_ind = abap_true.
    IF sy-subrc IS INITIAL. gv_locked_costobject = abap_true. ENDIF.

  ENDMETHOD.


  METHOD zif_myfi_document~in_header.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_DOCUMENT_PO~zif_myfi_document~in_header
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for MyFi Documents
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
* 30.11.20 220977FKC RD2K920449 DS-11-32-07-01 6000002172: MyFi Purchasing (Release 2.3)
*                                              Enable legacy i.e. non-myfi created docs
* 23.02.21 220977FKC RD2K920554 DS-11-32-07-01 6000002250: MyFi Purchasing (Release 2.4)
*                                              Enable PRF link for standalone PO's
* 04.08.21 210983DY RD2K921440  DS-11-32-07-01 S6000002451: MyFi Purchasing (August Release)
*                                              Enable Your reference field in MyFi Purchasing
*-----------------------------------------------------------------------
    DATA: ls_popartner TYPE bapiekkop.

    CALL METHOD me->map_odata_2_bapi
      EXPORTING
        is_sending_structure   = gs_po_deep
        is_sending_x_structure = abap_true
      IMPORTING
        es_data                = gs_poheader
        es_data_x              = gs_poheaderx.

    IF me->zif_myfi_document~gv_useraction EQ zif_mfp_constants=>gc_action-odata-create
    OR gs_po_deep-isdraft EQ abap_true
    OR gs_po_deep-islegacy EQ abap_true.
      gs_poheader-item_intvl = 00001.
      gs_poheaderx-item_intvl = abap_true.
      gs_poheader-doc_type = 'NB'.
      gs_poheaderx-doc_type = abap_true.
      IF gs_po_deep-islegacy NE abap_true.
        IF gv_l4l_requestor IS NOT INITIAL.
          gs_poheader-created_by = gv_l4l_requestor.
        ELSE.
          gs_poheader-created_by = sy-uname.
        ENDIF.
        gs_poheaderx-created_by = abap_true.
      ENDIF.
      gs_poheader-our_ref = '00000000001'.
      gs_poheaderx-our_ref = abap_true.

      gs_poheader-ref_1 = gs_po_deep-ihrez.
      gs_poheaderx-ref_1 = abap_true.

      CALL METHOD zcl_mfp_utilities=>get_porg_from_ccode
        EXPORTING
          bukrs = gs_poheader-comp_code
        RECEIVING
          ekorg = gs_poheader-purch_org.
      gs_poheaderx-purch_org = abap_true.
    ELSE.
      gs_poheader-our_ref = get_ref_number( iv_ebeln = gs_poheader-po_number ).
      gs_poheaderx-our_ref = abap_true.

      gs_poheader-ref_1 = gs_po_deep-ihrez.
      gs_poheaderx-ref_1 = abap_true.
    ENDIF.

    IF gs_po_deep-diff_inv IS INITIAL.
      me->zif_myfi_document~old_ekko = get_ekko( EXPORTING iv_ebeln = gs_po_deep-po_number ).
      IF me->zif_myfi_document~old_ekko-lifre IS NOT INITIAL.
        ls_popartner-buspartno = me->zif_myfi_document~old_ekko-lifre.
        ls_popartner-partnerdesc = 'PI'.
        ls_popartner-langu = 'E'.
        ls_popartner-delete_ind = abap_true.
        APPEND ls_popartner TO gt_popartner.
        gs_poheaderx-diff_inv = abap_true.
      ENDIF.

    ENDIF.

  ENDMETHOD.


  METHOD zif_myfi_document~in_line_items.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_DOCUMENT_PO~zif_myfi_document~in_line_items
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for MyFi Documents
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
* 16.06.20 290977SCN RD2K919514 DS-11-32-07-01 Updated for GR Flags
*          070667JPS
* 21/09/20 290977SCN RD2K919977 DS-11-32-07-01 S 6000002096: MyFi Purchasing (Release 2.2)
* 21.10.20 290977SCN RD2K919656 DS-11-32-07-01 S 6000002172: MyFi Purchasing (Release 2.3)
* 30/11/20 210983DY  RD2K919656 DS-11-32-07-01 S 6000002172: MyFi Purchasing (Release 2.3)
*                               Additional code for Item Texts and Free Item
* 03/03/21 210983DY  RD2K920554 DS-11-32-07-01 S 6000002250: MyFi Purchasing (Release 2.4 )
*                               Additional code to handle Multi delivery address
* 04.08.21 210983DY RD2K921440  DS-11-32-07-01 S6000002451: MyFi Purchasing (August Release)
* 05/11/21 210983DY  RD2K922034 DS-11-32-07-01 S6000002550: MyFi Applications (December Release)
*                    Additional code to enable Multi Account Assignment
*15/12/21  210983DY RD2K922296 DS-11-32-07-01 S6000002623: MyFi Applications (February Release)
* 29/03/22 210983DY RD2K922546  DS-11-32-07-01 S 6000002692: MyFi Applications (May Release)
*                              Additional Logic to handle Returns Item for PO
* 03/07/2023 210983DY RD2K923919 6000002957 MyFi Continuous Improvement -
*    Amend logic to maintain line item text updates for deletion of text
* 11.09.2023 210983DY RD2K924301,RD2K924353  6000002999 MyFi Continuous Improvement October Release
*          Additional logic to fix update of Plant for Legacy documents
* 29.04.2024 210983DY RD2K924931    6000003126: MyFi Fix
*                 Amended logic for new Prepayment and FMS field changes
*-----------------------------------------------------------------------
    DATA: ls_bapi_poitem     TYPE bapimepoitem,
          ls_bapi_poitemx    TYPE bapimepoitemx,
          lt_bapi_potext     TYPE bapimepotext_tp,
          ls_bapi_poaccount  TYPE bapimepoaccount,
          ls_bapi_poaccountx TYPE bapimepoaccountx,
          ls_ci_cobl         TYPE bapi_te_mereqaccounting,
          ls_ci_coblx        TYPE bapi_te_mereqaccountingx,
          ls_extension       TYPE bapiparex,
          ls_new_prepmnt     TYPE ztmfp_prepmnt,
          l_is_new           TYPE abap_bool,
          l_is_changed       TYPE abap_bool.

    LOOP AT gs_po_deep-purchaseorderlis INTO DATA(ls_odata_poitem).
      CLEAR: ls_bapi_poitem,ls_bapi_poitemx,ls_bapi_poaccount,ls_bapi_poaccountx,lt_bapi_potext.
      CALL METHOD me->map_odata_2_bapi
        EXPORTING
          is_sending_structure   = ls_odata_poitem
          is_sending_x_structure = abap_true
        IMPORTING
          es_data                = ls_bapi_poitem
          es_data_x              = ls_bapi_poitemx.

      CLEAR: ls_bapi_poitem-gr_non_val, ls_bapi_poitemx-gr_non_val.

      IF ls_odata_poitem-isreturn = abap_true.
        ls_bapi_poitem-ret_item = abap_true.
        ls_bapi_poitemx-ret_item = abap_true.
        ls_bapi_poitem-quantity = ls_bapi_poitem-quantity * -1.
      ENDIF.

      ls_bapi_poitem-gr_non_val = space.
      ls_bapi_poitemx-gr_non_val = abap_true.


      ls_bapi_poitem-agreement      = gs_poheader-agreement.
      ls_bapi_poitemx-agreement     = abap_true.

      IF ls_odata_poitem-distrib = '0'.
        ls_odata_poitem-distrib = ''.
      ENDIF.
      ls_bapi_poitem-distrib      = ls_odata_poitem-distrib.
      ls_bapi_poitemx-distrib      = abap_true.

      ls_bapi_poitem-part_inv    = ls_odata_poitem-part_inv.
      ls_bapi_poitemx-part_inv    = abap_true..

* Get the value of Plant from existing document
      DATA(lv_old_plant) = VALUE #( gt_old_poitems[ po_item = ls_bapi_poitem-po_item ]-plant OPTIONAL ).
      DATA(ls_old_item) = VALUE #( gt_old_poitems[ po_item = ls_bapi_poitem-po_item ] OPTIONAL ).
* Get the value of plant from company code
      SELECT SINGLE bwkey
               INTO @DATA(lv_plant)
               FROM t001k WHERE bukrs = @gs_poheader-comp_code.
* Pass Plant value from company code for creation of new documents and
* retain existing value for all other user actions
      IF zif_myfi_document~gv_useraction EQ zif_mfp_constants=>gc_action-odata-create OR
        ls_old_item-po_item IS INITIAL.
        ls_bapi_poitem-plant = lv_plant.
        ls_bapi_poitemx-plant = abap_true.
      ELSE.
        IF lv_old_plant IS INITIAL.
          ls_bapi_poitemx-plant         = abap_false.
        ELSE.
          ls_bapi_poitem-plant = lv_old_plant.
          ls_bapi_poitemx-plant = abap_true.
        ENDIF.
      ENDIF.

      ls_bapi_poitemx-po_item       = ls_bapi_poitem-po_item.
      ls_bapi_poitemx-po_itemx      = abap_true.

* Only update GR flags if new or if prepaypayment flag actually changed
      IF zif_myfi_document~gv_useraction EQ zif_mfp_constants=>gc_action-odata-create
      OR gs_po_deep-isdraft EQ abap_true.
        l_is_new = abap_true.
      ELSE.
        SELECT SINGLE isprepayment
          FROM ztmfp_prepmnt
          INTO @DATA(l_isprepayment_db)
          WHERE zmfp_doc_id = @gs_po_deep-po_number
            AND linenumber = @ls_bapi_poitem-po_item.

        l_isprepayment_db = SWITCH #( l_isprepayment_db
            WHEN 'X' THEN 'Y'
            WHEN 'Y' THEN 'Y'
            WHEN 'N' THEN 'N'
            WHEN ' ' THEN 'N' ).

        IF l_isprepayment_db <> ls_odata_poitem-isprepayment.
          l_is_changed = abap_true.
        ENDIF.
      ENDIF.

      IF l_is_new = abap_true OR l_is_changed = abap_true.
        IF ls_odata_poitem-isprepayment EQ 'Y'. "abap_true.
          CLEAR: ls_bapi_poitem-gr_basediv, ls_bapi_poitem-gr_ind,
                 ls_bapi_poitem-gr_non_val, ls_bapi_poitemx-gr_non_val.
          ls_bapi_poitemx-gr_non_val = abap_true.
        ELSE.
          ls_bapi_poitem-gr_basediv = ls_bapi_poitem-gr_ind = abap_true.
        ENDIF.
        ls_bapi_poitemx-gr_basediv = ls_bapi_poitemx-gr_ind = abap_true.
      ELSE.
        ls_bapi_poitemx-gr_basediv = ls_bapi_poitemx-gr_ind = abap_false.
      ENDIF.

      READ TABLE gt_old_poitems INTO DATA(ls_poitem_old) WITH KEY po_item = ls_bapi_poitem-po_item.
* Tracking Number
      IF NOT ls_odata_poitem-trackingno IS INITIAL OR ls_poitem_old-trackingno NE ls_odata_poitem-trackingno.
        ls_bapi_poitem-trackingno = ls_odata_poitem-trackingno.
        ls_bapi_poitemx-trackingno = abap_true.
      ENDIF.
* Vendor Material
      IF NOT ls_odata_poitem-vendormaterial IS INITIAL OR ls_odata_poitem-vendormaterial NE ls_poitem_old-vend_mat..
        ls_bapi_poitem-vend_mat = ls_odata_poitem-vendormaterial.
        ls_bapi_poitemx-vend_mat = abap_true.
      ENDIF.

* Zero based value
      IF ls_odata_poitem-zerovalue = abap_true.
        CLEAR: ls_bapi_poitem-gr_non_val, ls_bapi_poitemx-gr_non_val.
        ls_bapi_poitem-free_item = abap_true.
        ls_bapi_poitemx-free_item = abap_true.
        ls_bapi_poitem-net_price = '0.00'.
        ls_bapi_poitemx-net_price = abap_true.
        ls_bapi_poitem-gr_ind = abap_false.
        ls_bapi_poitemx-gr_ind = abap_true.
        ls_bapi_poitem-ir_ind = abap_false.
        ls_bapi_poitemx-ir_ind = abap_true.
        ls_bapi_poitem-gr_basediv = abap_false.
        ls_bapi_poitemx-gr_basediv = abap_true.
        ls_bapi_poitemx-gr_non_val = abap_true.

      ENDIF.


      SELECT SINGLE msehi FROM  t006a
             WHERE  spras  = 'E'
             AND    mseh3  = @ls_odata_poitem-po_unit
        INTO @ls_bapi_poitem-orderpr_un.
      ls_bapi_poitem-po_unit = ls_bapi_poitem-orderpr_un.

      SELECT SINGLE ebelp FROM ekpo INTO @DATA(lv_ebelp) WHERE ebeln = @me->gs_poheader-po_number AND ebelp = @ls_bapi_poitem-po_item.

      IF sy-subrc EQ 0.
        CLEAR ls_bapi_poitemx-po_unit.
      ENDIF.

      APPEND ls_bapi_poitem  TO gt_poitems.
      APPEND ls_bapi_poitemx TO gt_poitemsx.

      READ TABLE gs_po_deep-deliveryaddresses INTO DATA(ls_podelivery_addr) WITH KEY linenumber = ls_odata_poitem-linenumber.
      IF sy-subrc IS INITIAL.
        CALL METHOD me->convert_string_mm_table
          EXPORTING
            iv_string = ls_podelivery_addr-pickuplocation
            iv_tdid   = zif_mfp_constants=>gc_header_text-po-item-delivery "'F04'
            iv_item   = ls_bapi_poitem-po_item
          CHANGING
            rt_texts  = lt_bapi_potext.
      ENDIF.
*      lt_bapi_potext                = convert_string_mm_table( iv_string = gs_po_deep-deliveryaddresses-pickuplocation
*                                                iv_tdid   = 'F04'
*                                                iv_item   = ls_bapi_poitem-po_item ).

*      APPEND LINES OF lt_bapi_potext TO gt_potextitems

* PO Line item texts

*      IF NOT ls_odata_poitem-itemtext IS INITIAL.

      DATA(lv_itemtext) = convert_mm_table_string( EXPORTING it_texts  = gt_old_potextitems iv_item = ls_bapi_poitem-po_item
                                                                                   iv_tdid   = zif_mfp_constants=>gc_header_text-po-item-text ).
      IF NOT lv_itemtext = ls_odata_poitem-itemtext.
        CALL METHOD me->convert_string_mm_table
          EXPORTING
            iv_string = ls_odata_poitem-itemtext
            iv_tdid   = zif_mfp_constants=>gc_header_text-po-item-text "'F01'
            iv_item   = ls_bapi_poitem-po_item
          CHANGING
            rt_texts  = lt_bapi_potext.
      ENDIF.
*      ENDIF.

*      IF NOT ls_odata_poitem-inforecordpotext IS INITIAL.

      DATA(lv_inforecordpotext) = convert_mm_table_string( EXPORTING it_texts  = gt_old_potextitems iv_item = ls_bapi_poitem-po_item
                                                                                  iv_tdid   = zif_mfp_constants=>gc_header_text-po-item-info_record ).
      IF NOT lv_inforecordpotext = ls_odata_poitem-inforecordpotext.

        CALL METHOD me->convert_string_mm_table
          EXPORTING
            iv_string = ls_odata_poitem-inforecordpotext
            iv_tdid   = zif_mfp_constants=>gc_header_text-po-item-info_record "'F02'
            iv_item   = ls_bapi_poitem-po_item
          CHANGING
            rt_texts  = lt_bapi_potext.
      ENDIF.
*      ENDIF.

*      IF NOT ls_odata_poitem-materialpotext IS INITIAL.
      DATA(lv_materialpotext) = convert_mm_table_string( EXPORTING it_texts  = gt_old_potextitems iv_item = ls_bapi_poitem-po_item
                                                                                  iv_tdid   = zif_mfp_constants=>gc_header_text-po-item-mat_po ).
      IF NOT lv_materialpotext = ls_odata_poitem-materialpotext.
        CALL METHOD me->convert_string_mm_table
          EXPORTING
            iv_string = ls_odata_poitem-materialpotext
            iv_tdid   = zif_mfp_constants=>gc_header_text-po-item-mat_po "'F03'
            iv_item   = ls_bapi_poitem-po_item
          CHANGING
            rt_texts  = lt_bapi_potext.
      ENDIF.
*      ENDIF.

*      IF NOT ls_odata_poitem-infonote IS INITIAL.
*      IF NOT ls_odata_poitem-inforecordnote IS INITIAL.

      DATA(lv_inforecordnote) = convert_mm_table_string( EXPORTING it_texts  = gt_old_potextitems iv_item = ls_bapi_poitem-po_item
                                                                                  iv_tdid   = zif_mfp_constants=>gc_header_text-po-item-info_note ).
      IF NOT lv_inforecordnote = ls_odata_poitem-inforecordnote.

        CALL METHOD me->convert_string_mm_table
          EXPORTING
            iv_string = ls_odata_poitem-inforecordnote
            iv_tdid   = zif_mfp_constants=>gc_header_text-po-item-info_note "'F05'
            iv_item   = ls_bapi_poitem-po_item
          CHANGING
            rt_texts  = lt_bapi_potext.
      ENDIF.
*      ENDIF.

*      IF NOT ls_odata_poitem-infonote IS INITIAL.
      DATA(lv_infonote) = convert_mm_table_string( EXPORTING it_texts  = gt_old_potextitems iv_item = ls_bapi_poitem-po_item
                                                                                  iv_tdid   = zif_mfp_constants=>gc_header_text-po-item-note ).
      IF NOT lv_infonote = ls_odata_poitem-infonote.

        CALL METHOD me->convert_string_mm_table
          EXPORTING
            iv_string = ls_odata_poitem-infonote
            iv_tdid   = zif_mfp_constants=>gc_header_text-po-item-note "'F08'
            iv_item   = ls_bapi_poitem-po_item
          CHANGING
            rt_texts  = lt_bapi_potext.
      ENDIF.
*      ENDIF.


      APPEND LINES OF lt_bapi_potext TO gt_potextitems.


      CALL METHOD me->map_odata_2_bapi
        EXPORTING
          is_sending_structure   = ls_odata_poitem
          is_sending_x_structure = abap_true
        IMPORTING
          es_data                = ls_bapi_poaccount
          es_data_x              = ls_bapi_poaccountx.

      IF ls_odata_poitem-status = zif_mfp_constants=>gc_lock_type-blocked OR
         ls_odata_poitem-status = zif_mfp_constants=>gc_lock_type-deleted.
        ls_bapi_poaccount-delete_ind = zif_mfp_constants=>gc_lock_type-blocked.
        ls_bapi_poaccountx-delete_ind = abap_true..

      ENDIF.

      ls_bapi_poaccount-serial_no = '01'.

      APPEND ls_bapi_poaccount TO gt_poaccounts.

      ls_bapi_poaccountx-po_item    = ls_bapi_poaccount-po_item.
      ls_bapi_poaccountx-po_itemx   = abap_true.
      ls_bapi_poaccountx-serial_no  = ls_bapi_poaccount-serial_no.
      ls_bapi_poaccountx-serial_nox = abap_true.
      APPEND ls_bapi_poaccountx TO gt_poaccountsx.

* ESP
      IF ls_odata_poitem-esp IS NOT INITIAL.

        CALL METHOD me->map_odata_2_bapi
          EXPORTING
            is_sending_structure   = ls_odata_poitem
            is_sending_x_structure = abap_false
          IMPORTING
            es_data                = ls_ci_cobl
            es_data_x              = ls_ci_cobl.  "Not needed

        ls_ci_cobl-serial_no = ls_bapi_poaccount-serial_no.

        ls_extension-structure = zif_mfp_constants=>gc_cobl-po.
        ls_extension+30 = ls_ci_cobl.  "Causes a warning in the syntax check
        APPEND ls_extension TO gt_extension.

        ls_ci_coblx-preq_item = ls_ci_cobl-preq_item.
        ls_ci_coblx-serial_no = ls_ci_cobl-serial_no.
        ls_ci_coblx-zzesp = abap_true.

        ls_extension-structure = zif_mfp_constants=>gc_cobl-pox.
        ls_extension+30 = ls_ci_coblx.  "Causes a warning in the syntax check
        APPEND ls_extension TO gt_extension.
      ENDIF.

      in_prepmnt_line(
        EXPORTING
          is_odata_poitem = ls_odata_poitem                  " Purchase Order Item
          iv_po_item      = ls_bapi_poitem-po_item                 " Item Number of Purchasing Document
      ).


    ENDLOOP.

  ENDMETHOD.


  METHOD zif_myfi_document~in_phasings.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_DOCUMENT_PO~zif_myfi_document~in_phasings
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for MyFi Documents
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
* 22.07.20 290977SCN RD2K919533 DS-11-32-07-01 No Changes transported
* 24/03/21 210983DY  RD2K920865 DS-11-32-07-01 S 6000002310: MyFi Purchasing (April Release)
*                               Additional code to fix issue related to schedule lines
* 29/03/22 210983DY RD2K922546  DS-11-32-07-01 S 6000002692: MyFi Applications (May Release)
*                              Additional Logic to handle Returns Item for PO
* 27/04/22 210983DY RD2K922655 DS-11-32-07-01 S 6000002692: MyFi Applications (May Release)
*                              Additional Logic to handle Returns Item for PO
*-----------------------------------------------------------------------
    DATA: ls_bapi_poschedule  TYPE bapimeposchedule,
          ls_bapi_poschedulex TYPE bapimeposchedulx.

    LOOP AT gs_po_deep-phasings INTO DATA(ls_odata_phasing).

      READ TABLE gs_po_deep-purchaseorderlis INTO DATA(ls_poitem) WITH KEY linenumber = ls_odata_phasing-po_item.
      IF sy-subrc IS INITIAL AND ls_poitem-isreturn = abap_true AND ls_odata_phasing-quantity LT 0.
        ls_odata_phasing-quantity = ls_odata_phasing-quantity * -1.
      ENDIF.

      CALL METHOD me->map_odata_2_bapi
        EXPORTING
          is_sending_structure   = ls_odata_phasing
          is_sending_x_structure = abap_true
        IMPORTING
          es_data                = ls_bapi_poschedule
          es_data_x              = ls_bapi_poschedulex.

      IF ls_odata_phasing-delete_ind = abap_true.
        ls_bapi_poschedule-delete_ind = zif_mfp_constants=>gc_lock_type-deleted.
      ENDIF.

      APPEND ls_bapi_poschedule TO gt_poschedules.

      ls_bapi_poschedulex-po_item = ls_bapi_poschedule-po_item.
      ls_bapi_poschedulex-sched_line = ls_bapi_poschedule-sched_line.

      APPEND ls_bapi_poschedulex TO gt_poschedulesx.

      CLEAR : ls_bapi_poschedule, ls_bapi_poschedulex.

    ENDLOOP.

  ENDMETHOD.


  METHOD zif_myfi_document~in_strings.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_DOCUMENT_PO~zif_myfi_document~in_strings
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for MyFi Documents
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
* 30/11/20 210983DY  RD2K919656 DS-11-32-07-01 S 6000002172: MyFi Purchasing (Release 2.3)
*                               Additional code for Item Texts and Free Item
* 03/03/21 210983DY  RD2K920554 DS-11-32-07-01 S 6000002250: MyFi Purchasing (Release 2.4 )
*               Additional code to handle Multi Delivery address
* 07/11/23 210983DY        DS-11-32-07-01 MyFi Feb release 24
*-----------------------------------------------------------------------
    DATA: ls_string_entry TYPE ztmfp_strings,
          lt_strings      TYPE TABLE OF ztmfp_strings,
          lt_bapi_potext  TYPE bapimepotext_tp,
          lv_alternatetc  TYPE string,
          lv_string       TYPE string.

    ls_string_entry-zmfp_doc_id = me->zif_myfi_document~posting_doc_num.

*******  JSON ********
    me->gs_po_deep-po_number            = me->zif_myfi_document~posting_doc_num.
    me->gs_po_deep-statusdesclong =  me->gs_po_deep-statusdesc = zcl_mfp_utilities=>get_status_desc( iv_status = me->zif_myfi_document~new_doc_header-status ).
*    me->gs_po_deep-requestid            = me->zif_myfi_document~source_doc_num.
    ls_string_entry-string_data         = /ui2/cl_json=>serialize( data = me->gs_po_deep compress = abap_true pretty_name = /ui2/cl_json=>pretty_mode-camel_case ).
    ls_string_entry-string_type         = zif_mfp_constants=>gc_string_type-json.
    APPEND ls_string_entry TO lt_strings.

* Alternate Terms and Conditions Flag
    IF me->gs_po_deep-headertexts-alternatetc = abap_true.
      lv_alternatetc = '.'.
    ELSE.
      lv_alternatetc = ''.
    ENDIF.

    CALL METHOD me->convert_string_mm_table
      EXPORTING
        iv_string = lv_alternatetc
        iv_tdid   = zif_mfp_constants=>gc_header_text-po-alt_tc_cond
      CHANGING
        rt_texts  = gt_poheadertext.
* Header note
    IF NOT me->gs_po_deep-headertexts-headernote IS INITIAL.
      CALL METHOD me->convert_string_mm_table
        EXPORTING
          iv_string = me->gs_po_deep-headertexts-headernote
          iv_tdid   = zif_mfp_constants=>gc_header_text-po-note
        CHANGING
          rt_texts  = gt_poheadertext.

      ls_string_entry-string_data = me->gs_po_deep-headertexts-headernote.
      ls_string_entry-string_type = zif_mfp_constants=>gc_string_type-header-note.
      APPEND ls_string_entry TO lt_strings.
    ENDIF.
* Contract Riders
    IF NOT me->gs_po_deep-headertexts-contractriders IS INITIAL.
      CALL METHOD me->convert_string_mm_table
        EXPORTING
          iv_string = me->gs_po_deep-headertexts-contractriders
          iv_tdid   = zif_mfp_constants=>gc_header_text-po-riders
        CHANGING
          rt_texts  = gt_poheadertext.

      ls_string_entry-string_data = me->gs_po_deep-headertexts-contractriders.
      ls_string_entry-string_type = zif_mfp_constants=>gc_string_type-header-riders.
      APPEND ls_string_entry TO lt_strings.
    ENDIF.

*    IF me->gs_po_deep-romancomment IS NOT INITIAL.
* Roman Header Text - store in Header text
      CALL METHOD me->convert_string_mm_table
        EXPORTING
          iv_string = me->gs_po_deep-romancomment
          iv_tdid   = zif_mfp_constants=>gc_header_text-po-header
*         iv_item   =
        CHANGING
          rt_texts  = gt_poheadertext.

      ls_string_entry-string_data = me->gs_po_deep-romancomment.
      ls_string_entry-string_type = zif_mfp_constants=>gc_string_type-header.
      APPEND ls_string_entry TO lt_strings.
*    ENDIF.

* Special Delivery Instructions - store in Header Delivery text

    CALL METHOD me->convert_string_mm_table
      EXPORTING
        iv_string = me->gs_po_deep-contactdetails-specialinstructions
        iv_tdid   = zif_mfp_constants=>gc_header_text-po-delivery
*       iv_item   =
      CHANGING
        rt_texts  = gt_poheadertext.


* Delivery Address

    IF me->gs_po_deep-contactdetails-specialinstructions IS NOT INITIAL.
      ls_string_entry-string_data = me->gs_po_deep-contactdetails-specialinstructions.
      ls_string_entry-string_type =   zif_mfp_constants=>gc_string_type-spec_instr.
      APPEND ls_string_entry TO lt_strings.
    ENDIF.

* Approval Details
    IF me->gs_po_deep-approvaldetails-commentforapprover IS NOT INITIAL.
      ls_string_entry-string_data = me->gs_po_deep-approvaldetails-commentforapprover.
      ls_string_entry-string_type =   zif_mfp_constants=>gc_string_type-comment_approver.
      APPEND ls_string_entry TO lt_strings.
    ENDIF.

    IF me->gs_po_deep-approvaldetails-valueformoney IS NOT INITIAL.
      ls_string_entry-string_data = me->gs_po_deep-approvaldetails-valueformoney.
      ls_string_entry-string_type =   zif_mfp_constants=>gc_string_type-value_for_money.
      APPEND ls_string_entry TO lt_strings.
    ENDIF.

* SON ID - store in Header Alternate T&Cs Agreement Number text
    CALL METHOD me->convert_string_mm_table
      EXPORTING
        iv_string = me->gs_po_deep-sonid
        iv_tdid   = zif_mfp_constants=>gc_header_text-po-sonid
*       iv_item   =
      CHANGING
        rt_texts  = gt_poheadertext.

* Payment Term non-standard - store in Header Alternate T&Cs Condition text
**    IF me->gs_po_deep-pmnttrms EQ '0020'.
**      CLEAR lv_string.
**    ELSE.
**      lv_string = '.'.
**    ENDIF.
**
**    CALL METHOD me->convert_string_mm_table
**      EXPORTING
**        iv_string = lv_string
**        iv_tdid   = zif_mfp_constants=>gc_header_text-po-alt_tc_cond
***       iv_item   =
**      CHANGING
**        rt_texts  = gt_poheadertext.

    me->zif_myfi_document~new_strings = lt_strings.

  ENDMETHOD.


  METHOD zif_myfi_document~out_account_assignment ##NEEDED.
  ENDMETHOD.


  METHOD zif_myfi_document~out_header.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_DOCUMENT_PO~zif_myfi_document~out_header
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for MyFi Documents
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
* 30.11.20 220977FKC RD2K920449 DS-11-32-07-01 6000002172: MyFi Purchasing (Release 2.3)
*                                              Enable legacy i.e. non-myfi created docs
* 03/03/21 210983DY  RD2K920554 DS-11-32-07-01 S 6000002250: MyFi Purchasing (Release 2.4 )
*                               Additional code for PO close flag
* 04.08.21 210983DY RD2K921440  DS-11-32-07-01 S6000002451: MyFi Purchasing (August Release)
*                               Enable Your reference field in MyFi Purchasing
* 18.08.22 210983DY RD2K923033 DS-11-32-07-01 S 6000002805: MyFi Continuous Improvement September Release
*                   Condition to fill data based on $expand option
* 14.03.2024 210983DY RD2K924772    6000003112: MyFi Continuous Improvement Release 2024
*                 Amended logic for new Prepayment and FMS field changes
*-----------------------------------------------------------------------
    me->map_bapi_2_odata(
      EXPORTING
        is_sending_structure   = gs_poheader
      IMPORTING
        es_data                = gs_po_deep
    ).

    CHECK gv_consumption_only IS INITIAL.
    gs_po_deep-ihrez = gs_poheader-ref_1.
    SELECT SINGLE name1 FROM lfa1 INTO gs_po_deep-vendorname WHERE lifnr = gs_po_deep-vendor.

    CASE me->gv_doc_type.
      WHEN zif_mfp_constants=>gc_myfi_doc_type-l4l_po.
        gs_po_deep-issinglepo = abap_true.
      WHEN OTHERS.
    ENDCASE.
    IF me->zif_myfi_document~old_doc_header-status IS INITIAL.
      me->zif_myfi_document~old_doc_header-status = zcl_mfp_utilities=>translate_mm_status_to_mfp( gs_poheader-po_rel_ind ).
    ENDIF.
    gs_po_deep-status = me->zif_myfi_document~old_doc_header-status.
    gs_po_deep-statusdesclong = gs_po_deep-statusdesc
                              = zcl_mfp_utilities=>get_status_desc( iv_status = me->zif_myfi_document~old_doc_header-status ).

    IF gs_po_deep-agreement IS NOT INITIAL.
      gs_po_deep-iscopyable = is_po_copyable( iv_oa_doc = gs_po_deep-agreement ).
    ENDIF.

    gs_po_deep-isprepaymentexempt = zcl_mfp_utilities=>is_vendor_prepymnt_exempt( iv_lifnr = gs_po_deep-vendor ).
* Default iscloseable to True
    gs_po_deep-iscloseable = abap_true.

  ENDMETHOD.


  METHOD zif_myfi_document~out_line_items.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_DOCUMENT_PO~zif_myfi_document~out_line_items
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for MyFi Documents
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
* 07.09.20 290977SCN RD2K919977 DS-11-32-07-01 Changed - non-delete flag
* 21.10.20 290977SCN RD2K919656 DS-11-32-07-01 S 6000002172: MyFi Purchasing (Release 2.3) Changed - UOM Changeable Flag
* 30.11.20 220977FKC RD2K920449 DS-11-32-07-01 6000002172: MyFi Purchasing (Release 2.3)
*                                              Enable legacy i.e. non-myfi created docs
* 30/11/20 210983DY  RD2K919656 DS-11-32-07-01 S 6000002172: MyFi Purchasing (Release 2.3)
*                               Additional code for Item Texts and Free Item
* 14/01/21 210983DY  RD2K920558 DS-11-32-07-01 S 6000002251: MyFi Purchasing (Release 2.3 Defect Fixes)
*                               Additional code to fix Line Item Texts with line break
* 03/03/21 210983DY  RD2K920554 DS-11-32-07-01 S 6000002250: MyFi Purchasing (Release 2.4 )
*                               Additional code to handle Multi delivery address
*10/06/21 210983DY  RD2K921224  DS-11-32-07-01 S 6000002393: June DFSS release for MyFi Purchasing
*                               Additional logic to ignore deleted PO line item value
* 04.08.21 210983DY RD2K921440  DS-11-32-07-01 S6000002451: MyFi Purchasing (August Release)
* 26.08.21 210983DY RD2K921634 DS-11-32-07-01 S 6000002507: MyFi Continuous Improvement
* 20.09.21 210983DY RD2K921837 DS-11-32-07-01 S 4500000052: MyFi Purchasing – Delivery Date (Defect)
* 05/11/21 210983DY  RD2K922034 DS-11-32-07-01 S6000002550: MyFi Applications (December Release)
*                    Additional code to enable Multi Account Assignment
* 29/03/22 210983DY RD2K922546  DS-11-32-07-01 S 6000002692: MyFi Applications (May Release)
*                              Additional Logic to handle Returns Item for PO
* 18.08.22 210983DY RD2K923033 DS-11-32-07-01 S 6000002805: MyFi Continuous Improvement September Release
*                   Condition to fill data based on $expand option
* 20.10.2022 210983DY RD2K923161
*                     RD2K923261  6000002831: MyFi Continuous Improvement November Release
*                        Amended logic to fix issue with Close Document
* 18.12.2023 210983DY RD2K924523  6000003043 MyFi Continuous Improvement February Release
*        amended logic to fix issue with net price
* 14.03.2024 210983DY RD2K924772    6000003112: MyFi Continuous Improvement Release 2024
*                 Amended logic for new Prepayment and FMS field changes
* 30.04.2024 210983DY RD2K924953    6000003126: MyFi Fix
*         Amended logic to fix issue with Prepayment fields
*-----------------------------------------------------------------------
    DATA:
      ls_lineitem          TYPE bapimepoitem,
      ls_odata_lineitem    TYPE zcl_zedm_mfp_mpc=>ts_lineitem,
      lt_odata_lineitems   TYPE TABLE OF zcl_zedm_mfp_mpc=>ts_lineitem WITH DEFAULT KEY,
      ls_odata_phasing     TYPE zcl_zedm_mfp_mpc=>ts_phasing,
      ls_odata_assignments TYPE zcl_zedm_mfp_mpc=>ts_accountassignment,
      lt_odata_phasing     TYPE TABLE OF zcl_zedm_mfp_mpc=>ts_phasing,
      lt_odata_assignments TYPE TABLE OF zcl_zedm_mfp_mpc=>ts_accountassignment,
      ls_deliveryaddress   TYPE zcl_zedm_mfp_mpc=>ts_deliveryaddress,
      lt_deliveryaddress   TYPE TABLE OF zcl_zedm_mfp_mpc=>ts_deliveryaddress,
      lt_ekkn              TYPE STANDARD TABLE OF ekkn,
      ls_ekkn              TYPE ekkn,
      ls_old_prepmnts      TYPE ztmfp_prepmnt,
      lv_timestamp         TYPE timestampl,
      lv_item              TYPE ebelp,
      lt_ekbe              TYPE bapiekbe_tp,
      ls_ekbe              TYPE bapiekbe,
      lt_ekbe_item         TYPE bapiekbe_tp,
      ls_po_summary        TYPE zcl_zedm_mfp_mpc=>ts_consumptionsummary,
      lv_gr_qty            TYPE menge_d,
      lv_ir_qty            TYPE menge_d,
      lv_gross_amt         TYPE /bcv/sin_dec16_3,
      lv_po_close          TYPE boole,
      lv_multi_acc         TYPE boole_d.

* Get account assignment for the ourchasing document

    SELECT *
      FROM ekkn
      INTO TABLE @DATA(lt_account_assignments)
     WHERE ebeln = @me->gs_po_deep-po_number.

    LOOP AT lt_account_assignments INTO DATA(ls_account_assignment).
      ls_odata_assignments-parentnumber = ls_account_assignment-ebeln.
      ls_odata_assignments-linenumber = ls_account_assignment-ebelp.
      ls_odata_assignments-assignment_item = ls_account_assignment-zekkn.
      ls_odata_assignments-isdeleted = ls_account_assignment-loekz.
      ls_odata_assignments-quantity = ls_account_assignment-menge.
      ls_odata_assignments-amount = ls_account_assignment-netwr.
      ls_odata_assignments-vproz = ls_account_assignment-vproz.
      ls_odata_assignments-gl_account = ls_account_assignment-sakto.
      ls_odata_assignments-costcenter = ls_account_assignment-kostl.
      ls_odata_assignments-fund = ls_account_assignment-geber.
      ls_odata_assignments-asset_no = ls_account_assignment-anln1.
      ls_odata_assignments-sub_number = ls_account_assignment-anln2.
      ls_odata_assignments-wbs_element = ls_account_assignment-ps_psp_pnr.
      ls_odata_assignments-orderid = ls_account_assignment-aufnr.
      APPEND ls_odata_assignments TO lt_odata_assignments.
      CLEAR ls_odata_assignments.
    ENDLOOP.

* Read the EKKN account assignment data to get the ESP field
    SELECT *
      FROM ekkn
      INTO TABLE lt_ekkn
     WHERE ebeln = me->gs_po_deep-po_number
       AND zekkn = '01'.  " Only get the first account assignment row as the app only handles one Acct Assignment

    lv_po_close = abap_true. " default to True

* Delivary address: only want the first one from a non-deleted item line
* note currently does not handle/display multiple delivary addresses so
* read/update the first one only!
    SORT gt_poitems BY po_item.
    LOOP AT gt_poitems INTO ls_lineitem
    WHERE delete_ind IS INITIAL.
      DATA(lt_poaddrdelivery) = gt_poaddrdelivery.
      DELETE lt_poaddrdelivery WHERE po_item <> ls_lineitem-po_item.
      IF NOT lt_poaddrdelivery IS INITIAL.
        gv_invoice_contact_email = gs_po_deep-contactdetails-invoicecontactemail = lt_poaddrdelivery[ 1 ]-adr_notes.
        gs_po_deep-contactdetails-invoicecontactemail = gs_po_deep-contactdetails-invoicecontactemail = lt_poaddrdelivery[ 1 ]-adr_notes.
        DATA(lv_address) = lt_poaddrdelivery[ 1 ]-addr_no.
      ENDIF.
      EXIT.
    ENDLOOP.

*    Check for multi account assignment
    LOOP AT gt_poitems INTO DATA(ls_items_multiacc) WHERE distrib IS NOT INITIAL.
      lv_multi_acc = abap_true.
      EXIT.
    ENDLOOP.

    gs_po_deep-issameaddressforall = abap_true.
    LOOP AT gt_poaddrdelivery INTO DATA(ls_address).
      IF ls_address-addr_no NE lv_address.
        gs_po_deep-issameaddressforall = abap_false.
        EXIT.
      ENDIF.
    ENDLOOP.

    DATA: lt_ekpo TYPE TABLE OF ekpo.
    lt_ekpo = me->zif_myfi_document~old_ekpo.
    DELETE lt_ekpo WHERE adrn2 IS INITIAL.

    IF NOT lt_ekpo IS INITIAL AND gv_consumption_only IS INITIAL.
      SELECT * FROM adrc INTO TABLE @DATA(lt_adrc) FOR ALL ENTRIES IN @lt_ekpo WHERE addrnumber = @lt_ekpo-adrn2.
      IF sy-subrc IS INITIAL.
        SELECT * FROM adrct INTO TABLE @DATA(lt_adrc_email) FOR ALL ENTRIES IN @lt_adrc WHERE addrnumber = @lt_adrc-addrnumber.
      ENDIF.
    ENDIF.


    SELECT ebeln, ebelp, etenr, menge, wemng FROM eket INTO TABLE @DATA(lt_eket)
      WHERE ebeln =  @me->gs_po_deep-po_number.

    IF sy-subrc IS INITIAL. SORT lt_eket BY ebeln ebelp.ENDIF.


* Process line items:
    LOOP AT gt_poitems INTO ls_lineitem.
      IF ls_lineitem-ret_item = abap_true.
        ls_lineitem-quantity = ls_lineitem-quantity * -1.
      ENDIF.
      me->map_bapi_2_odata(
        EXPORTING
          is_sending_structure   = ls_lineitem
        IMPORTING
          es_data                = ls_odata_lineitem
      ).
      IF ls_lineitem-distrib IS INITIAL.
        ls_odata_lineitem-distrib = '0'..
      ELSE.
        ls_odata_lineitem-distrib = ls_lineitem-distrib.
      ENDIF.
      IF ls_lineitem-ret_item = abap_true.
        ls_odata_lineitem-isreturn = abap_true.
      ENDIF.


      ls_odata_lineitem-part_inv = ls_lineitem-part_inv.

      IF NOT ls_lineitem-trackingno IS INITIAL.
        ls_odata_lineitem-trackingno = ls_lineitem-trackingno.
      ENDIF.

      IF NOT ls_lineitem-vend_mat IS INITIAL.
        ls_odata_lineitem-vendormaterial = ls_lineitem-vend_mat.
      ENDIF.

      ls_odata_lineitem-isgr = ls_lineitem-gr_ind.
      IF ls_lineitem-free_item = abap_true.
        ls_odata_lineitem-zerovalue = abap_true.
        ls_odata_lineitem-net_price = '0.00'.

      ENDIF.

*      READ TABLE gt_poaccounts WITH KEY po_item = ls_lineitem-po_item INTO DATA(ls_account).
*      IF sy-subrc IS INITIAL.
*        me->map_bapi_2_odata(
*          EXPORTING
*            is_sending_structure   = ls_account
*          IMPORTING
*            es_data                = ls_odata_lineitem
*        ). ENDIF.

      ls_odata_lineitem-net_price = ls_odata_lineitem-price_unit * ls_odata_lineitem-target_qty.

**      IF ls_lineitem-ret_item = abap_true.
**        ls_odata_lineitem-net_price = ls_odata_lineitem-net_price * -1.
**      ENDIF.

      SELECT SINGLE mseh3 FROM  t006a
       WHERE  spras  = 'E'
       AND    msehi  = @ls_lineitem-orderpr_un
       INTO @ls_odata_lineitem-po_unit.

* ESP
      READ TABLE lt_ekkn INTO ls_ekkn
        WITH KEY ebelp = ls_lineitem-po_item.

      IF sy-subrc = 0.
        ls_odata_lineitem-esp = ls_ekkn-zzesp.
      ENDIF.

* UOM Changeable
      ls_odata_lineitem-uom_changeable = abap_false.

*      get_quantity_left( CHANGING is_odata_lineitem = ls_odata_lineitem ).
      ls_odata_lineitem-parentnumber = gs_po_deep-po_number.

      READ TABLE lt_ekpo INTO DATA(ls_ekpo) WITH KEY ebelp = ls_lineitem-po_item.
      IF sy-subrc IS INITIAL.
        READ TABLE lt_adrc INTO DATA(ls_adrc) WITH KEY addrnumber = ls_ekpo-adrn2.

        ls_deliveryaddress-newaddressname = ls_adrc-name1.

        CALL FUNCTION 'CONVERSION_EXIT_ALPHA_OUTPUT'
          EXPORTING
            input  = ls_lineitem-po_item
          IMPORTING
            output = ls_deliveryaddress-linenumber.
*        ls_deliveryaddress-linenumber = ls_lineitem-po_item.
        ls_deliveryaddress-newaddressstreet = ls_adrc-street.
        ls_deliveryaddress-newaddresscity = ls_adrc-city1.
        ls_deliveryaddress-newaddresspostcode = ls_adrc-post_code1.
        ls_deliveryaddress-newaddresscountry = ls_adrc-country.
        ls_deliveryaddress-newaddressregion = ls_adrc-region.
        ls_deliveryaddress-romanaddresscode = ls_adrc-addrnumber.

        READ TABLE lt_adrc_email INTO DATA(ls_adrc_email) WITH KEY addrnumber = ls_adrc-addrnumber.
        IF sy-subrc IS INITIAL.
          ls_deliveryaddress-invoicecontactemail = ls_adrc_email-remark.
        ENDIF.
      ENDIF.
      IF ls_deliveryaddress IS INITIAL.
        READ TABLE gt_poaddrdelivery INTO DATA(ls_delivery) WITH KEY po_item = ls_lineitem-po_item.

        IF ls_delivery IS NOT INITIAL.

          me->map_bapi_2_odata(
            EXPORTING
              is_sending_structure   = ls_delivery
            IMPORTING
              es_data                = ls_deliveryaddress ).
        ENDIF.

      ENDIF.
      IF ls_deliveryaddress-pickuplocation IS INITIAL.
        ls_deliveryaddress-pickuplocation = convert_mm_table_string(
                                                                   it_texts = gt_potextitems
                                                                   iv_tdid  = zif_mfp_constants=>gc_header_text-po-item-delivery "'F04'
                                                                   iv_item = ls_lineitem-po_item
                                                                   ).
      ENDIF.
      IF ls_deliveryaddress-pickuplocation IS NOT INITIAL.
        ls_deliveryaddress-deliverytype = zif_mfp_constants=>gc_address_types-pickup.   "'Pickup'
* Delivery addresses - if pickup location is populated, there should be no data in the gt_poaddrdelivery table except for the invoice approver email
        READ TABLE gt_poaddrdelivery WITH KEY po_item = ls_lineitem-po_item INTO DATA(ls_podelivery_addr).
        ls_deliveryaddress-invoicecontactemail = ls_podelivery_addr-adr_notes.
*          gs_po_deep-contactdetails-invoicecontactemail = ls_podelivery_addr-adr_notes. " R 2.4 Invoice Contact email is moved to Contact details tab
        " pass email address to global variable to handle change of email address
*          gv_invoice_contact_email = ls_podelivery_addr-adr_notes.
        ls_deliveryaddress-newaddressname = ls_podelivery_addr-name.
        ls_deliveryaddress-newaddressstreet = ls_podelivery_addr-street.
        ls_deliveryaddress-newaddresscity = ls_podelivery_addr-city.
        ls_deliveryaddress-newaddresspostcode = ls_podelivery_addr-postl_cod1.
        ls_deliveryaddress-newaddresscountry = ls_podelivery_addr-country.
        ls_deliveryaddress-newaddressregion = ls_podelivery_addr-region.
*        gs_po_deep-deliveryaddresses-specialinstructions = ls_podelivery_addr-name.
        ls_deliveryaddress-romanaddresscode = ls_podelivery_addr-addr_no.
* When address number is found, populate deliverytype with romancode
        IF NOT ls_deliveryaddress-romanaddresscode IS INITIAL.
          ls_deliveryaddress-deliverytype = zif_mfp_constants=>gc_address_types-romancode.
        ENDIF.
      ELSE.
        ls_deliveryaddress-deliverytype = zif_mfp_constants=>gc_address_types-romancode.
      ENDIF.

      APPEND ls_deliveryaddress TO lt_deliveryaddress.
      CLEAR ls_deliveryaddress.


      lv_item = ls_odata_lineitem-linenumber.
* Item text
      ls_odata_lineitem-itemtext = convert_mm_table_string( EXPORTING it_texts  = gt_potextitems iv_item = lv_item
                                                                                     iv_tdid   = zif_mfp_constants=>gc_header_text-po-item-text ).

      ls_odata_lineitem-inforecordpotext = convert_mm_table_string( EXPORTING it_texts  = gt_potextitems iv_item = lv_item
                                                                                   iv_tdid   = zif_mfp_constants=>gc_header_text-po-item-info_record ).

      ls_odata_lineitem-materialpotext =   convert_mm_table_string( EXPORTING it_texts  = gt_potextitems iv_item = lv_item
                                                                                        iv_tdid   = zif_mfp_constants=>gc_header_text-po-item-mat_po ).

      ls_odata_lineitem-infonote = convert_mm_table_string( EXPORTING it_texts  = gt_potextitems iv_item = lv_item
                                                                                        iv_tdid   = zif_mfp_constants=>gc_header_text-po-item-note ).

      ls_odata_lineitem-inforecordnote = convert_mm_table_string( EXPORTING it_texts  = gt_potextitems iv_item = lv_item
                                                                                        iv_tdid   = zif_mfp_constants=>gc_header_text-po-item-info_note ).
*** Phasings
**      LOOP AT gt_poschedules INTO DATA(ls_schedule) WHERE po_item EQ ls_lineitem-po_item.
**        me->map_bapi_2_odata(
**          EXPORTING
**            is_sending_structure = ls_schedule
**          IMPORTING
**            es_data              = ls_odata_phasing
**        ).
**
**        ls_odata_phasing-short_text = ls_odata_lineitem-short_text.
**        ls_odata_phasing-parentnumber = gs_po_deep-po_number.
**
**        IF ls_lineitem-gr_ind = abap_true.
**
**
**          READ TABLE lt_eket INTO DATA(ls_eket) WITH KEY ebeln = me->gs_po_deep-po_number
**                                                        ebelp = ls_schedule-po_item
**                                                        etenr = ls_schedule-sched_line.
**          IF sy-subrc IS INITIAL.
**            ls_odata_phasing-qtydelivered = ls_eket-wemng. "ls_odata_phasing-quantity - ls_eket-wemng.
**          ENDIF.
**
**        ENDIF.
**        APPEND ls_odata_phasing TO lt_odata_phasing.
**
**        IF ls_odata_lineitem-deliverydate IS INITIAL OR ls_odata_lineitem-deliverydate GT ls_odata_phasing-delivery_date .
**          ls_odata_lineitem-deliverydate = ls_odata_phasing-delivery_date.
**        ENDIF.
**        CLEAR ls_odata_phasing.
**      ENDLOOP.
**      gs_po_deep-phasings = lt_odata_phasing.
***      gs_po_deep-accountassignments = lt_odata_assignments.
**      gs_po_deep-deliveryaddresses = lt_deliveryaddress.

* Prepayments
      CLEAR ls_old_prepmnts.

      READ TABLE me->zif_myfi_document~old_prepmnts
            INTO ls_old_prepmnts
            WITH KEY zmfp_doc_id = gs_po_deep-po_number
                     linenumber = ls_lineitem-po_item.

      IF ls_old_prepmnts IS NOT INITIAL.

        IF ls_old_prepmnts-prepaymentcompleteddate IS NOT INITIAL.
          CONVERT DATE ls_old_prepmnts-prepaymentcompleteddate INTO TIME STAMP lv_timestamp TIME ZONE 'UTC'.
          ls_odata_lineitem-prepaymentcompleteddate = lv_timestamp.
        ENDIF.
        ls_odata_lineitem-purchasetype = ls_old_prepmnts-purchasetype.

      ENDIF.
*        ls_odata_lineitem-isprepayment = ls_old_prepmnts-isprepayment.
*        ls_odata_lineitem-isstraightline = ls_old_prepmnts-isstraightline.

      ls_odata_lineitem-isprepayment = SWITCH #( ls_old_prepmnts-isprepayment
            WHEN 'X' THEN 'Y'
            WHEN 'Y' THEN 'Y'
            WHEN 'N' THEN 'N'
            WHEN ' ' THEN 'N' ).
      ls_odata_lineitem-isstraightline = SWITCH #( ls_old_prepmnts-isstraightline
            WHEN 'X' THEN 'Y'
            WHEN 'Y' THEN 'Y'
            WHEN 'N' THEN 'N'
            WHEN ' ' THEN 'N' ).


      ls_odata_lineitem-currency = gs_po_deep-currency.
      ls_odata_lineitem-non_delete = zcl_mfp_utilities=>is_non_deleteable_line(
                                      it_po_history_totals = me->gt_pohistory_totals
                                      iv_ebelp             = ls_lineitem-po_item ).

      IF ls_lineitem-delete_ind IS INITIAL.

        lv_gross_amt = zcl_mfp_utilities=>get_line_total(
                             iv_currency  = gs_po_deep-currency
                             iv_comp_code = gs_po_deep-comp_code
                             iv_net_amt   = ls_odata_lineitem-net_price
                             iv_tax_code  = ls_odata_lineitem-tax_code ).

      ENDIF.

      gs_po_deep-totalvalue = gs_po_deep-totalvalue + lv_gross_amt.
      CLEAR : lv_gross_amt.

*  Is POItem Closable

      lt_ekbe_item = me->gt_pohistory.
      DELETE lt_ekbe_item WHERE po_item NE  ls_odata_lineitem-linenumber.


      LOOP AT me->gt_pohistory INTO ls_ekbe WHERE po_item EQ ls_odata_lineitem-linenumber.

        CASE ls_ekbe-process_id.
          WHEN zif_mfp_constants=>gc_grir-gr.
            IF ls_ekbe-db_cr_ind EQ 'H'.
              ls_ekbe-quantity = ls_ekbe-quantity * -1.
            ENDIF.
            lv_gr_qty = lv_gr_qty + ls_ekbe-quantity.

          WHEN zif_mfp_constants=>gc_grir-ir.
            IF ls_ekbe-db_cr_ind EQ 'H'.
              ls_ekbe-quantity = ls_ekbe-quantity * -1.
            ENDIF.
            lv_ir_qty = lv_ir_qty + ls_ekbe-quantity.

          WHEN OTHERS.

        ENDCASE.
      ENDLOOP.

* Phasings
      LOOP AT gt_poschedules INTO DATA(ls_schedule) WHERE po_item EQ ls_lineitem-po_item.
        me->map_bapi_2_odata(
          EXPORTING
            is_sending_structure = ls_schedule
          IMPORTING
            es_data              = ls_odata_phasing
        ).

        ls_odata_phasing-short_text = ls_odata_lineitem-short_text.
        ls_odata_phasing-parentnumber = gs_po_deep-po_number.

        IF ls_lineitem-gr_ind = abap_true.


          READ TABLE lt_eket INTO DATA(ls_eket) WITH KEY ebeln = me->gs_po_deep-po_number
                                                        ebelp = ls_schedule-po_item
                                                        etenr = ls_schedule-sched_line.
          IF sy-subrc IS INITIAL.
            ls_odata_phasing-qtydelivered = ls_eket-wemng. "ls_odata_phasing-quantity - ls_eket-wemng.
          ENDIF.
        ELSE.
*          IF ls_odata_phasing-sched_line EQ '1'.
*            ls_odata_phasing-qtyinvoiced = lv_ir_qty.
*          ELSE.
*            CONTINUE.
*          ENDIF.

        ENDIF.
        APPEND ls_odata_phasing TO lt_odata_phasing.

        IF ls_odata_lineitem-deliverydate IS INITIAL OR ls_odata_lineitem-deliverydate GT ls_odata_phasing-delivery_date .
          ls_odata_lineitem-deliverydate = ls_odata_phasing-delivery_date.
        ENDIF.
        CLEAR ls_odata_phasing.
      ENDLOOP.
      gs_po_deep-phasings = lt_odata_phasing.
*      gs_po_deep-accountassignments = lt_odata_assignments.
      gs_po_deep-deliveryaddresses = lt_deliveryaddress.


* For line item where gr indicator flag is turned off
*      IF ls_lineitem-gr_ind = abap_false.
*
*        IF ls_odata_lineitem-target_qty = '0' AND lv_ir_qty = '0'.
*          ls_odata_lineitem-iscloseable = abap_false.
*          lv_po_close = abap_false.
*        ELSEIF ls_odata_lineitem-target_qty = lv_ir_qty.
*          ls_odata_lineitem-iscloseable = abap_true.
*        ELSE.
*          ls_odata_lineitem-iscloseable = abap_false.
*          lv_po_close = abap_false.
*        ENDIF.
*
*      ELSE.

*      ENDIF.

* For document with Multi account assignment, CLose function is not available
*      IF lv_multi_acc = abap_true.
*        ls_odata_lineitem-iscloseable = abap_false.
*        lv_po_close = abap_false.
*      ELSE.
*        IF me->gt_pohistory IS INITIAL.
      READ TABLE me->gt_pohistory INTO DATA(ls_history) WITH KEY po_item = ls_odata_lineitem-linenumber.
      IF NOT sy-subrc IS INITIAL.
        ls_odata_lineitem-iscloseable = abap_false.

*          lv_po_close = abap_true.
      ELSE.
        IF ls_lineitem-gr_ind = abap_true.
          IF lv_gr_qty = lv_ir_qty.
            ls_odata_lineitem-iscloseable = abap_true.
*              lv_po_close = abap_true.
          ELSE.
            ls_odata_lineitem-iscloseable = abap_false.
            lv_po_close = abap_false.
*              data(lv_po_doc_close) = abap_false.
          ENDIF.
        ELSE.
          ls_odata_lineitem-iscloseable = abap_true.
*            lv_po_close = abap_true.
        ENDIF.
      ENDIF.
*      ENDIF.



      ls_odata_lineitem-itemqtyleft = lv_gr_qty.
      ls_odata_lineitem-qty_invoiced = lv_ir_qty.
      ls_odata_lineitem-exchrate_budget = gs_po_deep-exch_rate.
      APPEND ls_odata_lineitem TO lt_odata_lineitems.
      CLEAR : ls_odata_lineitem, lv_gr_qty, lv_ir_qty.
    ENDLOOP.
    gs_po_deep-purchaseorderlis = lt_odata_lineitems.
    gs_po_deep-iscloseable = lv_po_close.
*    gs_po_deep-iscloseable = lv_po_doc_close.


  ENDMETHOD.


  METHOD zif_myfi_document~out_strings.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_DOCUMENT_PO~zif_myfi_document~out_strings
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for MyFi Documents
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
* 03/03/21 210983DY  RD2K920554 DS-11-32-07-01 S 6000002250: MyFi Purchasing (Release 2.4 )
*                               Additional code to handle Multi delivery address
*-----------------------------------------------------------------------
    DATA: ls_string TYPE string.

    FIELD-SYMBOLS <string_record> LIKE LINE OF me->zif_myfi_document~old_strings.

* Header Note
    me->gs_po_deep-headertexts-headernote = convert_mm_table_string( EXPORTING it_texts  = gt_poheadertext
                                                                               iv_tdid   = zif_mfp_constants=>gc_header_text-po-note ).
*Contract Riders
    me->gs_po_deep-headertexts-contractriders = convert_mm_table_string( EXPORTING it_texts  = gt_poheadertext
                                                                               iv_tdid   = zif_mfp_constants=>gc_header_text-po-riders ).
* Alternate Terms and Conditions Flag
    DATA(lv_alternatetc) = convert_mm_table_string( EXPORTING it_texts  = gt_poheadertext
                                                                               iv_tdid   = zif_mfp_constants=>gc_header_text-po-alt_tc_cond ).

    IF lv_alternatetc IS INITIAL.
      me->gs_po_deep-headertexts-alternatetc = abap_false.
    ELSE.
      me->gs_po_deep-headertexts-alternatetc = abap_true.
    ENDIF.

    me->gs_po_deep-romancomment = convert_mm_table_string( EXPORTING it_texts  = gt_poheadertext
                                                                     iv_tdid   = zif_mfp_constants=>gc_header_text-po-header ).

      gs_po_deep-contactdetails-specialinstructions = convert_mm_table_string( EXPORTING it_texts  = gt_poheadertext
                                                                     iv_tdid   = zif_mfp_constants=>gc_header_text-po-delivery ).

    me->gs_po_deep-sonid = convert_mm_table_string( EXPORTING it_texts  = gt_poheadertext
                                                                     iv_tdid   = zif_mfp_constants=>gc_header_text-po-sonid ).


* Retrieve the strings table data from the me->zif_myfi_document~old_strings variable.
    LOOP AT me->zif_myfi_document~old_strings ASSIGNING <string_record>.

      CASE <string_record>-string_type.
        WHEN zif_mfp_constants=>gc_string_type-value_for_money.
          me->gs_po_deep-approvaldetails-valueformoney = <string_record>-string_data.
        WHEN zif_mfp_constants=>gc_string_type-comment_approver.
          me->gs_po_deep-approvaldetails-commentforapprover = <string_record>-string_data.
        WHEN zif_mfp_constants=>gc_string_type-reject_comment.
          me->gs_po_deep-approvaldetails-rejectcomments = <string_record>-string_data.
*        WHEN zif_mfp_constants=>gc_string_type-pickup_loc.
*          me->gs_po_deep-deliveryaddresses-pickuplocation = <string_record>-string_data.
*        WHEN zif_mfp_constants=>gc_string_type-spec_instr.
*          me->gs_po_deep-deliveryaddresses-specialinstructions = <string_record>-string_data.
      ENDCASE.

    ENDLOOP.


  ENDMETHOD.


  METHOD zif_myfi_document~reassign_doc ##NEEDED.
  ENDMETHOD.


  METHOD zif_myfi_document~save_draft.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_DOCUMENT_PO~zif_myfi_document~save_draft
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for MyFi Documents
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
* 18.12.2023 210983DY RD2K924523  6000003043 MyFi Continuous Improvement February Release
*          Stop auto deletion of draft documents
*-----------------------------------------------------------------------
    DATA: lv_event_success TYPE boole_d.
    me->gv_draft_indicator = abap_true.
    IF gs_po_deep-po_number IS INITIAL.
      gs_po_deep-po_number = gs_po_deep-requestid = zcl_mfp_utilities=>get_next_request_num( ) .
    ENDIF.
    me->zif_myfi_document~posting_doc_num = gs_po_deep-po_number.
    me->create_new_doc_header( iv_status = zif_mfp_constants=>gc_doc_status-draft ).
    gs_po_deep-status = zif_mfp_constants=>gc_doc_status-draft.
    gs_po_deep-statusdesc = zcl_mfp_utilities=>get_status_desc( iv_status = zif_mfp_constants=>gc_doc_status-draft ).
    gs_po_deep-statusdesclong = zcl_mfp_utilities=>get_status_desc( iv_status = zif_mfp_constants=>gc_doc_status-draft ).
    in_prepmnt_line( ).
    me->zif_myfi_document~new_doc_header-selected_delegate = gs_po_deep-approvaldetails-delegateid.
    me->zif_myfi_document~new_doc_header-section23 = gs_po_deep-approvaldetails-issection23.
    MOVE-CORRESPONDING gs_po_deep-contactdetails TO me->zif_myfi_document~new_doc_header.
*    me->zif_myfi_document~handle_odata( ).
    IF gs_po_deep-draftassigneeid IS NOT INITIAL.
      CALL METHOD me->assign_document
        EXPORTING
          iv_assignee = gs_po_deep-draftassigneeid.
    ENDIF.
    super->zif_myfi_document~save_draft( ).
*    IF me->zif_myfi_document~new_doc_header-category NE zif_mfp_constants=>gc_myfi_doc_type-l4l_po.
*      CALL METHOD zcl_mfp_po=>create_event
*        EXPORTING
*          iv_ebeln        = me->zif_myfi_document~posting_doc_num
*          iv_event        = zif_mfp_constants=>gc_event-draft
*        IMPORTING
*          ev_event_raised = lv_event_success.
*
*      IF lv_event_success = abap_true.
*        CALL METHOD zcl_mfp_utilities=>log_myfi_event
*          EXPORTING
*            iv_doc_number = me->zif_myfi_document~posting_doc_num
*            iv_user_id    = sy-uname
*            iv_sub_obj    = zif_mfp_constants=>gc_log-sub_obj-wf-draft.
*      ENDIF.
*    ENDIF.
  ENDMETHOD.


  METHOD zif_myfi_document~validate.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_DOCUMENT_PO~zif_myfi_document~validate
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for MyFi Documents
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
* 21.10.20 290977SCN RD2K919656 DS-11-32-07-01 S 6000002172: MyFi Purchasing (Release 2.3)
* 03/03/21 210983DY  RD2K920554 DS-11-32-07-01 S 6000002250: MyFi Purchasing (Release 2.4 )
*                               Additional code to validate invoice approver email
* 26.08.21 210983DY RD2K921634 DS-11-32-07-01 S 6000002507: MyFi Continuous Improvement
* 29.11.21 210983DY RD2K922223 DS-11-32-07-01 S 6000002550: MyFi Applications (December Release)
* 06/07/22 210983DY  RD2K922923 DS-11-32-07-01 S6000002777:MyFi Continuous Improvement
*                                              August Release - PO Currency validation
* 18.08.22 210983DY RD2K923033 DS-11-32-07-01 S 6000002805: MyFi Continuous Improvement September Release
*                              Remove validation for 5 day payment terms
* 10/01/23  210983DY RD2K923348
*                    RD2K923485 S 6000002854: MyFi Continuous Improvement December Rel
*          Additional logic to handle Account assignment validation for locked objects
* 03.03.2023 210983DY  RD2K923630,RD2K923771 6000002898 MyFi Continuous Improvement April Release
*                    Additional code for toggle of delivery address
* 03/07/2023 210983DY RD2K923919 6000002957 MyFi Continuous Improvement -
*    Amend logic to validate document currency against Vendor currency
* 10/10/23 210983DY RD2K924373 DS-11-32-07-01 6000003027: MyFi Continuous Improvement November Rel
*           Additional logic to validate agsinst cost objects of ASA Program
*-----------------------------------------------------------------------
    DATA: ls_header         TYPE bapimepoheader,
          ls_headerx        TYPE bapimepoheaderx,
          ls_header_ret     TYPE bapimepoheader,
          lt_return         TYPE TABLE OF bapiret2,
          lv_amtcheck       TYPE p LENGTH 9 DECIMALS 3,
          new_ekko          TYPE ekko,
          new_ekpo          TYPE me_ekpo,
          new_ekkn          TYPE me_ekkn,
          lv_error          TYPE boole_d,
          lt_cc_assignments TYPE zsfss_mfp_asa_cc_tt,
          ls_return         TYPE bapiret2.



    me->zif_myfi_document~handle_odata( ).
    super->zif_myfi_document~validate( ).

    new_ekpo = bapi_2_ekpo( it_bapiitem = gt_poitems ).
    me->zif_myfi_document~old_ekpo = get_ekpo( iv_ebeln = me->zif_myfi_document~source_doc_num ).

    new_ekkn = bapi_2_ekkn( it_bapimepoaccount = gt_poaccounts it_bapiparex = gt_extension ).
    me->zif_myfi_document~old_ekkn = get_ekkn( iv_ebeln = me->zif_myfi_document~source_doc_num ).

* Raise Error message if Line item is changed and Marked for deletion
* This check is introduced to stop Update Cancellation Error from BAPI
    LOOP AT new_ekpo INTO DATA(ls_new_ekpo) WHERE loekz = 'L'.

      READ TABLE me->zif_myfi_document~old_ekpo INTO DATA(ls_ekpo_old) WITH KEY ebelp = ls_new_ekpo-ebelp.
      IF sy-subrc IS INITIAL AND NOT ls_ekpo_old-loekz = 'L'.
        CLEAR : ls_new_ekpo-loekz, ls_ekpo_old-aedat, ls_ekpo_old-ebeln, ls_ekpo_old-mandt.
        IF ls_new_ekpo-werks NE ls_ekpo_old-werks OR
           ls_new_ekpo-matkl NE ls_ekpo_old-matkl OR
           ls_new_ekpo-ktmng NE ls_ekpo_old-ktmng OR
           ls_new_ekpo-menge NE ls_ekpo_old-menge OR
           ls_new_ekpo-meins NE ls_ekpo_old-meins OR
           ls_new_ekpo-bprme NE ls_ekpo_old-bprme OR
           ls_new_ekpo-mwskz NE ls_ekpo_old-mwskz OR
           ls_new_ekpo-knttp NE ls_ekpo_old-knttp.
          MESSAGE e105(zmfp) INTO ls_return-message WITH ls_new_ekpo-ebelp.
          ls_return-type = 'E'.
          APPEND ls_return TO gt_return.
          CLEAR : ls_return.
        ELSE.
          READ TABLE gt_poaccounts INTO DATA(ls_account) WITH KEY po_item = ls_new_ekpo-ebelp.
          READ TABLE me->zif_myfi_document~old_ekkn INTO DATA(ls_old_account) WITH KEY ebelp = ls_new_ekpo-ebelp.

          IF ls_account-gl_account NE ls_old_account-sakto OR
             ls_account-costcenter NE ls_old_account-kostl OR
             ls_account-orderid    NE ls_old_account-aufnr OR
             ls_account-asset_no      NE ls_old_account-anln1 OR
             ls_account-fund NE ls_old_account-geber." or.
            MESSAGE e105(zmfp) INTO ls_return-message WITH ls_new_ekpo-ebelp.
            ls_return-type = 'E'.
            APPEND ls_return TO gt_return.
            CLEAR : ls_return.
          ENDIF.
        ENDIF.
      ENDIF.
    ENDLOOP.

*    LOOP AT gt_poschedules INTO DATA(ls_schedules).
*
*      DATA(lv_valid_date) = zcl_mfp_utilities=>validate_deliverydate( iv_delivery_date = ls_schedules-delivery_date ).
*      IF lv_valid_date = abap_true.
*        MESSAGE e107(zmfp) INTO ls_return-message WITH ls_schedules-delivery_date ls_schedules-po_item. "ls_new_ekpo-ebelp.
*        ls_return-type = 'E'.
*        APPEND ls_return TO gt_return.
*        CLEAR : ls_return.
*      ENDIF.

*    ENDLOOP.

* Validate 5 day payment terms for peppol
*    IF gs_po_deep-pmnttrms = '0005' AND gs_po_deep-agreement IS INITIAL.
*
*      IF NOT gs_po_deep-isdraft = abap_true.
*        DATA(lv_valid_payterm) = zcl_mfp_document=>validate_einv_paymentterm( iv_ebeln = gs_poheader-po_number ).
*        IF lv_valid_payterm = abap_false.
*          MESSAGE e104(zmfp) INTO ls_return-message WITH TEXT-001 TEXT-002 TEXT-003 TEXT-004.
*          ls_return-type = 'E'.
*          APPEND ls_return TO gt_return.
*          CLEAR : ls_return.
*        ENDIF.
*      ELSE.
*        lv_amtcheck = '1000000.000'.
*        IF gs_po_deep-totalvalue GT lv_amtcheck.
*          MESSAGE e104(zmfp) INTO ls_return-message WITH TEXT-001 TEXT-002 TEXT-003 TEXT-004.
*          ls_return-type = 'E'.
*          APPEND ls_return TO gt_return.
*          CLEAR : ls_return.
*        ENDIF.
*      ENDIF.
*    ENDIF.

* Check if logged-on user is ASA employee and check if account assignment is for ASA related
    DATA(ls_asa_empl) = zcl_mfp_utilities=>is_asa_empl( ).
    IF ls_asa_empl-is_asa_empl = abap_true AND gs_po_deep-comp_code = '1000'.
      DATA(lt_nps_costcentres) = zcl_mfp_utilities=>get_nps_costcentres( ).

      CALL METHOD me->get_cc_accountassignments
        EXPORTING
          it_accountassignments = me->gs_po_deep-accountassignments
        IMPORTING
          et_cc_assignments     = lt_cc_assignments.

      LOOP AT lt_cc_assignments INTO DATA(ls_cc_assignments).
        READ TABLE lt_nps_costcentres TRANSPORTING NO FIELDS WITH KEY kostl = ls_cc_assignments-kostl.
        IF sy-subrc IS NOT INITIAL.
          DATA(lv_line) = |{ ls_cc_assignments-ebelp ALPHA = OUT }|.
          gv_errors = abap_true.
          MESSAGE e110(zmfp) INTO ls_return-message WITH lv_line.
          ls_return-type = 'E'.
          ls_return-id = sy-msgid.
          ls_return-number = sy-msgno.
          APPEND ls_return TO gt_return.
          CLEAR : ls_return.
        ENDIF.
      ENDLOOP.
    ENDIF.

*   Get vendor currency
    CALL METHOD zcl_mfp_utilities=>get_vendor_currency
      EXPORTING
        iv_vendor          = gs_po_deep-vendor
        iv_company         = gs_po_deep-comp_code
      IMPORTING
        ev_currency        = DATA(lv_vendor_currency)
        ev_permitted_payee = DATA(lv_permitted_payee).

    CLEAR : lv_error.
    lv_error = COND char1(
        WHEN lv_permitted_payee = abap_true AND gs_po_deep-diff_inv IS INITIAL THEN abap_true
        WHEN lv_permitted_payee = abap_false  THEN abap_true ).
    IF lv_vendor_currency NE gs_po_deep-currency.
      IF lv_error = abap_true.
        gv_errors = abap_true.
        MESSAGE e106(zmfp) INTO ls_return-message WITH TEXT-005.
        ls_return-type = 'E'.
        APPEND ls_return TO gt_return.
        CLEAR : ls_return.
      ENDIF.
    ENDIF.

* Validation for Invoice Approver email
*  Check if e-mail entered exists in one of tables for VIM
    READ TABLE gs_po_deep-deliveryaddresses INTO DATA(ls_deliveryaddress) INDEX 1.
    IF sy-subrc IS INITIAL AND NOT ls_deliveryaddress-invoicecontactemail IS INITIAL .
      DATA(lv_email) = ls_deliveryaddress-invoicecontactemail.

      TRANSLATE lv_email TO UPPER CASE.

      ls_return = zcl_mfp_document=>check_invoice_approver_email( iv_email = lv_email ).

      IF NOT ls_return IS INITIAL.
        gv_errors = abap_true.
        APPEND ls_return TO gt_return.
        CLEAR ls_return.
      ENDIF.
    ENDIF.

    ls_header = me->gs_poheader.
    ls_headerx = me->gs_poheaderx.

    ls_header-po_number = ''.
    ls_headerx-po_number = abap_false.
    IF ( me->zif_myfi_document~old_doc_header-status EQ zif_mfp_constants=>gc_doc_status-draft
    OR me->zif_myfi_document~old_doc_header-status IS INITIAL )
    AND me->gv_is_legacy NE abap_true.

      CALL FUNCTION 'BAPI_PO_CREATE1'
        EXPORTING
          poheader       = ls_header
          poheaderx      = ls_headerx
          testrun        = abap_true
        IMPORTING
*         exppurchaseorder       =                  " Purchasing Document Number
          expheader      = ls_header_ret                 " Header Data
*         exppoexpimpheader      =                  " Export Trade: Header Data
        TABLES
          return         = lt_return                 " Return Parameter
          poitem         = gt_poitems                 " Item Data
          poitemx        = gt_poitemsx                 " Item Data (Change Parameter)
          poaddrdelivery = gt_poaddrdelivery                 " Addresses for Inward Delivery (Item)
          poschedule     = gt_poschedules                 " Delivery Schedule
          poschedulex    = gt_poschedulesx                 " Delivery Schedule (Change Parameter)
          poaccount      = gt_poaccounts                 " Account Assignment Fields
          poaccountx     = gt_poaccountsx                 " Account Assignment Fields (Change Parameter)
*         pocondheader   =                  " Conditions (Header)
*         pocondheaderx  =                  " Conditions (Header, Change Parameter)
*         pocond         =                  " Conditions (Items)
*         pocondx        =                  " Conditions (Items, Change Parameter)
*         extensionin    =                  " Customer's Own Fields (Import Parameters)
*         extensionout   =                  " Customer's Own Fields (Export Parameters)
          potextheader   = gt_poheadertext                 " Header Texts
          potextitem     = gt_potextitems.                 " Item Texts

    ELSE.

      IF NOT gv_locked_costobject IS INITIAL.
        LOOP AT gt_poaccounts INTO DATA(ls_accounts) WHERE delete_ind = abap_true.

*          DATA(lv_old_address) = gt_old_poaddrdelivery[ po_item = ls_accounts-po_item ]-addr_no.
*          IF lv_new_address = lv_old_address.
          DELETE gt_poaccountsx WHERE po_item = ls_accounts-po_item.
          DELETE gt_poitems WHERE po_item = ls_accounts-po_item.
          DELETE gt_poitemsx WHERE po_item = ls_accounts-po_item.
          DELETE gt_poaddrdelivery WHERE po_item = ls_accounts-po_item.
          DELETE gt_poschedules WHERE po_item = ls_accounts-po_item.
          DELETE gt_poschedulesx WHERE po_item = ls_accounts-po_item.
          DELETE gt_potextitems WHERE po_item = ls_accounts-po_item.
          DELETE gt_extension WHERE valuepart1+0(5) = ls_accounts-po_item.
          DELETE gt_poaccounts WHERE delete_ind = abap_true AND po_item = ls_accounts-po_item.
*          ELSE.
*          * check if address changed for line item
          IF line_exists( gt_poaddrdelivery[ po_item = ls_accounts-po_item ] ).
            DATA(lv_new_address) = gt_poaddrdelivery[ po_item = ls_accounts-po_item ]-addr_no.
*          ENDIF.
*          DATA(lv_new_address) = gs_po_deep-deliveryaddresses[ po_item = ls_accounts-po_item ]-addr_no.
            IF line_exists( gt_old_poaddrdelivery[ po_item = ls_accounts-po_item ]  ).
              DATA(lv_old_address) = gt_old_poaddrdelivery[ po_item = ls_accounts-po_item ]-addr_no.
            ENDIF.
            IF lv_new_address NE lv_old_address.
              gv_errors = abap_true.
              SHIFT ls_accounts-po_item LEFT DELETING LEADING '0'.
              MESSAGE e109(zmfp) INTO ls_return-message WITH ls_accounts-po_item.
              ls_return-type = 'E'.
              APPEND ls_return TO gt_return.
              CLEAR : ls_return.
            ENDIF.
          ENDIF.
          CLEAR : lv_new_address, lv_old_address.
        ENDLOOP.
      ENDIF.


      CALL FUNCTION 'BAPI_PO_CHANGE'
        EXPORTING
          purchaseorder    = gs_poheader-po_number                " Purchasing Document Number
          poheader         = gs_poheader                 " Header Data
          poheaderx        = gs_poheaderx                 " Header Data (Change Parameter)
*         poaddrvendor     =                  " Address of Vendor
          testrun          = abap_true                 " Test Indicator
*         memory_uncomplete      =                  " Hold Purchase Order if Faulty
*         memory_complete  =                  " Hold Purchase Order if NOT Faulty
*         poexpimpheader   =                  " Export Trade: Header Data
*         poexpimpheaderx  =                  " Foreign Trade: Change Bar: Header Data
*         versions         =                  " Version Management
*         no_messaging     =                  " No message determination
*         no_message_req   =                  " No messages necessary
*         no_authority     =                  " No Authorization Check
*         no_price_from_po =                  " No Adoption of Price from Last Document
*         park_uncomplete  =                  " Park Document if Faulty
*         park_complete    =                  " Park Document if NOT Faulty
        IMPORTING
          expheader        = ls_header_ret                " Header Data
*         exppoexpimpheader      =                  " Export Trade: Header Data
        TABLES
          return           = lt_return                 " Return Parameter
          poitem           = gt_poitems                 " Item Data
          poitemx          = gt_poitemsx                 " Item Data (Change Parameter)
          poaddrdelivery   = gt_poaddrdelivery                 " Addresses for Inward Delivery (Item)
          poschedule       = gt_poschedules                 " Delivery Schedule
          poschedulex      = gt_poschedulesx                 " Delivery Schedule (Change Parameter)
          poaccount        = gt_poaccounts                 " Account Assignment Fields
*         poaccountprofitsegment =                  " Reservation Profitability Segment: BAPI_PROFITABILITY_SEGMEN
          poaccountx       = gt_poaccountsx                 " Account Assignment Fields (Change Parameter)
*         pocondheader     =                  " Conditions (Header)
*         pocondheaderx    =                  " Conditions (Header, Change Parameter)
*         pocond           =                  " Conditions (Items)
*         pocondx          =                  " Conditions (Items, Change Parameter)
*         polimits         =                  " External Services: Limits
*         pocontractlimits =                  " External Services: Contract Limits
*         poservices       =                  " External Services: Service Lines
*         posrvaccessvalues      =                  " External Services: Account Assignment Distribution for Servi
*         poservicestext   =                  " External Services: Service Long Text
*         extensionin      =                  " Customer's Own Fields (Import Parameters)
*         extensionout     =                  " Customer's Own Fields (Export Parameters)
*         poexpimpitem     =                  " Foreign Trade: Item Data
*         poexpimpitemx    =                  " Foreign Trade: Change Parameter: Item Data
          potextheader     = gt_poheadertext                 " Header Texts
          potextitem       = gt_potextitems                 " Item Texts
*         allversions      =                  " All Versions (Export Parameter)
          popartner        = gt_popartner                 " Partner
*         pocomponents     =                  " BAPI Structure for Components
*         pocomponentsx    =                  " Update Information for Components in BUS2012 API
*         poshipping       =                  " BAPI Shipping Data for Stock Transport Orders
*         poshippingx      =                  " BAPI Shipping Data Change Parameter
*         poshippingexp    =                  " Export Structure for Shipping Data
          pohistory        = gt_pohistory                 " Transfer Structure for PO History
          pohistory_totals = gt_pohistory_totals                 " Transfer Structure for PO History: Totals
*         poconfirmation   =                  " Transfer Structure: Display/List - Vendor Confirmation
*         serialnumber     =                  " Serial Numbers in Purchase Order BAPIs
*         serialnumberx    =                  " Change Parameter: Serial Number in Purchase Order BAPIs
*         invplanheader    =                  " Invoicing Plan Header Data
*         invplanheaderx   =                  " Invoicing Plan Header Data (Change Parameter)
*         invplanitem      =                  " Invoicing Plan Item Data
*         invplanitemx     =                  " Invoicing Plan Item Data (Change Parameter)
*         pohistory_ma     =                  " Transfer Structure for Purchase Order History Account Assign
        .

    ENDIF.
    IF gv_errors EQ abap_false AND ( ls_header_ret-po_rel_ind NE zif_mfp_constants=>gc_mm_doc_status-po_released AND ls_header_ret-po_rel_ind IS NOT INITIAL ).
      gv_errors = abap_true.
      MESSAGE e100(zmfp) INTO ls_return-message.
      ls_return-type = sy-msgty.
      ls_return-id = sy-msgid.
      ls_return-number = sy-msgno.
      APPEND ls_return TO gt_return.
    ENDIF.

    DELETE lt_return WHERE type = 'S'.
    DELETE lt_return WHERE type = 'I'.
    DELETE lt_return WHERE type = 'W'.
    IF lt_return IS NOT INITIAL.
      lt_return = message_handler( it_return = lt_return ).
      APPEND LINES OF lt_return TO gt_return.
      CLEAR gs_po_deep.
    ELSEIF gv_errors EQ abap_true.
      CLEAR gs_po_deep.
    ELSE.
      CLEAR: ls_return, gt_return.
      MESSAGE s014(zmfp) INTO ls_return-message.
      ls_return-type = sy-msgty.
      ls_return-id = sy-msgid.
      ls_return-number = sy-msgno.
      APPEND ls_return TO gt_return.
      gt_return = message_handler( it_return = gt_return ).
    ENDIF.
  ENDMETHOD.
ENDCLASS.