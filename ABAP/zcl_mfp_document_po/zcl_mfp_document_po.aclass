CLASS ZCL_MFP_DOCUMENT_PO IMPLEMENTATION.


  METHOD bapi_2_ekkn.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_DOCUMENT_PO~bapi_2_ekkn
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for MyFi Documents
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
* 15.07.20 290977SCN RD2K919533 DS-11-32-07-01 Fix to handle WBS
* 21.10.20 290977SCN RD2K919656 DS-11-32-07-01 S 6000002172: MyFi Purchasing (Release 2.3)
*-----------------------------------------------------------------------
    DATA: ls_bapimepoaccount TYPE bapimepoaccount,
          ls_mepoaccounting  TYPE mepoaccounting,
          ls_ekkn            TYPE ekkn.

    LOOP AT it_bapimepoaccount INTO ls_bapimepoaccount.
      CALL FUNCTION 'MAP2I_BAPIACCOUNT_TO_ACCOUNTIN'
        EXPORTING
          bapimepoaccount = ls_bapimepoaccount
        CHANGING
          mepoaccounting  = ls_mepoaccounting.

      CALL FUNCTION 'CONVERSION_EXIT_ABPSP_INPUT'
        EXPORTING
          input  = ls_bapimepoaccount-wbs_element
        IMPORTING
          output = ls_mepoaccounting-ps_psp_pnr.

      MOVE-CORRESPONDING ls_mepoaccounting TO ls_ekkn.
      READ TABLE it_bapiparex WITH KEY valuepart1(5) = ls_bapimepoaccount-po_item
                                           structure = zif_mfp_constants=>gc_cobl-po
                                     valuepart1+5(2) = ls_bapimepoaccount-serial_no
                                      INTO DATA(ls_ext).
      ls_ekkn-zzesp = ls_ext-valuepart1+7.
      ls_ekkn-zekkn = ls_mepoaccounting-zexkn.
      APPEND ls_ekkn TO rt_ekkn.
      CLEAR: ls_ext, ls_ekkn.
    ENDLOOP.
  ENDMETHOD.


  METHOD bapi_2_ekko.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_DOCUMENT_PO~bapi_2_ekko
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for MyFi Documents
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
*-----------------------------------------------------------------------
    DATA: ls_mepoheader TYPE mepoheader.

    CALL FUNCTION 'MAP2I_BAPIHEADER_TO_HEADER'
      EXPORTING
        bapimepoheader = is_bapimepoheader
      CHANGING
        mepoheader     = ls_mepoheader.
    MOVE-CORRESPONDING ls_mepoheader TO es_ekko.
  ENDMETHOD.


  METHOD bapi_2_ekpo.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_DOCUMENT_PO~bapi_2_ekpo
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for MyFi Documents
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
* 16.04.21 210983DY RD2K920923  DS-11-32-07-01 S 6000002348: MyFi Purchasing (May Release)
*                               Additional logic to calculate Tax based on effective value
*                               for purchase orders
*-----------------------------------------------------------------------
    DATA: ls_bapimepoitem TYPE bapimepoitem,
          ls_mepoitem     TYPE mepoitem,
          ls_ekpo         TYPE ekpo,
          lv_tax_amount   TYPE bapiwrbtr,
          lv_amount       TYPE wrbtr.

    LOOP AT it_bapiitem INTO ls_bapimepoitem.
      CALL FUNCTION 'MAP2I_BAPIITEM_TO_ITEM'
        EXPORTING
          bapimepoitem = ls_bapimepoitem
        CHANGING
          mepoitem     = ls_mepoitem.
      MOVE-CORRESPONDING ls_mepoitem TO ls_ekpo.
      ls_ekpo-effwr = ls_ekpo-menge * ls_ekpo-netpr.

      lv_amount = ls_ekpo-effwr.
      zcl_mfp_utilities=>calculate_tax(
      EXPORTING
        iv_bukrs = ls_mepoitem-werks                 " Company Code
        iv_mwskz =  ls_bapimepoitem-tax_code                " Sales Tax Code
        iv_wrbtr =  lv_amount                " Amount in document currency
        iv_koart = 'M'              " Account Type
      RECEIVING
        rv_wmwst = lv_tax_amount                 " Amount in document currency
    ).

      ls_ekpo-effwr = ls_ekpo-effwr + lv_tax_amount.
      CLEAR : lv_amount, lv_tax_amount.
      APPEND ls_ekpo TO rt_ekpo.
    ENDLOOP.
  ENDMETHOD.


  METHOD bapi_2_komv.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_DOCUMENT_PO~bapi_2_komv
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for MyFi Documents
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
*-----------------------------------------------------------------------
    DATA: ls_bapimepocond TYPE bapimepocond,
          ls_komv         TYPE komv.

    LOOP AT it_bapimepocond INTO ls_bapimepocond.
      CALL FUNCTION 'MAP2I_BAPICOND_TO_KOMV'
        EXPORTING
          bapimepocond = ls_bapimepocond
        CHANGING
          komv         = ls_komv.
      APPEND ls_komv TO rt_komv.
    ENDLOOP.

  ENDMETHOD.


  METHOD check_delegate.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_DOCUMENT_PO~check_delegate
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for MyFi Documents
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
* 16.06.20 290977SCN RD2K919514 DS-11-32-07-01 changed
*          070667JPS
* 03/03/21 210983DY  RD2K920554 DS-11-32-07-01 S 6000002250: MyFi Purchasing (Release 2.4 )
*                               Additional code to handle delgation amount for foreign currency
*10/06/21 210983DY  RD2K921224  DS-11-32-07-01 S 6000002393: June DFSS release for MyFi Purchasing
*                               Additional logic to ignore deleted line item value for delegation
* 13/01/22  210983DY RD2K922296 6000002623: MyFi Applications (February Release)
*         Convert Delgate amount from foreign currency to AUD and check delegate
*-----------------------------------------------------------------------
    DATA: lv_total_amt        TYPE effwr,
          lv_foreign_cur      TYPE waers,
          lv_foreign_amt_st   TYPE string,
          lv_foreign_amt      TYPE string,
          lv_delegation_limit TYPE effwr,
          ls_return           TYPE bapiret2,
          lv_amount           TYPE wrbtr,
          lv_tax_amount       TYPE bapiwrbtr.

    IF me->zif_myfi_document~old_doc_header-category EQ zif_mfp_constants=>gc_myfi_doc_type-l4l_po OR me->gs_po_deep-approvaldetails-delegateid IS INITIAL.
      gv_delegate_ok = rv_ok = abap_true.
      RETURN.
    ENDIF.
*
*    IF me->zif_myfi_document~new_doc_header-selected_delegate IS INITIAL.
*      rv_ok = abap_true.
*      RETURN.
*    ENDIF.

    LOOP AT me->gt_poitems ASSIGNING FIELD-SYMBOL(<fs_item>) WHERE delete_ind IS INITIAL.
      lv_amount = <fs_item>-quantity * <fs_item>-net_price.
      zcl_mfp_utilities=>calculate_tax(
            EXPORTING
              iv_bukrs = gs_poheader-comp_code                 " Company Code
              iv_mwskz =  <fs_item>-tax_code                " Sales Tax Code
              iv_wrbtr =  lv_amount                " Amount in document currency
              iv_koart = 'M'              " Account Type
            RECEIVING
              rv_wmwst = lv_tax_amount                 " Amount in document currency
          ).
      lv_total_amt = lv_total_amt + lv_amount + lv_tax_amount.
    ENDLOOP.

    IF me->gs_poheader-currency EQ 'AUD'.
      lv_total_amt = lv_total_amt.
    ELSE.
      lv_foreign_cur = me->gs_poheader-currency.
      lv_foreign_amt_st = lv_total_amt.

      SELECT SINGLE currdec INTO @DATA(lv_decimals) FROM  tcurx
                  WHERE  currkey = @me->gs_poheader-currency.

      CALL FUNCTION 'Z_CURRENCY_IN_DECIMAL'
        EXPORTING
          iv_amount   = lv_foreign_amt_st
          iv_currency = lv_foreign_cur
        IMPORTING
          ev_amount   = lv_foreign_amt.

      CASE lv_decimals.
        WHEN 2.
* for three decimal currency
        WHEN 3.
          lv_foreign_amt = lv_foreign_amt * 100.
        WHEN OTHERS.
      ENDCASE.

*      lv_total_amt = lv_foreign_amt * me->gs_po_deep-exch_rate.

      CALL FUNCTION 'CONVERT_TO_LOCAL_CURRENCY'
        EXPORTING
          date             = sy-datum
          foreign_amount   = lv_foreign_amt
          foreign_currency = lv_foreign_cur
          local_currency   = 'AUD'
          rate             = me->gs_po_deep-exch_rate
        IMPORTING
          local_amount     = lv_total_amt
        EXCEPTIONS
          no_rate_found    = 1
          overflow         = 2
          no_factors_found = 3
          no_spread_found  = 4
          derived_2_times  = 5
          OTHERS           = 6.
    ENDIF.

    lv_delegation_limit = zcl_mfp_utilities=>get_user_delegation( EXPORTING iv_userid = me->gs_po_deep-approvaldetails-delegateid ).

    IF lv_delegation_limit GE lv_total_amt.
      gv_delegate_ok = rv_ok = abap_true.
    ELSE.
      MESSAGE e101(zmfp) INTO ls_return-message.
      ls_return-type = sy-msgty.
      ls_return-id = sy-msgid.
      ls_return-number = sy-msgno.
      APPEND ls_return TO gt_return.
      gt_return = message_handler( it_return = gt_return ).
      CLEAR gs_po_deep.
    ENDIF.
  ENDMETHOD.


  METHOD constructor.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_DOCUMENT_PO~constructor
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for MyFi Documents
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
* 30.11.20 220977FKC RD2K920449 DS-11-32-07-01 6000002172: MyFi Purchasing (Release 2.3)
*                                              Enable legacy i.e. non-myfi created docs
* 23.02.21 220977FKC RD2K920554 DS-11-32-07-01 6000002250: MyFi Purchasing (Release 2.4)
*                                              Enable PO's with no OA in MyFi
* 18.08.22 210983DY RD2K923033 DS-11-32-07-01 S 6000002805: MyFi Continuous Improvement September Release
*                              Additional logic to get consumption data only when requested
*-----------------------------------------------------------------------

    super->constructor( ).
    me->zif_myfi_document~gv_useraction  = iv_action.
    me->zif_myfi_document~source_doc_num = iv_ebeln.
    gv_l4l_requestor = iv_requestor.


    IF iv_ebeln IS NOT INITIAL.
      SELECT SINGLE * FROM ztmfp_doc_header
        WHERE zmfp_doc_id EQ @iv_ebeln
        INTO CORRESPONDING FIELDS OF @me->zif_myfi_document~old_doc_header.
      IF sy-subrc = 0.
        me->gv_doc_type = me->zif_myfi_document~old_doc_header-category.
        me->gs_po_deep-changed_in_gui = zif_myfi_document~old_doc_header-changed_in_gui.
      ELSE.
        me->gv_is_legacy = me->gs_po_deep-islegacy = abap_true.
        SELECT SINGLE aedat, frgke
          FROM ekko
          INTO (@DATA(lv_aedat), @DATA(lv_frgke))
          WHERE ebeln = @iv_ebeln.
        me->zif_myfi_document~old_doc_header-status = zcl_mfp_utilities=>translate_mm_status_to_mfp( lv_frgke ).
        me->zif_myfi_document~old_doc_header-create_date = lv_aedat.
        me->zif_myfi_document~old_doc_header-category = zif_mfp_constants=>gc_myfi_doc_type-myfi_po.
      ENDIF.
      IF me->gv_doc_type IS INITIAL.
        me->gv_doc_type = zif_mfp_constants=>gc_myfi_doc_type-myfi_po.
      ENDIF.
    ELSE.
      me->gv_doc_type = iv_myfi_doc_type.
      me->gv_draft_indicator = abap_true.
    ENDIF.

    IF is_deep_entity IS NOT INITIAL.
      me->gs_po_deep = is_deep_entity.
    ENDIF.

    IF iv_request_details IS NOT INITIAL AND me->gv_doc_type = zif_mfp_constants=>gc_myfi_doc_type-myfi_po.

* Get the consumption flag from odata filter
      LOOP AT iv_request_details->filter_select_options INTO DATA(lv_filter)
      WHERE property EQ zif_mfp_constants=>gc_odata_filter-is_consumption.
        READ TABLE lv_filter-select_options INDEX 1 INTO DATA(lv_option).
        gv_expand_all = lv_option-low.
        gv_consumption_only = lv_option-low.
      ENDLOOP.

      DATA(ls_request) = iv_request_details->technical_request.
      DATA(gv_expand) = ls_request-expand.
      SPLIT gv_expand AT ',' INTO TABLE gt_expand.
    ELSE.
      gv_expand_all = abap_true.
    ENDIF.

    me->gt_doc_mapping = me->get_field_mappings( iv_doc_type = me->gv_doc_type ).
    me->zif_myfi_document~handle_action( ).

  ENDMETHOD.


  METHOD convert_mm_table_string.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_DOCUMENT_PO~convert_mm_table_string
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for MyFi Documents
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
* 16.06.20 070667JPS RD2K919514 DS-11-32-07-01 S 6000001863: MyFi
*                                              Purchasing Release 2_ECC
*                                              D0120,7-9
*-----------------------------------------------------------------------
    DATA: ls_line  TYPE string,
          lv_first TYPE boole_d VALUE abap_true.

    LOOP AT it_texts INTO DATA(ls_text).
      IF ( iv_item IS NOT INITIAL AND ls_text-po_item = iv_item )  "RD2K919514 Get line item text
       OR iv_item IS INITIAL.                                      "RD2K919514 Get Header text
        IF ls_text-text_id EQ iv_tdid.
          IF lv_first EQ abap_false AND ls_text-text_form EQ '*'.
            ls_line = |{ ls_line }{ cl_abap_char_utilities=>newline }{ ls_text-text_line }|.
          ELSE.
            ls_line = |{ ls_line }{ ls_text-text_line }|.
          ENDIF.
          lv_first = abap_false.

        ENDIF.
      ENDIF.                                                "RD2K919514
    ENDLOOP.
    rv_string = ls_line.

  ENDMETHOD.


  METHOD convert_string_mm_table.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_DOCUMENT_PO~convert_string_mm_table
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for MyFi Documents
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
* 16.06.20 070667JPS RD2K919514 DS-11-32-07-01 S 6000001863: MyFi
*                                              Purchasing Release 2_ECC
*                                              D0120,7-9
*-----------------------------------------------------------------------
    DATA: ls_bapi_string TYPE bapimepotext,
          lt_table       TYPE STANDARD TABLE OF text132,
          lv_string      TYPE string,
          lt_split_lines TYPE STANDARD TABLE OF string.

    SPLIT iv_string AT cl_abap_char_utilities=>newline INTO TABLE lt_split_lines.
* RD2K919514 - added logic to always clear out pickup location in the PO if an initial value is passed in
    IF lt_split_lines IS INITIAL.
*      IF iv_tdid EQ zif_mfp_constants=>gc_header_text-po-item-delivery or iv_tdid EQ zif_mfp_constants=>gc_header_text-po-alt_tc_cond. "'F04'
        ls_bapi_string-text_id = iv_tdid.
        ls_bapi_string-text_form = '*'.
        ls_bapi_string-po_item = iv_item.
        ls_bapi_string-text_line = ''.  "Empty string - i.e. clear out the pickup location if it has a value
        APPEND ls_bapi_string TO rt_texts.
*      ENDIF.
    ELSE.
* RD2K919514 - End of main added block
      LOOP AT lt_split_lines INTO lv_string.
        CALL FUNCTION 'CONVERT_STRING_TO_TABLE'
          EXPORTING
            i_string         = lv_string
            i_tabline_length = 132
          TABLES
            et_table         = lt_table.

        ls_bapi_string-text_id = iv_tdid.
        ls_bapi_string-text_form = '*'.
        ls_bapi_string-po_item = iv_item.
        LOOP AT lt_table INTO DATA(ls_table).
          ls_bapi_string-text_line = ls_table.
          APPEND ls_bapi_string TO rt_texts.
          CLEAR ls_bapi_string-text_form.
        ENDLOOP.
        CLEAR lt_table.
      ENDLOOP.
    ENDIF.                                                  " RD2K919514
  ENDMETHOD.


  METHOD create_new_doc_header.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_DOCUMENT_PO~create_new_doc_header
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for MyFi Documents
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
* 21/09/20 290977SCN RD2K919977 DS-11-32-07-01 S 6000002096: MyFi Purchasing (Release 2.2)
* 29/03/21 210983DY  RD2K920865 DS-11-32-07-01 S 6000002310: MyFi Purchasing (April Release )
*                               Additional code to populate agreement number for PO Draft
* 29/03/22 210983DY RD2K922546  DS-11-32-07-01 S 6000002692: MyFi Applications (May Release)
*                               Pass E-mail from Delivery Address maintained in UI
* 10.09.2023 210983DY RD2K924301     6000002999 MyFi Continuous Improvement October Release
*          Additional logic to Fix PO Draft document error
* 14.03.2024 210983DY RD2K924772    6000003112: MyFi Continuous Improvement Release 2024
*                 Amended logic for new Prepayment and FMS field changes
*-----------------------------------------------------------------------
    super->create_new_doc_header( iv_status = iv_status ).
    IF me->zif_myfi_document~old_doc_header IS INITIAL.
      IF me->gv_doc_type EQ zif_mfp_constants=>gc_myfi_doc_type-l4l_po.  "LP
        me->zif_myfi_document~new_doc_header-category = zif_mfp_constants=>gc_myfi_doc_type-l4l_po.  " Set L4L PO Doc Type
        me->zif_myfi_document~new_doc_header-ref_id = gs_po_deep-agreement.
      ELSE.
        me->zif_myfi_document~new_doc_header-category = zif_mfp_constants=>gc_myfi_doc_type-myfi_po.
        me->zif_myfi_document~new_doc_header-ref_id = gs_po_deep-agreement.
      ENDIF.
      me->zif_myfi_document~new_doc_header-selected_delegate = gs_po_deep-approvaldetails-delegateid.
      me->zif_myfi_document~new_doc_header-isaaicompliance = gs_po_deep-approvaldetails-isaaicompliance.
      me->zif_myfi_document~new_doc_header-isfpmapproved = gs_po_deep-approvaldetails-isfpmapproved.
      me->zif_myfi_document~new_doc_header-isasfinapproved = gs_po_deep-approvaldetails-isasfinapproved.

    ELSE.
      me->zif_myfi_document~new_doc_header = me->zif_myfi_document~old_doc_header.
      me->zif_myfi_document~new_doc_header-issameaddressforall = gs_po_deep-issameaddressforall.
      me->zif_myfi_document~new_doc_header-selected_delegate = gs_po_deep-approvaldetails-delegateid.
      me->zif_myfi_document~new_doc_header-isaaicompliance = gs_po_deep-approvaldetails-isaaicompliance.
      me->zif_myfi_document~new_doc_header-isfpmapproved = gs_po_deep-approvaldetails-isfpmapproved.
      me->zif_myfi_document~new_doc_header-isasfinapproved = gs_po_deep-approvaldetails-isasfinapproved.
      IF line_exists( gs_po_deep-deliveryaddresses[ 1 ] ).
        me->zif_myfi_document~new_doc_header-invoicecontactemail = gs_po_deep-deliveryaddresses[ 1 ]-invoicecontactemail.
      ENDIF.
    ENDIF.
  ENDMETHOD.


  METHOD delegate_required.
*----------------------------------------------------------------------*
* METHOD ID:          ZCL_MFP_DOCUMENT_PO~delegate_required
* DESCRIPTION:        This method is used by the MyFi Purchasing (MFP) UI5
*                     application (Self Service Purchasing (SSP) Release 2).
*                     This method is used for MyFi Documents
*
* AUTHOR:             Stephen Ning (290977SCN), James Southwell (070667JPS)
* CREATE DATE:        30.05.2020
* R/3 RELEASE VERSION: ECC6
*
* ACTIVITY:           AD-11-32-07 - Self Service Purchasing App
* CR Number:          6000001863 - MyFi Purchasing Release 2
*-----------------------------------------------------------------------
* VERSION CONTROL
*
* Date     Author    CTS Req    Dev Script     Description
*-----------------------------------------------------------------------
* 30.05.20 290977SCN RD2K919078 DS-11-32-07-01 Created
*          070667JPS
* 22.07.20 290977SCN RD2K919533 DS-11-32-07-01 Handle all lines deleted
* 16.04.21 210983DY RD2K920923  DS-11-32-07-01 S 6000002348: MyFi Purchasing (May Release)
*              Additional logic to make delegate mandatory when release code is not '2'
* 20/05/21 210983DY  RD2K921041 DS-11-32-07-01 S6000002393: June DFSS release for MyFi Purchasing
*             Revert the consition implemented as part of May Release
* 13/01/22  210983DY RD2K922296 6000002623: MyFi Applications (February Release)

*-----------------------------------------------------------------------
    DATA: new_ekko       TYPE ekko,
          new_ekpo       TYPE me_ekpo,
          new_ekkn       TYPE me_ekkn,
          lt_changes     TYPE TABLE OF zsmfp_changed_fields,
          lt_amt_changes TYPE zmfp_ekkn_totals_tt,
          ls_return      TYPE bapiret2.

    LOOP AT gs_po_deep-purchaseorderlis INTO DATA(ls_odata_poitem)
          WHERE status NE zif_mfp_constants=>gc_line_status-deleted.
      EXIT.
    ENDLOOP.
    CHECK sy-subrc EQ 0. "all lines deleted and target value is 0.01

    IF me->zif_myfi_document~gv_useraction = zif_mfp_constants=>gc_action-odata-create.
      gv_errors = abap_true.
    ENDIF.

**    IF gv_errors EQ abap_false AND me->zif_myfi_document~old_doc_header-ref_id IS INITIAL.
**
**      SELECT SINGLE frgke INTO @DATA(lv_release) FROM ekko WHERE ebeln = @me->zif_myfi_document~source_doc_num.
**      IF NOT lv_release = '2'.
**        gv_errors = abap_true.
**      ENDIF.
**
**    ENDIF.

    IF gv_errors EQ abap_false.

      new_ekko = bapi_2_ekko( is_bapimepoheader = gs_poheader ).
      me->zif_myfi_document~old_ekko = get_ekko( iv_ebeln = me->zif_myfi_document~source_doc_num ).

      CALL METHOD zcl_mfp_utilities=>check_sensitive_fields_ekko
        EXPORTING
          is_new_ekko        = new_ekko
          is_old_ekko        = me->zif_myfi_document~old_ekko
          iv_check_sensitive = abap_true
          iv_table_2_test    = 'EKKO'
        IMPORTING
          et_changed_fields  = lt_changes.

      READ TABLE lt_changes WITH KEY approval_req = abap_true TRANSPORTING NO FIELDS.
      IF sy-subrc = 0.
        gv_errors = abap_true.
      ENDIF.
    ENDIF.
    IF gv_errors EQ abap_false.

      new_ekpo = bapi_2_ekpo( it_bapiitem = gt_poitems ).
      me->zif_myfi_document~old_ekpo = get_ekpo( iv_ebeln = me->zif_myfi_document~source_doc_num ).

      CALL METHOD zcl_mfp_utilities=>check_sensitive_fields_ekpo
        EXPORTING
          it_new_ekpo        = new_ekpo                " Purchasing Document Header
          it_old_ekpo        = me->zif_myfi_document~old_ekpo                 " Purchasing Document Header
          iv_check_sensitive = abap_true                 " Data element for domain BOOLE: TRUE (='X') and FALSE (=' ')
          iv_table_2_test    = 'EKPO'                 " Field of length 16
        IMPORTING
          et_changed_fields  = lt_changes.                 " Sensitive fields tab
      READ TABLE lt_changes WITH KEY approval_req = abap_true TRANSPORTING NO FIELDS.
      IF sy-subrc = 0.
        gv_errors = abap_true.
      ENDIF.
    ENDIF.
    IF gv_errors EQ abap_false.

      new_ekkn = bapi_2_ekkn( it_bapimepoaccount = gt_poaccounts it_bapiparex = me->gt_extension ).
      me->zif_myfi_document~old_ekkn = get_ekkn( iv_ebeln = me->zif_myfi_document~source_doc_num ).
      LOOP AT me->zif_myfi_document~old_ekkn ASSIGNING FIELD-SYMBOL(<fs_old_ekkn>) .
        CLEAR <fs_old_ekkn>-vproz.
      ENDLOOP.
      CALL METHOD zcl_mfp_utilities=>check_sensitive_cost_assign
        EXPORTING
          it_ekpo_new        = new_ekpo                 " Table Type for Purchasing Document Items
          it_ekkn_new        = new_ekkn                 " Table Type for EKKN
          it_ekpo_old        = me->zif_myfi_document~old_ekpo                " Table Type for Purchasing Document Items
          it_ekkn_old        = me->zif_myfi_document~old_ekkn                " Table Type for EKKN
          iv_check_sensitive = abap_true                " Data element for domain BOOLE: TRUE (='X') and FALSE (=' ')
        RECEIVING
          rt_ekkn_total      = lt_amt_changes.                  " Table Type for EKKN

      LOOP AT lt_amt_changes ASSIGNING FIELD-SYMBOL(<ls_changes>).
        IF <ls_changes>-app_req EQ abap_true.
          gv_errors = abap_true.
          EXIT.
        ENDIF.
      ENDLOOP.
    ENDIF.

    IF gv_errors EQ abap_true.

      MESSAGE e100(zmfp) INTO ls_return-message.
      ls_return-type = sy-msgty.
      ls_return-id = sy-msgid.
      ls_return-number = sy-msgno.
      APPEND ls_return TO gt_return.
    ENDIF.



  ENDMETHOD.


